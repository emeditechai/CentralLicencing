@using System.Text.Json
@using CentralLicenceApp.Models
@using CentralLicenceApp.Models.ViewModels
@model CentralLicenceApp.Models.ViewModels.ClientDetailsViewModel
@{
    ViewData["Title"] = (Model.IsNew ? "Add" : "Edit") + " Client Details – " + Model.ClientCode;
    var productType = ViewBag.ProductType as string ?? "";
    var productCatalog = ViewBag.ProductCatalog as List<ProductMaster> ?? new();
    var productRateCatalog = ViewBag.ProductRateCatalog as List<ProductRate> ?? new();
    var jsonOptions = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    var productCatalogJson = JsonSerializer.Serialize(productCatalog.Select(x => new { x.Id, x.ProductName, x.ProductCode, x.ProductType }), jsonOptions);
    var productRateCatalogJson = JsonSerializer.Serialize(productRateCatalog.Select(x => new {
        x.Id,
        x.ProductId,
        x.PricingModel,
        x.BillingModel,
        x.BillingFrequency,
        x.Rate,
        x.AmcCalculationType,
        x.AmcPercentage,
        x.AmcAmount,
        x.IsActive
    }), jsonOptions);
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-controller="ClientLicense" asp-action="Index" asp-route-productType="@productType"
       class="btn btn-sm btn-outline-secondary" style="border-radius:8px;">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;">
            @(Model.IsNew ? "Add Client Details" : "Edit Client Details")
        </h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">
            @Model.ClientCode
            @if (!string.IsNullOrEmpty(Model.ClientName))
            {
                <span class="ms-1">— @Model.ClientName</span>
            }
        </p>
    </div>
</div>

<div class="card" style="max-width:980px;">
    <div class="card-body p-4">
        <form asp-action="Upsert" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ID" />
            <input type="hidden" asp-for="ClientCode" />
            <input type="hidden" name="productType" value="@productType" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 px-3 rounded-3 mb-3" style="font-size:.83rem;"></div>

            <div class="row g-3">

                <!-- Contact Person Name -->
                <div class="col-md-12">
                    <label asp-for="ClientPersonName" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="ClientPersonName" class="form-control" placeholder="e.g. Rajesh Kumar" style="border-radius:10px;" />
                    <span asp-validation-for="ClientPersonName" class="text-danger small"></span>
                </div>

                <!-- Address -->
                <div class="col-md-12">
                    <label asp-for="Address" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <textarea asp-for="Address" class="form-control" rows="2" placeholder="Full address…" style="border-radius:10px;"></textarea>
                </div>

                <div class="col-md-6">
                    <label asp-for="ReferenceClientCode" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="ReferenceClientCode" class="form-control" placeholder="Enter existing ClientCode" style="border-radius:10px;" />
                    <div class="text-muted mt-1" style="font-size:.72rem;">Use this to tag another client record as the same reference customer.</div>
                    <span asp-validation-for="ReferenceClientCode" class="text-danger small"></span>
                </div>

                <div class="col-md-6 d-flex align-items-end">
                    <div class="form-check mb-2">
                        <input asp-for="IsInternalUse" class="form-check-input" type="checkbox" onchange="toggleInternalUseSection()" />
                        <label asp-for="IsInternalUse" class="form-check-label fw-semibold" style="font-size:.85rem;"></label>
                    </div>
                </div>

                <div class="col-md-12">
                    <div id="productsPurchasedSection">
                    <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap mb-2">
                        <div>
                            <label class="form-label fw-semibold mb-1" style="font-size:.82rem;">Products Purchased</label>
                            <div class="text-muted" style="font-size:.76rem;">Select product, then pricing model. Base price and AMC details will be pulled automatically from eProduct Master.</div>
                        </div>
                        <button type="button" class="btn btn-sm btn-outline-primary" style="border-radius:10px;" onclick="addPurchasedProductRow()">
                            <i class="bi bi-plus-lg me-1"></i>Add Product
                        </button>
                    </div>
                    <span asp-validation-for="PurchasedProducts" class="text-danger small d-block mb-2"></span>
                    <div id="purchasedProductsContainer" class="d-flex flex-column gap-3">
                        @for (var i = 0; i < Model.PurchasedProducts.Count; i++)
                        {
                            var row = Model.PurchasedProducts[i];
                            <div class="purchase-row card border-0 shadow-sm" data-index="@i" style="background:#f8fbff;border-radius:16px;">
                                <div class="card-body p-3 p-lg-4">
                                    <div class="d-flex align-items-center justify-content-between mb-3 gap-2 flex-wrap">
                                        <div>
                                            <div class="fw-semibold" style="font-size:.86rem;color:#1e293b;">Purchased Product @(i + 1)</div>
                                            <div class="text-muted" style="font-size:.74rem;">Linked with pricing model snapshot for client records</div>
                                        </div>
                                        <button type="button" class="btn btn-sm btn-outline-danger" style="border-radius:10px;" onclick="removePurchasedProductRow(this)">
                                            <i class="bi bi-trash me-1"></i>Remove
                                        </button>
                                    </div>

                                    <div class="row g-3 align-items-start">
                                        <div class="col-md-5">
                                            <label class="form-label fw-semibold" style="font-size:.8rem;">Product Name</label>
                                            <select name="PurchasedProducts[@i].ProductId" class="form-select product-select" style="border-radius:10px;" onchange="handleProductChange(this)">
                                                <option value="">Select Product</option>
                                                @foreach (var product in productCatalog)
                                                {
                                                    <option value="@product.Id" selected="@(row.ProductId == product.Id)">@product.ProductName (@product.ProductCode)</option>
                                                }
                                            </select>
                                            <span class="text-danger small field-validation-valid" data-valmsg-for="PurchasedProducts[@i].ProductId" data-valmsg-replace="true"></span>
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label fw-semibold" style="font-size:.8rem;">Product Pricing Model</label>
                                            <select name="PurchasedProducts[@i].ProductRateId" class="form-select pricing-model-select" style="border-radius:10px;" data-selected-rate-id="@row.ProductRateId" onchange="handleRateChange(this)">
                                                <option value="">Select Pricing Model</option>
                                            </select>
                                            <span class="text-danger small field-validation-valid" data-valmsg-for="PurchasedProducts[@i].ProductRateId" data-valmsg-replace="true"></span>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label fw-semibold" style="font-size:.8rem;">Snapshot</label>
                                            <div class="rounded-3 px-3 py-2 h-100 purchase-row-state" style="background:#eef4ff;border:1px solid #dbe5f4;min-height:44px;font-size:.76rem;color:#475569;display:flex;align-items:center;">Select pricing model to load details</div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="rounded-3 px-3 py-2 h-100" style="background:#fff;border:1px solid #e2e8f0;">
                                                <div class="text-muted" style="font-size:.72rem;font-weight:700;letter-spacing:.04em;">BASE PRICE</div>
                                                <div class="purchase-base-price fw-bold mt-1" style="font-size:1rem;color:#1e293b;">@(row.BasePrice > 0 ? "₹" + row.BasePrice.ToString("0.00") : "-")</div>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="rounded-3 px-3 py-2 h-100" style="background:#fff;border:1px solid #e2e8f0;">
                                                <div class="text-muted" style="font-size:.72rem;font-weight:700;letter-spacing:.04em;">AMC TYPE / %</div>
                                                <div class="purchase-amc-type fw-semibold mt-1" style="font-size:.88rem;color:#1e293b;">
                                                    @(string.IsNullOrWhiteSpace(row.AmcCalculationType) ? "-" : row.AmcCalculationType + " • " + row.AmcPercentage.ToString("0.####") + "%")
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="rounded-3 px-3 py-2 h-100" style="background:#fff;border:1px solid #e2e8f0;">
                                                <div class="text-muted" style="font-size:.72rem;font-weight:700;letter-spacing:.04em;">AMC AMOUNT</div>
                                                <div class="purchase-amc-amount fw-bold mt-1" style="font-size:1rem;color:#1e293b;">@(row.AmcAmount > 0 ? "₹" + row.AmcAmount.ToString("0.00") : "-")</div>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label fw-semibold" style="font-size:.8rem;">Invoice No</label>
                                            <input type="text" name="PurchasedProducts[@i].InvoiceNo" value="@row.InvoiceNo"
                                                   class="form-control invoice-no-input" placeholder="e.g. EL/SL/26-27/0001"
                                                   style="border-radius:10px;"
                                                   data-initial="@row.InvoiceNo"
                                                   oninput="scheduleInvoiceFetch(this)" />
                                        </div>
                                        <div class="col-12">
                                            <div class="invoice-detail-panel d-none mt-1 p-3 rounded-3" style="background:#f0f7ff;border:1px solid #c7ddf9;font-size:.82rem;">
                                                <div class="d-flex flex-wrap gap-3 align-items-center">
                                                    <span class="inv-detail-item"><span class="text-muted">Invoice:</span> <strong class="inv-no"></strong></span>
                                                    <span class="inv-detail-item"><span class="text-muted">Date:</span> <strong class="inv-date"></strong></span>
                                                    <span class="inv-detail-item"><span class="text-muted">Party:</span> <strong class="inv-party"></strong></span>
                                                    <span class="ms-auto badge inv-status"></span>
                                                </div>
                                                <hr class="my-2" style="border-color:#c7ddf9;" />
                                                <div class="d-flex flex-wrap gap-3">
                                                    <div class="inv-stat-box">
                                                        <div class="inv-stat-lbl">Sub Total</div>
                                                        <div class="inv-stat-val inv-subtotal"></div>
                                                    </div>
                                                    <div class="inv-stat-box">
                                                        <div class="inv-stat-lbl">GST</div>
                                                        <div class="inv-stat-val inv-gst"></div>
                                                    </div>
                                                    <div class="inv-stat-box" style="border-color:#6366f1;">
                                                        <div class="inv-stat-lbl">Total Amount</div>
                                                        <div class="inv-stat-val inv-total" style="color:#6366f1;"></div>
                                                    </div>
                                                    <div class="inv-stat-box" style="border-color:#10b981;">
                                                        <div class="inv-stat-lbl">Paid Amount</div>
                                                        <div class="inv-stat-val inv-paid" style="color:#10b981;"></div>
                                                    </div>
                                                    <div class="inv-stat-box inv-balance-box">
                                                        <div class="inv-stat-lbl">Balance Due</div>
                                                        <div class="inv-stat-val inv-balance"></div>
                                                    </div>
                                                </div>
                                                <div class="mt-2 inv-lines-wrap" style="font-size:.78rem;color:#475569;"></div>
                                            </div>
                                            <div class="invoice-not-found-msg d-none text-danger mt-1" style="font-size:.78rem;">Invoice not found or cancelled.</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    </div>
                </div>

                <!-- DOB -->
                <div class="col-md-6">
                    <label asp-for="DOB" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="DOB" type="date" class="form-control" style="border-radius:10px;" />
                </div>

                <!-- Anniversary Date -->
                <div class="col-md-6">
                    <label asp-for="Anniversarydate" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="Anniversarydate" type="date" class="form-control" style="border-radius:10px;" />
                </div>

                <!-- Is Active -->
                <div class="col-md-12">
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label fw-semibold" style="font-size:.85rem;"></label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn text-white px-4" style="background:#6366f1;border:none;border-radius:10px;">
                    <i class="bi bi-check-lg me-1"></i> @(Model.IsNew ? "Save Details" : "Update Details")
                </button>
                <a asp-controller="ClientLicense" asp-action="Index" asp-route-productType="@productType"
                   class="btn btn-outline-secondary" style="border-radius:10px;">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<style>
    .inv-stat-box {
        background: #fff;
        border: 1px solid #dde8f9;
        border-radius: 8px;
        padding: 5px 10px;
        min-width: 100px;
    }
    .inv-stat-lbl { font-size: .68rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: #94a3b8; }
    .inv-stat-val { font-size: .92rem; font-weight: 700; color: #1e293b; margin-top: 1px; }
</style>
<script>
    const productCatalog = @Html.Raw(productCatalogJson);
    const productRateCatalog = @Html.Raw(productRateCatalogJson);

    function getRatesForProduct(productId) {
        return productRateCatalog.filter(x => x.productId === Number(productId) && x.isActive);
    }

    function populatePricingModelSelect(row, selectedRateId) {
        const productSelect = row.querySelector('.product-select');
        const pricingModelSelect = row.querySelector('.pricing-model-select');
        const rates = productSelect.value ? getRatesForProduct(productSelect.value) : [];

        pricingModelSelect.innerHTML = '<option value="">Select Pricing Model</option>';
        rates.forEach(rate => {
            const option = document.createElement('option');
            option.value = rate.id;
            const billingSummary = rate.billingFrequency ? `${rate.billingModel} / ${rate.billingFrequency}` : rate.billingModel;
            option.textContent = `${rate.pricingModel} • ${billingSummary} - ₹${Number(rate.rate).toFixed(2)}`;
            if (selectedRateId && Number(selectedRateId) === rate.id) {
                option.selected = true;
            }
            pricingModelSelect.appendChild(option);
        });
    }

    function updatePurchaseSnapshot(row) {
        const pricingModelSelect = row.querySelector('.pricing-model-select');
        const state = row.querySelector('.purchase-row-state');
        const basePrice = row.querySelector('.purchase-base-price');
        const amcType = row.querySelector('.purchase-amc-type');
        const amcAmount = row.querySelector('.purchase-amc-amount');
        const selectedRate = productRateCatalog.find(x => x.id === Number(pricingModelSelect.value));

        if (!selectedRate) {
            state.textContent = 'Select pricing model to load details';
            basePrice.textContent = '-';
            amcType.textContent = '-';
            amcAmount.textContent = '-';
            return;
        }

        const billingSummary = selectedRate.billingFrequency ? `${selectedRate.billingModel} / ${selectedRate.billingFrequency}` : selectedRate.billingModel;
        state.textContent = selectedRate.amcCalculationType
            ? `${selectedRate.pricingModel} • ${billingSummary}. Base ₹${Number(selectedRate.rate).toFixed(2)} with ${selectedRate.amcCalculationType} AMC snapshot.`
            : `${selectedRate.pricingModel} • ${billingSummary}. Base ₹${Number(selectedRate.rate).toFixed(2)} with no AMC configured.`;
        basePrice.textContent = `₹${Number(selectedRate.rate).toFixed(2)}`;
        amcType.textContent = selectedRate.amcCalculationType
            ? `${selectedRate.amcCalculationType} • ${Number(selectedRate.amcPercentage).toFixed(4)}%`
            : '-';
        amcAmount.textContent = selectedRate.amcCalculationType
            ? `₹${Number(selectedRate.amcAmount).toFixed(2)}`
            : '-';
    }

    function handleProductChange(select) {
        const row = select.closest('.purchase-row');
        populatePricingModelSelect(row, null);
        updatePurchaseSnapshot(row);
    }

    function handleRateChange(select) {
        const row = select.closest('.purchase-row');
        updatePurchaseSnapshot(row);
    }

    function toggleInternalUseSection() {
        const isInternalUse = document.getElementById('IsInternalUse')?.checked;
        const section = document.getElementById('productsPurchasedSection');
        if (!section) {
            return;
        }

        section.style.display = isInternalUse ? 'none' : '';
    }

    function addPurchasedProductRow() {
        const container = document.getElementById('purchasedProductsContainer');
        const index = container.querySelectorAll('.purchase-row').length;
        const productOptions = productCatalog.map(product => `<option value="${product.id}">${product.productName} (${product.productCode})</option>`).join('');

        const html = `
            <div class="purchase-row card border-0 shadow-sm" data-index="${index}" style="background:#f8fbff;border-radius:16px;">
                <div class="card-body p-3 p-lg-4">
                    <div class="d-flex align-items-center justify-content-between mb-3 gap-2 flex-wrap">
                        <div>
                            <div class="fw-semibold" style="font-size:.86rem;color:#1e293b;">Purchased Product ${index + 1}</div>
                            <div class="text-muted" style="font-size:.74rem;">Linked with pricing model snapshot for client records</div>
                        </div>
                        <button type="button" class="btn btn-sm btn-outline-danger" style="border-radius:10px;" onclick="removePurchasedProductRow(this)">
                            <i class="bi bi-trash me-1"></i>Remove
                        </button>
                    </div>
                    <div class="row g-3 align-items-start">
                        <div class="col-md-5">
                            <label class="form-label fw-semibold" style="font-size:.8rem;">Product Name</label>
                            <select name="PurchasedProducts[${index}].ProductId" class="form-select product-select" style="border-radius:10px;" onchange="handleProductChange(this)">
                                <option value="">Select Product</option>
                                ${productOptions}
                            </select>
                            <span class="text-danger small field-validation-valid" data-valmsg-for="PurchasedProducts[${index}].ProductId" data-valmsg-replace="true"></span>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold" style="font-size:.8rem;">Product Pricing Model</label>
                            <select name="PurchasedProducts[${index}].ProductRateId" class="form-select pricing-model-select" style="border-radius:10px;" onchange="handleRateChange(this)">
                                <option value="">Select Pricing Model</option>
                            </select>
                            <span class="text-danger small field-validation-valid" data-valmsg-for="PurchasedProducts[${index}].ProductRateId" data-valmsg-replace="true"></span>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold" style="font-size:.8rem;">Snapshot</label>
                            <div class="rounded-3 px-3 py-2 h-100 purchase-row-state" style="background:#eef4ff;border:1px solid #dbe5f4;min-height:44px;font-size:.76rem;color:#475569;display:flex;align-items:center;">Select pricing model to load details</div>
                        </div>
                        <div class="col-md-4">
                            <div class="rounded-3 px-3 py-2 h-100" style="background:#fff;border:1px solid #e2e8f0;">
                                <div class="text-muted" style="font-size:.72rem;font-weight:700;letter-spacing:.04em;">BASE PRICE</div>
                                <div class="purchase-base-price fw-bold mt-1" style="font-size:1rem;color:#1e293b;">-</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="rounded-3 px-3 py-2 h-100" style="background:#fff;border:1px solid #e2e8f0;">
                                <div class="text-muted" style="font-size:.72rem;font-weight:700;letter-spacing:.04em;">AMC TYPE / %</div>
                                <div class="purchase-amc-type fw-semibold mt-1" style="font-size:.88rem;color:#1e293b;">-</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="rounded-3 px-3 py-2 h-100" style="background:#fff;border:1px solid #e2e8f0;">
                                <div class="text-muted" style="font-size:.72rem;font-weight:700;letter-spacing:.04em;">AMC AMOUNT</div>
                                <div class="purchase-amc-amount fw-bold mt-1" style="font-size:1rem;color:#1e293b;">-</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold" style="font-size:.8rem;">Invoice No</label>
                            <input type="text" name="PurchasedProducts[${index}].InvoiceNo" class="form-control invoice-no-input" placeholder="e.g. EL/SL/26-27/0001" style="border-radius:10px;" oninput="scheduleInvoiceFetch(this)" />
                        </div>
                        <div class="col-12">
                            <div class="invoice-detail-panel d-none mt-1 p-3 rounded-3" style="background:#f0f7ff;border:1px solid #c7ddf9;font-size:.82rem;">
                                <div class="d-flex flex-wrap gap-3 align-items-center">
                                    <span class="inv-detail-item"><span class="text-muted">Invoice:</span> <strong class="inv-no"></strong></span>
                                    <span class="inv-detail-item"><span class="text-muted">Date:</span> <strong class="inv-date"></strong></span>
                                    <span class="inv-detail-item"><span class="text-muted">Party:</span> <strong class="inv-party"></strong></span>
                                    <span class="ms-auto badge inv-status"></span>
                                </div>
                                <hr class="my-2" style="border-color:#c7ddf9;" />
                                <div class="d-flex flex-wrap gap-3">
                                    <div class="inv-stat-box">
                                        <div class="inv-stat-lbl">Sub Total</div>
                                        <div class="inv-stat-val inv-subtotal"></div>
                                    </div>
                                    <div class="inv-stat-box">
                                        <div class="inv-stat-lbl">GST</div>
                                        <div class="inv-stat-val inv-gst"></div>
                                    </div>
                                    <div class="inv-stat-box" style="border-color:#6366f1;">
                                        <div class="inv-stat-lbl">Total Amount</div>
                                        <div class="inv-stat-val inv-total" style="color:#6366f1;"></div>
                                    </div>
                                    <div class="inv-stat-box" style="border-color:#10b981;">
                                        <div class="inv-stat-lbl">Paid Amount</div>
                                        <div class="inv-stat-val inv-paid" style="color:#10b981;"></div>
                                    </div>
                                    <div class="inv-stat-box inv-balance-box">
                                        <div class="inv-stat-lbl">Balance Due</div>
                                        <div class="inv-stat-val inv-balance"></div>
                                    </div>
                                </div>
                                <div class="mt-2 inv-lines-wrap" style="font-size:.78rem;color:#475569;"></div>
                            </div>
                            <div class="invoice-not-found-msg d-none text-danger mt-1" style="font-size:.78rem;">Invoice not found or cancelled.</div>
                        </div>
                    </div>
                </div>
            </div>`;

        container.insertAdjacentHTML('beforeend', html);
    }

    function removePurchasedProductRow(button) {
        button.closest('.purchase-row').remove();
        reindexPurchasedProductRows();
    }

    function reindexPurchasedProductRows() {
        document.querySelectorAll('#purchasedProductsContainer .purchase-row').forEach((row, index) => {
            row.dataset.index = index;
            const title = row.querySelector('.fw-semibold');
            if (title) {
                title.textContent = `Purchased Product ${index + 1}`;
            }

            row.querySelectorAll('select, input, span[data-valmsg-for]').forEach(element => {
                if (element.name) {
                    element.name = element.name.replace(/PurchasedProducts\[\d+\]/g, `PurchasedProducts[${index}]`);
                }
                const valMsgFor = element.getAttribute('data-valmsg-for');
                if (valMsgFor) {
                    element.setAttribute('data-valmsg-for', valMsgFor.replace(/PurchasedProducts\[\d+\]/g, `PurchasedProducts[${index}]`));
                }
            });
        });
    }

    document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('#purchasedProductsContainer .purchase-row').forEach(row => {
            const selectedRateId = row.querySelector('.pricing-model-select').dataset.selectedRateId || null;
            populatePricingModelSelect(row, selectedRateId);
            updatePurchaseSnapshot(row);
        });

        toggleInternalUseSection();

        // Auto-fetch for pre-filled Invoice No fields on page load
        document.querySelectorAll('.invoice-no-input').forEach(function(inp) {
            if (inp.dataset.initial && inp.dataset.initial.trim() !== '') {
                fetchInvoiceDetails(inp);
            }
        });
    });

    // ── Invoice No lookup ──────────────────────────────────────────
    var _invoiceFetchTimers = new WeakMap();

    function scheduleInvoiceFetch(input) {
        clearTimeout(_invoiceFetchTimers.get(input));
        var timer = setTimeout(function() { fetchInvoiceDetails(input); }, 600);
        _invoiceFetchTimers.set(input, timer);
    }

    function fetchInvoiceDetails(input) {
        var row = input.closest('.purchase-row');
        var panel = row.querySelector('.invoice-detail-panel');
        var notFound = row.querySelector('.invoice-not-found-msg');
        var val = input.value.trim();

        // Hide both if empty
        if (!val) {
            panel.classList.add('d-none');
            notFound.classList.add('d-none');
            return;
        }

        fetch('/ClientDetails/GetInvoiceDetails?invoiceNo=' + encodeURIComponent(val))
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (!data.found) {
                    panel.classList.add('d-none');
                    notFound.classList.remove('d-none');
                    return;
                }
                notFound.classList.add('d-none');

                // Header
                row.querySelector('.inv-no').textContent    = data.invoiceNo;
                row.querySelector('.inv-date').textContent  = data.invoiceDate;
                row.querySelector('.inv-party').textContent = data.partyName;

                var statusBadge = row.querySelector('.inv-status');
                statusBadge.textContent = data.status;
                var sc = { Paid: 'bg-success', Partial: 'bg-warning text-dark', Cancelled: 'bg-danger', Draft: 'bg-secondary', Sent: 'bg-info text-dark' };
                statusBadge.className = 'ms-auto badge ' + (sc[data.status] || 'bg-secondary');

                // Amounts
                var fmt = function(n) { return '\u20b9' + Number(n).toLocaleString('en-IN', {minimumFractionDigits:2, maximumFractionDigits:2}); };
                row.querySelector('.inv-subtotal').textContent = fmt(data.subTotal);
                row.querySelector('.inv-gst').textContent      = fmt(data.totalGst);
                row.querySelector('.inv-total').textContent    = fmt(data.totalAmount);
                row.querySelector('.inv-paid').textContent     = fmt(data.receivedAmount);

                var balBox = row.querySelector('.inv-balance-box');
                var balVal = row.querySelector('.inv-balance');
                balVal.textContent = fmt(data.balanceDue);
                balBox.style.borderColor = data.balanceDue > 0 ? '#ef4444' : '#10b981';
                balVal.style.color       = data.balanceDue > 0 ? '#ef4444' : '#10b981';

                // Line items
                var linesWrap = row.querySelector('.inv-lines-wrap');
                if (data.lines && data.lines.length) {
                    linesWrap.innerHTML = '<strong>Items:</strong> ' +
                        data.lines.map(function(l) {
                            return (l.itemDescription || '') +
                                (l.planName ? ' \u2022 ' + l.planName : '') +
                                (l.type ? ' (' + l.type + ')' : '') +
                                ' \u00d7' + l.qty + ' \u0040 \u20b9' + Number(l.rate).toLocaleString('en-IN') +
                                ' = \u20b9' + Number(l.amount).toLocaleString('en-IN');
                        }).join(' &nbsp;|&nbsp; ');
                } else {
                    linesWrap.innerHTML = '';
                }

                // Auto-select Product Name and Pricing Model from first invoice line
                if (data.lines && data.lines.length > 0) {
                    var firstLine = data.lines[0];
                    var productSelect = row.querySelector('.product-select');
                    var matchedProduct = productCatalog.find(function(p) {
                        return p.productName.toLowerCase() === (firstLine.itemDescription || '').toLowerCase();
                    });
                    if (matchedProduct) {
                        productSelect.value = matchedProduct.id;
                        var rates = getRatesForProduct(matchedProduct.id);
                        var matchedRate = rates.find(function(r) {
                            return r.pricingModel.toLowerCase() === (firstLine.planName || '').toLowerCase();
                        });
                        populatePricingModelSelect(row, matchedRate ? matchedRate.id : null);
                        updatePurchaseSnapshot(row);
                    }
                }

                panel.classList.remove('d-none');
            })
            .catch(function() {
                panel.classList.add('d-none');
                notFound.classList.remove('d-none');
            });
    }
</script>
}
