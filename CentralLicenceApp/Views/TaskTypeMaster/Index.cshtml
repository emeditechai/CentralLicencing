@model IEnumerable<CentralLicenceApp.Models.TaskTypeMaster>
@{
    ViewData["Title"] = "Task Type Master";
}

<style>
    .ms-hero { background:linear-gradient(135deg,#667eea 0%,#764ba2 100%); border-radius:20px; padding:1.75rem 2rem; margin-bottom:1.75rem; position:relative; overflow:hidden; }
    .ms-hero::before { content:''; position:absolute; top:-50%; right:-8%; width:280px; height:280px; background:rgba(255,255,255,.06); border-radius:50%; }
    .ms-hero h4 { color:#fff; font-weight:800; font-size:1.35rem; margin-bottom:.2rem; }
    .ms-hero .ms-sub { color:rgba(255,255,255,.7); font-size:.83rem; }

    .ms-stat { background:rgba(255,255,255,.15); backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,.18); border-radius:14px; padding:.6rem 1rem; min-width:85px; text-align:center; }
    .ms-stat-num { font-size:1.4rem; font-weight:800; color:#fff; line-height:1.2; }
    .ms-stat-lbl { font-size:.65rem; text-transform:uppercase; letter-spacing:.06em; font-weight:600; color:rgba(255,255,255,.7); }

    .ms-card { background:#fff; border-radius:14px; box-shadow:0 2px 12px rgba(0,0,0,.05); border:1px solid #f1f5f9; overflow:hidden; }
    .ms-table { margin-bottom:0; }
    .ms-table thead { background:linear-gradient(180deg,#f8fafc,#f1f5f9); }
    .ms-table thead th { font-size:.7rem; font-weight:700; color:#475569; text-transform:uppercase; letter-spacing:.08em; padding:.75rem .85rem; border-bottom:2px solid #e2e8f0; white-space:nowrap; }
    .ms-table tbody tr { transition:all .15s ease; border-bottom:1px solid #f8fafc; }
    .ms-table tbody tr:hover { background:linear-gradient(90deg,#f5f3ff,#eff6ff); }
    .ms-table td { vertical-align:middle; padding:.7rem .85rem; font-size:.85rem; color:#334155; }

    .ms-badge-active { background:linear-gradient(135deg,#dcfce7,#bbf7d0); color:#166534; font-size:.72rem; font-weight:700; padding:4px 10px; border-radius:20px; }
    .ms-badge-inactive { background:#f1f5f9; color:#64748b; font-size:.72rem; font-weight:700; padding:4px 10px; border-radius:20px; }

    .ms-action-btn { width:30px; height:30px; border-radius:8px; border:1.5px solid #e2e8f0; background:#fff; display:inline-flex; align-items:center; justify-content:center; transition:all .18s; font-size:.8rem; color:#64748b; cursor:pointer; }
    .ms-action-btn:hover { border-color:#818cf8; background:#f5f3ff; color:#6366f1; transform:translateY(-1px); }
    .ms-action-btn-danger:hover { border-color:#f87171; background:#fef2f2; color:#ef4444; }
    .ms-action-btn-toggle { border-color:#f59e0b; color:#d97706; }
    .ms-action-btn-toggle:hover { background:#fffbeb; border-color:#d97706; }
    .ms-action-btn-activate { border-color:#10b981; color:#059669; }
    .ms-action-btn-activate:hover { background:#ecfdf5; border-color:#059669; }

    .ms-add-card { background:#fff; border-radius:14px; box-shadow:0 2px 12px rgba(0,0,0,.05); border:1px solid #f1f5f9; max-width:480px; margin-top:1.5rem; }
    .ms-add-card .card-header { background:linear-gradient(90deg,#f8fafc,#f5f3ff); font-weight:700; font-size:.88rem; padding:.75rem 1.25rem; border-bottom:1px solid #f1f5f9; color:#1e293b; }
    .ms-add-card .card-body { padding:1.25rem; }
    .ms-add-card .form-label { font-size:.78rem; font-weight:700; color:#475569; }
    .ms-add-card .form-control { border-radius:10px; border:1.5px solid #e2e8f0; font-size:.85rem; }
    .ms-add-card .form-control:focus { border-color:#818cf8; box-shadow:0 0 0 3px rgba(129,140,248,.15); }

    .ms-save-btn { background:linear-gradient(135deg,#6366f1,#4f46e5); border:none; border-radius:10px; font-weight:700; font-size:.82rem; padding:.45rem 1.1rem; color:#fff; }
    .ms-save-btn:hover { color:#fff; transform:translateY(-1px); box-shadow:0 4px 12px rgba(99,102,241,.35); }

    .ms-empty { padding:3rem 1rem; text-align:center; }
    .ms-empty i { font-size:3rem; color:#cbd5e1; display:block; margin-bottom:.75rem; }
    .ms-empty span { color:#94a3b8; font-size:.9rem; }

    .ms-edit-form { display:none; }
    .ms-edit-form.active { display:inline-flex; gap:6px; align-items:center; }
    .ms-edit-form input { border-radius:8px; border:1.5px solid #e2e8f0; font-size:.82rem; padding:.3rem .5rem; }
    .ms-edit-form input:focus { border-color:#818cf8; box-shadow:0 0 0 2px rgba(129,140,248,.15); outline:none; }
</style>

@{
    var all = Model.ToList();
    var activeCount = all.Count(x => x.IsActive);
    var inactiveCount = all.Count(x => !x.IsActive);
}

<!-- ── Hero ── -->
<div class="ms-hero">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
            <h4><i class="bi bi-code-slash me-2" style="opacity:.85;"></i> Task Type Master</h4>
            <div class="ms-sub">Manage task types (e.g. Development, Support) used in task logs</div>
        </div>
        <div class="d-flex gap-2">
            <div class="ms-stat"><div class="ms-stat-num">@all.Count</div><div class="ms-stat-lbl">Total</div></div>
            <div class="ms-stat"><div class="ms-stat-num">@activeCount</div><div class="ms-stat-lbl">Active</div></div>
            <div class="ms-stat"><div class="ms-stat-num">@inactiveCount</div><div class="ms-stat-lbl">Inactive</div></div>
        </div>
    </div>
</div>

<!-- ── Table ── -->
<div class="ms-card">
    @if (!all.Any())
    {
        <div class="ms-empty">
            <i class="bi bi-ui-checks-grid"></i>
            <span>No task types found. Add one below.</span>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table ms-table">
                <thead>
                    <tr>
                        <th class="ps-3">#</th>
                        <th>Name</th>
                        <th>Status</th>
                        <th class="text-center pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var idx = 0; }
                    @foreach (var item in all)
                    {
                        idx++;
                        <tr>
                            <td class="ps-3 text-muted" style="font-size:.8rem;">@idx</td>
                            <td>
                                <span class="view-name-@item.Id fw-semibold">@item.Name</span>
                                <form class="ms-edit-form" id="edit-form-@item.Id" asp-action="Edit" asp-permission="TaskTypeMaster:Edit" asp-route-id="@item.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="text" name="name" value="@item.Name" style="width:200px;" required placeholder="Name" />
                                    <button type="submit" class="btn btn-sm btn-success py-0 px-2"><i class="bi bi-check-lg"></i></button>
                                    <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-2" onclick="cancelEdit(@item.Id)"><i class="bi bi-x-lg"></i></button>
                                </form>
                            </td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="ms-badge-active">Active</span>
                                }
                                else
                                {
                                    <span class="ms-badge-inactive">Inactive</span>
                                }
                            </td>
                            <td class="text-center pe-3">
                                <div class="d-flex gap-1 justify-content-center">
                                    <button type="button" class="ms-action-btn" title="Edit" onclick="startEdit(@item.Id)"><i class="bi bi-pencil-square"></i></button>
                                    <form asp-action="ToggleActive" asp-permission="TaskTypeMaster:Edit" asp-route-id="@item.Id" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        @if (item.IsActive)
                                        {
                                            <button type="submit" class="ms-action-btn ms-action-btn-toggle" title="Deactivate"><i class="bi bi-toggle-on"></i></button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="ms-action-btn ms-action-btn-activate" title="Activate"><i class="bi bi-toggle-off"></i></button>
                                        }
                                    </form>
                                    <form asp-action="Delete" asp-permission="TaskTypeMaster:Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirmDelete(event, '@item.Name.Replace("'", "\\'")'))">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="ms-action-btn ms-action-btn-danger" title="Delete"><i class="bi bi-trash3"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- ── Add New ── -->
<div class="ms-add-card">
    <div class="card-header">
        <i class="bi bi-plus-circle me-1"></i> Add New Task Type
    </div>
    <div class="card-body">
        <form asp-action="Create" asp-permission="TaskTypeMaster:Create" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3 align-items-end">
                <div class="col-8">
                    <label class="form-label">Name <span class="text-danger">*</span></label>
                    <input type="text" name="name" class="form-control form-control-sm" placeholder="e.g. Development" required maxlength="100" />
                </div>
                <div class="col-4">
                    <button type="submit" class="btn btn-sm w-100 ms-save-btn">
                        <i class="bi bi-plus-lg me-1"></i> Add
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function startEdit(id) {
        document.querySelector('.view-name-' + id).classList.add('d-none');
        document.getElementById('edit-form-' + id).classList.add('active');
    }

    function cancelEdit(id) {
        document.querySelector('.view-name-' + id).classList.remove('d-none');
        document.getElementById('edit-form-' + id).classList.remove('active');
    }

    function confirmDelete(e, name) {
        e.preventDefault();
        Swal.fire({
            ...swalTheme,
            icon: 'warning',
            title: 'Delete Task Type?',
            html: 'Are you sure you want to delete <strong>' + name + '</strong>?',
            showCancelButton: true,
            confirmButtonText: 'Delete',
            confirmButtonColor: '#ef4444'
        }).then(function (r) {
            if (r.isConfirmed) e.target.submit();
        });
        return false;
    }
</script>
}
