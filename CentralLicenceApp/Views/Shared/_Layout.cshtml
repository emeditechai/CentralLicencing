@using System.Security.Claims
@using CentralLicenceApp.Repositories
@inject ICompanySettingsRepository CompanySettingsRepo
@inject IUserRepository UserRepo
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var parentCompany = await CompanySettingsRepo.GetParentCompanyAsync();
    var brandName = string.IsNullOrWhiteSpace(parentCompany?.CompanyName) ? "Emeditech Plus LLP" : parentCompany.CompanyName.Trim();
    var hasBrandLogo = !string.IsNullOrWhiteSpace(parentCompany?.CompanyLogoPath);
    var brandLogoUrl = hasBrandLogo ? Url.Content(parentCompany!.CompanyLogoPath!) : "https://emeditechplus.com/img/emeditechplus-logo.png";
    var footerCompanyName = brandName.ToUpperInvariant();
    var antiforgeryToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="request-verification-token" content="@antiforgeryToken" />
    <title>@ViewData["Title"] - @brandName</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    @await RenderSectionAsync("HeadExtra", required: false)
</head>
<body>
@if (User.Identity?.IsAuthenticated == true)
{
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    Func<string, string> Act = c => ctrl == c ? "active" : "";
    var fullName = User.FindFirst("FullName")?.Value ?? User.Identity!.Name ?? "User";
    var initials = fullName.Length > 0 ? fullName[0].ToString().ToUpper() : "U";
    var username = User.Identity?.Name ?? string.Empty;
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
    var currentUserIdValue = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    var currentUser = int.TryParse(currentUserIdValue, out var currentUserId)
        ? await UserRepo.GetByIdAsync(currentUserId)
        : null;
    var availableRoles = currentUser?.Roles
        .Where(r => r.IsActive)
        .OrderBy(r => r.RoleName)
        .ToList()
        ?? new List<CentralLicenceApp.Models.RoleMaster>();
    var canSwitchRole = availableRoles.Count > 1;
    var currentPath = Context.Request.Path.HasValue ? Context.Request.Path.Value! : "/";
    var currentQuery = Context.Request.QueryString.HasValue ? Context.Request.QueryString.Value : string.Empty;
    var currentReturnUrl = $"{currentPath}{currentQuery}";
    var isSuperAdmin = string.Equals(username, "admin", System.StringComparison.OrdinalIgnoreCase) || User.HasClaim("IsSuperAdmin", "true");
    var isAdmin = User.IsInRole("Administrator") || isSuperAdmin;
    var isFinance = User.IsInRole("Finance") || isSuperAdmin;
    var isCrmOnly = (User.IsInRole("ClientTicket") || User.IsInRole("Ticket Admin") || User.IsInRole("Ticket Agent")) && !isAdmin;
    var profileImagePath = User.FindFirst("ProfileImagePath")?.Value ?? "";
    var currentProductType = Context.Request.Query["productType"].ToString();
    <div id="sidebar-overlay" onclick="closeSidebar()"></div>
    <div id="sidebar">
        <div class="brand">
            <img src="@brandLogoUrl" alt="@brandName" style="max-width:140px;max-height:54px;object-fit:contain;@(hasBrandLogo ? "background:rgba(255,255,255,.96);padding:.35rem .55rem;border-radius:12px;" : "filter:brightness(0) invert(1);")" />
        </div>
        <nav>
            @if (!isCrmOnly)
            {
            <div class="nav-lbl mt-2">Main</div>
            <div class="nav-item"><a asp-controller="Dashboard" asp-action="Index" class="@Act("Dashboard")"><i class="bi bi-speedometer2"></i> Dashboard</a></div>
            }

            <!-- Licences section -->
            @{
                var licencesOpen = ctrl == "ClientLicense" || ctrl == "LicenseHistory" || ctrl == "LicenseAuditLog";
                var masterOpen   = ctrl == "EmployeeDepartment" || ctrl == "EmployeeDesignation" || ctrl == "FinancialYearMaster";
                var businessUnitMasterOpen = ctrl == "ExpenseCategory" || ctrl == "ProductMaster" || ctrl == "ProductRate" || ctrl == "PartyMaster" || ctrl == "BankMaster" || ctrl == "PaymentMode" || ctrl == "TermsConditionTemplate";
                var businessUnitTransactionOpen = ctrl == "ExpenseRequest";
                var quotationInvoiceOpen = ctrl == "Quotation" || ctrl == "Invoice" || ctrl == "InvoicePayment";
                var businessUnitOpen = businessUnitMasterOpen || businessUnitTransactionOpen || quotationInvoiceOpen;
                var reportsOpen = ctrl == "Reports";
                var crmTicketOpen = ctrl == "HelpDeskTicket";
                var crmMasterOpen = ctrl == "TicketCategory" || ctrl == "TicketSubCategory" || ctrl == "TicketPriority";
                var crmReportsOpen = ctrl == "TicketReports";
                var crmOpen = crmTicketOpen || crmMasterOpen || crmReportsOpen;
                var adminOpen    = ctrl == "User" || ctrl == "Role" || ctrl == "EmailConfig" || ctrl == "EmailTemplate" || ctrl == "EmailLog" || ctrl == "CompanySettings" || masterOpen;
            }
            @if (!isCrmOnly)
            {
            <a href="#section-licences" data-bs-toggle="collapse"
               class="nav-lbl nav-lbl-toggle mt-2"
               aria-expanded="@(licencesOpen ? "true" : "false")"
               style="display:flex;align-items:center;justify-content:space-between;cursor:pointer;">
                <span class="nav-lbl-toggle-copy"><i class="bi bi-card-checklist"></i><span>Licences</span></span>
                <i class="bi bi-chevron-down nav-lbl-arrow @(licencesOpen ? "rotated" : "")"></i>
            </a>
            <div class="collapse @(licencesOpen ? "show" : "")" id="section-licences">
                <div class="nav-item"><a asp-controller="ClientLicense" asp-action="Index" class="@Act("ClientLicense")"><i class="bi bi-card-checklist"></i> Client Licences</a></div>
                <div class="nav-item"><a asp-controller="LicenseHistory" asp-action="Index" class="@Act("LicenseHistory")"><i class="bi bi-clock-history"></i> Validation History</a></div>
                <div class="nav-item"><a asp-controller="LicenseAuditLog" asp-action="Index" class="@Act("LicenseAuditLog")"><i class="bi bi-clipboard2-pulse"></i> Audit Log</a></div>
            </div><!-- /section-licences collapse -->
            }

            @if (isAdmin)
            {
                <a href="#section-admin" data-bs-toggle="collapse"
                   class="nav-lbl nav-lbl-toggle mt-2"
                   aria-expanded="@(adminOpen ? "true" : "false")"
                   style="display:flex;align-items:center;justify-content:space-between;cursor:pointer;">
                    <span class="nav-lbl-toggle-copy"><i class="bi bi-sliders2-vertical"></i><span>Administration</span></span>
                    <i class="bi bi-chevron-down nav-lbl-arrow @(adminOpen ? "rotated" : "")"></i>
                </a>
                <div class="collapse @(adminOpen ? "show" : "")" id="section-admin">
                <div class="nav-item"><a asp-controller="User" asp-action="Index" class="@Act("User")"><i class="bi bi-people"></i> User Management</a></div>
                <div class="nav-item"><a asp-controller="Role" asp-action="Index" class="@Act("Role")"><i class="bi bi-diagram-3"></i> Role Management</a></div>
                <div class="nav-item"><a asp-controller="CompanySettings" asp-action="Index" class="@Act("CompanySettings")"><i class="bi bi-buildings"></i> Company Settings</a></div>
                <div class="nav-item">
                    <a href="#section-master" data-bs-toggle="collapse" class="@(masterOpen ? "active" : "")" aria-expanded="@(masterOpen ? "true" : "false")">
                        <i class="bi bi-collection"></i> Master
                        <i class="bi bi-chevron-down submenu-arrow"></i>
                    </a>
                </div>
                <div class="collapse @(masterOpen ? "show" : "")" id="section-master">
                    <div class="nav-sub-item"><a asp-controller="EmployeeDepartment" asp-action="Index" class="@Act("EmployeeDepartment")"><i class="bi bi-building"></i> Employee Department</a></div>
                    <div class="nav-sub-item"><a asp-controller="EmployeeDesignation" asp-action="Index" class="@Act("EmployeeDesignation")"><i class="bi bi-person-workspace"></i> Employee Designation</a></div>
                    <div class="nav-sub-item"><a asp-controller="FinancialYearMaster" asp-action="Index" class="@Act("FinancialYearMaster")"><i class="bi bi-calendar-range"></i> Financial Year</a></div>
                </div>
                <div class="nav-item"><a asp-controller="EmailConfig" asp-action="Index" class="@Act("EmailConfig")"><i class="bi bi-send-check"></i> Email Engine</a></div>
                <div class="nav-item"><a asp-controller="EmailTemplate" asp-action="Index" class="@Act("EmailTemplate")"><i class="bi bi-file-earmark-text"></i> Email Templates</a></div>
                <div class="nav-item"><a asp-controller="EmailLog" asp-action="Index" class="@Act("EmailLog")"><i class="bi bi-journal-text"></i> Email Logs</a></div>
                </div><!-- /section-admin collapse -->
            }

            @if (!isCrmOnly)
            {
            <div class="nav-item mt-1">
                <a href="#section-business-unit" data-bs-toggle="collapse" class="@(businessUnitOpen ? "active" : "")" aria-expanded="@(businessUnitOpen ? "true" : "false")">
                    <i class="bi bi-diagram-2"></i> Business Unit
                    <i class="bi bi-chevron-down submenu-arrow"></i>
                </a>
            </div>
            <div class="collapse @(businessUnitOpen ? "show" : "")" id="section-business-unit">
                <div class="nav-item nav-item-nested">
                    <a href="#section-business-unit-transaction" data-bs-toggle="collapse" class="@(businessUnitTransactionOpen ? "active" : "")" aria-expanded="@(businessUnitTransactionOpen ? "true" : "false")">
                        <i class="bi bi-arrow-left-right"></i> Expenses &amp; Advance
                        <i class="bi bi-chevron-down submenu-arrow"></i>
                    </a>
                </div>
                <div class="collapse @(businessUnitTransactionOpen ? "show" : "")" id="section-business-unit-transaction">
                    <div class="nav-sub-item nav-sub-item-deep"><a asp-controller="ExpenseRequest" asp-action="Index" class="@Act("ExpenseRequest")"><i class="bi bi-wallet2"></i> Expense Requests</a></div>
                    <div class="nav-sub-item nav-sub-item-deep"><a asp-controller="ExpenseRequest" asp-action="Approvals" class="@(ctrl == "ExpenseRequest" && (ViewContext.RouteData.Values["action"]?.ToString() == "Approvals") ? "active" : "")"><i class="bi bi-check2-square"></i> Approval Inbox</a></div>
                    @if (isFinance)
                    {
                        <div class="nav-sub-item nav-sub-item-deep"><a asp-controller="ExpenseRequest" asp-action="FinanceDesk" class="@(ctrl == "ExpenseRequest" && (ViewContext.RouteData.Values["action"]?.ToString() == "FinanceDesk") ? "active" : "")"><i class="bi bi-cash-stack"></i> Reimbursement Desk</a></div>
                    }
                </div>
                <div class="nav-item nav-item-nested">
                    <a href="#section-quotation-invoice" data-bs-toggle="collapse" class="@(quotationInvoiceOpen ? "active" : "")" aria-expanded="@(quotationInvoiceOpen ? "true" : "false")">
                        <i class="bi bi-file-earmark-text"></i> Quotation &amp; Invoices
                        <i class="bi bi-chevron-down submenu-arrow"></i>
                    </a>
                </div>
                <div class="collapse @(quotationInvoiceOpen ? "show" : "")" id="section-quotation-invoice">
                    <div class="nav-sub-item nav-sub-item-deep"><a asp-controller="Quotation" asp-action="Index" class="@Act("Quotation")"><i class="bi bi-file-earmark-check"></i> Quotations</a></div>
                    <div class="nav-sub-item nav-sub-item-deep"><a asp-controller="Invoice" asp-action="Index" class="@Act("Invoice")"><i class="bi bi-receipt-cutoff"></i> Invoices</a></div>
                    <div class="nav-sub-item nav-sub-item-deep"><a asp-controller="InvoicePayment" asp-action="Index" class="@Act("InvoicePayment")"><i class="bi bi-cash-coin"></i> Payment Process</a></div>
                </div>
                @if (isAdmin)
                {
                    <div class="nav-item nav-item-nested">
                        <a href="#section-business-unit-master" data-bs-toggle="collapse" class="@(businessUnitMasterOpen ? "active" : "")" aria-expanded="@(businessUnitMasterOpen ? "true" : "false")">
                            <i class="bi bi-collection"></i> Master
                            <i class="bi bi-chevron-down submenu-arrow"></i>
                        </a>
                    </div>
                    <div class="collapse @(businessUnitMasterOpen ? "show" : "")" id="section-business-unit-master">
                        <div class="nav-sub-item nav-sub-item-deep"><a asp-controller="ExpenseCategory" asp-action="Index" class="@Act("ExpenseCategory")"><i class="bi bi-receipt"></i> Expense Category</a></div>
                        <div class="nav-sub-item nav-sub-item-deep"><a asp-controller="ProductMaster" asp-action="Index" class="@Act("ProductMaster")"><i class="bi bi-box-seam"></i> eProduct Master</a></div>
                        <div class="nav-sub-item nav-sub-item-deep"><a asp-controller="ProductRate" asp-action="Index" class="@Act("ProductRate")"><i class="bi bi-tags"></i> Product Rate List</a></div>
                        <div class="nav-sub-item nav-sub-item-deep"><a asp-controller="PartyMaster" asp-action="Index" class="@Act("PartyMaster")"><i class="bi bi-people"></i> Party Master</a></div>
                        <div class="nav-sub-item nav-sub-item-deep"><a asp-controller="BankMaster" asp-action="Index" class="@Act("BankMaster")"><i class="bi bi-bank2"></i> Bank Master</a></div>
                        <div class="nav-sub-item nav-sub-item-deep"><a asp-controller="PaymentMode" asp-action="Index" class="@Act("PaymentMode")"><i class="bi bi-credit-card-2-front"></i> Payment Modes</a></div>
                        <div class="nav-sub-item nav-sub-item-deep"><a asp-controller="TermsConditionTemplate" asp-action="Index" class="@Act("TermsConditionTemplate")"><i class="bi bi-file-text"></i> Terms &amp; Conditions</a></div>
                    </div>
                }
            </div>

            <div class="nav-item mt-1">
                <a href="#section-reports" data-bs-toggle="collapse" class="@(reportsOpen ? "active" : "")" aria-expanded="@(reportsOpen ? "true" : "false")">
                    <i class="bi bi-bar-chart-line"></i> Reports
                    <i class="bi bi-chevron-down submenu-arrow"></i>
                </a>
            </div>
            <div class="collapse @(reportsOpen ? "show" : "")" id="section-reports">
                <div class="nav-sub-item nav-sub-item-deep"><a asp-controller="Reports" asp-action="ClientDetails" class="@(ctrl == "Reports" && (ViewContext.RouteData.Values["action"]?.ToString() == "ClientDetails") ? "active" : "")"><i class="bi bi-file-earmark-bar-graph"></i> Client Details</a></div>
                <div class="nav-sub-item nav-sub-item-deep"><a asp-controller="Reports" asp-action="ExpenseReport" class="@(ctrl == "Reports" && (ViewContext.RouteData.Values["action"]?.ToString() == "ExpenseReport") ? "active" : "")"><i class="bi bi-wallet2"></i> Expense Report</a></div>
                <div class="nav-sub-item nav-sub-item-deep"><a asp-controller="Reports" asp-action="SettlementReport" class="@(ctrl == "Reports" && (ViewContext.RouteData.Values["action"]?.ToString() == "SettlementReport") ? "active" : "")"><i class="bi bi-cash-stack"></i> Settlement Report</a></div>
                <div class="nav-sub-item nav-sub-item-deep"><a asp-controller="Reports" asp-action="DailyCollectionRegister" class="@(ctrl == "Reports" && (ViewContext.RouteData.Values["action"]?.ToString() == "DailyCollectionRegister") ? "active" : "")"><i class="bi bi-cash-coin"></i> Daily Collection Register</a></div>
                <div class="nav-sub-item nav-sub-item-deep"><a asp-controller="Reports" asp-action="ClientDueReport" class="@(ctrl == "Reports" && (ViewContext.RouteData.Values["action"]?.ToString() == "ClientDueReport") ? "active" : "")"><i class="bi bi-exclamation-triangle"></i> Client Due Report</a></div>
            </div>
            }<!-- /!isCrmOnly -->

            <!-- CRM / Help Desk section -->
            <a href="#section-crm" data-bs-toggle="collapse"
               class="nav-lbl nav-lbl-toggle mt-2"
               aria-expanded="@(crmOpen ? "true" : "false")"
               style="display:flex;align-items:center;justify-content:space-between;cursor:pointer;">
                <span class="nav-lbl-toggle-copy"><i class="bi bi-headset"></i><span>CRM</span></span>
                <i class="bi bi-chevron-down nav-lbl-arrow @(crmOpen ? "rotated" : "")"></i>
            </a>
            <div class="collapse @(crmOpen ? "show" : "")" id="section-crm">
                <div class="nav-item"><a asp-controller="HelpDeskTicket" asp-action="MyTickets" class="@(ctrl == "HelpDeskTicket" && (ViewContext.RouteData.Values["action"]?.ToString() == "MyTickets") ? "active" : "")"><i class="bi bi-ticket-perforated"></i> My Tickets</a></div>
                @if (isAdmin || User.IsInRole("Ticket Admin") || User.IsInRole("Ticket Agent"))
                {
                    <div class="nav-item"><a asp-controller="HelpDeskTicket" asp-action="Index" class="@(ctrl == "HelpDeskTicket" && (ViewContext.RouteData.Values["action"]?.ToString() == "Index") ? "active" : "")"><i class="bi bi-kanban"></i> Ticket Management</a></div>
                }
                @if (isAdmin || User.IsInRole("Ticket Admin"))
                {
                    <div class="nav-item nav-item-nested">
                        <a href="#section-crm-master" data-bs-toggle="collapse" class="@(crmMasterOpen ? "active" : "")" aria-expanded="@(crmMasterOpen ? "true" : "false")">
                            <i class="bi bi-collection"></i> Master
                            <i class="bi bi-chevron-down submenu-arrow"></i>
                        </a>
                    </div>
                    <div class="collapse @(crmMasterOpen ? "show" : "")" id="section-crm-master">
                        <div class="nav-sub-item nav-sub-item-deep"><a asp-controller="TicketCategory" asp-action="Index" class="@Act("TicketCategory")"><i class="bi bi-tags"></i> Ticket Categories</a></div>
                        <div class="nav-sub-item nav-sub-item-deep"><a asp-controller="TicketSubCategory" asp-action="Index" class="@Act("TicketSubCategory")"><i class="bi bi-bookmark"></i> Ticket Sub Categories</a></div>
                        <div class="nav-sub-item nav-sub-item-deep"><a asp-controller="TicketPriority" asp-action="Index" class="@Act("TicketPriority")"><i class="bi bi-flag"></i> Ticket Priorities</a></div>
                    </div>
                }
                @if (isAdmin || User.IsInRole("Ticket Admin") || User.IsInRole("Ticket Agent"))
                {
                    <div class="nav-item nav-item-nested">
                        <a href="#section-crm-reports" data-bs-toggle="collapse" class="@(crmReportsOpen ? "active" : "")" aria-expanded="@(crmReportsOpen ? "true" : "false")">
                            <i class="bi bi-bar-chart-line"></i> Reports
                            <i class="bi bi-chevron-down submenu-arrow"></i>
                        </a>
                    </div>
                    <div class="collapse @(crmReportsOpen ? "show" : "")" id="section-crm-reports">
                        @if (isAdmin || User.IsInRole("Ticket Admin"))
                        {
                            <div class="nav-sub-item nav-sub-item-deep"><a asp-controller="TicketReports" asp-action="Dashboard" class="@(ctrl == "TicketReports" && (ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard") ? "active" : "")"><i class="bi bi-speedometer2"></i> Analytics Dashboard</a></div>
                        }
                        <div class="nav-sub-item nav-sub-item-deep"><a asp-controller="TicketReports" asp-action="AgentPerformance" class="@(ctrl == "TicketReports" && (ViewContext.RouteData.Values["action"]?.ToString() == "AgentPerformance") ? "active" : "")"><i class="bi bi-people"></i> Agent Performance</a></div>
                        @if (isAdmin || User.IsInRole("Ticket Admin"))
                        {
                            <div class="nav-sub-item nav-sub-item-deep"><a asp-controller="TicketReports" asp-action="SlaCompliance" class="@(ctrl == "TicketReports" && (ViewContext.RouteData.Values["action"]?.ToString() == "SlaCompliance") ? "active" : "")"><i class="bi bi-shield-check"></i> SLA Compliance</a></div>
                        }
                    </div>
                }
            </div><!-- /section-crm collapse -->
        </nav>
        <div style="padding:1rem 1.5rem;border-top:1px solid #2d1258;">
            <form asp-controller="Account" asp-action="Logout" method="post"
                  data-swal-confirm="true"
                  data-swal-title="Sign Out?"
                  data-swal-text="Your current session will be ended and you will be returned to the login page."
                  data-swal-confirm-button="Yes, sign out">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm w-100" style="background:#2d1258;color:#cbbfea;border:none;text-align:left;padding:.5rem .75rem;border-radius:8px;">
                    <i class="bi bi-box-arrow-left me-2"></i> Sign Out
                </button>
            </form>
        </div>
    </div>
    <div id="topbar">
        <div class="d-flex align-items-center gap-2">
            <button id="hamburger" onclick="toggleSidebar()" title="Menu"><i class="bi bi-list"></i></button>
            <span class="pg-title">@(ViewData["Title"] ?? "Dashboard")</span>
        </div>
        <div class="d-flex align-items-center gap-2">
            <a href="/Help" class="btn btn-sm" title="Help & Guide" style="border-radius:8px;color:#6366f1;background:#eef2ff;border:1px solid #e0e7ff;font-size:.78rem;font-weight:600;padding:.3rem .6rem;">
                <i class="bi bi-question-circle-fill me-1"></i> Help
            </a>
            <button type="button" id="browserNotificationToggle" class="btn btn-sm browser-notification-trigger">
                <i class="bi bi-bell me-1"></i> Enable Alerts
            </button>
            @if (!string.IsNullOrWhiteSpace(profileImagePath))
            {
                <img src="@Url.Content(profileImagePath)" alt="@fullName" class="avatar avatar-img" />
            }
            else
            {
                <div class="avatar">@initials</div>
            }
            <div>
                <div class="uname">@fullName</div>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <div class="urole"><i class="bi bi-circle-fill me-1" style="font-size:.45rem;color:#22c55e;vertical-align:middle;"></i>@role</div>
                    @if (canSwitchRole)
                    {
                        <div class="dropdown">
                            <button class="btn btn-sm role-switch-trigger dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-arrow-repeat me-1"></i> Switch Role
                            </button>
                            <div class="dropdown-menu dropdown-menu-end role-switch-menu p-2 shadow-sm border-0">
                                <div class="role-switch-title px-2 pb-2">Choose active role</div>
                                @foreach (var availableRole in availableRoles)
                                {
                                    var isCurrentRole = string.Equals(availableRole.RoleName, role, System.StringComparison.OrdinalIgnoreCase);
                                    <form asp-controller="Account" asp-action="SwitchRole" method="post" class="mb-1"
                                          data-swal-confirm="true"
                                          data-swal-title="Switch Active Role?"
                                          data-swal-text="You are about to switch your active role to <strong>@availableRole.RoleName</strong>. Navigation and permissions will refresh for this session."
                                          data-swal-confirm-button="Yes, switch role">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="selectedRoleId" value="@availableRole.Id" />
                                        <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
                                        <button type="submit" class="dropdown-item role-switch-option @(isCurrentRole ? "active" : string.Empty)" @(isCurrentRole ? "disabled" : null)>
                                            <span>@availableRole.RoleName</span>
                                            @if (isCurrentRole)
                                            {
                                                <i class="bi bi-check2"></i>
                                            }
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    }
                    <a asp-controller="Account" asp-action="ChangePassword" class="btn btn-sm role-switch-trigger">
                        <i class="bi bi-shield-lock me-1"></i> Change Password
                    </a>
                    @if (isSuperAdmin)
                    {
                        <span style="display:inline-flex;align-items:center;gap:.35rem;background:#fef3c7;color:#92400e;border-radius:999px;padding:.15rem .55rem;font-size:.68rem;font-weight:700;line-height:1;">
                            <i class="bi bi-stars"></i> Super Admin
                        </span>
                    }
                </div>
            </div>
        </div>
    </div>
    <div id="main-content">
        @RenderBody()
        <footer class="app-footer">
            <div class="app-footer-inner">
                <div class="af-brand">
                    <i class="bi bi-shield-lock-fill"></i>
                    <span>@footerCompanyName</span>
                </div>
                <div class="af-copy">
                    &copy; @DateTime.Now.Year &mdash; Developed by @brandName
                </div>
                <div class="af-links">
                    <span>Privacy Policy</span>
                    <span class="af-sep">|</span>
                    <span>Terms of Service</span>
                    <span class="af-sep">|</span>
                    <span class="af-version">Version 1.0.0</span>
                </div>
            </div>
        </footer>
    </div>
}
else
{
    @RenderBody()
}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<style>
    .role-switch-trigger {
        border-radius: 999px;
        border: 1px solid #dbe4f0;
        color: #334155;
        background: #fff;
        font-size: .72rem;
        font-weight: 600;
        padding: .18rem .65rem;
    }

    .role-switch-trigger:hover,
    .role-switch-trigger:focus {
        border-color: #c7d2fe;
        color: #312e81;
        background: #eef2ff;
    }

    .role-switch-menu {
        min-width: 220px;
        border-radius: 14px;
    }

    .role-switch-title {
        font-size: .74rem;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .role-switch-option {
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-radius: 10px;
        font-size: .84rem;
        padding: .6rem .75rem;
    }

    .role-switch-option.active,
    .role-switch-option:active {
        background: #eef2ff;
        color: #312e81;
    }

    .role-switch-option[disabled] {
        opacity: 1;
        cursor: default;
    }

    .browser-notification-trigger {
        border-radius: 999px;
        border: 1px solid #dbe4f0;
        color: #334155;
        background: #fff;
        font-size: .72rem;
        font-weight: 600;
        padding: .18rem .65rem;
    }

    .browser-notification-trigger:hover,
    .browser-notification-trigger:focus {
        border-color: #c7d2fe;
        color: #312e81;
        background: #eef2ff;
    }

    .browser-notification-trigger.is-enabled {
        border-color: #bbf7d0;
        background: #f0fdf4;
        color: #166534;
    }

    .browser-notification-trigger.is-blocked {
        border-color: #fecaca;
        background: #fef2f2;
        color: #991b1b;
    }

    .browser-notification-trigger.is-live-only {
        border-color: #bfdbfe;
        background: #eff6ff;
        color: #1d4ed8;
    }
</style>
<script>
    const swalSuccessMessage = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["Success"]?.ToString()));
    const swalErrorMessage = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["Error"]?.ToString()));
    const swalWarningMessage = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["Warning"]?.ToString()));

    const swalTheme = {
        confirmButtonColor: '#180a3c',
        cancelButtonColor: '#94a3b8',
        customClass: {
            popup: 'app-swal-popup',
            confirmButton: 'app-swal-confirm',
            cancelButton: 'app-swal-cancel'
        },
        buttonsStyling: false
    };

    function showAppAlert(icon, title, html) {
        return Swal.fire({
            ...swalTheme,
            icon: icon,
            title: title,
            html: html,
            confirmButtonText: 'OK'
        });
    }

    function wireSweetConfirmations() {
        document.querySelectorAll('form[data-swal-confirm]').forEach(function (form) {
            form.addEventListener('submit', function (event) {
                if (form.dataset.swalConfirmed === 'true') {
                    form.dataset.swalConfirmed = 'false';
                    return;
                }

                event.preventDefault();

                Swal.fire({
                    ...swalTheme,
                    icon: 'warning',
                    title: form.dataset.swalTitle || 'Are you sure?',
                    html: form.dataset.swalText || 'This action cannot be undone.',
                    showCancelButton: true,
                    confirmButtonText: form.dataset.swalConfirmButton || 'Yes, delete it',
                    cancelButtonText: 'Cancel',
                    reverseButtons: true,
                    focusCancel: true
                }).then(function (result) {
                    if (result.isConfirmed) {
                        form.dataset.swalConfirmed = 'true';
                        form.requestSubmit ? form.requestSubmit() : form.submit();
                    }
                });
            });
        });
    }

    function toggleSidebar() {
        document.getElementById('sidebar').classList.toggle('sidebar-open');
        document.getElementById('sidebar-overlay').classList.toggle('show');
    }
    function closeSidebar() {
        document.getElementById('sidebar').classList.remove('sidebar-open');
        document.getElementById('sidebar-overlay').classList.remove('show');
    }
    // Close sidebar on nav link click (mobile)
    document.querySelectorAll('#sidebar .nav-sub-item a, #sidebar .nav-item > a:not([data-bs-toggle])').forEach(function(el) {
        el.addEventListener('click', function() {
            if (window.innerWidth < 768) closeSidebar();
        });
    });

    wireSweetConfirmations();

    if (swalSuccessMessage) {
        showAppAlert('success', 'Success', swalSuccessMessage);
    }

    if (swalErrorMessage) {
        showAppAlert('error', 'Something went wrong', swalErrorMessage);
    }

    if (swalWarningMessage) {
        showAppAlert('warning', 'Warning', swalWarningMessage);
    }
</script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
