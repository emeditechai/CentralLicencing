@model CentralLicenceApp.Models.InvoicePayment
@{
    ViewData["Title"] = "Receipt Details";
    var company = ViewBag.CompanySettings as CentralLicenceApp.Models.CompanySetting;
    var totalRefunded  = Model.Refunds.Sum(r => r.Amount);
    var netPaid        = Model.TotalAmountPaid - totalRefunded;
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary py-1">
        <i class="bi bi-arrow-left me-1"></i> Back
    </a>
    <div class="flex-grow-1">
        <h4 class="fw-bold mb-0" style="color:#1e293b;">
            @Model.ReceiptNo
            @if (Model.IsVoided)
            {
                <span class="badge ms-2" style="background:#fee2e2;color:#b91c1c;font-size:.65rem;vertical-align:middle;">VOIDED</span>
            }
        </h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">Payment Receipt</p>
    </div>
    @if (!Model.IsVoided)
    {
        <a asp-action="Print" asp-permission="InvoicePayment:Print" asp-route-id="@Model.Id" target="_blank"
           class="btn btn-sm btn-outline-primary py-1">
            <i class="bi bi-printer me-1"></i> Print
        </a>
    }
</div>

@if (Model.IsVoided)
{
    <div class="alert alert-danger border-0 rounded-3 mb-4" style="font-size:.875rem;">
        <i class="bi bi-x-circle-fill me-2"></i>
        <strong>This payment has been voided</strong> by <strong>@Model.VoidedBy</strong>
        on @Model.VoidedAt?.ToString("dd MMM yyyy, hh:mm tt").
        @if (!string.IsNullOrWhiteSpace(Model.VoidRemarks))
        {
            <span>Reason: <em>@Model.VoidRemarks</em></span>
        }
    </div>
}

<div class="row g-4">
    <div class="col-lg-8">

        <!-- Payment info -->
        <div class="card mb-3">
            <div class="card-header fw-semibold" style="background:#f0f4ff;font-size:.9rem;">
                <i class="bi bi-receipt me-1"></i> Receipt Information
            </div>
            <div class="card-body">
                <div class="row g-3" style="font-size:.875rem;">
                    <div class="col-sm-4 text-muted">Receipt No</div>
                    <div class="col-sm-8 fw-semibold" style="color:#6366f1;">@Model.ReceiptNo</div>

                    <div class="col-sm-4 text-muted">Payment Date</div>
                    <div class="col-sm-8">@Model.PaymentDate.ToString("dd MMM yyyy")</div>

                    <div class="col-sm-4 text-muted">Invoice No</div>
                    <div class="col-sm-8">
                        <a asp-controller="Invoice" asp-action="Details" asp-route-id="@Model.InvoiceId"
                           style="color:#6366f1;text-decoration:none;">@Model.InvoiceNo</a>
                    </div>

                    <div class="col-sm-4 text-muted">Party</div>
                    <div class="col-sm-8 fw-semibold">@Model.PartyName</div>

                    @if (!string.IsNullOrWhiteSpace(Model.Notes))
                    {
                        <div class="col-sm-4 text-muted">Notes</div>
                        <div class="col-sm-8">@Model.Notes</div>
                    }

                    <div class="col-sm-4 text-muted">Recorded By</div>
                    <div class="col-sm-8 text-muted" style="font-size:.8rem;">@Model.CreatedBy — @Model.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")</div>
                </div>
            </div>
        </div>

        <!-- Payment lines -->
        <div class="card mb-3">
            <div class="card-header fw-semibold" style="background:#f8fafc;font-size:.9rem;">
                <i class="bi bi-credit-card me-1"></i> Payment Breakdown
            </div>
            <div class="card-body p-0">
                <table class="table tbl-clean mb-0">
                    <thead>
                        <tr>
                            <th class="ps-3">#</th>
                            <th>Payment Mode</th>
                            <th>Reference No</th>
                            <th class="pe-3 text-end">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int sno = 1; }
                        @foreach (var line in Model.Lines)
                        {
                            <tr>
                                <td class="ps-3 text-muted" style="font-size:.8rem;">@sno</td>
                                <td class="fw-semibold">@line.PaymentModeName</td>
                                <td class="text-muted">@(string.IsNullOrWhiteSpace(line.ReferenceNo) ? "—" : line.ReferenceNo)</td>
                                <td class="pe-3 text-end fw-semibold">₹@line.Amount.ToString("N2")</td>
                            </tr>
                            sno++;
                        }
                    </tbody>
                    <tfoot>
                        <tr style="background:#1e293b;color:#fff;">
                            <td colspan="3" class="ps-3 fw-bold" style="font-size:.95rem;">Total Paid</td>
                            <td class="pe-3 text-end fw-bold" style="font-size:1rem;">₹@Model.TotalAmountPaid.ToString("N2")</td>
                        </tr>
                        @if (totalRefunded > 0)
                        {
                            <tr style="background:#fef3c7;color:#92400e;">
                                <td colspan="3" class="ps-3 fw-semibold" style="font-size:.875rem;">Total Refunded</td>
                                <td class="pe-3 text-end fw-semibold">− ₹@totalRefunded.ToString("N2")</td>
                            </tr>
                            <tr style="background:#dcfce7;color:#166534;">
                                <td colspan="3" class="ps-3 fw-bold" style="font-size:.95rem;">Net Effective</td>
                                <td class="pe-3 text-end fw-bold" style="font-size:1rem;">₹@netPaid.ToString("N2")</td>
                            </tr>
                        }
                    </tfoot>
                </table>
            </div>
        </div>

        <!-- Refunds Section -->
        @if (Model.Refunds.Any())
        {
            <div class="card mb-3">
                <div class="card-header fw-semibold" style="background:#fff7ed;font-size:.9rem;">
                    <i class="bi bi-arrow-counterclockwise me-1" style="color:#ea580c;"></i> Refunds Issued
                </div>
                <div class="card-body p-0">
                    <table class="table tbl-clean mb-0">
                        <thead>
                            <tr>
                                <th class="ps-3">Refund No</th>
                                <th>Date</th>
                                <th>Mode</th>
                                <th>Reference</th>
                                <th>Remarks</th>
                                <th class="text-end">Amount</th>
                                <th class="pe-3 text-center">Credit Note</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model.Refunds)
                            {
                                <tr>
                                    <td class="ps-3 fw-semibold" style="color:#ea580c;font-size:.85rem;">@r.RefundNo</td>
                                    <td style="font-size:.85rem;">@r.RefundDate.ToString("dd MMM yyyy")</td>
                                    <td style="font-size:.85rem;">@r.PaymentModeName</td>
                                    <td class="text-muted" style="font-size:.82rem;">@(string.IsNullOrWhiteSpace(r.ReferenceNo) ? "—" : r.ReferenceNo)</td>
                                    <td class="text-muted" style="font-size:.82rem;">@(string.IsNullOrWhiteSpace(r.Remarks) ? "—" : r.Remarks)</td>
                                    <td class="text-end fw-semibold" style="color:#ea580c;">₹@r.Amount.ToString("N2")</td>
                                    <td class="pe-3 text-center">
                                        @if (r.CreditNoteId.HasValue)
                                        {
                                            <a asp-controller="CreditNote" asp-action="Details" asp-route-id="@r.CreditNoteId"
                                               class="badge text-decoration-none"
                                               style="background:#dcfce7;color:#166534;font-size:.78rem;padding:4px 8px;border-radius:6px;">
                                                <i class="bi bi-file-earmark-check me-1"></i>@r.CreditNoteNo
                                            </a>
                                        }
                                        else if (User.IsInRole("Administrator"))
                                        {
                                            <a asp-controller="CreditNote" asp-action="Generate" asp-route-id="@r.Id"
                                               class="btn btn-sm py-0 px-2"
                                               style="background:#f0fdf4;color:#16a34a;border:1px solid #bbf7d0;border-radius:6px;font-size:.78rem;">
                                                <i class="bi bi-plus-circle me-1"></i> Issue Credit Note
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted" style="font-size:.78rem;">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

    </div>

    <!-- Right sidebar -->
    <div class="col-lg-4">
        <!-- Invoice Status card -->
        <div class="card mb-3">
            <div class="card-header fw-semibold" style="background:#f8fafc;font-size:.9rem;">
                <i class="bi bi-info-circle me-1"></i> Invoice Status
            </div>
            <div class="card-body text-center py-4">
                @{
                    var statusStyle = Model.InvoiceStatus switch
                    {
                        "Paid"    => "background:#dcfce7;color:#166534;",
                        "Partial" => "background:#fef9c3;color:#854d0e;",
                        _         => "background:#f1f5f9;color:#475569;"
                    };
                }
                <span class="badge px-3 py-2 fs-6" style="@statusStyle">@Model.InvoiceStatus</span>
                <p class="text-muted mt-3 mb-0" style="font-size:.8rem;">
                    Current invoice status.
                </p>
            </div>
        </div>

        @if (User.IsInRole("Administrator") && !Model.IsVoided)
        {
            <!-- Actions card -->
            <div class="card">
                <div class="card-header fw-semibold" style="background:#f8fafc;font-size:.9rem;">
                    <i class="bi bi-lightning me-1" style="color:#6366f1;"></i> Actions
                </div>
                <div class="card-body d-flex flex-column gap-2">
                    <button type="button" class="btn btn-outline-danger w-100" style="border-radius:10px;"
                            data-bs-toggle="modal" data-bs-target="#voidModal">
                        <i class="bi bi-x-circle me-1"></i> Void Payment
                    </button>
                    <small class="text-muted text-center" style="font-size:.78rem;">
                        <i class="bi bi-info-circle me-1"></i>
                        Void the payment first to enable refund.
                    </small>
                </div>
            </div>
        }

        @if (User.IsInRole("Administrator") && Model.IsVoided)
        {
            var alreadyRefunded = Model.Refunds.Sum(r => r.Amount);
            var refundable      = Model.TotalAmountPaid - alreadyRefunded;
            if (refundable > 0)
            {
                <!-- Refund card — only after void -->
                <div class="card">
                    <div class="card-header fw-semibold" style="background:#fff7ed;font-size:.9rem;">
                        <i class="bi bi-arrow-counterclockwise me-1" style="color:#ea580c;"></i> Refund
                    </div>
                    <div class="card-body d-flex flex-column gap-2">
                        <p class="text-muted mb-1" style="font-size:.8rem;">
                            This payment has been voided. You can now issue a refund of up to
                            <strong>₹@refundable.ToString("N2")</strong> to the party.
                        </p>
                        <a asp-action="Refund" asp-permission="InvoicePayment:Refund" asp-route-id="@Model.Id"
                           class="btn w-100 text-white" style="background:#ea580c;border:none;border-radius:10px;">
                            <i class="bi bi-arrow-counterclockwise me-1"></i> Issue Refund
                        </a>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-success border-0 rounded-3 mb-0 py-2 px-3" style="font-size:.8rem;">
                    <i class="bi bi-check-circle-fill me-1"></i> Full amount has been refunded.
                </div>
                    var pendingCreditNotes = Model.Refunds.Where(r => !r.CreditNoteId.HasValue).ToList();
                if (User.IsInRole("Administrator") && pendingCreditNotes.Any())
                {
                    <div class="mt-2">
                        @foreach (var pr in pendingCreditNotes)
                        {
                            <a asp-controller="CreditNote" asp-action="Generate" asp-route-id="@pr.Id"
                               class="btn w-100 mb-1 text-white" style="background:#16a34a;border:none;border-radius:10px;font-size:.85rem;">
                                <i class="bi bi-file-earmark-plus me-1"></i> Issue Credit Note for @pr.RefundNo
                            </a>
                        }
                    </div>
                }
            }
        }
    </div>
</div>

@if (User.IsInRole("Administrator") && !Model.IsVoided)
{
    <!-- Void Payment Modal -->
    <div class="modal fade" id="voidModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius:16px;">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold text-danger"><i class="bi bi-x-circle me-2"></i>Void Payment</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form asp-action="VoidPayment" asp-route-id="@Model.Id" method="post" id="voidForm">
                    @Html.AntiForgeryToken()
                    <div class="modal-body pt-2">
                        <div class="alert alert-warning border-0 rounded-3 mb-3" style="font-size:.8rem;">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            Voiding <strong>@Model.ReceiptNo</strong> will reverse ₹@Model.TotalAmountPaid.ToString("N2")
                            from the invoice balance. This cannot be undone.
                        </div>
                        <label class="form-label fw-semibold" style="font-size:.85rem;">
                            Reason for Voiding <span class="text-danger">*</span>
                        </label>
                        <textarea name="voidRemarks" id="voidRemarks" class="form-control" rows="3"
                                  placeholder="Enter reason for voiding this payment…" style="border-radius:10px;"></textarea>
                        <div id="voidRemarksError" class="text-danger mt-1" style="font-size:.82rem;display:none;">
                            Reason is required.
                        </div>
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" style="border-radius:8px;">Cancel</button>
                        <button type="submit" class="btn btn-danger" style="border-radius:8px;">
                            <i class="bi bi-x-circle me-1"></i> Confirm Void
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <script>
        document.getElementById('voidForm')?.addEventListener('submit', function (e) {
            var r = document.getElementById('voidRemarks').value.trim();
            if (!r) { e.preventDefault(); document.getElementById('voidRemarksError').style.display = 'block'; document.getElementById('voidRemarks').focus(); }
        });
        document.getElementById('voidRemarks')?.addEventListener('input', function () {
            if (this.value.trim()) document.getElementById('voidRemarksError').style.display = 'none';
        });
    </script>
}

