@model List<CentralLicenceApp.Models.InvoicePayment>
@using System.Linq
@{
    ViewData["Title"] = "Payment Process";
    var today           = DateTime.Today;
    var activePayments  = Model.Where(p => !p.IsVoided).ToList();
    var totalCollected  = activePayments.Sum(p => p.TotalAmountPaid - p.Refunds.Sum(r => r.Amount));
    var thisMonthPmts   = activePayments.Where(p => p.PaymentDate.Year == today.Year && p.PaymentDate.Month == today.Month);
    var thisMonthCount  = thisMonthPmts.Count();
    var thisMonthAmount = thisMonthPmts.Sum(p => p.TotalAmountPaid - p.Refunds.Sum(r => r.Amount));
    var partyCount      = activePayments.Select(p => p.PartyId).Distinct().Count();
    var fullyPaidCount  = activePayments.Count(p => p.InvoiceStatus == "Paid");
    var fromVal         = ViewBag.From   as string ?? string.Empty;
    var toVal           = ViewBag.To     as string ?? string.Empty;
    var statusVal       = ViewBag.Status as string ?? string.Empty;
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;">Payment Process</h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">
            @Model.Count receipt@(Model.Count == 1 ? "" : "s") recorded
            <span class="ms-1" style="color:#6366f1;">(@fromVal.Replace("-","/") – @toVal.Replace("-","/"))</span>
        </p>
    </div>
    @if (User.IsInRole("Administrator"))
    {
        <a asp-action="Create" asp-permission="InvoicePayment:Create" class="btn btn-primary" style="background:#180a3c;border:none;border-radius:10px;">
            <i class="bi bi-cash-coin me-1"></i> Record Payment
        </a>
    }
</div>

<!-- Filter Bar -->
<form method="get" asp-action="Index" class="card mb-4 border-0 shadow-sm">
    <div class="card-body py-3">
        <div class="row g-2 align-items-end">
            <div class="col-6 col-md-3">
                <label class="form-label mb-1" style="font-size:.78rem;font-weight:600;">From Date</label>
                <input type="date" name="from" value="@fromVal" class="form-control form-control-sm" style="border-radius:8px;" />
            </div>
            <div class="col-6 col-md-3">
                <label class="form-label mb-1" style="font-size:.78rem;font-weight:600;">To Date</label>
                <input type="date" name="to" value="@toVal" class="form-control form-control-sm" style="border-radius:8px;" />
            </div>
            <div class="col-6 col-md-3">
                <label class="form-label mb-1" style="font-size:.78rem;font-weight:600;">Status</label>
                <select name="status" class="form-select form-select-sm" style="border-radius:8px;">
                    <option value=""       selected="@(statusVal == "")">All</option>
                    <option value="Active" selected="@(statusVal == "Active")">Active</option>
                    <option value="Voided" selected="@(statusVal == "Voided")">Voided</option>
                </select>
            </div>
            <div class="col-6 col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-primary flex-fill" style="background:#6366f1;border:none;border-radius:8px;">
                    <i class="bi bi-funnel me-1"></i> Filter
                </button>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary" style="border-radius:8px;" title="Clear filters">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </div>
    </div>
</form>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3 col-xl-3">
        <div class="card h-100 border-0 shadow-sm" style="border-radius:14px;">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="rounded-3 d-flex align-items-center justify-content-center" style="width:36px;height:36px;background:#dcfce7;">
                        <i class="bi bi-cash-stack" style="color:#16a34a;font-size:1.05rem;"></i>
                    </div>
                    <span class="text-muted" style="font-size:.74rem;font-weight:600;letter-spacing:.03em;">TOTAL COLLECTED</span>
                </div>
                <div class="fw-bold" style="font-size:1.25rem;color:#16a34a;line-height:1.2;">₹@totalCollected.ToString("N2")</div>
                <div class="text-muted mt-1" style="font-size:.73rem;">@Model.Count receipts</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3 col-xl-3">
        <div class="card h-100 border-0 shadow-sm" style="border-radius:14px;">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="rounded-3 d-flex align-items-center justify-content-center" style="width:36px;height:36px;background:#e0f2fe;">
                        <i class="bi bi-calendar-check" style="color:#0284c7;font-size:1.05rem;"></i>
                    </div>
                    <span class="text-muted" style="font-size:.74rem;font-weight:600;letter-spacing:.03em;">THIS MONTH</span>
                </div>
                <div class="fw-bold" style="font-size:1.25rem;color:#0284c7;line-height:1.2;">₹@thisMonthAmount.ToString("N2")</div>
                <div class="text-muted mt-1" style="font-size:.73rem;">@thisMonthCount receipt@(thisMonthCount == 1 ? "" : "s")</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3 col-xl-3">
        <div class="card h-100 border-0 shadow-sm" style="border-radius:14px;">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="rounded-3 d-flex align-items-center justify-content-center" style="width:36px;height:36px;background:#fef3c7;">
                        <i class="bi bi-people" style="color:#d97706;font-size:1.05rem;"></i>
                    </div>
                    <span class="text-muted" style="font-size:.74rem;font-weight:600;letter-spacing:.03em;">PARTIES</span>
                </div>
                <div class="fw-bold" style="font-size:1.6rem;color:#1e293b;line-height:1.1;">@partyCount</div>
                <div class="text-muted mt-1" style="font-size:.73rem;">Unique clients</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3 col-xl-3">
        <div class="card h-100 border-0 shadow-sm" style="border-radius:14px;">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="rounded-3 d-flex align-items-center justify-content-center" style="width:36px;height:36px;background:#ede9fe;">
                        <i class="bi bi-patch-check" style="color:#7c3aed;font-size:1.05rem;"></i>
                    </div>
                    <span class="text-muted" style="font-size:.74rem;font-weight:600;letter-spacing:.03em;">FULLY PAID INVOICES</span>
                </div>
                <div class="fw-bold" style="font-size:1.6rem;color:#1e293b;line-height:1.1;">@fullyPaidCount</div>
                <div class="text-muted mt-1" style="font-size:.73rem;">Invoice settled</div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table tbl-clean mb-0">
                <thead>
                    <tr>
                        <th class="ps-3">Receipt No</th>
                        <th>FY</th>
                        <th>Date</th>
                        <th>Invoice No</th>
                        <th>Party</th>
                        <th>Payment Modes</th>
                        <th>Amount Paid</th>
                        <th>Invoice Status</th>
                        <th class="pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center py-5 text-muted">
                                <i class="bi bi-cash-coin fs-1 d-block mb-2"></i>No payments recorded yet
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var pmt in Model)
                        {
                            var rowStyle = pmt.IsVoided ? "opacity:.55;" : "";
                            var statusStyle = pmt.IsVoided
                                ? "background:#fee2e2;color:#b91c1c;"
                                : pmt.InvoiceStatus switch
                                {
                                    "Paid"    => "background:#dcfce7;color:#166534;",
                                    "Partial" => "background:#fef9c3;color:#854d0e;",
                                    "Sent"    => "background:#dbeafe;color:#1d4ed8;",
                                    _         => "background:#f1f5f9;color:#475569;"
                                };
                            var displayStatus = pmt.IsVoided ? "Voided" : pmt.InvoiceStatus;
                            var netAmt = pmt.TotalAmountPaid - pmt.Refunds.Sum(r => r.Amount);
                            <tr style="@rowStyle">
                                <td class="ps-3 fw-semibold" style="color:#6366f1;">@pmt.ReceiptNo</td>
                                <td><span class="badge" style="font-size:.71rem;background:#ede9fe;color:#6d28d9;">@(pmt.FYCode ?? "—")</span></td>
                                <td style="font-size:.85rem;">@pmt.PaymentDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    <a asp-controller="Invoice" asp-action="Details" asp-route-id="@pmt.InvoiceId"
                                       style="color:#6366f1;text-decoration:none;font-size:.875rem;">@pmt.InvoiceNo</a>
                                </td>
                                <td class="fw-semibold" style="font-size:.875rem;">@pmt.PartyName</td>
                                <td style="font-size:.8rem;">
                                    @string.Join(", ", pmt.Lines.Select(l => l.PaymentModeName).Distinct())
                                </td>
                                <td class="fw-semibold">
                                    ₹@pmt.TotalAmountPaid.ToString("N2")
                                    @if (pmt.Refunds.Any() && !pmt.IsVoided)
                                    {
                                        <br /><small class="text-muted" style="font-size:.75rem;">Net: ₹@netAmt.ToString("N2")</small>
                                    }
                                </td>
                                <td>
                                    <span class="badge" style="@statusStyle font-size:.76rem;">@displayStatus</span>
                                </td>
                                <td class="pe-3">
                                    <a asp-action="Details" asp-route-id="@pmt.Id"
                                       class="btn btn-sm btn-outline-secondary py-0 px-2" title="View">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @if (!pmt.IsVoided)
                                    {
                                        <a asp-action="Print" asp-permission="InvoicePayment:Print" asp-route-id="@pmt.Id"
                                           class="btn btn-sm btn-outline-primary py-0 px-2 ms-1" title="Print" target="_blank">
                                            <i class="bi bi-printer"></i>
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
