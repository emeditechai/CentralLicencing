@model List<CentralLicenceApp.Models.InvoicePayment>
@{
    ViewData["Title"] = "Payment Process";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;">Payment Process</h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">@Model.Count receipt@(Model.Count == 1 ? "" : "s") recorded</p>
    </div>
    @if (User.IsInRole("Administrator"))
    {
        <a asp-action="Create" class="btn btn-primary" style="background:#180a3c;border:none;border-radius:10px;">
            <i class="bi bi-cash-coin me-1"></i> Record Payment
        </a>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show py-2 px-3 rounded-3" style="font-size:.85rem;">
        @Html.Raw(TempData["Success"])
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show py-2 px-3 rounded-3" style="font-size:.85rem;">
        @Html.Raw(TempData["Error"])
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table tbl-clean mb-0">
                <thead>
                    <tr>
                        <th class="ps-3">Receipt No</th>
                        <th>Date</th>
                        <th>Invoice No</th>
                        <th>Party</th>
                        <th>Payment Modes</th>
                        <th>Amount Paid</th>
                        <th>Invoice Status</th>
                        <th class="pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">
                                <i class="bi bi-cash-coin fs-1 d-block mb-2"></i>No payments recorded yet
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var pmt in Model)
                        {
                            var statusStyle = pmt.InvoiceStatus switch
                            {
                                "Paid"    => "background:#dcfce7;color:#166534;",
                                "Partial" => "background:#fef9c3;color:#854d0e;",
                                "Sent"    => "background:#dbeafe;color:#1d4ed8;",
                                _         => "background:#f1f5f9;color:#475569;"
                            };
                            <tr>
                                <td class="ps-3 fw-semibold" style="color:#6366f1;">@pmt.ReceiptNo</td>
                                <td style="font-size:.85rem;">@pmt.PaymentDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    <a asp-controller="Invoice" asp-action="Details" asp-route-id="@pmt.InvoiceId"
                                       style="color:#6366f1;text-decoration:none;font-size:.875rem;">@pmt.InvoiceNo</a>
                                </td>
                                <td class="fw-semibold" style="font-size:.875rem;">@pmt.PartyName</td>
                                <td style="font-size:.8rem;">
                                    @string.Join(", ", pmt.Lines.Select(l => l.PaymentModeName).Distinct())
                                </td>
                                <td class="fw-semibold">₹@pmt.TotalAmountPaid.ToString("N2")</td>
                                <td>
                                    <span class="badge" style="@statusStyle font-size:.76rem;">@pmt.InvoiceStatus</span>
                                </td>
                                <td class="pe-3">
                                    <a asp-action="Details" asp-route-id="@pmt.Id"
                                       class="btn btn-sm btn-outline-secondary py-0 px-2" title="View">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Print" asp-route-id="@pmt.Id"
                                       class="btn btn-sm btn-outline-primary py-0 px-2 ms-1" title="Print" target="_blank">
                                        <i class="bi bi-printer"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
