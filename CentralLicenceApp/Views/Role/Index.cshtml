@model List<CentralLicenceApp.Models.RoleMaster>
@{
    ViewData["Title"] = "Role Management";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;">Role Management</h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">@Model.Count role(s) configured</p>
    </div>
    <a asp-action="Create" class="btn btn-primary" style="background:#6366f1;border:none;border-radius:10px;">
        <i class="bi bi-plus-lg me-1"></i> New Role
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table tbl-clean mb-0">
                <thead>
                    <tr>
                        <th class="ps-3">#</th>
                        <th>Role Name</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th class="pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td class="ps-3" style="color:#94a3b8;font-size:.8rem;">@r.Id</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div style="width:32px;height:32px;background:#ede9fe;border-radius:8px;display:flex;align-items:center;justify-content:center;color:#6d28d9;font-size:.9rem;">
                                        <i class="bi bi-diagram-3"></i>
                                    </div>
                                    <span class="fw-semibold" style="font-size:.875rem;">@r.RoleName</span>
                                </div>
                            </td>
                            <td class="text-muted" style="font-size:.85rem;">@(r.Description ?? "—")</td>
                            <td>
                                @if (r.IsActive)
                                {
                                    <span class="badge badge-ok rounded-pill px-2 py-1" style="font-size:.73rem;">Active</span>
                                }
                                else
                                {
                                    <span class="badge badge-neu rounded-pill px-2 py-1" style="font-size:.73rem;">Inactive</span>
                                }
                            </td>
                            <td style="font-size:.82rem;">@r.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td class="pe-3">
                                <div class="d-flex gap-1">
                                    <a asp-action="Edit" asp-route-id="@r.Id" class="btn btn-sm btn-outline-secondary" title="Edit" style="border-radius:7px;border-color:#e2e8f0;"><i class="bi bi-pencil"></i></a>
                                    <form asp-action="Delete" method="post" onsubmit="return confirm('Delete role @r.RoleName?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@r.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete" style="border-radius:7px;"><i class="bi bi-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
