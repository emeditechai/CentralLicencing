@model CentralLicenceApp.Models.ViewModels.RoleFormViewModel
@{
    ViewData["Title"] = "Edit Role";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary" style="border-radius:8px;"><i class="bi bi-arrow-left"></i></a>
    <h4 class="fw-bold mb-0" style="color:#1e293b;">Edit Role</h4>
</div>

<div class="card" style="max-width:480px;">
    <div class="card-body p-4">
        <form asp-action="Edit" asp-permission="Role:Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 px-3 rounded-3 mb-3" style="font-size:.83rem;"></div>

            <div class="mb-3">
                <label asp-for="RoleName" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                <input asp-for="RoleName" class="form-control" style="border-radius:10px;" />
                <span asp-validation-for="RoleName" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                <textarea asp-for="Description" class="form-control" rows="3" style="border-radius:10px;"></textarea>
            </div>
            <div class="mb-3 form-check">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                <label asp-for="IsActive" class="form-check-label fw-semibold" style="font-size:.85rem;"></label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn text-white px-4" style="background:#6366f1;border:none;border-radius:10px;">
                    <i class="bi bi-check-lg me-1"></i> Save Changes
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius:10px;">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
