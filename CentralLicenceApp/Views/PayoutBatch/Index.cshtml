@model CentralLicenceApp.Models.ViewModels.PayoutBatchIndexViewModel
@{
    ViewData["Title"] = "Payout Batches";
}

<style>
    .pb-hero { background:linear-gradient(135deg,#667eea 0%,#764ba2 100%); border-radius:20px; padding:2rem 2.25rem; margin-bottom:1.75rem; position:relative; overflow:hidden; }
    .pb-hero::before { content:''; position:absolute; top:-50%; right:-8%; width:320px; height:320px; background:rgba(255,255,255,.06); border-radius:50%; pointer-events:none; }
    .pb-hero h4 { color:#fff; font-weight:800; font-size:1.4rem; margin-bottom:.15rem; }
    .pb-hero .pb-sub { color:rgba(255,255,255,.75); font-size:.85rem; }

    .pb-stat { background:rgba(255,255,255,.15); backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,.18); border-radius:14px; padding:.7rem 1.1rem; min-width:110px; text-align:center; }
    .pb-stat-num { font-size:1.5rem; font-weight:800; color:#fff; line-height:1.2; }
    .pb-stat-lbl { font-size:.68rem; text-transform:uppercase; letter-spacing:.06em; font-weight:600; color:rgba(255,255,255,.7); }

    .pb-card { background:#fff; border-radius:14px; box-shadow:0 2px 12px rgba(0,0,0,.05); border:1px solid #f1f5f9; overflow:hidden; }
    .pb-table { margin-bottom:0; }
    .pb-table thead { background:linear-gradient(180deg,#f8fafc,#f1f5f9); }
    .pb-table thead th { font-size:.7rem; font-weight:700; color:#475569; text-transform:uppercase; letter-spacing:.08em; padding:.75rem .85rem; border-bottom:2px solid #e2e8f0; white-space:nowrap; }
    .pb-table tbody tr { transition:all .15s ease; border-bottom:1px solid #f8fafc; }
    .pb-table tbody tr:hover { background:linear-gradient(90deg,#f5f3ff,#eff6ff); }
    .pb-table td { vertical-align:middle; padding:.65rem .85rem; font-size:.84rem; color:#334155; }

    .pb-filter-card { background:linear-gradient(145deg,#faf8ff,#f3f0ff); border:1px solid #e9e4f5; border-radius:14px; padding:1.1rem 1.5rem; margin-bottom:1.25rem; }
    .pb-btn-gen { background:linear-gradient(135deg,#6366f1,#4f46e5); color:#fff; border-radius:10px; font-weight:600; font-size:.82rem; border:none; }
    .pb-btn-gen:hover { background:linear-gradient(135deg,#4f46e5,#4338ca); color:#fff; transform:translateY(-1px); }
</style>

<!-- Hero -->
<div class="pb-hero">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
            <h4><i class="bi bi-collection me-2"></i>Payout Batches</h4>
            <div class="pb-sub">Generate, review and manage payout batches</div>
        </div>
        <div class="d-flex gap-3 flex-wrap">
            <div class="pb-stat">
                <div class="pb-stat-num">@Model.TotalBatches</div>
                <div class="pb-stat-lbl">Batches</div>
            </div>
            <div class="pb-stat">
                <div class="pb-stat-num">₹@Model.TotalGross.ToString("N0")</div>
                <div class="pb-stat-lbl">Gross</div>
            </div>
            <div class="pb-stat">
                <div class="pb-stat-num">₹@Model.TotalNet.ToString("N0")</div>
                <div class="pb-stat-lbl">Net</div>
            </div>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="pb-filter-card">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-3">
            <label class="form-label fw-semibold" style="font-size:.78rem;">Employee</label>
            <select name="userId" class="form-select form-select-sm" style="border-radius:10px;">
                <option value="">All Employees</option>
                @foreach (var u in Model.Users)
                {
                    <option value="@u.Id" selected="@(Model.UserFilter == u.Id)">@u.FullName @(!string.IsNullOrEmpty(u.EmployeeCode) ? $"({u.EmployeeCode})" : "")</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label fw-semibold" style="font-size:.78rem;">Status</label>
            <select name="status" class="form-select form-select-sm" style="border-radius:10px;">
                <option value="">All Statuses</option>
                <option value="Draft" selected="@(Model.StatusFilter == "Draft")">Draft</option>
                <option value="PendingApproval" selected="@(Model.StatusFilter == "PendingApproval")">Pending Approval</option>
                <option value="L1Approved" selected="@(Model.StatusFilter == "L1Approved")">L1 Approved</option>
                <option value="Approved" selected="@(Model.StatusFilter == "Approved")">Approved</option>
                <option value="Paid" selected="@(Model.StatusFilter == "Paid")">Paid</option>
                <option value="Rejected" selected="@(Model.StatusFilter == "Rejected")">Rejected</option>
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label fw-semibold" style="font-size:.78rem;">From Date</label>
            <input type="date" name="from" class="form-control form-control-sm" style="border-radius:10px;" value="@Model.FromDate?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-md-2">
            <label class="form-label fw-semibold" style="font-size:.78rem;">To Date</label>
            <input type="date" name="to" class="form-control form-control-sm" style="border-radius:10px;" value="@Model.ToDate?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-sm btn-primary" style="border-radius:10px;"><i class="bi bi-funnel me-1"></i> Filter</button>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary" style="border-radius:10px;"><i class="bi bi-x-lg"></i></a>
            <a asp-action="Generate" class="btn btn-sm pb-btn-gen ms-auto"><i class="bi bi-plus-lg me-1"></i> Generate</a>
        </div>
    </form>
</div>

<!-- Table -->
<div class="pb-card">
    <div class="table-responsive">
        <table class="table pb-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Employee</th>
                    <th>Period</th>
                    <th>Model</th>
                    <th>Tasks</th>
                    <th>Time</th>
                    <th>Gross (₹)</th>
                    <th>Net (₹)</th>
                    <th>Status</th>
                    <th>Generated</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Batches.Any())
                {
                    <tr><td colspan="11" class="text-center text-muted py-4"><i class="bi bi-inbox me-1"></i> No batches found.</td></tr>
                }
                @foreach (var b in Model.Batches)
                {
                    <tr>
                        <td class="text-muted" style="font-size:.78rem;">@b.Id</td>
                        <td>
                            <div class="fw-semibold" style="font-size:.82rem;">@b.UserName</div>
                            @if (!string.IsNullOrEmpty(b.EmployeeCode))
                            {
                                <small class="text-muted">@b.EmployeeCode</small>
                            }
                        </td>
                        <td style="font-size:.82rem;">@b.FromDate.ToString("dd MMM") – @b.ToDate.ToString("dd MMM yyyy")</td>
                        <td>
                            <span class="badge @(b.PayoutModel == "Hourly" ? "bg-success" : "bg-purple")" style="font-size:.7rem;@(b.PayoutModel == "Commission" ? "background:#7c3aed !important;" : "")">@b.PayoutModel</span>
                        </td>
                        <td class="fw-semibold">@b.TotalTasks</td>
                        <td style="font-size:.82rem;">@b.FormattedTotalTime</td>
                        <td class="fw-bold">₹@b.GrossAmount.ToString("N2")</td>
                        <td class="fw-bold text-primary">₹@b.NetAmount.ToString("N2")</td>
                        <td><span class="badge @b.StatusBadgeClass" style="font-size:.7rem;">@b.StatusDisplay</span></td>
                        <td style="font-size:.78rem;">@b.GeneratedAt.ToString("dd MMM yyyy")</td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@b.Id" class="btn btn-sm btn-outline-primary" style="border-radius:8px;font-size:.75rem;">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
