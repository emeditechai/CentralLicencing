@model CentralLicenceApp.Models.ViewModels.UserFormViewModel
@{
    ViewData["Title"] = "Edit User";
}

<div class="uf-header mb-4">
    <a asp-action="Index" class="uf-back-btn"><i class="bi bi-arrow-left"></i></a>
    <div>
        <h4 class="uf-title">Edit User</h4>
        <p class="uf-sub">@@@Model.Username</p>
    </div>
</div>

<form asp-action="Edit" method="post" enctype="multipart/form-data" id="userForm" class="uf-form" autocomplete="off">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 px-3 rounded-3 mb-4" style="font-size:.83rem;"></div>

    <!-- Username badge -->
    <div class="uf-username-badge mb-2">
        <i class="bi bi-person-circle"></i>
        <div>
            <div class="uf-username-label">USERNAME</div>
            <div class="uf-username-val">@@@Model.Username</div>
        </div>
    </div>

    <!-- Section: Account Info -->
    <div class="uf-section">
        <div class="uf-section-title"><i class="bi bi-person-badge"></i> Account Information</div>
        <div class="uf-photo-block mb-3">
            <div class="uf-photo-preview-wrap">
                <img id="profilePreview" src="@(string.IsNullOrWhiteSpace(Model.ExistingProfileImagePath) ? "https://placehold.co/120x120/e2e8f0/64748b?text=Photo" : Url.Content(Model.ExistingProfileImagePath))" alt="Profile preview" class="uf-photo-preview" />
            </div>
            <div class="flex-grow-1">
                <label asp-for="ProfileImage" class="uf-label"></label>
                <input asp-for="ProfileImage" type="file" class="form-control uf-input" accept=".jpg,.jpeg,.png,.gif,.webp" onchange="previewProfileImage(this)" />
                <div class="uf-hint">Upload a new image to replace the current profile picture.</div>
            </div>
        </div>
        <div class="row g-3">
            <div class="col-sm-6">
                <label asp-for="FullName" class="uf-label"></label>
                <input asp-for="FullName" class="form-control uf-input" />
                <span asp-validation-for="FullName" class="uf-err"></span>
            </div>
            <div class="col-sm-6">
                <label asp-for="PhoneNumber" class="uf-label"></label>
                <input asp-for="PhoneNumber" class="form-control uf-input" placeholder="+91 98765 43210" />
                <span asp-validation-for="PhoneNumber" class="uf-err"></span>
            </div>
            <div class="col-sm-12">
                <label asp-for="Email" class="uf-label"></label>
                <input asp-for="Email" class="form-control uf-input" type="email" />
                <span asp-validation-for="Email" class="uf-err"></span>
            </div>
            <div class="col-sm-6">
                <label asp-for="Password" class="uf-label"></label>
                <div class="input-group">
                    <input asp-for="Password" type="password" id="pwField" class="form-control uf-input" placeholder="Leave blank to keep current" autocomplete="new-password" />
                    <button type="button" class="uf-eye-btn" onclick="togglePw('pwField','pwEye')"><i id="pwEye" class="bi bi-eye"></i></button>
                </div>
                <div class="uf-hint">Leave blank to keep existing password</div>
            </div>
            <div class="col-sm-6">
                <label asp-for="ConfirmPassword" class="uf-label"></label>
                <div class="input-group">
                    <input asp-for="ConfirmPassword" type="password" id="cpwField" class="form-control uf-input" autocomplete="new-password" />
                    <button type="button" class="uf-eye-btn" onclick="togglePw('cpwField','cpwEye')"><i id="cpwEye" class="bi bi-eye"></i></button>
                </div>
                <div id="pwMatchMsg" class="uf-hint" style="display:none;"></div>
            </div>
        </div>
    </div>

    <div class="uf-section">
        <div class="uf-section-title"><i class="bi bi-calendar3"></i> Personal Dates</div>
        <div class="row g-3">
            <div class="col-sm-6">
                <label asp-for="DateOfBirth" class="uf-label"></label>
                <input asp-for="DateOfBirth" type="date" class="form-control uf-input" />
                <span asp-validation-for="DateOfBirth" class="uf-err"></span>
            </div>
            <div class="col-sm-6">
                <label asp-for="DateOfJoining" class="uf-label"></label>
                <input asp-for="DateOfJoining" type="date" class="form-control uf-input" />
                <span asp-validation-for="DateOfJoining" class="uf-err"></span>
            </div>
        </div>
    </div>

    <!-- Section: Role & Location -->
    <div class="uf-section">
        <div class="uf-section-title"><i class="bi bi-shield-lock"></i> Role & Location</div>
        <div class="row g-3">
            <div class="col-sm-6">
                <label asp-for="RoleIds" class="uf-label"></label>
                <div class="dropdown uf-role-dropdown" data-bs-auto-close="outside">
                    <button class="btn form-control uf-input uf-role-trigger dropdown-toggle text-start" type="button" id="roleDropdownButton" data-bs-toggle="dropdown" aria-expanded="false">
                        <span id="roleDropdownText">Select one or more roles</span>
                    </button>
                    <div class="dropdown-menu w-100 p-2 uf-role-menu" aria-labelledby="roleDropdownButton">
                        <div class="uf-role-menu-title px-2 pb-2">Available Roles</div>
                        <div class="px-2 pb-2">
                            <div class="position-relative">
                                <i class="bi bi-search uf-role-search-icon"></i>
                                <input type="text" id="roleSearchInput" class="form-control uf-input uf-role-search" placeholder="Search roles" autocomplete="off" />
                            </div>
                        </div>
                        <div class="d-flex align-items-center justify-content-between gap-2 px-2 pb-2 uf-role-actions">
                            <button type="button" id="selectAllRolesButton" class="btn btn-sm uf-role-action-btn">Select All</button>
                            <button type="button" id="clearRolesButton" class="btn btn-sm uf-role-action-btn uf-role-action-btn-secondary">Clear All</button>
                        </div>
                        <div class="uf-role-option-list">
                            @foreach (var role in Model.Roles)
                            {
                                <label class="uf-role-option" data-role-name="@role.RoleName.ToLowerInvariant()">
                                    <input type="checkbox" name="RoleIds" value="@role.Id" class="uf-role-checkbox" checked="@(Model.RoleIds.Contains(role.Id))" />
                                    <span class="uf-role-option-copy">
                                        <span class="uf-role-option-title">@role.RoleName</span>
                                        <span class="uf-role-option-sub">@(string.IsNullOrWhiteSpace(role.Description) ? "Grant access for this role." : role.Description)</span>
                                    </span>
                                </label>
                            }
                        </div>
                        <div id="roleSearchEmptyState" class="uf-role-empty-state d-none">No roles match your search.</div>
                    </div>
                </div>
                <div id="roleSelectionSummary" class="uf-role-summary mt-2"></div>
                <div class="uf-hint">Open the list and select all roles that should be available for this user.</div>
                <span asp-validation-for="RoleIds" class="uf-err"></span>
            </div>
            <div class="col-sm-6">
                <label asp-for="LocationId" class="uf-label"></label>
                <select asp-for="LocationId" class="form-select uf-input" asp-items="@(new SelectList(Model.Locations, "Id", "Name", Model.LocationId))">
                    <option value="">-- Select Location --</option>
                </select>
            </div>
            <div class="col-sm-6">
                <label asp-for="ClientId" class="uf-label"></label>
                <select asp-for="ClientId" class="form-select uf-input" asp-items="@(new SelectList(Model.Clients, "Id", "PartyName", Model.ClientId))">
                    <option value="">-- Select Client --</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Section: Status & Employment -->
    <div class="uf-section">
        <div class="uf-section-title"><i class="bi bi-toggles"></i> Status & Employment</div>

        <div class="uf-toggle-row mb-3">
            <label class="uf-toggle-item">
                <input asp-for="IsActive" type="checkbox" class="uf-toggle-chk" id="chkIsActive" onchange="onActiveToggle()" disabled="@(Model.DisableActiveToggle ? "disabled" : null)" />
                @if (Model.DisableActiveToggle)
                {
                    <input type="hidden" asp-for="IsActive" />
                }
                <span class="uf-toggle-pill"></span>
                <span class="uf-toggle-lbl" id="activeToggleLabel">@(Model.IsActive ? "Active" : "Inactive")</span>
            </label>
            <label class="uf-toggle-item">
                <input asp-for="IsEmployee" type="checkbox" class="uf-toggle-chk" id="chkIsEmployee" onchange="onEmployeeToggle()" />
                <span class="uf-toggle-pill"></span>
                <span class="uf-toggle-lbl">Is Employee</span>
            </label>
            <label class="uf-toggle-item" id="chkCoreMemberWrap" style="display:none;">
                <input asp-for="IsCoreMember" type="checkbox" class="uf-toggle-chk" id="chkIsCoreMember" onchange="onCoreMemberToggle()" />
                <span class="uf-toggle-pill"></span>
                <span class="uf-toggle-lbl">Core Member</span>
            </label>
            <label class="uf-toggle-item">
                <input asp-for="IsSalesAgent" type="checkbox" class="uf-toggle-chk" />
                <span class="uf-toggle-pill"></span>
                <span class="uf-toggle-lbl">Is Sales Agent</span>
            </label>
        </div>

        @if (Model.DisableActiveToggle)
        {
            <div class="uf-hint mb-3">You cannot deactivate your own account.</div>
        }

        <div id="empSection" style="display:none;">
            <div class="row g-3">
                <div class="col-sm-6">
                    <label asp-for="EmployeeCode" class="uf-label"></label>
                    <input asp-for="EmployeeCode" id="EmployeeCode" class="form-control uf-input" placeholder="Unique employee code" />
                    <span asp-validation-for="EmployeeCode" class="uf-err"></span>
                    <div id="empCodeMsg" class="uf-hint" style="display:none;"></div>
                </div>
                <div class="col-sm-6" id="managerWrap">
                    <label asp-for="ManagerId" class="uf-label">Manager <span id="managerReqStar" class="text-danger">*</span></label>
                    <select asp-for="ManagerId" id="ManagerId" class="form-select uf-input"
                            asp-items="@(new SelectList(Model.Managers, "Id", "FullName", Model.ManagerId))">
                        <option value="">-- Select Manager --</option>
                    </select>
                    <span asp-validation-for="ManagerId" class="uf-err"></span>
                </div>
                <div class="col-sm-6">
                    <label asp-for="DepartmentId" class="uf-label"></label>
                    <select asp-for="DepartmentId" id="DepartmentId" class="form-select uf-input"
                            asp-items="@(new SelectList(Model.Departments, "Id", "DepartmentName", Model.DepartmentId))">
                        <option value="">-- Select Department --</option>
                    </select>
                    <span asp-validation-for="DepartmentId" class="uf-err"></span>
                </div>
                <div class="col-sm-6">
                    <label asp-for="DesignationId" class="uf-label"></label>
                    <select asp-for="DesignationId" id="DesignationId" class="form-select uf-input"
                            asp-items="@(new SelectList(Model.Designations, "Id", "DesignationName", Model.DesignationId))">
                        <option value="">-- Select Designation --</option>
                    </select>
                    <span asp-validation-for="DesignationId" class="uf-err"></span>
                </div>
                <div class="col-sm-6">
                    <label asp-for="EmployeeTypeId" class="uf-label"></label>
                    <select asp-for="EmployeeTypeId" id="EmployeeTypeId" class="form-select uf-input"
                            asp-items="@(new SelectList(Model.EmployeeTypes, "Id", "TypeName", Model.EmployeeTypeId))">
                        <option value="">-- Select Employee Type --</option>
                    </select>
                    <span asp-validation-for="EmployeeTypeId" class="uf-err"></span>
                </div>
            </div>
        </div>
    </div>

    <!-- Section: Digital Signature -->
    <div class="uf-section">
        <div class="uf-section-title"><i class="bi bi-pen"></i> Digital Signature</div>
        <div class="row g-3 align-items-start">
            <div class="col-sm-6">
                <label asp-for="SignatureImage" class="uf-label"></label>
                <input asp-for="SignatureImage" type="file" class="form-control uf-input" accept=".jpg,.jpeg,.png" onchange="previewSignatureImage(this)" />
                <div class="uf-hint">Accepted formats: JPG, JPEG, PNG. Leave blank to keep existing signature.</div>
                <span asp-validation-for="SignatureImage" class="uf-err"></span>
            </div>
            <div class="col-sm-6">
                @if (!string.IsNullOrWhiteSpace(Model.ExistingSignaturePath))
                {
                    <div id="sigPreviewWrap" style="border:1px dashed #cbd5e1;border-radius:8px;padding:12px;background:#f8fafc;text-align:center;">
                        <div class="uf-hint mb-1">Current Signature</div>
                        <img id="sigPreview" src="@Url.Content(Model.ExistingSignaturePath)" alt="Signature preview" style="max-height:80px;max-width:100%;object-fit:contain;" />
                    </div>
                }
                else
                {
                    <div id="sigPreviewWrap" style="display:none;border:1px dashed #cbd5e1;border-radius:8px;padding:12px;background:#f8fafc;text-align:center;">
                        <div class="uf-hint mb-1">Preview</div>
                        <img id="sigPreview" src="" alt="Signature preview" style="max-height:80px;max-width:100%;object-fit:contain;" />
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="uf-actions">
        <button type="submit" class="btn uf-btn-primary">
            <i class="bi bi-check-lg me-1"></i> Save Changes
        </button>
        <a asp-action="Index" class="btn uf-btn-cancel">Cancel</a>
    </div>
</form>

<style>
    .uf-role-trigger {
        min-height: 44px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-right: 2.5rem;
        background: #fff;
    }

    .uf-role-trigger::after {
        position: absolute;
        right: 1rem;
        margin-top: 0;
    }

    .uf-role-menu {
        border: 1px solid #dbe4f0;
        border-radius: 14px;
        box-shadow: 0 18px 38px rgba(15, 23, 42, .12);
    }

    .uf-role-menu-title {
        font-size: .72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: #64748b;
    }

    .uf-role-search {
        padding-left: 2.2rem;
    }

    .uf-role-search-icon {
        position: absolute;
        left: .8rem;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        font-size: .9rem;
        pointer-events: none;
    }

    .uf-role-actions {
        border-bottom: 1px solid #eef2f7;
        margin: 0 .25rem .5rem;
    }

    .uf-role-action-btn {
        border-radius: 999px;
        border: 1px solid #c7d2fe;
        color: #3730a3;
        background: #eef2ff;
        font-size: .72rem;
        font-weight: 700;
        padding: .25rem .7rem;
    }

    .uf-role-action-btn:hover {
        background: #e0e7ff;
        color: #312e81;
    }

    .uf-role-action-btn-secondary {
        border-color: #e2e8f0;
        background: #fff;
        color: #475569;
    }

    .uf-role-action-btn-secondary:hover {
        background: #f8fafc;
        color: #1e293b;
    }

    .uf-role-option-list {
        display: flex;
        flex-direction: column;
        gap: .35rem;
        max-height: 240px;
        overflow-y: auto;
    }

    .uf-role-option {
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: .7rem .8rem;
        background: #fff;
        display: flex;
        align-items: flex-start;
        gap: .7rem;
        cursor: pointer;
        transition: border-color .2s ease, background .2s ease, box-shadow .2s ease;
    }

    .uf-role-option:hover {
        border-color: #c7d2fe;
        background: #f8faff;
        box-shadow: 0 8px 18px rgba(15, 23, 42, .05);
    }

    .uf-role-checkbox {
        width: 1rem;
        height: 1rem;
        margin-top: .15rem;
        accent-color: #4f46e5;
        flex-shrink: 0;
    }

    .uf-role-option-copy {
        display: flex;
        flex-direction: column;
        gap: .15rem;
    }

    .uf-role-option-title {
        font-weight: 700;
        color: #1e293b;
        font-size: .92rem;
    }

    .uf-role-option-sub {
        color: #64748b;
        font-size: .76rem;
        line-height: 1.4;
    }

    .uf-role-summary {
        display: flex;
        flex-wrap: wrap;
        gap: .4rem;
        min-height: 1.75rem;
    }

    .uf-role-chip {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        padding: .32rem .65rem;
        border-radius: 999px;
        background: #eef2ff;
        color: #3730a3;
        font-size: .74rem;
        font-weight: 700;
        line-height: 1;
    }

    .uf-role-chip-admin {
        background: #ede9fe;
        color: #6d28d9;
    }

    .uf-role-chip-finance {
        background: #dcfce7;
        color: #166534;
    }

    .uf-role-chip-staff {
        background: #f1f5f9;
        color: #475569;
    }

    .uf-role-chip-ticket {
        background: #fef3c7;
        color: #92400e;
    }

    .uf-role-empty-state {
        font-size: .8rem;
        color: #64748b;
        text-align: center;
        padding: .75rem;
    }
</style>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
    var currentUserId = @Model.Id;
    var roleDropdownText = document.getElementById('roleDropdownText');
    var roleSelectionSummary = document.getElementById('roleSelectionSummary');
    var roleSearchInput = document.getElementById('roleSearchInput');
    var selectAllRolesButton = document.getElementById('selectAllRolesButton');
    var clearRolesButton = document.getElementById('clearRolesButton');
    var roleSearchEmptyState = document.getElementById('roleSearchEmptyState');

    function previewProfileImage(input) {
        var preview = document.getElementById('profilePreview');
        if (!input.files || !input.files[0]) {
            return;
        }
        preview.src = URL.createObjectURL(input.files[0]);
    }

    function previewSignatureImage(input) {
        var wrap = document.getElementById('sigPreviewWrap');
        var preview = document.getElementById('sigPreview');
        if (!input.files || !input.files[0]) {
            return;
        }
        preview.src = URL.createObjectURL(input.files[0]);
        wrap.style.display = 'block';
    }

    function togglePw(fId, eId) {
        var f = document.getElementById(fId), e = document.getElementById(eId);
        f.type = (f.type === 'password') ? 'text' : 'password';
        e.className = (f.type === 'text') ? 'bi bi-eye-slash' : 'bi bi-eye';
    }

    document.getElementById('pwField').addEventListener('input', checkPwMatch);
    document.getElementById('cpwField').addEventListener('input', checkPwMatch);
    function checkPwMatch() {
        var pw = document.getElementById('pwField').value;
        var cpw = document.getElementById('cpwField').value;
        var msg = document.getElementById('pwMatchMsg');
        if (!cpw && !pw) { msg.style.display = 'none'; return; }
        if (!cpw) { msg.style.display = 'none'; return; }
        msg.style.display = 'block';
        if (pw === cpw) { msg.style.color = '#16a34a'; msg.textContent = '✓ Passwords match'; }
        else            { msg.style.color = '#ef4444'; msg.textContent = '✗ Passwords do not match'; }
    }

    function getRoleChipClass(roleName) {
        var normalized = (roleName || '').toLowerCase();
        if (normalized.indexOf('admin') !== -1) return 'uf-role-chip-admin';
        if (normalized.indexOf('finance') !== -1) return 'uf-role-chip-finance';
        if (normalized.indexOf('staff') !== -1) return 'uf-role-chip-staff';
        if (normalized.indexOf('ticket') !== -1) return 'uf-role-chip-ticket';
        return '';
    }

    function updateRoleSelectionDisplay() {
        var selectedRoles = Array.from(document.querySelectorAll('.uf-role-checkbox:checked')).map(function (checkbox) {
            var label = checkbox.closest('.uf-role-option');
            var title = label ? label.querySelector('.uf-role-option-title') : null;
            return {
                id: checkbox.value,
                name: title ? title.textContent.trim() : checkbox.value
            };
        });

        if (!selectedRoles.length) {
            roleDropdownText.textContent = 'Select one or more roles';
            roleSelectionSummary.innerHTML = '';
            return;
        }

        roleDropdownText.textContent = selectedRoles.length === 1
            ? selectedRoles[0].name
            : selectedRoles.length + ' roles selected';

        roleSelectionSummary.innerHTML = selectedRoles.map(function (role) {
            return '<span class="uf-role-chip ' + getRoleChipClass(role.name) + '"><i class="bi bi-check2"></i>' + role.name + '</span>';
        }).join('');
    }

    function filterRoleOptions() {
        var searchTerm = (roleSearchInput.value || '').trim().toLowerCase();
        var visibleCount = 0;

        document.querySelectorAll('.uf-role-option').forEach(function (option) {
            var roleName = option.dataset.roleName || '';
            var optionText = option.textContent.toLowerCase();
            var isMatch = !searchTerm || roleName.indexOf(searchTerm) !== -1 || optionText.indexOf(searchTerm) !== -1;
            option.classList.toggle('d-none', !isMatch);
            if (isMatch) {
                visibleCount += 1;
            }
        });

        roleSearchEmptyState.classList.toggle('d-none', visibleCount > 0);
    }

    function setVisibleRoleSelection(isSelected) {
        document.querySelectorAll('.uf-role-option:not(.d-none) .uf-role-checkbox').forEach(function (checkbox) {
            checkbox.checked = isSelected;
        });
        updateRoleSelectionDisplay();
    }

    document.querySelectorAll('.uf-role-checkbox').forEach(function (checkbox) {
        checkbox.addEventListener('change', updateRoleSelectionDisplay);
    });

    roleSearchInput.addEventListener('input', filterRoleOptions);
    selectAllRolesButton.addEventListener('click', function () { setVisibleRoleSelection(true); });
    clearRolesButton.addEventListener('click', function () { setVisibleRoleSelection(false); });

    filterRoleOptions();
    updateRoleSelectionDisplay();

    function onActiveToggle() {
        var isActive = document.getElementById('chkIsActive').checked;
        document.getElementById('activeToggleLabel').textContent = isActive ? 'Active' : 'Inactive';
    }

    function onEmployeeToggle() {
        var isEmp = document.getElementById('chkIsEmployee').checked;
        document.getElementById('empSection').style.display        = isEmp ? 'block' : 'none';
        document.getElementById('chkCoreMemberWrap').style.display = isEmp ? 'flex' : 'none';
        if (!isEmp) {
            document.getElementById('chkIsCoreMember').checked = false;
            document.getElementById('EmployeeCode').value = '';
            document.getElementById('empCodeMsg').style.display = 'none';
            document.getElementById('ManagerId').value = '';
            document.getElementById('DepartmentId').value = '';
            document.getElementById('DesignationId').value = '';
            document.getElementById('EmployeeTypeId').value = '';
            onCoreMemberToggle();
        }
    }

    function onCoreMemberToggle() {
        var isCore = document.getElementById('chkIsCoreMember').checked;
        document.getElementById('managerReqStar').style.display = isCore ? 'none' : 'inline';
    }

    document.getElementById('EmployeeCode').addEventListener('blur', async function () {
        var code = this.value.trim();
        var msg = document.getElementById('empCodeMsg');
        if (!code) { msg.style.display = 'none'; return; }
        var r = await fetch('/User/CheckEmployeeCode?code=' + encodeURIComponent(code) + '&excludeId=' + currentUserId);
        var ok = await r.json();
        msg.style.display = 'block';
        if (ok) { msg.style.color = '#16a34a'; msg.textContent = '✓ Employee Code available'; this.classList.remove('is-invalid'); this.classList.add('is-valid'); }
        else    { msg.style.color = '#ef4444'; msg.textContent = '✗ Employee Code already exists'; this.classList.remove('is-valid'); this.classList.add('is-invalid'); }
    });

    onActiveToggle();
    if (document.getElementById('chkIsEmployee').checked) onEmployeeToggle();
    onCoreMemberToggle();
</script>
}
