@model CentralLicenceApp.Models.ViewModels.UserListViewModel
@{
    ViewData["Title"] = "User Management";
    var currentUserId = int.Parse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)!.Value);
    var hasFilters = !string.IsNullOrWhiteSpace(Model.SearchTerm) || !string.IsNullOrWhiteSpace(Model.StatusFilter) || Model.RoleId.HasValue;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;">User Management</h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">@Model.TotalCount @(hasFilters ? "matching" : "system") user(s)</p>
    </div>
    <a asp-action="Create" class="btn btn-primary" style="background:#6366f1;border:none;border-radius:10px;">
        <i class="bi bi-plus-lg me-1"></i> New User
    </a>
</div>

<div class="card mb-4">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label mb-1" style="font-size:.78rem;font-weight:600;color:#64748b;">Search</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="search" value="@Model.SearchTerm" class="form-control border-start-0" placeholder="Name, username, email, phone or employee code..." style="border-radius:0 10px 10px 0;" />
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <label class="form-label mb-1" style="font-size:.78rem;font-weight:600;color:#64748b;">Status</label>
                <select name="status" class="form-select" style="border-radius:10px;">
                    <option value="">All Status</option>
                    <option value="active" selected="@(Model.StatusFilter == "active")">Active</option>
                    <option value="inactive" selected="@(Model.StatusFilter == "inactive")">Inactive</option>
                </select>
            </div>
            <div class="col-md-3 col-sm-6">
                <label class="form-label mb-1" style="font-size:.78rem;font-weight:600;color:#64748b;">Role</label>
                <select name="roleId" class="form-select" style="border-radius:10px;">
                    <option value="">All Roles</option>
                    @foreach (var role in Model.AvailableRoles)
                    {
                        <option value="@role.Id" selected="@(Model.RoleId == role.Id)">@role.RoleName</option>
                    }
                </select>
            </div>
            <div class="col-md-auto">
                <button type="submit" class="btn btn-primary" style="background:#6366f1;border:none;border-radius:10px;">
                    <i class="bi bi-funnel me-1"></i> Filter
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-1" style="border-radius:10px;">Clear</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table tbl-clean mb-0">
                <thead>
                    <tr>
                        <th class="ps-3">#</th>
                        <th>User</th>
                        <th>Phone</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Location</th>
                        <th>Employee</th>
                        <th>Employee Type</th>
                        <th>Status</th>
                        <th class="pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Users.Any())
                    {
                        <tr>
                            <td colspan="10" class="text-center py-5 text-muted"><i class="bi bi-inbox fs-1 d-block mb-2"></i>No users found</td>
                        </tr>
                    }
                    @foreach (var u in Model.Users)
                    {
                        <tr>
                            <td class="ps-3" style="color:#94a3b8;font-size:.8rem;">@u.Id</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div style="width:34px;height:34px;background:#e0e7ff;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#6366f1;font-weight:700;font-size:.85rem;flex-shrink:0;">
                                        @(u.FullName?.Length > 0 ? u.FullName[0].ToString().ToUpper() : u.Username[0].ToString().ToUpper())
                                    </div>
                                    <div>
                                        <div class="fw-semibold" style="font-size:.875rem;">@(u.FullName ?? u.Username)</div>
                                        <div class="text-muted" style="font-size:.75rem;">@@@u.Username</div>
                                    </div>
                                </div>
                            </td>
                            <td style="font-size:.82rem;">@(u.PhoneNumber ?? "—")</td>
                            <td style="font-size:.85rem;">@u.Email</td>
                            <td>
                                @if (u.RoleName == "Administrator")
                                {
                                    <span class="badge" style="background:#ede9fe;color:#6d28d9;font-size:.73rem;border-radius:20px;padding:.3rem .7rem;"><i class="bi bi-shield-fill me-1"></i>@u.RoleName</span>
                                }
                                else
                                {
                                    <span class="badge" style="background:#f1f5f9;color:#475569;font-size:.73rem;border-radius:20px;padding:.3rem .7rem;"><i class="bi bi-person me-1"></i>@u.RoleName</span>
                                }
                            </td>
                            <td style="font-size:.82rem;">@(u.LocationName ?? "—")</td>
                            <td>
                                @if (u.IsEmployee)
                                {
                                    <span class="badge rounded-pill px-2 py-1" style="background:#dcfce7;color:#166534;font-size:.72rem;"><i class="bi bi-person-badge me-1"></i>@(u.EmployeeCode ?? "Yes")</span>
                                }
                                else
                                {
                                    <span class="text-muted" style="font-size:.78rem;">—</span>
                                }
                            </td>
                            <td style="font-size:.82rem;">@(u.EmployeeTypeName ?? "—")</td>
                            <td>
                                @if (u.IsActive)
                                {
                                    <span class="badge badge-ok rounded-pill px-2 py-1" style="font-size:.73rem;">Active</span>
                                }
                                else
                                {
                                    <span class="badge badge-neu rounded-pill px-2 py-1" style="font-size:.73rem;">Inactive</span>
                                }
                            </td>
                            <td class="pe-3">
                                <div class="d-flex gap-1">
                                    <a asp-action="Details" asp-route-id="@u.Id" class="btn btn-sm btn-outline-primary" title="View" style="border-radius:7px;border-color:#c7d2fe;color:#4f46e5;"><i class="bi bi-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@u.Id" class="btn btn-sm btn-outline-secondary" title="Edit" style="border-radius:7px;border-color:#e2e8f0;"><i class="bi bi-pencil"></i></a>
                                    @if (u.Id != currentUserId)
                                    {
                                        <form asp-action="Delete" method="post"
                                              data-swal-confirm="true"
                                              data-swal-title="Delete User?"
                                              data-swal-text="User <strong>@u.Username</strong> will be deleted permanently."
                                              data-swal-confirm-button="Yes, delete user">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@u.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete" style="border-radius:7px;"><i class="bi bi-trash"></i></button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="d-flex align-items-center justify-content-between px-3 py-3 border-top" style="font-size:.82rem;">
                <span class="text-muted">Showing @((Model.PageNumber - 1) * Model.PageSize + 1)–@(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount)) of @Model.TotalCount</span>
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        @for (int p = 1; p <= Model.TotalPages; p++)
                        {
                            <li class="page-item @(p == Model.PageNumber ? "active" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@p"
                                   asp-route-search="@Model.SearchTerm"
                                   asp-route-status="@Model.StatusFilter"
                                   asp-route-roleId="@Model.RoleId">@p</a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

