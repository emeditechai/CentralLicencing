@model CentralLicenceApp.Models.ViewModels.PartyMasterFormViewModel
@{
    ViewData["Title"] = "New Party";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary" style="border-radius:8px;"><i class="bi bi-arrow-left"></i></a>
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;">New Party</h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">Add a client / party for quotations and invoices</p>
    </div>
</div>

<div class="card" style="max-width:720px;">
    <div class="card-body p-4">
        <form asp-action="Create" asp-permission="PartyMaster:Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 px-3 rounded-3 mb-3" style="font-size:.83rem;"></div>

            <div class="row g-3">
                <div class="col-md-12">
                    <label asp-for="PartyName" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="PartyName" class="form-control" placeholder="e.g. RAJ Traders" style="border-radius:10px;" />
                    <span asp-validation-for="PartyName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ContactPerson" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="ContactPerson" class="form-control" placeholder="e.g. Rajesh Kumar" style="border-radius:10px;" />
                    <span asp-validation-for="ContactPerson" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Mobile" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="Mobile" class="form-control" placeholder="e.g. 9876543210" style="border-radius:10px;" />
                    <span asp-validation-for="Mobile" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="Email" class="form-control" placeholder="e.g. party@example.com" style="border-radius:10px;" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="GSTINNo" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="GSTINNo" class="form-control" placeholder="e.g. 19AAUFR5370C2ZS" style="border-radius:10px;" maxlength="15" />
                    <span asp-validation-for="GSTINNo" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="PANNo" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="PANNo" class="form-control" placeholder="e.g. AAUFR5370C" style="border-radius:10px;" maxlength="10" />
                    <span asp-validation-for="PANNo" class="text-danger small"></span>
                </div>
                <div class="col-md-12">
                    <label asp-for="Address" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <textarea asp-for="Address" class="form-control" rows="2" placeholder="Full address…" style="border-radius:10px;"></textarea>
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>
                <div class="col-md-12">
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label fw-semibold" style="font-size:.85rem;"></label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn text-white px-4" style="background:#6366f1;border:none;border-radius:10px;">
                    <i class="bi bi-check-lg me-1"></i> Save Party
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius:10px;">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
