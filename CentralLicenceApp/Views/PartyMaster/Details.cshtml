@model CentralLicenceApp.Models.PartyMaster
@{
    ViewData["Title"] = "Party Details";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary" style="border-radius:8px;"><i class="bi bi-arrow-left"></i></a>
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;">Party Details</h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">@Model.PartyName</p>
    </div>
    <div class="ms-auto d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary" style="border-radius:8px;">
            <i class="bi bi-pencil me-1"></i> Edit
        </a>
    </div>
</div>

<div class="card" style="max-width:720px;border-radius:14px;">
    <div class="card-body p-4">
        <div class="row g-3">
            <div class="col-md-12">
                <label class="form-label fw-semibold text-muted" style="font-size:.78rem;">Party Name</label>
                <p class="mb-0 fw-semibold" style="font-size:.95rem;">@Model.PartyName</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted" style="font-size:.78rem;">Contact Person</label>
                <p class="mb-0" style="font-size:.92rem;">@(Model.ContactPerson ?? "—")</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted" style="font-size:.78rem;">Mobile</label>
                <p class="mb-0" style="font-size:.92rem;">@(Model.Mobile ?? "—")</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted" style="font-size:.78rem;">Email</label>
                <p class="mb-0" style="font-size:.92rem;">@(Model.Email ?? "—")</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted" style="font-size:.78rem;">Address</label>
                <p class="mb-0" style="font-size:.92rem;">@(Model.Address ?? "—")</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted" style="font-size:.78rem;">GSTIN No</label>
                @if (!string.IsNullOrWhiteSpace(Model.GSTINNo))
                {
                    <p class="mb-0" style="font-size:.92rem;"><span class="badge bg-success-subtle text-success" style="font-size:.82rem;">@Model.GSTINNo</span></p>
                }
                else
                {
                    <p class="mb-0" style="font-size:.92rem;">—</p>
                }
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted" style="font-size:.78rem;">PAN No</label>
                @if (!string.IsNullOrWhiteSpace(Model.PANNo))
                {
                    <p class="mb-0" style="font-size:.92rem;"><span class="badge bg-danger-subtle text-danger" style="font-size:.82rem;">@Model.PANNo</span></p>
                }
                else
                {
                    <p class="mb-0" style="font-size:.92rem;">—</p>
                }
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted" style="font-size:.78rem;">Status</label>
                <p class="mb-0">
                    @if (Model.IsActive)
                    {
                        <span class="badge bg-success-subtle text-success" style="font-size:.82rem;">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary-subtle text-secondary" style="font-size:.82rem;">Inactive</span>
                    }
                </p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted" style="font-size:.78rem;">Created At</label>
                <p class="mb-0" style="font-size:.92rem;">@Model.CreatedAt.ToString("dd MMM yyyy hh:mm tt")</p>
            </div>
        </div>
    </div>
</div>