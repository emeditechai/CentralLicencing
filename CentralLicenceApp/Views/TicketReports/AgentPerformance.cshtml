@model CentralLicenceApp.Models.ViewModels.AgentPerformanceReportViewModel
@{
    ViewData["Title"] = "Agent Performance Report";
    var fromVal = Model.FromDate?.ToString("yyyy-MM-dd") ?? "";
    var toVal = Model.ToDate?.ToString("yyyy-MM-dd") ?? "";
}

<div class="container-fluid px-4 py-3">
    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
        <div>
            <h4 class="fw-bold mb-0" style="color:#1e293b;">Agent Performance Report</h4>
            <small class="text-muted">Individual agent metrics, response times, and resolution rates</small>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="ExportAgentPerformanceExcel" asp-permission="TicketReports:Export"
               asp-route-fromDate="@fromVal"
               asp-route-toDate="@toVal"
               class="btn btn-sm text-white"
               style="border-radius:10px;background:#15803d;border:none;">
                <i class="bi bi-file-earmark-excel me-1"></i>Excel
            </a>
            <a asp-action="ExportAgentPerformancePdf" asp-permission="TicketReports:Export"
               asp-route-fromDate="@fromVal"
               asp-route-toDate="@toVal"
               class="btn btn-sm text-white"
               style="border-radius:10px;background:#b91c1c;border:none;">
                <i class="bi bi-file-earmark-pdf me-1"></i>PDF
            </a>
        </div>
    </div>

    <!-- Date Filter -->
    <form method="get" class="card border-0 shadow-sm mb-4" style="border-radius:12px;">
        <div class="card-body py-3 px-4">
            <div class="row g-3 align-items-end">
                <div class="col-auto">
                    <label class="form-label small fw-semibold text-muted mb-1">From Date</label>
                    <input type="date" name="fromDate" value="@fromVal" class="form-control form-control-sm" style="border-radius:8px;border-color:#e2e8f0;" />
                </div>
                <div class="col-auto">
                    <label class="form-label small fw-semibold text-muted mb-1">To Date</label>
                    <input type="date" name="toDate" value="@toVal" class="form-control form-control-sm" style="border-radius:8px;border-color:#e2e8f0;" />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-sm text-white" style="background:#4f46e5;border-radius:8px;padding:6px 20px;">
                        <i class="bi bi-funnel me-1"></i> Filter
                    </button>
                    <a asp-action="AgentPerformance" class="btn btn-sm btn-outline-secondary ms-1" style="border-radius:8px;">Reset</a>
                </div>
            </div>
        </div>
    </form>

    @if (Model.Agents.Any())
    {
        <!-- Summary Cards -->
        <div class="row g-3 mb-4">
            <div class="col-xl-3 col-md-6">
                <div class="card border-0 shadow-sm" style="border-radius:12px;">
                    <div class="card-body d-flex align-items-center gap-3 py-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:44px;height:44px;background:#ede9fe;">
                            <i class="bi bi-people fs-5" style="color:#7c3aed;"></i>
                        </div>
                        <div>
                            <div class="text-muted" style="font-size:.72rem;font-weight:600;">ACTIVE AGENTS</div>
                            <div class="fw-bold fs-4">@Model.Agents.Count</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="card border-0 shadow-sm" style="border-radius:12px;">
                    <div class="card-body d-flex align-items-center gap-3 py-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:44px;height:44px;background:#dbeafe;">
                            <i class="bi bi-ticket-perforated fs-5" style="color:#2563eb;"></i>
                        </div>
                        <div>
                            <div class="text-muted" style="font-size:.72rem;font-weight:600;">TOTAL ASSIGNED</div>
                            <div class="fw-bold fs-4">@Model.Agents.Sum(a => a.TotalAssigned)</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="card border-0 shadow-sm" style="border-radius:12px;">
                    <div class="card-body d-flex align-items-center gap-3 py-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:44px;height:44px;background:#dcfce7;">
                            <i class="bi bi-check-circle fs-5" style="color:#16a34a;"></i>
                        </div>
                        <div>
                            <div class="text-muted" style="font-size:.72rem;font-weight:600;">TOTAL RESOLVED</div>
                            <div class="fw-bold fs-4">@Model.Agents.Sum(a => a.Resolved + a.Closed)</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="card border-0 shadow-sm" style="border-radius:12px;">
                    <div class="card-body d-flex align-items-center gap-3 py-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:44px;height:44px;background:#fef3c7;">
                            <i class="bi bi-speedometer2 fs-5" style="color:#d97706;"></i>
                        </div>
                        <div>
                            <div class="text-muted" style="font-size:.72rem;font-weight:600;">AVG RESOLUTION RATE</div>
                            @{
                                var avgRate = Model.Agents.Any() ? Model.Agents.Average(a => a.ResolutionRate) : 0;
                            }
                            <div class="fw-bold fs-4">@avgRate.ToString("0.#")%</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Performance Chart -->
        <div class="card border-0 shadow-sm mb-4" style="border-radius:12px;">
            <div class="card-header bg-white border-0 py-3 px-4">
                <h6 class="fw-bold mb-0"><i class="bi bi-bar-chart me-2"></i>Agent Ticket Distribution</h6>
            </div>
            <div class="card-body pt-0 px-4 pb-3">
                <canvas id="agentChart" height="80"></canvas>
            </div>
        </div>

        <!-- Agent Table -->
        <div class="card border-0 shadow-sm" style="border-radius:12px;">
            <div class="card-header bg-white border-0 py-3 px-4">
                <h6 class="fw-bold mb-0"><i class="bi bi-table me-2"></i>Detailed Metrics</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr style="background:#f8fafc;">
                                <th class="ps-4">#</th>
                                <th>Agent</th>
                                <th class="text-center">Assigned</th>
                                <th class="text-center">Open</th>
                                <th class="text-center">In Progress</th>
                                <th class="text-center">Resolved</th>
                                <th class="text-center">Closed</th>
                                <th class="text-center">Avg Response</th>
                                <th class="text-center">Avg Resolution</th>
                                <th class="text-center pe-4">Resolution Rate</th>
                            </tr>
                        </thead>
                        <tbody>
                        @{ var idx = (Model.PageNumber - 1) * Model.PageSize; }
                        @foreach (var a in Model.Agents)
                        {
                            idx++;
                            var rateColor = a.ResolutionRate >= 80 ? "#16a34a" : a.ResolutionRate >= 50 ? "#d97706" : "#ef4444";
                            <tr>
                                <td class="ps-4 text-muted" style="font-size:.82rem;">@idx</td>
                                <td class="fw-semibold" style="font-size:.85rem;">@a.AgentName</td>
                                <td class="text-center fw-bold" style="font-size:.85rem;">@a.TotalAssigned</td>
                                <td class="text-center" style="font-size:.85rem;"><span class="badge rounded-pill" style="background:#dbeafe;color:#2563eb;">@a.Open</span></td>
                                <td class="text-center" style="font-size:.85rem;"><span class="badge rounded-pill" style="background:#fef3c7;color:#d97706;">@a.InProgress</span></td>
                                <td class="text-center" style="font-size:.85rem;"><span class="badge rounded-pill" style="background:#dcfce7;color:#16a34a;">@a.Resolved</span></td>
                                <td class="text-center" style="font-size:.85rem;"><span class="badge rounded-pill" style="background:#f1f5f9;color:#64748b;">@a.Closed</span></td>
                                <td class="text-center" style="font-size:.83rem;">@a.AvgResponseTimeHours.ToString("0.#")h</td>
                                <td class="text-center" style="font-size:.83rem;">@a.AvgResolutionTimeHours.ToString("0.#")h</td>
                                <td class="text-center pe-4">
                                    <div class="d-flex align-items-center justify-content-center gap-2">
                                        <div class="progress flex-grow-1" style="height:6px;max-width:80px;border-radius:3px;">
                                            <div class="progress-bar" style="width:@a.ResolutionRate.ToString("0")%;background:@rateColor;border-radius:3px;"></div>
                                        </div>
                                        <span class="fw-bold" style="font-size:.82rem;color:@rateColor;">@a.ResolutionRate.ToString("0.#")%</span>
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
            @if (Model.TotalPages > 1)
            {
                <div class="d-flex align-items-center justify-content-between px-3 py-3 border-top" style="font-size:.82rem;">
                    <span class="text-muted">
                        Showing @((Model.PageNumber - 1) * Model.PageSize + 1)&ndash;@(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount)) of @Model.TotalCount records
                    </span>
                    <nav>
                        <ul class="pagination pagination-sm mb-0">
                            @if (Model.PageNumber > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="AgentPerformance"
                                       asp-route-page="@(Model.PageNumber - 1)"
                                       asp-route-fromDate="@fromVal"
                                       asp-route-toDate="@toVal">&laquo;</a>
                                </li>
                            }
                            @{
                                int startPg = Math.Max(1, Model.PageNumber - 2);
                                int endPg   = Math.Min(Model.TotalPages, startPg + 4);
                                if (endPg - startPg < 4) startPg = Math.Max(1, endPg - 4);
                            }
                            @for (int pg = startPg; pg <= endPg; pg++)
                            {
                                <li class="page-item @(pg == Model.PageNumber ? "active" : "")">
                                    <a class="page-link" asp-action="AgentPerformance"
                                       asp-route-page="@pg"
                                       asp-route-fromDate="@fromVal"
                                       asp-route-toDate="@toVal">@pg</a>
                                </li>
                            }
                            @if (Model.PageNumber < Model.TotalPages)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="AgentPerformance"
                                       asp-route-page="@(Model.PageNumber + 1)"
                                       asp-route-fromDate="@fromVal"
                                       asp-route-toDate="@toVal">&raquo;</a>
                                </li>
                            }
                        </ul>
                    </nav>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm" style="border-radius:12px;">
            <div class="card-body text-center py-5">
                <i class="bi bi-inbox fs-1 d-block mb-2 text-muted"></i>
                <p class="text-muted">No agent performance data available for the selected period.</p>
            </div>
        </div>
    }
</div>

@section Scripts {
@if (Model.Agents.Any())
{
<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<script>
(function() {
    var labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Agents.Select(a => a.AgentName)));
    var resolved = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Agents.Select(a => a.Resolved)));
    var closed = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Agents.Select(a => a.Closed)));
    var open = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Agents.Select(a => a.Open)));
    var inProg = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Agents.Select(a => a.InProgress)));

    new Chart(document.getElementById('agentChart'), {
        type: 'bar',
        data: {
            labels: labels,
            datasets: [
                { label: 'Resolved', data: resolved, backgroundColor: '#16a34a', borderRadius: 4 },
                { label: 'Closed', data: closed, backgroundColor: '#64748b', borderRadius: 4 },
                { label: 'In Progress', data: inProg, backgroundColor: '#d97706', borderRadius: 4 },
                { label: 'Open', data: open, backgroundColor: '#2563eb', borderRadius: 4 }
            ]
        },
        options: {
            responsive: true,
            plugins: { legend: { position: 'bottom' } },
            scales: { x: { stacked: true }, y: { stacked: true, beginAtZero: true, ticks: { stepSize: 1 } } }
        }
    });
})();
</script>
}
}
