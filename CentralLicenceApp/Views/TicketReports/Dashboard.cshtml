@model CentralLicenceApp.Models.ViewModels.TicketReportDashboardViewModel
@{
    ViewData["Title"] = "Ticket Analytics Dashboard";
    var fromVal = Model.FromDate?.ToString("yyyy-MM-dd") ?? "";
    var toVal = Model.ToDate?.ToString("yyyy-MM-dd") ?? "";
}

<div class="container-fluid px-4 py-3">
    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
        <div>
            <h4 class="fw-bold mb-0" style="color:#1e293b;">Ticket Analytics Dashboard</h4>
            <small class="text-muted">Overview of help desk ticket metrics and trends</small>
        </div>
    </div>

    <!-- Date Filter -->
    <form method="get" class="card border-0 shadow-sm mb-4" style="border-radius:12px;">
        <div class="card-body py-3 px-4">
            <div class="row g-3 align-items-end">
                <div class="col-auto">
                    <label class="form-label small fw-semibold text-muted mb-1">From Date</label>
                    <input type="date" name="fromDate" value="@fromVal" class="form-control form-control-sm" style="border-radius:8px;border-color:#e2e8f0;" />
                </div>
                <div class="col-auto">
                    <label class="form-label small fw-semibold text-muted mb-1">To Date</label>
                    <input type="date" name="toDate" value="@toVal" class="form-control form-control-sm" style="border-radius:8px;border-color:#e2e8f0;" />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-sm text-white" style="background:#4f46e5;border-radius:8px;padding:6px 20px;">
                        <i class="bi bi-funnel me-1"></i> Filter
                    </button>
                    <a asp-action="Dashboard" class="btn btn-sm btn-outline-secondary ms-1" style="border-radius:8px;">Reset</a>
                </div>
            </div>
        </div>
    </form>

    <!-- KPI Cards Row 1 -->
    <div class="row g-3 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm h-100" style="border-radius:12px;">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:48px;height:48px;background:#ede9fe;">
                        <i class="bi bi-ticket-perforated fs-5" style="color:#7c3aed;"></i>
                    </div>
                    <div>
                        <div class="text-muted" style="font-size:.72rem;font-weight:600;">TOTAL TICKETS</div>
                        <div class="fw-bold fs-4" style="color:#1e293b;">@Model.TotalTickets</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm h-100" style="border-radius:12px;">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:48px;height:48px;background:#dcfce7;">
                        <i class="bi bi-check-circle fs-5" style="color:#16a34a;"></i>
                    </div>
                    <div>
                        <div class="text-muted" style="font-size:.72rem;font-weight:600;">RESOLVED</div>
                        <div class="fw-bold fs-4" style="color:#1e293b;">@Model.ResolvedTickets</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm h-100" style="border-radius:12px;">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:48px;height:48px;background:#dbeafe;">
                        <i class="bi bi-clock-history fs-5" style="color:#2563eb;"></i>
                    </div>
                    <div>
                        <div class="text-muted" style="font-size:.72rem;font-weight:600;">AVG RESPONSE TIME</div>
                        <div class="fw-bold fs-4" style="color:#1e293b;">@Model.AvgResponseTimeHours.ToString("0.#")h</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm h-100" style="border-radius:12px;">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:48px;height:48px;background:#fef3c7;">
                        <i class="bi bi-hourglass-split fs-5" style="color:#d97706;"></i>
                    </div>
                    <div>
                        <div class="text-muted" style="font-size:.72rem;font-weight:600;">AVG RESOLUTION TIME</div>
                        <div class="fw-bold fs-4" style="color:#1e293b;">@Model.AvgResolutionTimeHours.ToString("0.#")h</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- KPI Cards Row 2 (Status breakdown) -->
    <div class="row g-3 mb-4">
        <div class="col-xl col-md-4">
            <div class="card border-0 shadow-sm" style="border-radius:10px;border-left:4px solid #2563eb!important;">
                <div class="card-body py-2 px-3 d-flex justify-content-between align-items-center">
                    <span class="text-muted" style="font-size:.78rem;">Open</span>
                    <span class="fw-bold" style="color:#2563eb;">@Model.OpenTickets</span>
                </div>
            </div>
        </div>
        <div class="col-xl col-md-4">
            <div class="card border-0 shadow-sm" style="border-radius:10px;border-left:4px solid #d97706!important;">
                <div class="card-body py-2 px-3 d-flex justify-content-between align-items-center">
                    <span class="text-muted" style="font-size:.78rem;">In Progress</span>
                    <span class="fw-bold" style="color:#d97706;">@Model.InProgressTickets</span>
                </div>
            </div>
        </div>
        <div class="col-xl col-md-4">
            <div class="card border-0 shadow-sm" style="border-radius:10px;border-left:4px solid #0891b2!important;">
                <div class="card-body py-2 px-3 d-flex justify-content-between align-items-center">
                    <span class="text-muted" style="font-size:.78rem;">Waiting</span>
                    <span class="fw-bold" style="color:#0891b2;">@Model.WaitingTickets</span>
                </div>
            </div>
        </div>
        <div class="col-xl col-md-4">
            <div class="card border-0 shadow-sm" style="border-radius:10px;border-left:4px solid #16a34a!important;">
                <div class="card-body py-2 px-3 d-flex justify-content-between align-items-center">
                    <span class="text-muted" style="font-size:.78rem;">Resolved</span>
                    <span class="fw-bold" style="color:#16a34a;">@Model.ResolvedTickets</span>
                </div>
            </div>
        </div>
        <div class="col-xl col-md-4">
            <div class="card border-0 shadow-sm" style="border-radius:10px;border-left:4px solid #64748b!important;">
                <div class="card-body py-2 px-3 d-flex justify-content-between align-items-center">
                    <span class="text-muted" style="font-size:.78rem;">Closed</span>
                    <span class="fw-bold" style="color:#64748b;">@Model.ClosedTickets</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row g-4 mb-4">
        <!-- Daily Trend Chart -->
        <div class="col-xl-8">
            <div class="card border-0 shadow-sm" style="border-radius:12px;">
                <div class="card-header bg-white border-0 py-3 px-4">
                    <h6 class="fw-bold mb-0" style="color:#1e293b;"><i class="bi bi-graph-up me-2"></i>Ticket Trend (Created vs Resolved)</h6>
                </div>
                <div class="card-body pt-0 px-4 pb-3">
                    <canvas id="trendChart" height="120"></canvas>
                </div>
            </div>
        </div>
        <!-- Status Pie -->
        <div class="col-xl-4">
            <div class="card border-0 shadow-sm" style="border-radius:12px;">
                <div class="card-header bg-white border-0 py-3 px-4">
                    <h6 class="fw-bold mb-0" style="color:#1e293b;"><i class="bi bi-pie-chart me-2"></i>Status Distribution</h6>
                </div>
                <div class="card-body pt-0 px-4 pb-3">
                    <canvas id="statusChart" height="200"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Distribution Tables Row -->
    <div class="row g-4 mb-4">
        <!-- Category Table -->
        <div class="col-xl-6">
            <div class="card border-0 shadow-sm" style="border-radius:12px;">
                <div class="card-header bg-white border-0 py-3 px-4">
                    <h6 class="fw-bold mb-0" style="color:#1e293b;"><i class="bi bi-tags me-2"></i>Tickets by Category</h6>
                </div>
                <div class="card-body p-0">
                    <table class="table mb-0">
                        <thead><tr><th class="ps-4">Category</th><th class="text-end pe-4">Count</th><th style="width:40%;">Distribution</th></tr></thead>
                        <tbody>
                        @{ var maxCat = Model.CategoryDistribution.Any() ? Model.CategoryDistribution.Max(c => c.Count) : 1; }
                        @foreach (var c in Model.CategoryDistribution)
                        {
                            var pct = maxCat > 0 ? (c.Count * 100.0 / maxCat) : 0;
                            <tr>
                                <td class="ps-4" style="font-size:.85rem;">@c.CategoryName</td>
                                <td class="text-end pe-4 fw-bold" style="font-size:.85rem;">@c.Count</td>
                                <td>
                                    <div class="progress" style="height:8px;border-radius:4px;">
                                        <div class="progress-bar" role="progressbar" style="width:@pct.ToString("0")%;background:#4f46e5;border-radius:4px;"></div>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!Model.CategoryDistribution.Any())
                        {
                            <tr><td colspan="3" class="text-center text-muted py-4">No data</td></tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <!-- Priority Table -->
        <div class="col-xl-6">
            <div class="card border-0 shadow-sm" style="border-radius:12px;">
                <div class="card-header bg-white border-0 py-3 px-4">
                    <h6 class="fw-bold mb-0" style="color:#1e293b;"><i class="bi bi-flag me-2"></i>Tickets by Priority</h6>
                </div>
                <div class="card-body p-0">
                    <table class="table mb-0">
                        <thead><tr><th class="ps-4">Priority</th><th class="text-end pe-4">Count</th><th style="width:40%;">Distribution</th></tr></thead>
                        <tbody>
                        @{ var maxPri = Model.PriorityDistribution.Any() ? Model.PriorityDistribution.Max(p => p.Count) : 1; }
                        @foreach (var p in Model.PriorityDistribution)
                        {
                            var pct = maxPri > 0 ? (p.Count * 100.0 / maxPri) : 0;
                            var clr = p.ColorCode ?? "#6b7280";
                            <tr>
                                <td class="ps-4"><span class="badge rounded-pill px-2 py-1" style="font-size:.73rem;background:@(clr)20;color:@clr;">@p.PriorityName</span></td>
                                <td class="text-end pe-4 fw-bold" style="font-size:.85rem;">@p.Count</td>
                                <td>
                                    <div class="progress" style="height:8px;border-radius:4px;">
                                        <div class="progress-bar" role="progressbar" style="width:@pct.ToString("0")%;background:@clr;border-radius:4px;"></div>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!Model.PriorityDistribution.Any())
                        {
                            <tr><td colspan="3" class="text-center text-muted py-4">No data</td></tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<script>
(function() {
    // Trend Chart
    var trendLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailyTrend.Select(d => d.TicketDate.ToString("dd MMM"))));
    var createdData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailyTrend.Select(d => d.CreatedCount)));
    var resolvedData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailyTrend.Select(d => d.ResolvedCount)));

    new Chart(document.getElementById('trendChart'), {
        type: 'line',
        data: {
            labels: trendLabels,
            datasets: [
                { label: 'Created', data: createdData, borderColor: '#4f46e5', backgroundColor: 'rgba(79,70,229,.1)', fill: true, tension: .4, borderWidth: 2, pointRadius: 2 },
                { label: 'Resolved', data: resolvedData, borderColor: '#16a34a', backgroundColor: 'rgba(22,163,74,.1)', fill: true, tension: .4, borderWidth: 2, pointRadius: 2 }
            ]
        },
        options: { responsive: true, plugins: { legend: { position: 'bottom' } }, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } }
    });

    // Status Pie
    var statusLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.StatusDistribution.Select(s => s.Status)));
    var statusData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.StatusDistribution.Select(s => s.Count)));
    var statusColors = statusLabels.map(function(s) {
        switch(s) {
            case 'Open': return '#2563eb';
            case 'In Progress': return '#d97706';
            case 'Waiting for Client': return '#0891b2';
            case 'Resolved': return '#16a34a';
            case 'Closed': return '#64748b';
            default: return '#94a3b8';
        }
    });

    new Chart(document.getElementById('statusChart'), {
        type: 'doughnut',
        data: { labels: statusLabels, datasets: [{ data: statusData, backgroundColor: statusColors, borderWidth: 0, hoverOffset: 6 }] },
        options: { responsive: true, plugins: { legend: { position: 'bottom', labels: { padding: 12, font: { size: 11 } } } }, cutout: '60%' }
    });
})();
</script>
}
