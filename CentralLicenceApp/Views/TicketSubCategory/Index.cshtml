@model List<CentralLicenceApp.Models.TicketSubCategoryMaster>
@{
    ViewData["Title"] = "Ticket Sub Categories";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;">Ticket Sub Categories</h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">@Model.Count sub-categor@(Model.Count == 1 ? "y" : "ies") configured</p>
    </div>
    <a asp-action="Create" class="btn btn-primary" style="background:#180a3c;border:none;border-radius:10px;">
        <i class="bi bi-plus-lg me-1"></i> New Sub Category
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table tbl-clean mb-0">
                <thead>
                    <tr>
                        <th class="ps-3">#</th>
                        <th>Sub Category Name</th>
                        <th>Category</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th class="pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted"><i class="bi bi-inbox fs-1 d-block mb-2"></i>No ticket sub-categories found</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-3" style="color:#94a3b8;font-size:.8rem;">@item.Id</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div style="width:32px;height:32px;background:#ede9fe;border-radius:8px;display:flex;align-items:center;justify-content:center;color:#6d28d9;font-size:.9rem;">
                                            <i class="bi bi-bookmark"></i>
                                        </div>
                                        <span class="fw-semibold" style="font-size:.875rem;">@item.SubCategoryName</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge rounded-pill px-2 py-1" style="font-size:.73rem;background:#e0e7ff;color:#4f46e5;">@item.CategoryName</span>
                                </td>
                                <td class="text-muted" style="font-size:.85rem;">@(string.IsNullOrWhiteSpace(item.Description) ? "-" : item.Description)</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge badge-ok rounded-pill px-2 py-1" style="font-size:.73rem;">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-neu rounded-pill px-2 py-1" style="font-size:.73rem;">Inactive</span>
                                    }
                                </td>
                                <td style="font-size:.82rem;">@item.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td class="pe-3">
                                    <div class="d-flex gap-1">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" title="Edit" style="border-radius:7px;border-color:#e2e8f0;"><i class="bi bi-pencil"></i></a>
                                        <form asp-action="Delete" method="post"
                                              data-swal-confirm="true"
                                              data-swal-title="Delete Sub Category?"
                                              data-swal-text="Sub-category <strong>@item.SubCategoryName</strong> will be deleted permanently."
                                              data-swal-confirm-button="Yes, delete">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete" style="border-radius:7px;"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
