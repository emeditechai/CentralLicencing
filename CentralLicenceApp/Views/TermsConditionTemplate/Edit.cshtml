@model CentralLicenceApp.Models.ViewModels.TermsConditionTemplateFormViewModel
@{
    ViewData["Title"] = "Edit Terms & Condition Template";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary" style="border-radius:8px;"><i class="bi bi-arrow-left"></i></a>
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;">Edit Terms &amp; Condition Template</h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">Update template content</p>
    </div>
</div>

<div class="card" style="max-width:780px;">
    <div class="card-body p-4">
        <form asp-action="Edit" asp-permission="TermsConditionTemplate:Edit" method="post" id="templateForm">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <!-- Hidden field carries rich-text HTML value -->
            <input type="hidden" asp-for="Description" id="descriptionHidden" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 px-3 rounded-3 mb-3" style="font-size:.83rem;"></div>

            <div class="row g-4">
                <!-- Terms Name -->
                <div class="col-12">
                    <label asp-for="TermsName" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="TermsName" class="form-control" style="border-radius:10px;" />
                    <span asp-validation-for="TermsName" class="text-danger small"></span>
                </div>

                <!-- Rich Text Description -->
                <div class="col-12">
                    <label class="form-label fw-semibold" style="font-size:.82rem;">Description</label>
                    <!-- Quill toolbar -->
                    <div id="quillToolbar" style="border-radius:10px 10px 0 0;border:1px solid #dee2e6;">
                        <span class="ql-formats">
                            <select class="ql-header">
                                <option selected></option>
                                <option value="1">Heading 1</option>
                                <option value="2">Heading 2</option>
                                <option value="3">Heading 3</option>
                            </select>
                        </span>
                        <span class="ql-formats">
                            <button class="ql-bold"></button>
                            <button class="ql-italic"></button>
                            <button class="ql-underline"></button>
                            <button class="ql-strike"></button>
                        </span>
                        <span class="ql-formats">
                            <button class="ql-list" value="ordered"></button>
                            <button class="ql-list" value="bullet"></button>
                            <button class="ql-indent" value="-1"></button>
                            <button class="ql-indent" value="+1"></button>
                        </span>
                        <span class="ql-formats">
                            <button class="ql-link"></button>
                            <button class="ql-blockquote"></button>
                            <button class="ql-clean"></button>
                        </span>
                    </div>
                    <!-- Quill editor area — pre-populated with existing HTML -->
                    <div id="quillEditor" style="border:1px solid #dee2e6;border-top:none;border-radius:0 0 10px 10px;min-height:260px;font-size:.9rem;">
                        @if (!string.IsNullOrWhiteSpace(Model.Description))
                        {
                            @Html.Raw(Model.Description)
                        }
                    </div>
                </div>

                <!-- Is Active -->
                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label fw-semibold" style="font-size:.85rem;"></label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn text-white px-4" style="background:#180a3c;border:none;border-radius:10px;">
                    <i class="bi bi-check-lg me-1"></i> Save Changes
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius:10px;">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section HeadExtra {
    <link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css" rel="stylesheet" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>
    <script>
        const quill = new Quill('#quillEditor', {
            theme: 'snow',
            modules: { toolbar: '#quillToolbar' },
            placeholder: 'Enter terms and conditions content…'
        });

        document.getElementById('templateForm').addEventListener('submit', function () {
            document.getElementById('descriptionHidden').value = quill.getSemanticHTML();
        });
    </script>
}
