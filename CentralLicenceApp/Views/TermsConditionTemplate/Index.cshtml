@model List<CentralLicenceApp.Models.TermsConditionTemplate>
@{
    ViewData["Title"] = "Terms & Condition Templates";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;">Terms &amp; Condition Templates</h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">@Model.Count template@(Model.Count == 1 ? "" : "s") configured</p>
    </div>
    <a asp-action="Create" class="btn btn-primary" style="background:#180a3c;border:none;border-radius:10px;">
        <i class="bi bi-plus-lg me-1"></i> New Template
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table tbl-clean mb-0">
                <thead>
                    <tr>
                        <th class="ps-3">#</th>
                        <th>Terms Name</th>
                        <th>Description Preview</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th class="pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="bi bi-file-text fs-1 d-block mb-2"></i>No Terms &amp; Condition templates found
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            // Strip HTML tags for preview
                            var plainDescription = string.IsNullOrWhiteSpace(item.Description)
                                ? "-"
                                : System.Text.RegularExpressions.Regex.Replace(item.Description, "<.*?>", " ").Trim();
                            var preview = plainDescription.Length > 80 ? plainDescription[..80] + "…" : plainDescription;

                            <tr>
                                <td class="ps-3" style="color:#94a3b8;font-size:.8rem;">@item.Id</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div style="width:32px;height:32px;background:#e0f2fe;border-radius:8px;display:flex;align-items:center;justify-content:center;color:#0369a1;font-size:.9rem;">
                                            <i class="bi bi-file-text"></i>
                                        </div>
                                        <span class="fw-semibold" style="font-size:.875rem;">@item.TermsName</span>
                                    </div>
                                </td>
                                <td class="text-muted" style="font-size:.82rem;max-width:320px;">@preview</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge badge-ok rounded-pill px-2 py-1" style="font-size:.73rem;">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-neu rounded-pill px-2 py-1" style="font-size:.73rem;">Inactive</span>
                                    }
                                </td>
                                <td style="font-size:.82rem;">@item.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td class="pe-3">
                                    <div class="d-flex gap-1">
                                        <a asp-action="Edit" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-secondary" title="Edit"
                                           style="border-radius:7px;border-color:#e2e8f0;">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="Delete" method="post"
                                              data-swal-confirm="true"
                                              data-swal-title="Delete Template?"
                                              data-swal-text="Template &lt;strong&gt;@item.TermsName&lt;/strong&gt; will be permanently deleted."
                                              data-swal-confirm-button="Yes, delete template">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete" style="border-radius:7px;">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
