@model CentralLicenceApp.Models.ViewModels.TicketPriorityFormViewModel
@{
    ViewData["Title"] = "New Ticket Priority";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary" style="border-radius:8px;"><i class="bi bi-arrow-left"></i></a>
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;">New Ticket Priority</h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">Create a ticket priority level</p>
    </div>
</div>

<div class="card" style="max-width:560px;">
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 px-3 rounded-3 mb-3" style="font-size:.83rem;"></div>

            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="PriorityName" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="PriorityName" class="form-control" style="border-radius:10px;" />
                    <span asp-validation-for="PriorityName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ColorCode" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="ColorCode" type="color" class="form-control form-control-color" style="border-radius:10px;width:60px;height:40px;" />
                </div>
                <div class="col-md-6">
                    <label asp-for="SortOrder" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="SortOrder" type="number" class="form-control" style="border-radius:10px;" />
                </div>
                <div class="col-md-6">
                    <label asp-for="SlaResponseHours" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="SlaResponseHours" type="number" class="form-control" style="border-radius:10px;" placeholder="Hours" />
                </div>
                <div class="col-md-6">
                    <label asp-for="SlaResolutionHours" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="SlaResolutionHours" type="number" class="form-control" style="border-radius:10px;" placeholder="Hours" />
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label fw-semibold" style="font-size:.85rem;"></label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn text-white px-4" style="background:#180a3c;border:none;border-radius:10px;">
                    <i class="bi bi-check2-circle me-1"></i> Save Priority
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius:10px;">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
