@model LoginViewModel
@using CentralLicenceApp.Repositories
@inject ICompanySettingsRepository CompanySettingsRepo
@{
    Layout = null;
    var parentCompany = await CompanySettingsRepo.GetParentCompanyAsync();
    var brandName = string.IsNullOrWhiteSpace(parentCompany?.CompanyName) ? "Emeditech Plus LLP" : parentCompany.CompanyName.Trim();
    var hasBrandLogo = !string.IsNullOrWhiteSpace(parentCompany?.CompanyLogoPath);
    var brandLogoUrl = hasBrandLogo ? Url.Content(parentCompany!.CompanyLogoPath!) : "https://emeditechplus.com/img/emeditechplus-logo.png";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In – @brandName</title>
    <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate, max-age=0" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        body {
            margin: 0;
            min-height: 100vh;
            display: flex;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: #f0f4ff;
        }
        /* Left panel */
        .lp-left {
            flex: 1;
            background: linear-gradient(160deg, #0d0626 0%, #180a3c 55%, #230e52 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 3rem 2.5rem;
            color: #fff;
            position: relative;
            overflow: hidden;
        }
        .lp-left::before {
            content: '';
            position: absolute;
            width: 420px; height: 420px;
            border-radius: 50%;
            background: rgba(167,139,250,.12);
            top: -80px; right: -80px;
        }
        .lp-left::after {
            content: '';
            position: absolute;
            width: 300px; height: 300px;
            border-radius: 50%;
            background: rgba(167,139,250,.08);
            bottom: -60px; left: -60px;
        }
        .lp-logo-wrap { margin-bottom: 2rem; position: relative; z-index: 1; }
        .lp-logo-wrap img {
            max-width: 180px;
            max-height: 78px;
            object-fit: contain;
            border-radius: 16px;
        }
        .lp-logo-custom {
            background: rgba(255,255,255,.96);
            padding: .55rem .8rem;
            box-shadow: 0 10px 30px rgba(15, 23, 42, .18);
        }
        .lp-logo-default { filter: brightness(0) invert(1); }
        .lp-company { font-size: 1.6rem; font-weight: 800; letter-spacing: .03em; position: relative; z-index: 1; text-align: center; }
        .lp-tagline { font-size: .88rem; color: #c9b8f0; margin-top: .5rem; position: relative; z-index: 1; text-align: center; }
        .lp-divider { width: 48px; height: 3px; background: #a78bfa; border-radius: 99px; margin: 1.5rem auto; position: relative; z-index: 1; }
        .lp-features { list-style: none; padding: 0; margin: 0; position: relative; z-index: 1; }
        .lp-features li { font-size: .82rem; color: #e2d9f8; margin-bottom: .6rem; display: flex; align-items: center; gap: .6rem; }
        .lp-features li i { color: #c4aff7; font-size: 1rem; }
        /* Right panel */
        .lp-right {
            width: 100%;
            max-width: 480px;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2.5rem 2rem;
            background: #fff;
        }
        .login-box { width: 100%; max-width: 380px; }
        .login-box .app-title { font-size: 1.35rem; font-weight: 800; color: #0f172a; margin-bottom: .25rem; }
        .login-box .app-sub { font-size: .83rem; color: #64748b; margin-bottom: 2rem; }
        .form-label { font-size: .78rem; font-weight: 600; color: #475569; margin-bottom: .3rem; letter-spacing: .02em; text-transform: uppercase; }
        .form-control {
            border: 1.5px solid #e2e8f0;
            border-radius: 10px;
            padding: .65rem .9rem .65rem 2.5rem;
            font-size: .9rem;
            transition: border-color .2s, box-shadow .2s;
        }
        .form-control:focus { border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,.12); outline: none; }
        .input-wrap { position: relative; }
        .input-wrap .fi {
            position: absolute; left: .85rem; top: 50%; transform: translateY(-50%);
            color: #94a3b8; font-size: .95rem; pointer-events: none;
        }
        .btn-signin {
            width: 100%;
            background: linear-gradient(135deg, #6366f1, #4f46e5);
            color: #fff;
            border: none;
            border-radius: 10px;
            padding: .72rem;
            font-weight: 700;
            font-size: .95rem;
            letter-spacing: .01em;
            transition: opacity .2s, transform .1s;
            box-shadow: 0 4px 14px rgba(99,102,241,.35);
        }
        .btn-signin:hover { opacity: .92; transform: translateY(-1px); color: #fff; }
        .btn-signin:active { transform: translateY(0); }
        .role-choice-card {
            border: 1px solid #dbe4f0;
            border-radius: 14px;
            padding: 1rem;
            display: block;
            cursor: pointer;
            transition: border-color .2s ease, box-shadow .2s ease, transform .2s ease;
        }
        .role-choice-card:hover {
            border-color: #6366f1;
            box-shadow: 0 12px 25px rgba(79, 70, 229, .1);
            transform: translateY(-1px);
        }
        .role-choice-input {
            accent-color: #4f46e5;
            width: 1rem;
            height: 1rem;
        }
        .role-choice-title {
            font-weight: 700;
            color: #0f172a;
        }
        .role-choice-sub {
            color: #64748b;
            font-size: .82rem;
        }
        .footer-copy { font-size: .73rem; color: #94a3b8; text-align: center; margin-top: 2rem; }
        @@media (max-width: 768px) {
            body { flex-direction: column; }
            .lp-left { padding: 2rem 1.5rem; }
            .lp-right { max-width: 100%; }
        }
    </style>
</head>
<body>
<!-- Left branding panel -->
<div class="lp-left d-none d-md-flex">
    <div class="lp-logo-wrap">
        <img src="@brandLogoUrl" alt="@brandName" class="@(hasBrandLogo ? "lp-logo-custom" : "lp-logo-default")" />
    </div>
    <div class="lp-company">@brandName.ToUpperInvariant()</div>
    <div class="lp-tagline">Innovative Healthcare Technology Solutions</div>
    <div class="lp-divider"></div>
    <ul class="lp-features">
        <li><i class="bi bi-shield-check"></i> Secure licence management</li>
        <li><i class="bi bi-graph-up"></i> Real-time validation tracking</li>
        <li><i class="bi bi-people"></i> Role-based access control</li>
        <li><i class="bi bi-hdd-network"></i> Multi-client support</li>
    </ul>
</div>
<!-- Right login panel -->
<div class="lp-right">
    <div class="login-box">
        <div class="d-md-none text-center mb-4" style="display:none!important;">
            <img src="@brandLogoUrl" alt="@brandName" style="max-width:140px;max-height:60px;object-fit:contain;@(hasBrandLogo ? "background:#fff;padding:.35rem .5rem;border-radius:12px;box-shadow:0 10px 25px rgba(15,23,42,.08);" : string.Empty)" />
            <div style="font-size:1rem;font-weight:800;color:#0f172a;margin-top:.5rem;">@brandName.ToUpperInvariant()</div>
        </div>
        <div class="text-center mb-4">
            <img src="@brandLogoUrl" alt="@brandName" style="max-width:160px;max-height:68px;object-fit:contain;@(hasBrandLogo ? "background:#fff;padding:.35rem .6rem;border-radius:14px;box-shadow:0 12px 30px rgba(15,23,42,.08);" : string.Empty)" />
        </div>
        <div class="app-title">@brandName</div>
        <div class="app-sub">Sign in to your account to continue</div>

        <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@(ViewData["ReturnUrl"] as string)" method="post" autocomplete="off">
            @Html.AntiForgeryToken()
            @if (TempData["Error"] is string errorMessage)
            {
                <div class="alert alert-danger py-2 px-3 rounded-3 mb-3" style="font-size:.82rem;">@errorMessage</div>
            }
            @if (TempData["Success"] is string successMessage)
            {
                <div class="alert alert-success py-2 px-3 rounded-3 mb-3" style="font-size:.82rem;">@successMessage</div>
            }
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="alert alert-danger py-2 px-3 rounded-3 mb-3" style="font-size:.82rem;"></div>
            }

            <div class="mb-3">
                <label class="form-label">Username</label>
                <div class="input-wrap">
                    <i class="fi bi bi-person"></i>
                    <input asp-for="Username" class="form-control" placeholder="Enter your username" autocomplete="off" autocapitalize="none" spellcheck="false" />
                </div>
                <span asp-validation-for="Username" class="text-danger" style="font-size:.77rem;"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Password</label>
                <div class="input-wrap">
                    <i class="fi bi bi-lock"></i>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Enter your password" autocomplete="off" />
                </div>
                <span asp-validation-for="Password" class="text-danger" style="font-size:.77rem;"></span>
            </div>

            <div class="form-check mb-4">
                <input asp-for="RememberMe" class="form-check-input" type="checkbox" id="rememberMe" />
                <label class="form-check-label" for="rememberMe" style="font-size:.83rem;color:#475569;">Keep me signed in</label>
            </div>

            <button type="submit" class="btn btn-signin">
                <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
            </button>
        </form>

        <div class="footer-copy">&copy; @DateTime.Now.Year @brandName. All rights reserved.</div>
    </div>
</div>

@if (Model?.ShowRoleSelectionPopup == true)
{
    <div class="modal fade" id="roleSelectionModal" tabindex="-1" aria-labelledby="roleSelectionModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius:20px;overflow:hidden;">
                <div class="modal-header" style="background:#eef2ff;border-bottom:1px solid #dbe4f0;">
                    <div>
                        <h5 class="modal-title fw-bold" id="roleSelectionModalLabel">Choose your role</h5>
                        <div class="text-muted" style="font-size:.82rem;">This account has multiple roles. Select the role for this session.</div>
                    </div>
                </div>
                <form asp-controller="Account" asp-action="SelectRole" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-body">
                        <input type="hidden" name="pendingSelectionToken" value="@Model.PendingSelectionToken" />
                        <div class="d-grid gap-2">
                            @for (var i = 0; i < Model.AvailableRoles.Count; i++)
                            {
                                var role = Model.AvailableRoles[i];
                                <label class="role-choice-card">
                                    <div class="d-flex align-items-start gap-3">
                                        <input class="role-choice-input mt-1" type="radio" name="selectedRoleId" value="@role.Id" checked="@(i == 0)" required />
                                        <div>
                                            <div class="role-choice-title">@role.RoleName</div>
                                            <div class="role-choice-sub">@(string.IsNullOrWhiteSpace(role.Description) ? "Use this role for the current login session." : role.Description)</div>
                                        </div>
                                    </div>
                                </label>
                            }
                        </div>
                    </div>
                    <div class="modal-footer border-0 pt-0 px-4 pb-4">
                        <button type="submit" class="btn btn-signin">Continue</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.21.0/dist/jquery.validate.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var roleModalEl = document.getElementById('roleSelectionModal');
        if (!roleModalEl) {
            return;
        }

        var roleModal = new bootstrap.Modal(roleModalEl, {
            backdrop: 'static',
            keyboard: false
        });
        roleModal.show();
    });
</script>
</body>
</html>
