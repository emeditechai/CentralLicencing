@using CentralLicenceApp.Repositories
@inject ICompanySettingsRepository CompanySettingsRepo
@{
    Layout = null;
    var parentCompany = await CompanySettingsRepo.GetParentCompanyAsync();
    var brandName = string.IsNullOrWhiteSpace(parentCompany?.CompanyName) ? "Emeditech Plus LLP" : parentCompany.CompanyName.Trim();
    var hasBrandLogo = !string.IsNullOrWhiteSpace(parentCompany?.CompanyLogoPath);
    var brandLogoUrl = hasBrandLogo ? Url.Content(parentCompany!.CompanyLogoPath!) : "https://emeditechplus.com/img/emeditechplus-logo.png";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Check Your Email – @brandName</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        body { margin:0; min-height:100vh; display:flex; font-family:'Segoe UI',system-ui,-apple-system,sans-serif; background:#f0f4ff; }
        .lp-left { flex:1; background:linear-gradient(160deg,#0d0626 0%,#180a3c 55%,#230e52 100%); display:flex; flex-direction:column; align-items:center; justify-content:center; padding:3rem 2.5rem; color:#fff; position:relative; overflow:hidden; }
        .lp-left::before { content:''; position:absolute; width:420px; height:420px; border-radius:50%; background:rgba(167,139,250,.12); top:-80px; right:-80px; }
        .lp-left::after { content:''; position:absolute; width:300px; height:300px; border-radius:50%; background:rgba(167,139,250,.08); bottom:-60px; left:-60px; }
        .lp-logo-wrap { margin-bottom:2rem; position:relative; z-index:1; }
        .lp-logo-wrap img { max-width:180px; max-height:78px; object-fit:contain; border-radius:16px; }
        .lp-logo-custom { background:rgba(255,255,255,.96); padding:.55rem .8rem; box-shadow:0 10px 30px rgba(15,23,42,.18); }
        .lp-logo-default { filter:brightness(0) invert(1); }
        .lp-company { font-size:1.6rem; font-weight:800; letter-spacing:.03em; position:relative; z-index:1; text-align:center; }
        .lp-tagline { font-size:.88rem; color:#c9b8f0; margin-top:.5rem; position:relative; z-index:1; text-align:center; }
        .lp-divider { width:48px; height:3px; background:#a78bfa; border-radius:99px; margin:1.5rem auto; position:relative; z-index:1; }
        .lp-features { list-style:none; padding:0; margin:0; position:relative; z-index:1; }
        .lp-features li { font-size:.82rem; color:#e2d9f8; margin-bottom:.6rem; display:flex; align-items:center; gap:.6rem; }
        .lp-features li i { color:#c4aff7; font-size:1rem; }
        .lp-right { width:100%; max-width:480px; display:flex; align-items:center; justify-content:center; padding:2.5rem 2rem; background:#fff; }
        .login-box { width:100%; max-width:380px; }
        .footer-copy { font-size:.73rem; color:#94a3b8; text-align:center; margin-top:2rem; }
        .success-icon { width:72px; height:72px; background:linear-gradient(135deg,#22c55e,#16a34a); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 1.5rem; box-shadow:0 8px 24px rgba(22,163,74,.25); }
        .success-icon i { font-size:2rem; color:#fff; }
        @@media (max-width:768px) { body{flex-direction:column;} .lp-left{padding:2rem 1.5rem;} .lp-right{max-width:100%;} }
    </style>
</head>
<body>
<div class="lp-left d-none d-md-flex">
    <div class="lp-logo-wrap">
        <img src="@brandLogoUrl" alt="@brandName" class="@(hasBrandLogo ? "lp-logo-custom" : "lp-logo-default")" />
    </div>
    <div class="lp-company">@brandName.ToUpperInvariant()</div>
    <div class="lp-tagline">Innovative Healthcare Technology Solutions</div>
    <div class="lp-divider"></div>
    <ul class="lp-features">
        <li><i class="bi bi-shield-check"></i> Secure licence management</li>
        <li><i class="bi bi-graph-up"></i> Real-time validation tracking</li>
        <li><i class="bi bi-people"></i> Role-based access control</li>
        <li><i class="bi bi-hdd-network"></i> Multi-client support</li>
    </ul>
</div>
<div class="lp-right">
    <div class="login-box text-center">
        <div class="success-icon">
            <i class="bi bi-envelope-check"></i>
        </div>
        <h4 style="font-weight:800;color:#0f172a;margin-bottom:.5rem;">Check Your Email</h4>
        <p style="font-size:.88rem;color:#64748b;margin-bottom:2rem;">
            If an account exists with the email you provided, we've sent a password reset link.
            Please check your inbox and follow the instructions.
        </p>
        <a href="@Url.Action("Login", "Account")" class="btn" style="background:linear-gradient(135deg,#6366f1,#4f46e5);color:#fff;border-radius:10px;padding:.65rem 2rem;font-weight:700;font-size:.9rem;box-shadow:0 4px 14px rgba(99,102,241,.35);">
            <i class="bi bi-arrow-left me-2"></i>Back to Sign In
        </a>
        <div class="footer-copy">&copy; @DateTime.Now.Year @brandName. All rights reserved.</div>
    </div>
</div>
</body>
</html>
