@model CentralLicenceApp.Models.ViewModels.SalesCommDetailReportViewModel
@{
    ViewData["Title"] = "Sales Commission Detail Report";
}

<style>
    .rpd-hero { background:linear-gradient(135deg,#667eea 0%,#764ba2 100%); border-radius:20px; padding:2rem 2.25rem; margin-bottom:1.75rem; position:relative; overflow:hidden; }
    .rpd-hero::before { content:''; position:absolute; top:-50%; right:-8%; width:320px; height:320px; background:rgba(255,255,255,.06); border-radius:50%; pointer-events:none; }
    .rpd-hero h4 { color:#fff; font-weight:800; font-size:1.4rem; margin-bottom:.15rem; }
    .rpd-hero .rpd-sub { color:rgba(255,255,255,.8); font-size:.85rem; }

    .rpd-stat { background:rgba(255,255,255,.18); backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,.2); border-radius:14px; padding:.7rem 1.1rem; min-width:110px; text-align:center; }
    .rpd-stat-num { font-size:1.4rem; font-weight:800; color:#fff; line-height:1.2; }
    .rpd-stat-lbl { font-size:.68rem; text-transform:uppercase; letter-spacing:.06em; font-weight:600; color:rgba(255,255,255,.7); }

    .rpd-filter { background:linear-gradient(145deg,#faf8ff,#f3f0ff); border:1px solid #e9e4f5; border-radius:14px; padding:1rem 1.5rem; margin-bottom:1.25rem; }
    .rpd-card { background:#fff; border-radius:14px; box-shadow:0 2px 12px rgba(0,0,0,.05); border:1px solid #f1f5f9; overflow:hidden; }
    .rpd-table { margin-bottom:0; }
    .rpd-table thead { background:linear-gradient(180deg,#f8fafc,#f1f5f9); }
    .rpd-table thead th { font-size:.68rem; font-weight:700; color:#475569; text-transform:uppercase; letter-spacing:.08em; padding:.7rem .8rem; border-bottom:2px solid #e2e8f0; white-space:nowrap; }
    .rpd-table tbody tr { transition:all .15s; border-bottom:1px solid #f8fafc; }
    .rpd-table tbody tr:hover { background:linear-gradient(90deg,#f5f3ff,#eff6ff); }
    .rpd-table td { vertical-align:middle; padding:.6rem .8rem; font-size:.8rem; color:#334155; }
</style>

<!-- Hero -->
<div class="rpd-hero">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
            <h4><i class="bi bi-list-columns-reverse me-2"></i>Sales Commission Detail</h4>
            <div class="rpd-sub">Payment-level breakdown of all commission batches</div>
        </div>
        <div class="d-flex gap-3 flex-wrap">
            <div class="rpd-stat">
                <div class="rpd-stat-num">@Model.Items.Count</div>
                <div class="rpd-stat-lbl">Line Items</div>
            </div>
            <div class="rpd-stat">
                <div class="rpd-stat-num">₹@Model.GrandTotalCommission.ToString("N0")</div>
                <div class="rpd-stat-lbl">Total Commission</div>
            </div>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="rpd-filter">
    <form method="get" class="row g-2 align-items-end">
        @if (Model.IsAdminView)
        {
        <div class="col-md-3">
            <label class="form-label fw-semibold" style="font-size:.78rem;">Sales User</label>
            <select name="userId" class="form-select form-select-sm" style="border-radius:10px;">
                <option value="">All Users</option>
                @foreach (var u in Model.Users)
                {
                    <option value="@u.Id" selected="@(Model.UserFilter == u.Id)">@u.FullName</option>
                }
            </select>
        </div>
        }
        <div class="col-md-2">
            <label class="form-label fw-semibold" style="font-size:.78rem;">Batch #</label>
            <input type="number" name="batchId" class="form-control form-control-sm" style="border-radius:10px;"
                   value="@Model.BatchIdFilter" placeholder="Optional" />
        </div>
        <div class="col-md-2">
            <label class="form-label fw-semibold" style="font-size:.78rem;">From Date</label>
            <input type="date" name="from" class="form-control form-control-sm" style="border-radius:10px;" value="@Model.FromDate?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-md-2">
            <label class="form-label fw-semibold" style="font-size:.78rem;">To Date</label>
            <input type="date" name="to" class="form-control form-control-sm" style="border-radius:10px;" value="@Model.ToDate?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-sm btn-primary" style="border-radius:10px;"><i class="bi bi-funnel me-1"></i> Filter</button>
            <a asp-action="Detail" class="btn btn-sm btn-outline-secondary" style="border-radius:10px;"><i class="bi bi-x-lg"></i></a>
        </div>
    </form>
</div>

<!-- Table -->
<div class="rpd-card">
    <div class="table-responsive">
        <table class="table rpd-table">
            <thead>
                <tr>
                    <th>Batch</th>
                    <th>Sales User</th>
                    <th>Period</th>
                    <th>Invoice</th>
                    <th>Party</th>
                    <th>Payment Date</th>
                    <th>Payment (₹)</th>
                    <th>Product</th>
                    <th>Type</th>
                    <th>Rate</th>
                    <th>Source</th>
                    <th>Commission (₹)</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr><td colspan="12" class="text-center text-muted py-4"><i class="bi bi-inbox me-1"></i> No data found.</td></tr>
                }
                @foreach (var r in Model.Items)
                {
                    <tr>
                        <td><a asp-controller="SalesCommissionBatch" asp-action="Details" asp-route-id="@r.BatchId" class="text-primary fw-semibold">#@r.BatchId</a></td>
                        <td class="fw-semibold" style="font-size:.78rem;">@r.UserName</td>
                        <td style="font-size:.76rem;">@r.BatchPeriod</td>
                        <td class="fw-semibold">@r.InvoiceNo</td>
                        <td style="max-width:160px;">
                            <div class="text-truncate" title="@r.PartyName">@r.PartyName</div>
                        </td>
                        <td style="font-size:.76rem;">@r.PaymentDate.ToString("dd MMM yyyy")</td>
                        <td class="fw-semibold">₹@r.PaymentAmount.ToString("N2")</td>
                        <td>@(r.ProductName ?? "—")</td>
                        <td>
                            <span class="badge" style="font-size:.65rem; background:@(r.CommissionType == "Percentage" ? "#7c3aed" : "#0891b2") !important;">
                                @r.CommissionType
                            </span>
                        </td>
                        <td class="fw-semibold">
                            @if (r.CommissionType == "Percentage")
                            {
                                @($"{r.RateApplied:N2}%")
                            }
                            else
                            {
                                @($"₹{r.RateApplied:N2}")
                            }
                        </td>
                        <td>
                            @{
                                var srcClass = r.RateSource switch
                                {
                                    "ProductRule" => "bg-primary",
                                    "DefaultConfig" => "bg-success",
                                    _ => "bg-secondary"
                                };
                            }
                            <span class="badge @srcClass" style="font-size:.65rem;">@r.RateSource</span>
                        </td>
                        <td class="fw-bold">₹@r.CommissionAmount.ToString("N2")</td>
                    </tr>
                }
            </tbody>
            @if (Model.Items.Any())
            {
                <tfoot style="background:#ecfeff;">
                    <tr>
                        <td colspan="6" class="fw-bold text-end">Grand Total</td>
                        <td class="fw-bold">₹@Model.GrandTotalPayment.ToString("N2")</td>
                        <td colspan="4"></td>
                        <td class="fw-bold text-primary">₹@Model.GrandTotalCommission.ToString("N2")</td>
                    </tr>
                </tfoot>
            }
        </table>
    </div>
</div>
