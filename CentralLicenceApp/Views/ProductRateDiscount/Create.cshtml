@model CentralLicenceApp.Models.ViewModels.ProductRateDiscountFormViewModel
@{
    ViewData["Title"] = "New Discount Offer";
    var productRates = ViewBag.ProductRates as List<CentralLicenceApp.Models.ProductRate> ?? new List<CentralLicenceApp.Models.ProductRate>();
    var discountTypes = ViewBag.DiscountTypes as string[] ?? System.Array.Empty<string>();
}

<div class="catalog-form-shell catalog-discount">
    <div class="catalog-form-hero">
        <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap position-relative" style="z-index:1;">
            <div class="d-flex align-items-start gap-3">
                <a asp-action="Index" asp-route-productRateId="@Model.ProductRateId" class="catalog-form-back"><i class="bi bi-arrow-left"></i></a>
                <div>
                    <div class="catalog-form-eyebrow mb-2">Offer Campaign</div>
                    <h3 class="fw-bold mb-1" style="color:#1e293b;">New Discount Offer</h3>
                    <p class="catalog-form-subtitle">Create a promotional discount with a cleaner campaign setup for pricing model, value, validity, and promo metadata.</p>
                </div>
            </div>
            <div class="catalog-form-mini-stat">
                <div class="catalog-form-mini-label">Campaign Type</div>
                <div class="catalog-form-mini-value" style="color:#c2410c;">Promotion</div>
            </div>
        </div>
    </div>

    <div class="catalog-form-card">
        <div class="catalog-form-surface">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 px-3 rounded-3 mb-3" style="font-size:.83rem;"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="ProductRateId" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <select asp-for="ProductRateId" class="form-select catalog-select">
                        <option value="0">Select Pricing Model</option>
                        @foreach (var item in productRates)
                        {
                            <option value="@item.Id">@item.ProductName - @item.PricingModel</option>
                        }
                    </select>
                    <span asp-validation-for="ProductRateId" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="DiscountName" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="DiscountName" class="form-control catalog-input" />
                    <span asp-validation-for="DiscountName" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="DiscountType" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <select asp-for="DiscountType" class="form-select catalog-select">
                        <option value="">Select Discount Model</option>
                        @foreach (var item in discountTypes)
                        {
                            <option value="@item">@item</option>
                        }
                    </select>
                    <span asp-validation-for="DiscountType" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="DiscountValue" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="DiscountValue" class="form-control catalog-input" type="number" step="0.01" min="0.01" />
                    <span asp-validation-for="DiscountValue" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="PromoCode" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="PromoCode" class="form-control catalog-input" />
                    <span asp-validation-for="PromoCode" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ValidFrom" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="ValidFrom" class="form-control catalog-input" type="date" />
                    <span asp-validation-for="ValidFrom" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ValidTo" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="ValidTo" class="form-control catalog-input" type="date" />
                    <span asp-validation-for="ValidTo" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Description" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <textarea asp-for="Description" class="form-control catalog-textarea" rows="3" placeholder="Describe the promotion, eligibility, or campaign note"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <div class="catalog-toggle">
                        <div class="form-check mb-0">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                            <label asp-for="IsActive" class="form-check-label fw-semibold" style="font-size:.85rem;"></label>
                            <div class="catalog-help">Inactive offers remain stored but will not count as valid promotions.</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn catalog-submit px-4">
                    <i class="bi bi-check2-circle me-1"></i> Save Discount Offer
                </button>
                <a asp-action="Index" asp-route-productRateId="@Model.ProductRateId" class="btn catalog-cancel">Cancel</a>
            </div>
        </form>
    </div>
</div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}