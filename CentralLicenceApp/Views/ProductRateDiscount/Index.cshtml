@model CentralLicenceApp.Models.ViewModels.ProductRateDiscountIndexViewModel
@{
    ViewData["Title"] = "Pricing Model Discounts";
    var activeOffers = Model.Items.Count(x => x.IsActive && x.ValidFrom.Date <= DateTime.Today && x.ValidTo.Date >= DateTime.Today);
    var scheduledOffers = Model.Items.Count(x => x.IsActive && x.ValidFrom.Date > DateTime.Today);
    var expiredOffers = Model.Items.Count(x => x.IsActive && x.ValidTo.Date < DateTime.Today);
}

<div class="discount-shell">
    <div class="hero-panel mb-4">
        <div class="d-flex align-items-start justify-content-between mb-4 gap-3 flex-wrap position-relative" style="z-index:1;">
            <div>
                <div class="section-label mb-2">Promotional Offers</div>
                <h3 class="fw-bold mb-1" style="color:#1e293b;">Pricing Model Discounts</h3>
                <p class="mb-0" style="font-size:.9rem;color:#54657e;max-width:620px;">
                    @if (Model.SelectedProductRate != null)
                    {
                        <span>Showing promotion discounts for <strong style="color:#4338ca;">@Model.SelectedProductRate.PricingModel</strong> with the <strong style="color:#0f766e;">@Model.SelectedProductRate.BillingSummary</strong> commercial setup.</span>
                    }
                    else
                    {
                        <span>@Model.Items.Count discount offer(s) across pricing models@(Model.TodayOnly ? " valid today" : string.Empty) with a cleaner campaign overview.</span>
                    }
                </p>
            </div>
            <a asp-action="Create" asp-route-productRateId="@Model.SelectedProductRateId" class="btn btn-primary align-self-start" style="background:#180a3c;border:none;border-radius:14px;padding:.8rem 1.1rem;box-shadow:0 10px 24px rgba(24,10,60,.18);">
                <i class="bi bi-plus-lg me-1"></i> New Discount Offer
            </a>
        </div>
        <div class="d-flex gap-3 flex-wrap position-relative" style="z-index:1;">
            <div class="hero-stat">
                <div class="section-label">Offers</div>
                <div class="hero-stat-value">@Model.Items.Count</div>
            </div>
            <div class="hero-stat">
                <div class="section-label">Active Today</div>
                <div class="hero-stat-value" style="color:#059669;">@activeOffers</div>
            </div>
            <div class="hero-stat">
                <div class="section-label">Scheduled</div>
                <div class="hero-stat-value" style="color:#2563eb;">@scheduledOffers</div>
            </div>
            <div class="hero-stat">
                <div class="section-label">Expired</div>
                <div class="hero-stat-value" style="color:#dc2626;">@expiredOffers</div>
            </div>
        </div>
    </div>

<div class="soft-card mb-4">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label mb-1" style="font-size:.78rem;font-weight:600;color:#64748b;">Pricing Model</label>
                <select name="productRateId" class="form-select" style="border-radius:10px;" onchange="this.form.submit()">
                    <option value="">All Pricing Models</option>
                    @foreach (var item in Model.ProductRates)
                    {
                        <option value="@item.Id" selected="@(Model.SelectedProductRateId == item.Id)">@item.ProductName - @item.PricingModel - @item.BillingSummary</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <div class="form-check form-switch pt-2 ps-4">
                    <input class="form-check-input" type="checkbox" id="todayOnly" name="todayOnly" value="true" @(Model.TodayOnly ? "checked" : null)>
                    <label class="form-check-label fw-semibold" for="todayOnly" style="font-size:.82rem;color:#475569;">Today only</label>
                    <div class="text-muted" style="font-size:.72rem;">Show only offers valid today</div>
                </div>
            </div>
            <div class="col-md-auto">
                <button type="submit" class="btn btn-primary" style="background:#6366f1;border:none;border-radius:10px;"><i class="bi bi-funnel me-1"></i> Filter</button>
                <a asp-action="Index" class="btn ms-1" style="border-radius:10px;border:1px solid #cfd9e6;color:#475569;background:#fff;">Clear</a>
            </div>
        </form>
    </div>
</div>

@if (Model.SelectedProductRate != null)
{
    <div class="soft-card mb-4" style="background:linear-gradient(135deg,#ffffff 0%,#fffaf5 100%);">
        <div class="card-body d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div>
                <div class="fw-semibold" style="font-size:1rem;color:#1e293b;">@Model.SelectedProductRate.ProductName</div>
                <div style="font-size:.82rem;color:#6366f1;">@Model.SelectedProductRate.ProductCode • @Model.SelectedProductRate.ProductType • @Model.SelectedProductRate.PricingModel • @Model.SelectedProductRate.BillingSummary</div>
                <div class="text-muted" style="font-size:.78rem;">Base Rate: ₹@Model.SelectedProductRate.Rate.ToString("0.00")</div>
            </div>
            <a asp-controller="ProductRate" asp-action="Index" asp-route-productId="@Model.SelectedProductRate.ProductId" class="btn btn-sm" style="border-radius:10px;background:#fff;color:#475569;border:1px solid #dbe4f0;">
                <i class="bi bi-arrow-left me-1"></i> Back To Rate List
            </a>
        </div>
    </div>
}

<div class="soft-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table tbl-clean mb-0">
                <thead>
                    <tr>
                        <th class="ps-3">#</th>
                        <th>Offer</th>
                        <th>Discount Model</th>
                        <th>Promo Code</th>
                        <th>Validity</th>
                        <th>Status</th>
                        <th class="pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Items.Any())
                    {
                        <tr><td colspan="7" class="text-center py-5 text-muted"><i class="bi bi-inbox fs-1 d-block mb-2"></i>No discount offers found</td></tr>
                    }
                    else
                    {
                        foreach (var item in Model.Items)
                        {
                            var now = DateTime.Today;
                            var isCurrentlyValid = item.IsActive && item.ValidFrom.Date <= now && item.ValidTo.Date >= now;
                            var isExpired = item.IsActive && item.ValidTo.Date < now;
                            var expiresToday = item.IsActive && item.ValidTo.Date == now;
                            var expiresSoon = item.IsActive && item.ValidTo.Date > now && item.ValidTo.Date <= now.AddDays(3);
                            var isScheduled = item.IsActive && item.ValidFrom.Date > now;
                            var rowStyle = isExpired
                                ? "background:#fff6f7;"
                                : expiresToday
                                    ? "background:#fffdf2;"
                                    : expiresSoon
                                        ? "background:#fff8f1;"
                                        : isScheduled
                                            ? "background:#f4f8ff;"
                                            : string.Empty;
                            <tr style="@rowStyle">
                                <td class="ps-3" style="color:#94a3b8;font-size:.8rem;">@item.Id</td>
                                <td style="min-width:220px;">
                                    <div class="offer-block">
                                        <div class="fw-semibold" style="font-size:.86rem;">@item.DiscountName</div>
                                        <div style="font-size:.75rem;color:#6366f1;">@item.ProductName • @item.PricingModel • @item.BillingSummary</div>
                                        <div class="text-muted" style="font-size:.75rem;white-space:normal;word-break:break-word;">@(string.IsNullOrWhiteSpace(item.Description) ? "No description" : item.Description)</div>
                                    </div>
                                </td>
                                <td style="font-size:.82rem;white-space:nowrap;">
                                    <span class="badge rounded-pill px-2 py-1" style="background:#f3e8ff;color:#6d28d9;border:1px solid #ddd6fe;">@item.DiscountType</span>
                                    <div class="fw-semibold mt-1">@(item.DiscountType == "Percentage" ? item.DiscountValue.ToString("0.##") + "%" : "₹" + item.DiscountValue.ToString("0.00"))</div>
                                </td>
                                <td style="font-size:.8rem;white-space:nowrap;">@(string.IsNullOrWhiteSpace(item.PromoCode) ? "-" : item.PromoCode)</td>
                                <td style="font-size:.8rem;white-space:nowrap;">
                                    <div>@item.ValidFrom.ToString("dd MMM yyyy")</div>
                                    <div class="text-muted">to @item.ValidTo.ToString("dd MMM yyyy")</div>
                                    @if (expiresToday)
                                    {
                                        <div style="font-size:.72rem;color:#b45309;">Expires today</div>
                                    }
                                    else if (expiresSoon)
                                    {
                                        <div style="font-size:.72rem;color:#c2410c;">Expires within 3 days</div>
                                    }
                                    else if (isExpired)
                                    {
                                        <div style="font-size:.72rem;color:#be123c;">Expired</div>
                                    }
                                    else if (isScheduled)
                                    {
                                        <div style="font-size:.72rem;color:#2563eb;">Upcoming offer</div>
                                    }
                                </td>
                                <td>
                                    @if (isCurrentlyValid)
                                    {
                                        <span class="badge rounded-pill px-2 py-1" style="font-size:.73rem;background:#dcfce7;color:#166534;border:1px solid #bbf7d0;">Active</span>
                                    }
                                    else if (expiresToday)
                                    {
                                        <span class="badge rounded-pill px-2 py-1" style="font-size:.73rem;background:#fef3c7;color:#92400e;">Expires Today</span>
                                    }
                                    else if (expiresSoon)
                                    {
                                        <span class="badge rounded-pill px-2 py-1" style="font-size:.73rem;background:#fed7aa;color:#9a3412;">Expiring Soon</span>
                                    }
                                    else if (isExpired)
                                    {
                                        <span class="badge rounded-pill px-2 py-1" style="font-size:.73rem;background:#ffe4e6;color:#be123c;">Expired</span>
                                    }
                                    else if (isScheduled)
                                    {
                                        <span class="badge rounded-pill px-2 py-1" style="font-size:.73rem;background:#dbeafe;color:#1d4ed8;">Scheduled</span>
                                    }
                                    else if (item.IsActive)
                                    {
                                        <span class="badge badge-neu rounded-pill px-2 py-1" style="font-size:.73rem;">Scheduled/Expired</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-neu rounded-pill px-2 py-1" style="font-size:.73rem;">Inactive</span>
                                    }
                                </td>
                                <td class="pe-3">
                                    <div class="d-flex gap-1">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm" style="border-radius:9px;background:#f8fafc;color:#475569;border:1px solid #dbe4f0;"><i class="bi bi-pencil"></i></a>
                                        <form asp-action="Delete" method="post"
                                              data-swal-confirm="true"
                                              data-swal-title="Delete Discount Offer?"
                                              data-swal-text="Discount offer <strong>@item.DiscountName</strong> will be deleted permanently."
                                              data-swal-confirm-button="Yes, delete offer">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="productRateId" value="@item.ProductRateId" />
                                            <button type="submit" class="btn btn-sm" style="border-radius:9px;background:#fff1f2;color:#dc2626;border:1px solid #fecdd3;"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
</div>