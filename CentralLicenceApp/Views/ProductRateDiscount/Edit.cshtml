@model CentralLicenceApp.Models.ViewModels.ProductRateDiscountFormViewModel
@{
    ViewData["Title"] = "Edit Discount Offer";
    var productRates = ViewBag.ProductRates as List<CentralLicenceApp.Models.ProductRate> ?? new List<CentralLicenceApp.Models.ProductRate>();
    var discountTypes = ViewBag.DiscountTypes as string[] ?? System.Array.Empty<string>();
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" asp-route-productRateId="@Model.ProductRateId" class="btn btn-sm btn-outline-secondary" style="border-radius:8px;"><i class="bi bi-arrow-left"></i></a>
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;">Edit Discount Offer</h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">Update the mapped promotional discount</p>
    </div>
</div>

<div class="card" style="max-width:820px;">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 px-3 rounded-3 mb-3" style="font-size:.83rem;"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="ProductRateId" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <select asp-for="ProductRateId" class="form-select" style="border-radius:10px;">
                        <option value="0">Select Pricing Model</option>
                        @foreach (var item in productRates)
                        {
                            <option value="@item.Id">@item.ProductName - @item.PricingModel</option>
                        }
                    </select>
                    <span asp-validation-for="ProductRateId" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="DiscountName" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="DiscountName" class="form-control" style="border-radius:10px;" />
                    <span asp-validation-for="DiscountName" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="DiscountType" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <select asp-for="DiscountType" class="form-select" style="border-radius:10px;">
                        <option value="">Select Discount Model</option>
                        @foreach (var item in discountTypes)
                        {
                            <option value="@item">@item</option>
                        }
                    </select>
                    <span asp-validation-for="DiscountType" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="DiscountValue" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="DiscountValue" class="form-control" type="number" step="0.01" min="0.01" style="border-radius:10px;" />
                    <span asp-validation-for="DiscountValue" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="PromoCode" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="PromoCode" class="form-control" style="border-radius:10px;" />
                    <span asp-validation-for="PromoCode" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ValidFrom" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="ValidFrom" class="form-control" type="date" style="border-radius:10px;" />
                    <span asp-validation-for="ValidFrom" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ValidTo" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="ValidTo" class="form-control" type="date" style="border-radius:10px;" />
                    <span asp-validation-for="ValidTo" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Description" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <textarea asp-for="Description" class="form-control" rows="3" style="border-radius:10px;"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label fw-semibold" style="font-size:.85rem;"></label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn text-white px-4" style="background:#180a3c;border:none;border-radius:10px;">
                    <i class="bi bi-check-lg me-1"></i> Save Changes
                </button>
                <a asp-action="Index" asp-route-productRateId="@Model.ProductRateId" class="btn btn-outline-secondary" style="border-radius:10px;">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}