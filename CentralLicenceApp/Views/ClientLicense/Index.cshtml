@model CentralLicenceApp.Models.ViewModels.ClientLicenseListViewModel
@{
    ViewData["Title"] = "Client Licences" + (Model.ProductType != null ? " – " + Model.ProductType : "");
    var isAdmin = User.IsInRole("Administrator");
    var selectedPT = Model.ProductType ?? "";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;">Client Licences</h4>
        @if (!string.IsNullOrEmpty(selectedPT))
        {
            <p class="text-muted mb-0" style="font-size:.82rem;">Showing data for <strong style="color:#6366f1;">@selectedPT</strong> &mdash; @Model.TotalCount licence(s)</p>
        }
        else
        {
            <p class="text-muted mb-0" style="font-size:.82rem;">@Model.TotalCount registered licence(s)</p>
        }
    </div>
    <div class="d-flex align-items-center gap-3">
        <form method="get" class="d-flex align-items-center gap-2">
            <label class="fw-semibold mb-0" style="font-size:.82rem;color:#64748b;white-space:nowrap;">Product Type</label>
            <select name="productType" class="form-select form-select-sm" style="min-width:160px;border-radius:10px;"
                    onchange="this.form.submit()">
                <option value="">All Products</option>
                @foreach (var pt in Model.AvailableProductTypes)
                {
                    <option value="@pt" selected="@(selectedPT == pt)">@pt</option>
                }
            </select>
            @if (!string.IsNullOrEmpty(selectedPT))
            {
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary" style="border-radius:8px;white-space:nowrap;">Clear</a>
            }
        </form>
        @if (isAdmin)
        {
            <a asp-action="Create" asp-route-productType="@selectedPT" class="btn btn-primary" style="background:#6366f1;border:none;border-radius:10px;">
                <i class="bi bi-plus-lg me-1"></i> New Licence
            </a>
        }
    </div>
</div>

<!-- Filters -->
<div class="card mb-4">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <input type="hidden" name="productType" value="@selectedPT" />
            <div class="col-sm-5">
                <label class="form-label mb-1" style="font-size:.78rem;font-weight:600;color:#64748b;">Search</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="search" value="@Model.SearchTerm" class="form-control border-start-0" placeholder="Client name, code or email…" style="border-radius:0 10px 10px 0;" />
                </div>
            </div>
            <div class="col-sm-3">
                <label class="form-label mb-1" style="font-size:.78rem;font-weight:600;color:#64748b;">Status</label>
                <select name="status" class="form-select" style="border-radius:10px;">
                    <option value="">All Status</option>
                    <option value="active"   selected="@(Model.StatusFilter=="active")">Active</option>
                    <option value="expired"  selected="@(Model.StatusFilter=="expired")">Expired</option>
                    <option value="inactive" selected="@(Model.StatusFilter=="inactive")">Inactive</option>
                </select>
            </div>
            <div class="col-sm-auto">
                <button type="submit" class="btn btn-primary" style="background:#6366f1;border:none;border-radius:10px;">
                    <i class="bi bi-funnel me-1"></i> Filter
                </button>
                <a asp-action="Index" asp-route-productType="@selectedPT" class="btn btn-outline-secondary ms-1" style="border-radius:10px;">Clear</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table tbl-clean mb-0">
                <thead>
                    <tr>
                        <th class="ps-3">#</th>
                        <th>Client</th>
                        <th>Contact</th>
                        <th>App URL</th>
                        <th>License Key</th>
                        <th>Start Date</th>
                        <th>Expiry Date</th>
                        <th>AMC Expiry</th>
                        <th>Status</th>
                        <th class="pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Licenses.Any())
                    {
                        <tr><td colspan="10" class="text-center py-5 text-muted"><i class="bi bi-inbox fs-1 d-block mb-2"></i>No records found</td></tr>
                    }
                    @foreach (var lic in Model.Licenses)
                    {
                        var isExpired = lic.ExpiryDate < DateTime.Now;
                        var badgeCls  = !lic.IsActive ? "badge-neu" : isExpired ? "badge-err" : "badge-ok";
                        var badgeTxt  = !lic.IsActive ? "Inactive" : isExpired ? "Expired" : "Active";
                        var amcExpired = lic.AMC_Expireddate.HasValue && lic.AMC_Expireddate < DateTime.Now;
                        <tr>
                            <td class="ps-3" style="color:#94a3b8;font-size:.8rem;">@lic.Id</td>
                            <td>
                                <div class="fw-semibold" style="font-size:.875rem;">@lic.ClientName</div>
                                <div style="font-size:.75rem;color:#6366f1;">@lic.ClientCode</div>
                                @if (!string.IsNullOrEmpty(lic.EmailID))
                                {
                                    <div style="font-size:.73rem;color:#94a3b8;">@lic.EmailID</div>
                                }
                            </td>
                            <td style="font-size:.85rem;">@lic.ContactNumber</td>
                            <td style="font-size:.82rem;">
                                @if (!string.IsNullOrEmpty(lic.AppUrl))
                                {
                                    <a href="@lic.AppUrl" target="_blank" rel="noopener noreferrer" style="color:#6366f1;word-break:break-all;">@lic.AppUrl</a>
                                }
                                else
                                { <span class="text-muted">—</span> }
                            </td>
                            <td>
                                <button type="button"
                                        onclick="showLicenseKey('@Html.Raw(lic.LicenseKey?.Replace("'", "\\'"))', '@lic.ClientName')"
                                        title="View License Key"
                                        class="btn btn-sm btn-outline-secondary"
                                        style="border-radius:7px;border-color:#e2e8f0;font-size:.78rem;">
                                    <i class="bi bi-eye" style="color:#6366f1;"></i>
                                </button>
                            </td>
                            <td style="font-size:.82rem;">@lic.Startdate.ToString("dd MMM yyyy")</td>
                            <td style="font-size:.82rem;">
                                @lic.ExpiryDate.ToString("dd MMM yyyy")
                                @if (isExpired)
                                {
                                    <div style="font-size:.7rem;color:#ef4444;">Expired</div>
                                }
                            </td>
                            <td style="font-size:.82rem;">
                                @if (lic.AMC_Expireddate.HasValue)
                                {
                                    <span class="@(amcExpired ? "text-danger" : "")">@lic.AMC_Expireddate.Value.ToString("dd MMM yyyy")</span>
                                }
                                else
                                { <span class="text-muted">—</span> }
                            </td>
                            <td><span class="badge @badgeCls rounded-pill px-2 py-1" style="font-size:.73rem;">@badgeTxt</span></td>
                            <td class="pe-3">
                                <div class="d-flex gap-1">
                                    <a asp-action="Details" asp-route-id="@lic.Id" class="btn btn-sm btn-outline-primary" title="Details" style="border-radius:7px;border-color:#e2e8f0;"><i class="bi bi-eye"></i></a>
                                    @if (isAdmin)
                                    {
                                        <a asp-action="Edit" asp-route-id="@lic.Id" class="btn btn-sm btn-outline-secondary" title="Edit" style="border-radius:7px;border-color:#e2e8f0;"><i class="bi bi-pencil"></i></a>
                                    }
                                    @{
                                        var hasDetails = Model.ClientCodesWithDetails.Contains(lic.ClientCode ?? "");
                                    }
                                    <a asp-controller="ClientDetails" asp-action="Upsert"
                                       asp-route-clientCode="@lic.ClientCode"
                                       asp-route-productType="@Model.ProductType"
                                       class="btn btn-sm @(hasDetails ? "btn-info" : "btn-outline-info")"
                                       title="@(hasDetails ? "Edit Client Details" : "Add Client Details")"
                                       style="border-radius:7px;border-color:#e2e8f0;">
                                        <i class="bi bi-person-lines-fill"></i>
                                    </a>
                                    @if (isAdmin)
                                    {
                                        <button type="button" class="btn btn-sm @(lic.IsDisplayAlerts ? "btn-warning" : "btn-outline-warning")" title="Maintenance Alerts" style="border-radius:7px;border-color:#e2e8f0;" onclick="openMaintenanceAlert(@lic.Id)">
                                            <i class="bi bi-bell"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="d-flex align-items-center justify-content-between px-3 py-3 border-top" style="font-size:.82rem;">
                <span class="text-muted">Showing @((Model.PageNumber - 1) * Model.PageSize + 1)–@(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount)) of @Model.TotalCount</span>
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        @for (int p = 1; p <= Model.TotalPages; p++)
                        {
                            <li class="page-item @(p == Model.PageNumber ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@p" asp-route-search="@Model.SearchTerm" asp-route-status="@Model.StatusFilter" asp-route-productType="@Model.ProductType">@p</a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

<!-- License Key Modal -->
<div class="modal fade" id="licenseKeyModal" tabindex="-1" aria-labelledby="licenseKeyModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:16px;border:none;box-shadow:0 20px 60px rgba(0,0,0,.15);">
            <div class="modal-header" style="border-bottom:1px solid #f1f5f9;padding:1.25rem 1.5rem;">
                <h6 class="modal-title fw-bold mb-0" id="licenseKeyModalLabel" style="color:#1e293b;">
                    <i class="bi bi-key-fill me-2" style="color:#6366f1;"></i>License Key
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="padding:1.5rem;">
                <div class="text-muted mb-2" style="font-size:.78rem;" id="lkModalClientName"></div>
                <div class="p-3 rounded-3 text-center" style="background:#f8fafc;border:1px dashed #e2e8f0;">
                    <code id="lkModalKey" style="font-size:.82rem;font-weight:600;word-break:break-all;color:#6366f1;"></code>
                </div>
            </div>
            <div class="modal-footer" style="border-top:1px solid #f1f5f9;padding:.75rem 1.5rem;">
                <button type="button" onclick="copyModalKey(this)" class="btn btn-sm btn-outline-secondary" style="border-radius:8px;">
                    <i class="bi bi-copy me-1"></i> Copy
                </button>
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal" style="border-radius:8px;">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Maintenance Alert Modal -->
<div class="modal fade" id="maintenanceAlertModal" tabindex="-1" aria-labelledby="maintenanceAlertModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:16px;border:none;box-shadow:0 20px 60px rgba(0,0,0,.15);">
            <div class="modal-header" style="border-bottom:1px solid #f1f5f9;padding:1.25rem 1.5rem;">
                <h6 class="modal-title fw-bold mb-0" id="maintenanceAlertModalLabel" style="color:#1e293b;">
                    <i class="bi bi-bell-fill me-2" style="color:#f59e0b;"></i>Set Maintenance Alert
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="padding:1.5rem;">
                <input type="hidden" id="maLicenseId" />
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" id="maIsDisplayAlerts" onchange="toggleAlertFields()">
                    <label class="form-check-label fw-semibold" for="maIsDisplayAlerts">Enable Maintenance Alert</label>
                </div>
                <div id="maFieldsContainer">
                    <div class="row mb-3">
                        <div class="col-6">
                            <label for="maAlertStartDate" class="form-label" style="font-size:.82rem;">Start Date</label>
                            <input type="date" class="form-control form-control-sm" id="maAlertStartDate" disabled>
                        </div>
                        <div class="col-6">
                            <label for="maAlertStartTime" class="form-label" style="font-size:.82rem;">Start Time</label>
                            <input type="time" class="form-control form-control-sm" id="maAlertStartTime" disabled>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-6">
                            <label for="maAlertEndDate" class="form-label" style="font-size:.82rem;">End Date</label>
                            <input type="date" class="form-control form-control-sm" id="maAlertEndDate" disabled>
                        </div>
                        <div class="col-6">
                            <label for="maAlertEndTime" class="form-label" style="font-size:.82rem;">End Time</label>
                            <input type="time" class="form-control form-control-sm" id="maAlertEndTime" disabled>
                        </div>
                    </div>
                    <div class="mb-2">
                        <label for="maAlertMessage" class="form-label" style="font-size:.82rem;">Alert Message</label>
                        <textarea class="form-control form-control-sm" id="maAlertMessage" rows="3" placeholder="Enter maintenance alert message..." disabled></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer" style="border-top:1px solid #f1f5f9;padding:.75rem 1.5rem;">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal" style="border-radius:8px;">Cancel</button>
                <button type="button" class="btn btn-sm btn-primary" onclick="saveMaintenanceAlert()" style="border-radius:8px;">
                    <i class="bi bi-check2 me-1"></i> Save
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function showLicenseKey(key, clientName) {
        document.getElementById('lkModalKey').textContent = key;
        document.getElementById('lkModalClientName').textContent = clientName;
        new bootstrap.Modal(document.getElementById('licenseKeyModal')).show();
    }

    function copyModalKey(btn) {
        var key = document.getElementById('lkModalKey').textContent;
        navigator.clipboard.writeText(key).then(function () {
            btn.innerHTML = '<i class="bi bi-check2 me-1"></i> Copied!';
            btn.style.color = '#10b981';
            setTimeout(function () {
                btn.innerHTML = '<i class="bi bi-copy me-1"></i> Copy';
                btn.style.color = '';
            }, 1800);
        });
    }

    function toggleAlertFields() {
        var enabled = document.getElementById('maIsDisplayAlerts').checked;
        var fields = ['maAlertStartDate', 'maAlertStartTime', 'maAlertEndDate', 'maAlertEndTime', 'maAlertMessage'];
        fields.forEach(function (id) {
            document.getElementById(id).disabled = !enabled;
        });
        if (!enabled) {
            fields.forEach(function (id) { document.getElementById(id).value = ''; });
        }
    }

    function openMaintenanceAlert(id) {
        document.getElementById('maLicenseId').value = id;
        document.getElementById('maIsDisplayAlerts').checked = false;
        ['maAlertStartDate', 'maAlertStartTime', 'maAlertEndDate', 'maAlertEndTime', 'maAlertMessage'].forEach(function (fld) {
            document.getElementById(fld).value = '';
            document.getElementById(fld).disabled = true;
        });

        fetch('@Url.Action("GetMaintenanceAlert", "ClientLicense")' + '?id=' + id)
            .then(function (r) { return r.json(); })
            .then(function (data) {
                document.getElementById('maIsDisplayAlerts').checked = data.isDisplayAlerts;
                document.getElementById('maAlertStartDate').value = data.alertStartDate || '';
                document.getElementById('maAlertStartTime').value = data.alertStartTime || '';
                document.getElementById('maAlertEndDate').value = data.alertEndDate || '';
                document.getElementById('maAlertEndTime').value = data.alertEndTime || '';
                document.getElementById('maAlertMessage').value = data.alertMessage || '';
                toggleAlertFields();
                new bootstrap.Modal(document.getElementById('maintenanceAlertModal')).show();
            });
    }

    function saveMaintenanceAlert() {
        var isDisplay = document.getElementById('maIsDisplayAlerts').checked;
        if (isDisplay) {
            var sd = document.getElementById('maAlertStartDate').value;
            var st = document.getElementById('maAlertStartTime').value;
            var ed = document.getElementById('maAlertEndDate').value;
            var et = document.getElementById('maAlertEndTime').value;
            var msg = document.getElementById('maAlertMessage').value.trim();
            if (!sd || !st || !ed || !et || !msg) {
                alert('Please fill in all fields when alert is enabled.');
                return;
            }
            if (new Date(sd + 'T' + st) >= new Date(ed + 'T' + et)) {
                alert('End date/time must be after start date/time.');
                return;
            }
        }

        var formData = new FormData();
        formData.append('id', document.getElementById('maLicenseId').value);
        formData.append('isDisplayAlerts', isDisplay);
        formData.append('alertStartDate', document.getElementById('maAlertStartDate').value || '');
        formData.append('alertStartTime', document.getElementById('maAlertStartTime').value || '');
        formData.append('alertEndDate', document.getElementById('maAlertEndDate').value || '');
        formData.append('alertEndTime', document.getElementById('maAlertEndTime').value || '');
        formData.append('alertMessage', document.getElementById('maAlertMessage').value || '');

        fetch('@Url.Action("UpdateMaintenanceAlert", "ClientLicense")', {
            method: 'POST',
            headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || '' },
            body: formData
        })
        .then(function (r) { return r.json(); })
        .then(function (data) {
            if (data.success) {
                bootstrap.Modal.getInstance(document.getElementById('maintenanceAlertModal')).hide();
                location.reload();
            } else {
                alert(data.message || 'Failed to update.');
            }
        });
    }
</script>
}
