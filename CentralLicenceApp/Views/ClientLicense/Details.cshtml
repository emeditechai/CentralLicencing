@model CentralLicenceApp.Models.ClientAppLicense
@using CentralLicenceApp.Models
@{
    ViewData["Title"] = "Licence Details – " + Model.ClientCode;
    var isExpired = Model.ExpiryDate < DateTime.Now;
    var badgeCls  = !Model.IsActive ? "badge-neu" : isExpired ? "badge-err" : "badge-ok";
    var badgeTxt  = !Model.IsActive ? "Inactive" : isExpired ? "Expired" : "Active";
    var cd        = ViewBag.ClientDetails as ClientDetails;
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary" style="border-radius:8px;"><i class="bi bi-arrow-left"></i></a>
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;">Licence Details</h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">@Model.ClientCode</p>
    </div>
    <span class="badge @badgeCls rounded-pill px-3 py-2 ms-auto" style="font-size:.8rem;">@badgeTxt</span>
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header"><i class="bi bi-person-badge me-2" style="color:#6366f1;"></i>Client Information</div>
            <div class="card-body">
                <dl class="row mb-0" style="font-size:.875rem;">
                    <dt class="col-sm-4 text-muted fw-normal">Product Type</dt>
                    <dd class="col-sm-8"><span class="badge rounded-pill px-2 py-1" style="background:#ede9fe;color:#6366f1;font-size:.75rem;">@Model.ProductType</span></dd>
                    <dt class="col-sm-4 text-muted fw-normal">Client Code</dt>
                    <dd class="col-sm-8 fw-semibold" style="color:#6366f1;">@Model.ClientCode</dd>
                    <dt class="col-sm-4 text-muted fw-normal">Client Name</dt>
                    <dd class="col-sm-8 fw-semibold">@Model.ClientName</dd>
                    <dt class="col-sm-4 text-muted fw-normal">Contact</dt>
                    <dd class="col-sm-8">@Model.ContactNumber</dd>
                    <dt class="col-sm-4 text-muted fw-normal">Email</dt>
                    <dd class="col-sm-8">@(Model.EmailID ?? "—")</dd>
                    <dt class="col-sm-4 text-muted fw-normal">App URL</dt>
                    <dd class="col-sm-8">
                        @if (!string.IsNullOrEmpty(Model.AppUrl))
                        {
                            <a href="@Model.AppUrl" target="_blank" rel="noopener noreferrer">@Model.AppUrl</a>
                        }
                        else { <span>—</span> }
                    </dd>
                    <dt class="col-sm-4 text-muted fw-normal">Public IP</dt>
                    <dd class="col-sm-8">@(Model.PublicIPAddress ?? "—")</dd>
                    <dt class="col-sm-4 text-muted fw-normal">Last Login</dt>
                    <dd class="col-sm-8">@(Model.LastLoginDate.HasValue ? Model.LastLoginDate.Value.ToString("dd MMM yyyy HH:mm") : "—")</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card mb-3">
            <div class="card-header"><i class="bi bi-key-fill me-2" style="color:#6366f1;"></i>Licence Key</div>
            <div class="card-body">
                <div class="p-3 rounded-3 text-center" style="background:#f8fafc;border:1px dashed #e2e8f0;">
                    <code style="font-size:.8rem;font-weight:600;word-break:break-all;color:#6366f1;">@Model.LicenseKey</code>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header"><i class="bi bi-calendar3 me-2" style="color:#6366f1;"></i>Dates</div>
            <div class="card-body">
                <dl class="row mb-0" style="font-size:.875rem;">
                    <dt class="col-sm-5 text-muted fw-normal">Start Date</dt>
                    <dd class="col-sm-7">@Model.Startdate.ToString("dd MMM yyyy")</dd>
                    <dt class="col-sm-5 text-muted fw-normal">Expiry Date</dt>
                    <dd class="col-sm-7 @(isExpired ? "text-danger fw-semibold" : "")">@Model.ExpiryDate.ToString("dd MMM yyyy")</dd>
                    <dt class="col-sm-5 text-muted fw-normal">AMC Expiry</dt>
                    <dd class="col-sm-7">@(Model.AMC_Expireddate.HasValue ? Model.AMC_Expireddate.Value.ToString("dd MMM yyyy") : "—")</dd>
                    <dt class="col-sm-5 text-muted fw-normal">Created</dt>
                    <dd class="col-sm-7">@Model.CreatedAt.ToString("dd MMM yyyy HH:mm")</dd>
                </dl>
            </div>
        </div>

        <div class="card">
            <div class="card-header"><i class="bi bi-hdd me-2" style="color:#6366f1;"></i>Hardware</div>
            <div class="card-body" style="font-size:.82rem;">
                <div class="mb-2">
                    <div class="text-muted">HDD Serial</div>
                    <code>@(string.IsNullOrEmpty(Model.HardDiskNumber) ? "—" : Model.HardDiskNumber)</code>
                </div>
                <div class="mb-2">
                    <div class="text-muted">Server MAC</div>
                    <code>@(string.IsNullOrEmpty(Model.ServerMacID) ? "—" : Model.ServerMacID)</code>
                </div>
                <div>
                    <div class="text-muted">Motherboard</div>
                    <code>@(string.IsNullOrEmpty(Model.MotherboardNumber) ? "—" : Model.MotherboardNumber)</code>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.ConnectionString))
        {
            <div class="card mt-3">
                <div class="card-header"><i class="bi bi-database me-2" style="color:#6366f1;"></i>Connection String</div>
                <div class="card-body">
                    <div class="p-3 rounded-3" style="background:#f8fafc;border:1px dashed #e2e8f0;">
                        <code style="font-size:.78rem;word-break:break-all;color:#334155;">@Model.ConnectionString</code>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Client Details Card -->
@if (cd != null)
{
    <div class="row g-3 mt-1">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <span><i class="bi bi-person-lines-fill me-2" style="color:#6366f1;"></i>Client Details</span>
                </div>
                <div class="card-body">
                    <div class="row g-3" style="font-size:.875rem;">
                        <div class="col-sm-6 col-lg-3">
                            <div class="text-muted mb-1" style="font-size:.75rem;">Contact Person</div>
                            <div class="fw-semibold">@(string.IsNullOrEmpty(cd.ClientPersonName) ? "—" : cd.ClientPersonName)</div>
                        </div>
                        <div class="col-sm-6 col-lg-3">
                            <div class="text-muted mb-1" style="font-size:.75rem;">Address</div>
                            <div>@(string.IsNullOrEmpty(cd.Address) ? "—" : cd.Address)</div>
                        </div>
                        <div class="col-sm-6 col-lg-3">
                            <div class="text-muted mb-1" style="font-size:.75rem;">Date of Birth</div>
                            <div>@(cd.DOB.HasValue ? cd.DOB.Value.ToString("dd MMM yyyy") : "—")</div>
                        </div>
                        <div class="col-sm-6 col-lg-3">
                            <div class="text-muted mb-1" style="font-size:.75rem;">Anniversary Date</div>
                            <div>@(cd.Anniversarydate.HasValue ? cd.Anniversarydate.Value.ToString("dd MMM yyyy") : "—")</div>
                        </div>
                        <div class="col-sm-6 col-lg-3">
                            <div class="text-muted mb-1" style="font-size:.75rem;">Status</div>
                            <div>
                                @if (cd.IsActive)
                                {
                                    <span class="badge badge-ok rounded-pill px-2 py-1" style="font-size:.72rem;">Active</span>
                                }
                                else
                                {
                                    <span class="badge badge-neu rounded-pill px-2 py-1" style="font-size:.72rem;">Inactive</span>
                                }
                            </div>
                        </div>
                        <div class="col-sm-6 col-lg-3">
                            <div class="text-muted mb-1" style="font-size:.75rem;">Internal Use</div>
                            <div>
                                @if (cd.IsInternalUse)
                                {
                                    <span class="badge rounded-pill px-2 py-1" style="background:#dbeafe;color:#1d4ed8;font-size:.72rem;">Yes</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill px-2 py-1" style="background:#f1f5f9;color:#475569;font-size:.72rem;">No</span>
                                }
                            </div>
                        </div>
                        <div class="col-sm-6 col-lg-3">
                            <div class="text-muted mb-1" style="font-size:.75rem;">Reference ClientCode</div>
                            <div class="fw-semibold">@(string.IsNullOrWhiteSpace(cd.ReferenceClientCode) ? "—" : cd.ReferenceClientCode)</div>
                        </div>
                        @if (!cd.IsInternalUse && cd.PurchasedProducts.Any())
                        {
                            <div class="col-12">
                                <div class="text-muted mb-1" style="font-size:.75rem;">Products Purchased</div>
                                <div class="table-responsive">
                                    <table class="table table-sm align-middle mb-0" id="productsPurchasedTable">
                                        <thead>
                                            <tr>
                                                <th>Product</th>
                                                <th>Pricing Model</th>
                                                <th>Base Price</th>
                                                <th>AMC</th>
                                                <th>Invoice No</th>
                                                <th>Sub Total</th>
                                                <th>GST</th>
                                                <th>Total Amount</th>
                                                <th>Paid Amount</th>
                                                <th>Balance Due</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in cd.PurchasedProducts)
                                            {
                                                <tr data-invoice-no="@item.InvoiceNo">
                                                    <td>
                                                        <div class="fw-semibold">@item.ProductName</div>
                                                        <div class="text-muted" style="font-size:.74rem;">@item.ProductCode</div>
                                                    </td>
                                                    <td>
                                                        <span class="badge rounded-pill px-2 py-1" style="background:#ede9fe;color:#6366f1;font-size:.75rem;">@item.PricingModel</span>
                                                        <div class="text-muted mt-1" style="font-size:.72rem;">@item.BillingSummary</div>
                                                    </td>
                                                    <td class="fw-semibold">₹@item.BasePrice.ToString("0.00")</td>
                                                    <td>
                                                        @if (string.IsNullOrWhiteSpace(item.AmcCalculationType))
                                                        {
                                                            <div class="fw-semibold">-</div>
                                                            <div class="text-muted" style="font-size:.74rem;">No AMC</div>
                                                        }
                                                        else
                                                        {
                                                            <div class="fw-semibold">₹@item.AmcAmount.ToString("0.00")</div>
                                                            <div class="text-muted" style="font-size:.74rem;">@item.AmcCalculationType • @item.AmcPercentage.ToString("0.####")%</div>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (string.IsNullOrWhiteSpace(item.InvoiceNo))
                                                        {
                                                            <span class="text-muted">—</span>
                                                        }
                                                        else
                                                        {
                                                            <div class="fw-semibold" style="color:#6366f1;">@item.InvoiceNo</div>
                                                            <div class="text-muted inv-inv-date" style="font-size:.72rem;"></div>
                                                        }
                                                    </td>
                                                    <td class="inv-subtotal-cell" style="font-size:.82rem;">@(string.IsNullOrWhiteSpace(item.InvoiceNo) ? "—" : "…")</td>
                                                    <td class="inv-gst-cell" style="font-size:.82rem;">@(string.IsNullOrWhiteSpace(item.InvoiceNo) ? "—" : "…")</td>
                                                    <td class="inv-total-cell fw-semibold" style="font-size:.82rem;color:#6366f1;">@(string.IsNullOrWhiteSpace(item.InvoiceNo) ? "—" : "…")</td>
                                                    <td class="inv-paid-cell fw-semibold" style="font-size:.82rem;color:#10b981;">@(string.IsNullOrWhiteSpace(item.InvoiceNo) ? "—" : "…")</td>
                                                    <td class="inv-balance-cell fw-semibold" style="font-size:.82rem;">@(string.IsNullOrWhiteSpace(item.InvoiceNo) ? "—" : "…")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        }
                        else if (!cd.IsInternalUse && !string.IsNullOrEmpty(cd.ProductPurchased))
                        {
                            <div class="col-sm-12 col-lg-9">
                                <div class="text-muted mb-1" style="font-size:.75rem;">Products Purchased</div>
                                <div class="d-flex flex-wrap gap-1">
                                    @foreach (var p in cd.ProductPurchased.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        <span class="badge rounded-pill px-2 py-1" style="background:#ede9fe;color:#6366f1;font-size:.75rem;">@p.Trim()</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<div class="d-flex gap-2 mt-4">
    <a asp-action="Index" asp-route-productType="@Model.ProductType" class="btn btn-outline-secondary" style="border-radius:10px;">
        <i class="bi bi-arrow-left me-1"></i> Back
    </a>
</div>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var fmt = function (n) {
            return '\u20b9' + Number(n).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        };
        var statusColors = { Paid: 'bg-success', Partial: 'bg-warning text-dark', Cancelled: 'bg-danger', Draft: 'bg-secondary', Sent: 'bg-info text-dark' };

        document.querySelectorAll('#productsPurchasedTable tbody tr[data-invoice-no]').forEach(function (tr) {
            var invNo = tr.getAttribute('data-invoice-no');
            if (!invNo || invNo.trim() === '') return;

            fetch('/ClientDetails/GetInvoiceDetails?invoiceNo=' + encodeURIComponent(invNo.trim()))
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (!data.found) {
                        tr.querySelector('.inv-subtotal-cell').textContent = '—';
                        tr.querySelector('.inv-gst-cell').textContent = '—';
                        tr.querySelector('.inv-total-cell').textContent = '—';
                        tr.querySelector('.inv-paid-cell').textContent = '—';
                        tr.querySelector('.inv-balance-cell').textContent = '—';
                        var dateEl = tr.querySelector('.inv-inv-date');
                        if (dateEl) dateEl.textContent = 'Not found';
                        return;
                    }

                    // Date under invoice number
                    var dateEl = tr.querySelector('.inv-inv-date');
                    if (dateEl) dateEl.textContent = data.invoiceDate;

                    // Status badge alongside invoice no
                    var noCell = tr.querySelector('td:nth-child(5)');
                    var existing = noCell.querySelector('.inv-status-badge');
                    if (!existing) {
                        var badge = document.createElement('span');
                        badge.className = 'badge rounded-pill px-2 py-1 mt-1 d-block inv-status-badge';
                        badge.style.fontSize = '.68rem';
                        badge.textContent = data.status;
                        badge.className += ' ' + (statusColors[data.status] || 'bg-secondary');
                        noCell.appendChild(badge);
                    }

                    // Amounts
                    tr.querySelector('.inv-subtotal-cell').textContent = fmt(data.subTotal);
                    tr.querySelector('.inv-gst-cell').textContent      = fmt(data.totalGst);
                    tr.querySelector('.inv-total-cell').textContent    = fmt(data.totalAmount);
                    tr.querySelector('.inv-paid-cell').textContent     = fmt(data.receivedAmount);

                    var balCell = tr.querySelector('.inv-balance-cell');
                    balCell.textContent = fmt(data.balanceDue);
                    balCell.style.color = data.balanceDue > 0 ? '#ef4444' : '#10b981';
                })
                .catch(function () {
                    ['inv-subtotal-cell', 'inv-gst-cell', 'inv-total-cell', 'inv-paid-cell', 'inv-balance-cell'].forEach(function (c) {
                        var el = tr.querySelector('.' + c);
                        if (el) el.textContent = '—';
                    });
                });
        });
    });
</script>
}
