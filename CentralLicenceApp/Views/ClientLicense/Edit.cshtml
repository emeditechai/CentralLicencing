@model CentralLicenceApp.Models.ViewModels.ClientLicenseFormViewModel
@{
    ViewData["Title"] = "Edit Licence – " + Model.ClientCode;
    var productType = Model.ProductType;
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" asp-route-productType="@productType" class="btn btn-sm btn-outline-secondary" style="border-radius:8px;"><i class="bi bi-arrow-left"></i></a>
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;">Edit Licence</h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">@Model.ClientCode — @Model.ClientName</p>
    </div>
</div>

<div class="card" style="max-width:680px;">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 px-3 rounded-3 mb-3" style="font-size:.83rem;"></div>

            <div class="mb-3 p-3 rounded-3" style="background:#f8fafc;border:1px solid #e2e8f0;">
                <div style="font-size:.75rem;color:#64748b;font-weight:600;">CLIENT CODE</div>
                <div class="fw-semibold" style="color:#6366f1;">@Model.ClientCode</div>
            </div>

            <div class="row g-3">
                <div class="col-md-12">
                    <label asp-for="ProductType" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <select asp-for="ProductType" class="form-select" style="border-radius:10px;">
                        @foreach (var pt in CentralLicenceApp.Models.ViewModels.ClientLicenseFormViewModel.AvailableProductTypes)
                        {
                            <option value="@pt" selected="@(Model.ProductType == pt)">@pt</option>
                        }
                    </select>
                    <span asp-validation-for="ProductType" class="text-danger small"></span>
                </div>
                <div class="col-md-12">
                    <label asp-for="ClientName" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="ClientName" class="form-control" style="border-radius:10px;" />
                    <span asp-validation-for="ClientName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ContactNumber" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="ContactNumber" class="form-control" style="border-radius:10px;" />
                    <span asp-validation-for="ContactNumber" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="EmailID" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="EmailID" class="form-control" style="border-radius:10px;" />
                    <span asp-validation-for="EmailID" class="text-danger small"></span>
                </div>
                <div class="col-md-12">
                    <label asp-for="AppUrl" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="AppUrl" class="form-control" style="border-radius:10px;" />
                </div>
                <div class="col-md-6">
                    <label asp-for="ExpiryDate" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="ExpiryDate" type="date" class="form-control" style="border-radius:10px;" />
                    <span asp-validation-for="ExpiryDate" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="AMC_Expireddate" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="AMC_Expireddate" type="date" class="form-control" style="border-radius:10px;" />
                </div>
                <div class="col-md-12">
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label fw-semibold" style="font-size:.85rem;"></label>
                    </div>
                </div>
                <div class="col-md-12">
                    <label asp-for="ConnectionString" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <textarea asp-for="ConnectionString" class="form-control font-monospace" rows="3" style="border-radius:10px;font-size:.8rem;" placeholder="Server=...;Database=...;User Id=...;Password=...;TrustServerCertificate=True;"></textarea>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn text-white px-4" style="background:#6366f1;border:none;border-radius:10px;">
                    <i class="bi bi-check-lg me-1"></i> Save Changes
                </button>
                <a asp-action="Index" asp-route-productType="@productType" class="btn btn-outline-secondary" style="border-radius:10px;">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
