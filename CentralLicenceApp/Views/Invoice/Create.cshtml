@model CentralLicenceApp.Models.ViewModels.InvoiceFormViewModel
@using System.Text.Json
@{
    ViewData["Title"] = Model.IsNew ? "New Invoice" : "Edit Invoice";
    var parties      = ViewBag.Parties      as List<CentralLicenceApp.Models.PartyMaster> ?? new();
    var paymentModes = ViewBag.PaymentModes as List<CentralLicenceApp.Models.PaymentMode>  ?? new();
    var banks        = ViewBag.Banks        as List<CentralLicenceApp.Models.BankMaster>   ?? new();
    var companyGstin = (ViewBag.CompanyGstin as string) ?? string.Empty;
    var partiesJson  = JsonSerializer.Serialize(parties.Select(p => new {
        id = p.Id, gstinNo = p.GSTINNo ?? string.Empty
    }));
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary" style="border-radius:8px;"><i class="bi bi-arrow-left"></i></a>
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;">@(Model.IsNew ? (Model.QuotationId.HasValue ? "Convert to Invoice" : "New Invoice") : "Edit Invoice")</h4>
        @if (!Model.IsNew) { <p class="text-muted mb-0" style="font-size:.85rem;">@Model.InvoiceNo</p> }
    </div>
</div>

@if (Model.QuotationId.HasValue && Model.IsNew)
{
    <div class="alert alert-info d-flex align-items-center gap-2 py-2 px-3 rounded-3 mb-3" style="font-size:.85rem;">
        <i class="bi bi-arrow-right-circle-fill fs-5"></i>
        <div>
            Converting from Quotation <strong>@Model.QuotationNo</strong>. Review the details below, update payment information if needed, then click <strong>Convert to Invoice</strong>.
        </div>
    </div>
}

<form id="invoiceForm" asp-action="@(Model.IsNew ? "Create" : "Edit")" asp-route-id="@(Model.IsNew ? null : Model.Id.ToString())" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="InvoiceNo" />
    <input type="hidden" asp-for="QuotationId" />
    <input type="hidden" asp-for="QuotationNo" />

    <div class="row g-3">
        <div class="col-12">
            <div class="card">
                <div class="card-header fw-semibold" style="font-size:.85rem;">
                    <i class="bi bi-receipt me-2" style="color:#6366f1;"></i>Invoice Details
                </div>
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger py-2 px-3 rounded-3 mb-3" style="font-size:.83rem;"></div>

                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label fw-semibold" style="font-size:.82rem;">Invoice No</label>
                            <input class="form-control" value="@(string.IsNullOrEmpty(Model.InvoiceNo) ? "" : Model.InvoiceNo)"
                                   placeholder="Auto-generated on save" readonly
                                   style="border-radius:10px;background:#f8fafc;color:@(string.IsNullOrEmpty(Model.InvoiceNo) ? "#94a3b8" : "inherit");" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="InvoiceDate" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                            <input asp-for="InvoiceDate" type="date" class="form-control" style="border-radius:10px;" />
                            <span asp-validation-for="InvoiceDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="DueDate" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                            <input asp-for="DueDate" type="date" class="form-control" style="border-radius:10px;" />
                        </div>
                        @if (!string.IsNullOrWhiteSpace(Model.QuotationNo))
                        {
                            <div class="col-md-3">
                                <label class="form-label fw-semibold" style="font-size:.82rem;">From Quotation</label>
                                <input class="form-control" value="@Model.QuotationNo" readonly style="border-radius:10px;background:#f8fafc;" />
                            </div>
                        }
                        <div class="col-md-12">
                            <label asp-for="PartyId" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                            <select asp-for="PartyId" class="form-select" style="border-radius:10px;">
                                <option value="">— Select Party —</option>
                                @foreach (var p in parties)
                                {
                                    <option value="@p.Id" selected="@(Model.PartyId == p.Id)">
                                        @p.PartyName @(!string.IsNullOrWhiteSpace(p.ContactPerson) ? $"({p.ContactPerson})" : "")
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="PartyId" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Line Items -->
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <span class="fw-semibold" style="font-size:.85rem;"><i class="bi bi-list-ul me-2" style="color:#6366f1;"></i>Line Items</span>
                    <button type="button" class="btn btn-sm btn-outline-primary" style="border-radius:8px;" onclick="addLineRow()">
                        <i class="bi bi-plus-lg me-1"></i> Add Row
                    </button>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm mb-0" id="lineTable" style="min-width:1000px;">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3" style="width:36px;">#</th>
                                    <th style="min-width:220px;">Item / Description</th>
                                    <th style="width:120px;">Plan</th>
                                    <th style="width:85px;">Type</th>
                                    <th style="width:65px;">Qty</th>
                                    <th style="width:100px;">Rate (₹)</th>
                                    <th style="width:75px;">Disc %</th>
                                    <th style="width:100px;">Taxable (₹)</th>
                                    <th style="width:72px;">GST %</th>
                                    <th style="width:100px;">GST Amt (₹)</th>
                                    <th style="width:44px;"></th>
                                </tr>
                            </thead>
                            <tbody id="lineBody">
                                @for (var i = 0; i < Model.Lines.Count; i++)
                                {
                                    var line = Model.Lines[i];
                                    <tr class="line-row">
                                        <td class="ps-3 sno-cell align-middle" style="color:#94a3b8;font-size:.8rem;">@(i+1)</td>
                                        <td>
                                            <select class="form-select form-select-sm prod-picker mb-1" style="font-size:.75rem;">
                                                <option value="">↓ From rate list…</option>
                                            </select>
                                            <input type="text" name="Lines[@i].ItemDescription" value="@line.ItemDescription" class="form-control form-control-sm item-desc" placeholder="Item description…" required />
                                        </td>
                                        <td><input type="text" name="Lines[@i].PlanName" value="@line.PlanName" class="form-control form-control-sm item-plan" /></td>
                                        <td><input type="text" name="Lines[@i].Type" value="@line.Type" class="form-control form-control-sm item-type" /></td>
                                        <td><input type="number" name="Lines[@i].Qty" value="@line.Qty" class="form-control form-control-sm line-qty" min="1" /></td>
                                        <td><input type="number" name="Lines[@i].Rate" value="@line.Rate" class="form-control form-control-sm line-rate" min="0" step="0.01" /></td>
                                        <td><input type="number" name="Lines[@i].DiscountPercent" value="@line.DiscountPercent" class="form-control form-control-sm line-disc" min="0" max="100" step="0.01" /></td>
                                        <td><input type="text" readonly class="form-control form-control-sm line-taxable bg-light" value="@line.Amount.ToString("0.00")" /></td>
                                        <td>
                                            <select name="Lines[@i].GstPercent" class="form-select form-select-sm line-gst">
                                                @foreach (var pct in new[] { 0, 5, 12, 18, 28 })
                                                {
                                                    <option value="@pct" selected="@(line.GstPercent == pct)">@pct%</option>
                                                }
                                            </select>
                                        </td>
                                        <td><input type="text" readonly class="form-control form-control-sm line-gst-amt bg-light" value="@((line.CgstAmount + line.SgstAmount + line.IgstAmount).ToString("0.00"))" /></td>
                                        <td>
                                            <input type="hidden" name="Lines[@i].CgstAmount" class="hid-cgst" value="@line.CgstAmount" />
                                            <input type="hidden" name="Lines[@i].SgstAmount" class="hid-sgst" value="@line.SgstAmount" />
                                            <input type="hidden" name="Lines[@i].IgstAmount" class="hid-igst" value="@line.IgstAmount" />
                                            <button type="button" class="btn btn-sm btn-outline-danger px-2" onclick="removeRow(this)">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <!-- Totals panel -->
                    <div class="d-flex justify-content-end p-3">
                        <table style="font-size:.875rem;min-width:260px;">
                            <tr><td class="text-muted pe-4 py-1">Sub Total</td><td class="fw-semibold text-end" id="subTotalDisplay">₹0.00</td></tr>
                            <tr id="row-cgst" style="display:none;"><td class="text-muted pe-4 py-1">CGST</td><td class="text-end" id="cgstDisplay">₹0.00</td></tr>
                            <tr id="row-sgst" style="display:none;"><td class="text-muted pe-4 py-1">SGST</td><td class="text-end" id="sgstDisplay">₹0.00</td></tr>
                            <tr id="row-igst" style="display:none;"><td class="text-muted pe-4 py-1">IGST</td><td class="text-end" id="igstDisplay">₹0.00</td></tr>
                            <tr style="border-top:2px solid #e2e8f0;">
                                <td class="fw-bold pe-4 py-1">Grand Total</td>
                                <td class="fw-bold text-end" id="grandTotalDisplay" style="color:#6366f1;font-size:1rem;">₹0.00</td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Payment & Notes -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header fw-semibold" style="font-size:.85rem;">Payment Details</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-6">
                            <label asp-for="ReceivedAmount" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                            <div class="input-group">
                                <span class="input-group-text">₹</span>
                                <input asp-for="ReceivedAmount" type="number" class="form-control" min="0" step="0.01" style="border-radius:0 10px 10px 0;" />
                            </div>
                        </div>
                        <div class="col-6">
                            <label asp-for="PreviousBalance" class="form-label fw-semibold" style="font-size:.82rem;">
                                Previous Balance
                                <span id="prevBalLoader" class="spinner-border spinner-border-sm ms-1 text-secondary d-none" role="status"></span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text">₹</span>
                                <input asp-for="PreviousBalance" id="PreviousBalance" type="number" class="form-control"
                                       readonly style="border-radius:0 10px 10px 0;background:#f8fafc;" />
                            </div>
                            <div class="form-text text-muted" style="font-size:.75rem;">Auto-fetched from party's outstanding dues</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <label asp-for="Notes" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <textarea asp-for="Notes" class="form-control" rows="3" style="border-radius:10px;"></textarea>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <label asp-for="TermsAndConditions" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <textarea asp-for="TermsAndConditions" class="form-control" rows="3" style="border-radius:10px;"></textarea>
                </div>
            </div>
        </div>

        <!-- Authorised Signatory -->
        @{
            var signatoryUsers = ViewBag.SignatoryUsers as List<CentralLicenceApp.Models.UserMaster> ?? new();
        }
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <label class="form-label fw-semibold" style="font-size:.82rem;">Authorised Signatory <span style="color:#9ca3af;font-size:.75rem;">(max 3 — core members with digital signature)</span></label>
                    @if (!signatoryUsers.Any())
                    {
                        <div class="text-muted" style="font-size:.82rem;"><i class="bi bi-info-circle me-1"></i>No core members with a digital signature found. Upload signatures via User Master.</div>
                    }
                    else
                    {
                        <div id="signatoryDropdown" class="dropdown">
                            <button type="button" class="form-control text-start d-flex justify-content-between align-items-center" style="border-radius:10px;background:#fff;" id="signatoryBtn" onclick="toggleSignatoryDropdown()">
                                <span id="signatoryLabel">-- Select Signatories --</span>
                                <i class="bi bi-chevron-down" style="font-size:.75rem;"></i>
                            </button>
                            <div id="signatoryMenu" class="dropdown-menu w-100 p-2" style="display:none;max-height:220px;overflow-y:auto;border-radius:10px;box-shadow:0 4px 16px rgba(0,0,0,.12);">
                                @foreach (var u in signatoryUsers)
                                {
                                    var displayName = string.IsNullOrWhiteSpace(u.FullName) ? u.Username : u.FullName;
                                    <label class="dropdown-item d-flex align-items-center gap-2 py-2" style="cursor:pointer;border-radius:6px;">
                                        <input type="checkbox" name="SignatoryUserIds" value="@u.Id"
                                               class="sig-check form-check-input" style="margin:0;"
                                               @(Model.SignatoryUserIds.Contains(u.Id) ? "checked" : "") />
                                        <span style="font-size:.88rem;">@displayName</span>
                                    </label>
                                }
                            </div>
                        </div>
                        <div id="signatoryChips" class="d-flex flex-wrap gap-1 mt-2"></div>
                        <div class="text-muted mt-1" style="font-size:.78rem;">Select up to 3. Order of selection determines Left → Middle → Right position on print.</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="d-flex gap-2">
                <button type="button" id="mainSubmitBtn" class="btn text-white px-4" style="background:#6366f1;border:none;border-radius:10px;"
                        onclick="handleSubmit()">
                    <i class="bi @(Model.IsNew && Model.QuotationId.HasValue ? "bi-arrow-right-circle" : "bi-check-lg") me-1"></i>
                    @(Model.IsNew && Model.QuotationId.HasValue ? "Convert to Invoice" : (Model.IsNew ? "Save Invoice" : "Update Invoice"))
                </button>
                <a asp-action="@(Model.IsNew ? "Index" : "Details")" asp-route-id="@(Model.IsNew ? null : Model.Id.ToString())"
                   class="btn btn-outline-secondary" style="border-radius:10px;">Cancel</a>
            </div>
        </div>
    </div>

<!-- ═══════════════════════════════════════════════════════════════
     Advance Payment Modal (inside form so inputs are submitted)
     ════════════════════════════════════════════════════════════════ -->
@if (Model.IsNew)
{
<div class="modal fade" id="advPaymentModal" tabindex="-1" aria-labelledby="advPaymentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="border-radius:14px;">
            <div class="modal-header" style="background:#f0f4ff;border-radius:14px 14px 0 0;">
                <h5 class="modal-title fw-bold" id="advPaymentModalLabel">
                    <i class="bi bi-wallet2 me-2 text-primary"></i>Record Advance Payment
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">

                <!-- Invoice amount summary bar -->
                <div class="d-flex flex-wrap gap-3 mb-3 p-2 rounded" style="background:#f8fafc;font-size:.85rem;">
                    <span><span class="text-muted">Invoice Amount:</span> <strong id="adv-invoiceTotal">₹0.00</strong></span>
                    <span><span class="text-muted">Received Amount:</span> <strong class="text-success" id="adv-receivedAmt">₹0.00</strong></span>
                    <span><span class="text-muted">Balance Due:</span> <strong style="color:#854d0e;" id="adv-balance">₹0.00</strong></span>
                </div>

                <!-- Payment lines -->
                <div id="advPaymentLinesContainer"></div>

                <button type="button" class="btn btn-sm btn-outline-primary mt-1" onclick="advAddRow()">
                    <i class="bi bi-plus-lg me-1"></i> Add Row
                </button>

                <div class="d-flex justify-content-between align-items-center mt-3 pt-2 border-top">
                    <span class="fw-semibold">Total Paying</span>
                    <span class="fw-bold" style="font-size:1.1rem;color:#180a3c;" id="advTotalDisplay">₹0.00</span>
                </div>
                <div id="advOverWarning" class="alert alert-warning py-1 px-2 mt-2 d-none" style="font-size:.8rem;">
                    <i class="bi bi-exclamation-triangle me-1"></i> Total exceeds received amount.
                </div>
                <div id="advUnderWarning" class="alert alert-info py-1 px-2 mt-2 d-none" style="font-size:.8rem;">
                    <i class="bi bi-info-circle me-1"></i> Partial advance — remaining balance will stay as due on the invoice.
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn text-white fw-semibold px-4" style="background:#180a3c;border:none;border-radius:8px;"
                        onclick="advConfirm()">
                    <i class="bi bi-check-circle me-1"></i> Confirm &amp; Save Invoice
                </button>
            </div>
        </div>
    </div>
</div>
}
</form>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
    const COMPANY_GSTIN = '@Html.Raw(companyGstin)';
    const PARTIES_DATA  = @Html.Raw(partiesJson);
    let productRates    = [];

    function isInterState() {
        const partyId  = document.getElementById('PartyId')?.value;
        const party    = PARTIES_DATA.find(p => String(p.id) === String(partyId));
        const pGstin   = party?.gstinNo ?? '';
        if (!pGstin || pGstin.length < 2 || !COMPANY_GSTIN || COMPANY_GSTIN.length < 2) return false;
        return pGstin.substring(0, 2).toUpperCase() !== COMPANY_GSTIN.substring(0, 2).toUpperCase();
    }

    function computeRow(row) {
        const qty      = parseFloat(row.querySelector('.line-qty')?.value)  || 0;
        const rate     = parseFloat(row.querySelector('.line-rate')?.value) || 0;
        const disc     = parseFloat(row.querySelector('.line-disc')?.value) || 0;
        const taxable  = qty * rate - qty * rate * disc / 100;
        const gstPct   = parseFloat(row.querySelector('.line-gst')?.value) || 0;
        const inter    = isInterState();

        let cgst = 0, sgst = 0, igst = 0;
        if (inter) {
            igst = taxable * gstPct / 100;
        } else {
            cgst = taxable * gstPct / 200;
            sgst = taxable * gstPct / 200;
        }
        const gstAmt = cgst + sgst + igst;

        const taxableEl = row.querySelector('.line-taxable');
        if (taxableEl) taxableEl.value = taxable.toFixed(2);
        const gstAmtEl = row.querySelector('.line-gst-amt');
        if (gstAmtEl) gstAmtEl.value = gstAmt.toFixed(2);
        const hidCgst = row.querySelector('.hid-cgst');
        if (hidCgst) hidCgst.value = cgst.toFixed(4);
        const hidSgst = row.querySelector('.hid-sgst');
        if (hidSgst) hidSgst.value = sgst.toFixed(4);
        const hidIgst = row.querySelector('.hid-igst');
        if (hidIgst) hidIgst.value = igst.toFixed(4);

        return { taxable, cgst, sgst, igst };
    }

    function recompute() {
        let subTotal = 0, totalCgst = 0, totalSgst = 0, totalIgst = 0;
        document.querySelectorAll('#lineBody .line-row').forEach(r => {
            const { taxable, cgst, sgst, igst } = computeRow(r);
            subTotal  += taxable;
            totalCgst += cgst;
            totalSgst += sgst;
            totalIgst += igst;
        });
        const grandTotal = subTotal + totalCgst + totalSgst + totalIgst;
        document.getElementById('subTotalDisplay').textContent  = '₹' + subTotal.toFixed(2);
        document.getElementById('grandTotalDisplay').textContent = '₹' + grandTotal.toFixed(2);

        const rowCgst = document.getElementById('row-cgst');
        const rowSgst = document.getElementById('row-sgst');
        const rowIgst = document.getElementById('row-igst');
        if (isInterState()) {
            rowCgst.style.display = 'none'; rowSgst.style.display = 'none';
            rowIgst.style.display = totalIgst > 0 || document.querySelectorAll('#lineBody .line-row').length > 0 ? '' : 'none';
            document.getElementById('igstDisplay').textContent = '₹' + totalIgst.toFixed(2);
        } else {
            rowIgst.style.display = 'none';
            rowCgst.style.display = totalCgst > 0 || document.querySelectorAll('#lineBody .line-row').length > 0 ? '' : 'none';
            rowSgst.style.display = totalSgst > 0 || document.querySelectorAll('#lineBody .line-row').length > 0 ? '' : 'none';
            document.getElementById('cgstDisplay').textContent = '₹' + totalCgst.toFixed(2);
            document.getElementById('sgstDisplay').textContent = '₹' + totalSgst.toFixed(2);
        }
    }

    function populatePicker(select) {
        select.innerHTML = '<option value="">↓ From rate list…</option>';
        productRates.forEach(pr => {
            const opt = document.createElement('option');
            opt.value = pr.id;
            const freq = pr.billingFrequency ? ` / ${pr.billingFrequency}` : '';
            opt.textContent = `${pr.productName} – ${pr.billingModel}${freq} — ₹${pr.rate}`;
            select.appendChild(opt);
        });
    }

    function wireRow(row) {
        const picker = row.querySelector('.prod-picker');
        if (picker) {
            populatePicker(picker);
            picker.addEventListener('change', () => {
                const pr = productRates.find(r => String(r.id) === picker.value);
                if (!pr) return;
                row.querySelector('.item-desc').value = pr.productName   || '';
                row.querySelector('.item-plan').value = pr.pricingModel  || '';
                const isSubscription = (pr.billingModel || '').toLowerCase() === 'subscription';
                row.querySelector('.item-type').value = isSubscription ? 'Subscription' : 'Onetime';
                row.querySelector('.line-rate').value = pr.rate          || 0;
                computeRow(row);
                recompute();
            });
        }
        row.querySelectorAll('.line-qty,.line-rate,.line-disc,.line-gst').forEach(el =>
            el.addEventListener('input', recompute)
        );
        row.querySelector('.line-gst')?.addEventListener('change', recompute);
    }

    function reindex() {
        document.querySelectorAll('#lineBody .line-row').forEach((row, i) => {
            row.querySelector('.sno-cell').textContent = i + 1;
            row.querySelectorAll('input, select').forEach(el => {
                if (el.name) el.name = el.name.replace(/Lines\[\d+\]/g, `Lines[${i}]`);
            });
        });
    }

    function addLineRow() {
        const body  = document.getElementById('lineBody');
        const index = body.querySelectorAll('.line-row').length;
        const row   = document.createElement('tr');
        row.className = 'line-row';
        row.innerHTML = `
            <td class="ps-3 sno-cell align-middle" style="color:#94a3b8;font-size:.8rem;">${index+1}</td>
            <td>
                <select class="form-select form-select-sm prod-picker mb-1" style="font-size:.75rem;"><option value="">↓ From rate list…</option></select>
                <input type="text" name="Lines[${index}].ItemDescription" class="form-control form-control-sm item-desc" placeholder="Item description…" required />
            </td>
            <td><input type="text" name="Lines[${index}].PlanName" class="form-control form-control-sm item-plan" /></td>
            <td><input type="text" name="Lines[${index}].Type" class="form-control form-control-sm item-type" /></td>
            <td><input type="number" name="Lines[${index}].Qty" value="1" class="form-control form-control-sm line-qty" min="1" /></td>
            <td><input type="number" name="Lines[${index}].Rate" value="0" class="form-control form-control-sm line-rate" min="0" step="0.01" /></td>
            <td><input type="number" name="Lines[${index}].DiscountPercent" value="0" class="form-control form-control-sm line-disc" min="0" max="100" step="0.01" /></td>
            <td><input type="text" readonly class="form-control form-control-sm line-taxable bg-light" value="0.00" /></td>
            <td>
                <select name="Lines[${index}].GstPercent" class="form-select form-select-sm line-gst">
                    <option value="0">0%</option><option value="5">5%</option>
                    <option value="12">12%</option><option value="18">18%</option>
                    <option value="28">28%</option>
                </select>
            </td>
            <td><input type="text" readonly class="form-control form-control-sm line-gst-amt bg-light" value="0.00" /></td>
            <td>
                <input type="hidden" name="Lines[${index}].CgstAmount" class="hid-cgst" value="0" />
                <input type="hidden" name="Lines[${index}].SgstAmount" class="hid-sgst" value="0" />
                <input type="hidden" name="Lines[${index}].IgstAmount" class="hid-igst" value="0" />
                <button type="button" class="btn btn-sm btn-outline-danger px-2" onclick="removeRow(this)"><i class="bi bi-x-lg"></i></button>
            </td>`;
        body.appendChild(row);
        wireRow(row);
        recompute();
    }

    function removeRow(btn) {
        const body = document.getElementById('lineBody');
        if (body.querySelectorAll('.line-row').length <= 1) return;
        btn.closest('.line-row').remove();
        reindex();
        recompute();
    }

    document.addEventListener('DOMContentLoaded', () => {
        fetch('/Invoice/ProductRatesJson')
            .then(r => r.json())
            .then(data => {
                productRates = data;
                document.querySelectorAll('#lineBody .line-row').forEach(row => wireRow(row));
                recompute();
            })
            .catch(() => {
                document.querySelectorAll('#lineBody .line-row').forEach(row => wireRow(row));
                recompute();
            });

        // Auto-fetch previous balance on party change
        function fetchPartyBalance(partyId) {
            if (!partyId) {
                document.getElementById('PreviousBalance').value = '0';
                recompute();
                return;
            }
            const loader = document.getElementById('prevBalLoader');
            const field  = document.getElementById('PreviousBalance');
            loader?.classList.remove('d-none');
            const excludeId = @(Model.Id > 0 ? Model.Id.ToString() : "0");
            const url = `/Invoice/PartyBalanceJson?partyId=${partyId}${excludeId > 0 ? '&excludeInvoiceId=' + excludeId : ''}`;
            fetch(url)
                .then(r => r.json())
                .then(d => {
                    field.value = (d.balance ?? 0).toFixed(2);
                    recompute();
                })
                .catch(() => { field.value = '0'; recompute(); })
                .finally(() => loader?.classList.add('d-none'));
        }

        document.getElementById('PartyId')?.addEventListener('change', function () {
            fetchPartyBalance(this.value);
            recompute();
        });

        // On page load, fetch balance if party is already pre-selected (e.g. from quotation) and PreviousBalance is 0
        const initialPartyId = document.getElementById('PartyId')?.value;
        const initialBalance = parseFloat(document.getElementById('PreviousBalance')?.value ?? '0');
        if (initialPartyId && initialBalance === 0) {
            fetchPartyBalance(initialPartyId);
        }
    });

    // ── Authorised Signatory dropdown ─────────────────────────
    function toggleSignatoryDropdown() {
        var m = document.getElementById('signatoryMenu');
        if (!m) return;
        m.style.display = m.style.display === 'none' ? 'block' : 'none';
    }
    document.addEventListener('click', function(e) {
        var menu = document.getElementById('signatoryMenu');
        var btn  = document.getElementById('signatoryBtn');
        if (menu && btn && !btn.contains(e.target) && !menu.contains(e.target))
            menu.style.display = 'none';
    });
    document.querySelectorAll('.sig-check').forEach(function(cb) {
        cb.addEventListener('change', updateSignatorySelection);
    });
    function updateSignatorySelection() {
        var checked = Array.from(document.querySelectorAll('.sig-check:checked'));
        if (checked.length > 3) {
            this.checked = false;
            checked = Array.from(document.querySelectorAll('.sig-check:checked'));
        }
        document.querySelectorAll('.sig-check').forEach(function(cb) {
            cb.disabled = (!cb.checked && checked.length >= 3);
            cb.closest('label').style.opacity = cb.disabled ? '0.45' : '1';
        });
        var label = document.getElementById('signatoryLabel');
        label.textContent = checked.length === 0 ? '-- Select Signatories --'
            : checked.map(function(cb) { return cb.closest('label').querySelector('span').textContent.trim(); }).join(', ');
        var chips = document.getElementById('signatoryChips');
        chips.innerHTML = '';
        checked.forEach(function(cb, i) {
            var name = cb.closest('label').querySelector('span').textContent.trim();
            var pos  = ['Left','Middle','Right'][i] || '';
            var chip = document.createElement('span');
            chip.className = 'badge rounded-pill';
            chip.style.cssText = 'background:#ede9fe;color:#6d28d9;font-size:.78rem;padding:4px 10px;';
            chip.textContent = pos + ': ' + name;
            chips.appendChild(chip);
        });
    }
    updateSignatorySelection();

    // ── Edit mode: simple passthrough ──────────────────────────
    @if (!Model.IsNew)
    {
        <text>
    function handleSubmit() { document.getElementById('invoiceForm').submit(); }
        </text>
    }
</script>
}

@if (Model.IsNew)
{
<script>
    // ══════════════════════════════════════════════════════════
    // Advance Payment Modal logic (new invoice / convert flow)
    // ══════════════════════════════════════════════════════════
    var advLineIndex   = 0;
    var advReceivedAmt = 0;

    var ADV_MODES = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        paymentModes.Select(m => new { id = m.Id, name = m.Name })));

    var ADV_BANKS = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        banks.Select(b => new { id = b.Id, name = b.BankName })));

    var ADV_BANK_MODES = ['cheque','neft','rtgs','imps','bank transfer','cards'];
    var ADV_CARD_MODES = ['cards'];

    function advBankLabelFor(modeName) {
        if (modeName === 'cards') return 'Card Bank';
        if (['bank transfer','neft','rtgs'].includes(modeName)) return 'Received Bank';
        return 'Bank';
    }
    function advModeNameOf(sel) {
        var opt = sel.options[sel.selectedIndex];
        return opt ? (opt.dataset.name || opt.text || '').toLowerCase().trim() : '';
    }
    function advOnModeChange(sel) {
        var row      = sel.closest('.adv-line-row');
        var modeName = advModeNameOf(sel);
        var extra    = row.querySelector('.adv-extra');
        var cardDiv  = row.querySelector('.adv-card-fields');
        var bankDiv  = row.querySelector('.adv-bank-field');
        var bankLbl  = row.querySelector('.adv-bank-label');
        var cardType = row.querySelector('.adv-card-type');
        var last4    = row.querySelector('.adv-last4');
        var bankSel  = row.querySelector('.adv-bank-sel');
        var showCard = ADV_CARD_MODES.includes(modeName);
        var showBank = ADV_BANK_MODES.includes(modeName);
        extra.style.display  = (showCard || showBank) ? '' : 'none';
        cardDiv.style.display = showCard ? '' : 'none';
        bankDiv.style.display = showBank ? '' : 'none';
        if (bankLbl) bankLbl.innerHTML = advBankLabelFor(modeName) + ' <span class="text-danger">*</span>';
        if (cardType) cardType.required = showCard;
        if (last4)    last4.required    = showCard;
        if (bankSel)  bankSel.required  = showBank;
        if (!showCard) { if (cardType) cardType.value = ''; if (last4) last4.value = ''; }
        if (!showBank) { if (bankSel)  bankSel.value  = ''; }
        advUpdateTotal();
    }
    function advBuildModeOpts() {
        return '<option value="" data-name="">\u2014 Select Mode \u2014</option>' +
            ADV_MODES.map(function(m) {
                return '<option value="' + m.id + '" data-name="' + m.name + '">' + m.name + '</option>';
            }).join('');
    }
    function advBuildBankOpts() {
        return '<option value="">\u2014 Select Bank \u2014</option>' +
            ADV_BANKS.map(function(b) {
                return '<option value="' + b.id + '">' + b.name + '</option>';
            }).join('');
    }
    function sanitizeDigits(inp) { inp.value = inp.value.replace(/\D/g, ''); }
    function advBuildRow(i) {
        var html =
            '<div class="adv-line-row border rounded p-2 mb-2 position-relative" data-index="' + i + '">' +
            '<button type="button" class="btn-close position-absolute" style="top:6px;right:6px;font-size:.6rem;" onclick="advRemoveRow(this)"></button>' +
            '<div class="mb-2"><label class="form-label form-label-sm fw-semibold mb-1">Payment Mode</label>' +
            '<select class="form-select form-select-sm adv-mode-sel" name="AdvancePaymentLines[' + i + '].PaymentModeId" onchange="advOnModeChange(this)" required>' + advBuildModeOpts() + '</select></div>' +
            '<div class="row g-2">' +
            '<div class="col-6"><label class="form-label form-label-sm fw-semibold mb-1">Amount</label>' +
            '<input type="number" class="form-control form-control-sm adv-amount" name="AdvancePaymentLines[' + i + '].Amount"' +
            ' placeholder="0.00" step="0.01" min="0.01" required oninput="advUpdateTotal()" /></div>' +
            '<div class="col-6"><label class="form-label form-label-sm fw-semibold mb-1">Reference No</label>' +
            '<input type="text" class="form-control form-control-sm" name="AdvancePaymentLines[' + i + '].ReferenceNo" placeholder="Cheque/UTR/etc." /></div></div>' +
            '<div class="adv-extra mt-2" style="display:none;">' +
            '<div class="adv-card-fields row g-2 mb-2" style="display:none;">' +
            '<div class="col-6"><label class="form-label form-label-sm fw-semibold mb-1">Card Type <span class="text-danger">*</span></label>' +
            '<select class="form-select form-select-sm adv-card-type" name="AdvancePaymentLines[' + i + '].CardType">' +
            '<option value="">\u2014 Select \u2014</option><option value="Debit">Debit</option><option value="Credit">Credit</option></select></div>' +
            '<div class="col-6"><label class="form-label form-label-sm fw-semibold mb-1">Last 4 Digits <span class="text-danger">*</span></label>' +
            '<input type="text" class="form-control form-control-sm adv-last4" name="AdvancePaymentLines[' + i + '].CardLastFour"' +
            ' maxlength="4" placeholder="e.g. 1234" oninput="sanitizeDigits(this)" /></div></div>' +
            '<div class="adv-bank-field mb-2" style="display:none;">' +
            '<label class="form-label form-label-sm fw-semibold mb-1 adv-bank-label">Bank <span class="text-danger">*</span></label>' +
            '<select class="form-select form-select-sm adv-bank-sel" name="AdvancePaymentLines[' + i + '].BankId">' + advBuildBankOpts() + '</select></div>' +
            '</div></div>';
        return html;
    }
    function advAddRow() {
        advLineIndex++;
        var i = advLineIndex - 1;
        document.getElementById('advPaymentLinesContainer').insertAdjacentHTML('beforeend', advBuildRow(i));
        advUpdateTotal();
    }
    function advRemoveRow(btn) {
        if (document.querySelectorAll('.adv-line-row').length <= 1) return;
        btn.closest('.adv-line-row').remove();
        advUpdateTotal();
    }
    function advUpdateTotal() {
        var total = 0;
        document.querySelectorAll('.adv-amount').forEach(function(inp) { total += parseFloat(inp.value) || 0; });
        document.getElementById('advTotalDisplay').textContent = '\u20b9' + total.toFixed(2);
        document.getElementById('advOverWarning').classList.toggle('d-none',  total <= advReceivedAmt + 0.005);
        document.getElementById('advUnderWarning').classList.toggle('d-none', total >= advReceivedAmt - 0.005 || total === 0);
    }

    // ── Main submit button ─────────────────────────────────────
    function handleSubmit() {
        var received = parseFloat(document.getElementById('ReceivedAmount') && document.getElementById('ReceivedAmount').value) || 0;
        if (received <= 0) { document.getElementById('invoiceForm').submit(); return; }

        var grandTotalText = document.getElementById('grandTotalDisplay') ? document.getElementById('grandTotalDisplay').textContent : '0';
        var grandTotal = parseFloat(grandTotalText.replace(/[^\d.]/g, '')) || 0;
        advReceivedAmt = received;
        document.getElementById('adv-invoiceTotal').textContent = '\u20b9' + grandTotal.toFixed(2);
        document.getElementById('adv-receivedAmt').textContent  = '\u20b9' + received.toFixed(2);
        document.getElementById('adv-balance').textContent      = '\u20b9' + Math.max(0, grandTotal - received).toFixed(2);

        advLineIndex = 0;
        document.getElementById('advPaymentLinesContainer').innerHTML = '';
        advAddRow();
        var firstAmt = document.querySelector('.adv-amount');
        if (firstAmt) { firstAmt.value = received.toFixed(2); advUpdateTotal(); }

        new bootstrap.Modal(document.getElementById('advPaymentModal')).show();
    }

    function advConfirm() {
        var total = 0;
        document.querySelectorAll('.adv-amount').forEach(function(inp) { total += parseFloat(inp.value) || 0; });
        if (total > advReceivedAmt + 0.005) {
            document.getElementById('advOverWarning').classList.remove('d-none');
            return;
        }
        if (total <= 0) { alert('Please enter at least one payment amount.'); return; }
        var inst = bootstrap.Modal.getInstance(document.getElementById('advPaymentModal'));
        if (inst) inst.hide();
        document.getElementById('invoiceForm').submit();
    }
</script>
}