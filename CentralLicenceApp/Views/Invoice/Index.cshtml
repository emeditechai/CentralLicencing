@model List<CentralLicenceApp.Models.Invoice>
@using System.Linq
@{
    ViewData["Title"] = "Invoices";
    var today          = DateTime.Today;
    var totalBilled    = Model.Where(i => i.Status != "Cancelled").Sum(i => i.TotalAmount);
    var totalReceived  = Model.Sum(i => i.ReceivedAmount);
    var totalBalance   = Model.Where(i => i.Status != "Cancelled").Sum(i => i.CurrentBalance);
    var paidCount      = Model.Count(i => i.Status == "Paid");
    var partialCount   = Model.Count(i => i.Status == "Partial");
    var draftCount     = Model.Count(i => i.Status == "Draft");
    var overdueCount   = Model.Count(i => i.Status is not "Paid" and not "Cancelled" && i.DueDate.HasValue && i.DueDate.Value.Date < today);
    var cancelledCount  = Model.Count(i => i.Status == "Cancelled");
    var cancelledAmount = Model.Where(i => i.Status == "Cancelled").Sum(i => i.TotalAmount);
    var fromVal        = ViewBag.From   as string ?? string.Empty;
    var toVal          = ViewBag.To     as string ?? string.Empty;
    var statusVal      = ViewBag.Status as string ?? string.Empty;
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;">Invoices</h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">
            @Model.Count invoice@(Model.Count == 1 ? "" : "s")
            <span class="ms-1" style="color:#6366f1;">(@fromVal.Replace("-","/") – @toVal.Replace("-","/"))</span>
        </p>
    </div>
    @if (User.IsInRole("Administrator"))
    {
        <a asp-action="Create" class="btn btn-primary" style="background:#180a3c;border:none;border-radius:10px;">
            <i class="bi bi-plus-lg me-1"></i> New Invoice
        </a>
    }
</div>

<!-- Filter Bar -->
<form method="get" asp-action="Index" class="card mb-4 border-0 shadow-sm">
    <div class="card-body py-3">
        <div class="row g-2 align-items-end">
            <div class="col-6 col-md-3">
                <label class="form-label mb-1" style="font-size:.78rem;font-weight:600;">From Date</label>
                <input type="date" name="from" value="@fromVal" class="form-control form-control-sm" style="border-radius:8px;" />
            </div>
            <div class="col-6 col-md-3">
                <label class="form-label mb-1" style="font-size:.78rem;font-weight:600;">To Date</label>
                <input type="date" name="to" value="@toVal" class="form-control form-control-sm" style="border-radius:8px;" />
            </div>
            <div class="col-6 col-md-3">
                <label class="form-label mb-1" style="font-size:.78rem;font-weight:600;">Status</label>
                <select name="status" class="form-select form-select-sm" style="border-radius:8px;">
                    <option value=""          selected="@(statusVal == "")">All Status</option>
                    <option value="Draft"     selected="@(statusVal == "Draft")">Draft</option>
                    <option value="Sent"      selected="@(statusVal == "Sent")">Sent</option>
                    <option value="Partial"   selected="@(statusVal == "Partial")">Partial</option>
                    <option value="Paid"      selected="@(statusVal == "Paid")">Paid</option>
                    <option value="Cancelled" selected="@(statusVal == "Cancelled")">Cancelled</option>
                </select>
            </div>
            <div class="col-6 col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-primary flex-fill" style="background:#6366f1;border:none;border-radius:8px;">
                    <i class="bi bi-funnel me-1"></i> Filter
                </button>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary" style="border-radius:8px;" title="Clear filters">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </div>
    </div>
</form>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card h-100 border-0 shadow-sm" style="border-radius:14px;">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="rounded-3 d-flex align-items-center justify-content-center" style="width:36px;height:36px;background:#ede9fe;">
                        <i class="bi bi-receipt-cutoff" style="color:#7c3aed;font-size:1.05rem;"></i>
                    </div>
                    <span class="text-muted" style="font-size:.74rem;font-weight:600;letter-spacing:.03em;">TOTAL BILLED</span>
                </div>
                <div class="fw-bold" style="font-size:1.25rem;color:#1e293b;line-height:1.2;">₹@totalBilled.ToString("N2")</div>
                <div class="text-muted mt-1" style="font-size:.73rem;">@Model.Count invoices</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card h-100 border-0 shadow-sm" style="border-radius:14px;">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="rounded-3 d-flex align-items-center justify-content-center" style="width:36px;height:36px;background:#dcfce7;">
                        <i class="bi bi-cash-stack" style="color:#16a34a;font-size:1.05rem;"></i>
                    </div>
                    <span class="text-muted" style="font-size:.74rem;font-weight:600;letter-spacing:.03em;">RECEIVED</span>
                </div>
                <div class="fw-bold" style="font-size:1.25rem;color:#16a34a;line-height:1.2;">₹@totalReceived.ToString("N2")</div>
                <div class="text-muted mt-1" style="font-size:.73rem;">@paidCount paid in full</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card h-100 border-0 shadow-sm" style="border-radius:14px;">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="rounded-3 d-flex align-items-center justify-content-center" style="width:36px;height:36px;background:#fef3c7;">
                        <i class="bi bi-hourglass-split" style="color:#d97706;font-size:1.05rem;"></i>
                    </div>
                    <span class="text-muted" style="font-size:.74rem;font-weight:600;letter-spacing:.03em;">OUTSTANDING</span>
                </div>
                <div class="fw-bold" style="font-size:1.25rem;color:#d97706;line-height:1.2;">₹@totalBalance.ToString("N2")</div>
                <div class="text-muted mt-1" style="font-size:.73rem;">@partialCount partial</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card h-100 border-0 shadow-sm" style="border-radius:14px;">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="rounded-3 d-flex align-items-center justify-content-center" style="width:36px;height:36px;background:#fee2e2;">
                        <i class="bi bi-exclamation-triangle" style="color:#dc2626;font-size:1.05rem;"></i>
                    </div>
                    <span class="text-muted" style="font-size:.74rem;font-weight:600;letter-spacing:.03em;">OVERDUE</span>
                </div>
                <div class="fw-bold" style="font-size:1.6rem;color:#dc2626;line-height:1.1;">@overdueCount</div>
                <div class="text-muted mt-1" style="font-size:.73rem;">Past due date</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card h-100 border-0 shadow-sm" style="border-radius:14px;">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="rounded-3 d-flex align-items-center justify-content-center" style="width:36px;height:36px;background:#f1f5f9;">
                        <i class="bi bi-pencil-square" style="color:#64748b;font-size:1.05rem;"></i>
                    </div>
                    <span class="text-muted" style="font-size:.74rem;font-weight:600;letter-spacing:.03em;">DRAFT</span>
                </div>
                <div class="fw-bold" style="font-size:1.6rem;color:#1e293b;line-height:1.1;">@draftCount</div>
                <div class="text-muted mt-1" style="font-size:.73rem;">Not sent</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card h-100 border-0 shadow-sm" style="border-radius:14px;">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="rounded-3 d-flex align-items-center justify-content-center" style="width:36px;height:36px;background:#f8fafc;">
                        <i class="bi bi-slash-circle" style="color:#94a3b8;font-size:1.05rem;"></i>
                    </div>
                    <span class="text-muted" style="font-size:.74rem;font-weight:600;letter-spacing:.03em;">CANCELLED</span>
                </div>
                <div class="fw-bold" style="font-size:1.25rem;color:#94a3b8;line-height:1.2;">₹@cancelledAmount.ToString("N2")</div>
                <div class="text-muted mt-1" style="font-size:.73rem;">@cancelledCount Voided</div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table tbl-clean mb-0">
                <thead>
                    <tr>
                        <th class="ps-3">Invoice No</th>
                        <th>Party</th>
                        <th>Invoice Date</th>
                        <th>Due Date</th>
                        <th>Total</th>
                        <th>Balance</th>
                        <th>Status</th>
                        <th class="pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">
                                <i class="bi bi-receipt fs-1 d-block mb-2"></i>No invoices yet
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            var statusStyle = item.Status switch
                            {
                                "Paid"    => "background:#dcfce7;color:#166534;",
                                "Partial" => "background:#fef9c3;color:#854d0e;",
                                "Sent"    => "background:#dbeafe;color:#1d4ed8;",
                                _         => "background:#f1f5f9;color:#475569;"
                            };
                            <tr>
                                <td class="ps-3">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="fw-semibold" style="color:#6366f1;text-decoration:none;">@item.InvoiceNo</a>
                                    @if (!string.IsNullOrWhiteSpace(item.QuotationNo))
                                    {
                                        <div class="text-muted" style="font-size:.74rem;"><i class="bi bi-arrow-return-left me-1"></i>From @item.QuotationNo</div>
                                    }
                                </td>
                                <td class="fw-semibold" style="font-size:.875rem;">@item.PartyName</td>
                                <td style="font-size:.85rem;">@item.InvoiceDate.ToString("dd MMM yyyy")</td>
                                <td style="font-size:.85rem;">@(item.DueDate.HasValue ? item.DueDate.Value.ToString("dd MMM yyyy") : "—")</td>
                                <td class="fw-semibold">₹@item.TotalAmount.ToString("0.00")</td>
                                <td class="fw-semibold @(item.CurrentBalance > 0 ? "text-danger" : "text-success")">
                                    ₹@item.CurrentBalance.ToString("0.00")
                                </td>
                                <td><span class="badge rounded-pill px-2 py-1" style="font-size:.72rem;@statusStyle">@item.Status</span></td>
                                <td class="pe-3">
                                    <div class="d-flex gap-2">
                                        <a asp-action="Details" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-primary" style="border-radius:8px;font-size:.78rem;" title="View">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (User.IsInRole("Administrator"))
                                        {
                                            @if (item.ReceivedAmount == 0)
                                            {
                                                <a asp-action="Edit" asp-route-id="@item.Id"
                                                   class="btn btn-sm btn-outline-secondary" style="border-radius:8px;font-size:.78rem;" title="Edit">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-outline-secondary disabled" style="border-radius:8px;font-size:.78rem;" title="Cannot edit — payment recorded" disabled>
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                            }
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
