@model CentralLicenceApp.Models.Invoice
@using CentralLicenceApp.Repositories
@inject IInvoicePaymentRepository InvoicePaymentRepo
@{
    ViewData["Title"] = "Invoice – " + Model.InvoiceNo;
    var statusStyle = Model.Status switch
    {
        "Paid"      => "background:#dcfce7;color:#166534;",
        "Partial"   => "background:#fef9c3;color:#854d0e;",
        "Sent"      => "background:#dbeafe;color:#1d4ed8;",
        "Cancelled" => "background:#fee2e2;color:#b91c1c;",
        _           => "background:#f1f5f9;color:#475569;"
    };
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary" style="border-radius:8px;"><i class="bi bi-arrow-left"></i></a>
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;">Invoice Details</h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">@Model.InvoiceNo</p>
    </div>
    <span class="badge rounded-pill px-3 py-2 ms-auto" style="font-size:.8rem;@statusStyle">@Model.Status</span>
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <!-- Party & Dates -->
        <div class="card mb-3">
            <div class="card-header"><i class="bi bi-building me-2" style="color:#6366f1;"></i>Bill To</div>
            <div class="card-body">
                <dl class="row mb-0" style="font-size:.875rem;">
                    <dt class="col-sm-4 text-muted fw-normal">Party Name</dt>
                    <dd class="col-sm-8 fw-semibold">@Model.PartyName</dd>
                    @if (!string.IsNullOrWhiteSpace(Model.PartyAddress))
                    {
                        <dt class="col-sm-4 text-muted fw-normal">Address</dt>
                        <dd class="col-sm-8">@Model.PartyAddress</dd>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.PartyGSTINNo))
                    {
                        <dt class="col-sm-4 text-muted fw-normal">GSTIN</dt>
                        <dd class="col-sm-8"><code>@Model.PartyGSTINNo</code></dd>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.PartyPANNo))
                    {
                        <dt class="col-sm-4 text-muted fw-normal">PAN</dt>
                        <dd class="col-sm-8"><code>@Model.PartyPANNo</code></dd>
                    }
                    <dt class="col-sm-4 text-muted fw-normal">Invoice Date</dt>
                    <dd class="col-sm-8">@Model.InvoiceDate.ToString("dd MMM yyyy")</dd>
                    <dt class="col-sm-4 text-muted fw-normal">Due Date</dt>
                    <dd class="col-sm-8 @(Model.DueDate.HasValue && Model.DueDate < DateTime.Today && Model.Status != "Paid" ? "text-danger fw-semibold" : "")">
                        @(Model.DueDate.HasValue ? Model.DueDate.Value.ToString("dd MMM yyyy") : "—")
                    </dd>
                    @if (!string.IsNullOrWhiteSpace(Model.QuotationNo))
                    {
                        <dt class="col-sm-4 text-muted fw-normal">From Quotation</dt>
                        <dd class="col-sm-8">
                            <a asp-controller="Quotation" asp-action="Details" asp-route-id="@Model.QuotationId">@Model.QuotationNo</a>
                        </dd>
                    }
                </dl>
            </div>
        </div>

        <!-- Line Items -->
        <div class="card mb-3">
            <div class="card-header"><i class="bi bi-list-ul me-2" style="color:#6366f1;"></i>Line Items</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3" style="width:40px;">#</th>
                                <th>Item</th>
                                <th>Plan</th>
                                <th>Type</th>
                                <th class="text-end">Qty</th>
                                <th class="text-end">Rate</th>
                                <th class="text-end">Disc</th>
                                <th class="text-end">Taxable</th>
                                <th class="text-end">GST %</th>
                                <th class="text-end pe-3">GST Amt</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var line in Model.Lines)
                            {
                                var lineGst = line.CgstAmount + line.SgstAmount + line.IgstAmount;
                                <tr>
                                    <td class="ps-3 text-muted" style="font-size:.8rem;">@line.SNo</td>
                                    <td class="fw-semibold" style="font-size:.875rem;">@line.ItemDescription</td>
                                    <td style="font-size:.82rem;">@(line.PlanName ?? "—")</td>
                                    <td style="font-size:.82rem;">@(line.Type ?? "—")</td>
                                    <td class="text-end">@line.Qty</td>
                                    <td class="text-end">₹@line.Rate.ToString("0.00")</td>
                                    <td class="text-end" style="font-size:.8rem;">
                                        @if (line.DiscountPercent > 0)
                                        { <span>₹@line.DiscountAmount.ToString("0.00") <span class="text-muted">(@line.DiscountPercent.ToString("0.##")%)</span></span> }
                                        else { <span>—</span> }
                                    </td>
                                    <td class="text-end">₹@line.Amount.ToString("0.00")</td>
                                    <td class="text-end" style="font-size:.82rem;">@line.GstPercent.ToString("0.##")%</td>
                                    <td class="text-end pe-3 fw-semibold">₹@lineGst.ToString("0.00")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Notes))
        {
            <div class="card mb-3">
                <div class="card-header"><i class="bi bi-chat-text me-2" style="color:#6366f1;"></i>Notes</div>
                <div class="card-body" style="font-size:.875rem;">@Model.Notes</div>
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.TermsAndConditions))
        {
            <div class="card mb-3">
                <div class="card-header"><i class="bi bi-file-text me-2" style="color:#6366f1;"></i>Terms &amp; Conditions</div>
                <div class="card-body terms-html" style="font-size:.875rem;">@Html.Raw(Model.TermsAndConditions)</div>
            </div>
        }

        @{
            var pmtHistory = (await InvoicePaymentRepo.GetByInvoiceIdAsync(Model.Id)).ToList();
        }
        @if (pmtHistory.Any())
        {
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-cash-coin me-2" style="color:#10b981;"></i>Payment History</span>
                    <span class="badge" style="background:#dcfce7;color:#166534;font-size:.75rem;">
                        @pmtHistory.Count receipt@(pmtHistory.Count == 1 ? "" : "s")
                    </span>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3" style="font-size:.78rem;">Receipt No</th>
                                <th style="font-size:.78rem;">Date</th>
                                <th style="font-size:.78rem;">Mode(s)</th>
                                <th class="text-end" style="font-size:.78rem;">Amount</th>
                                <th class="text-end pe-3" style="font-size:.78rem;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var pmt in pmtHistory)
                            {
                                <tr>
                                    <td class="ps-3 fw-semibold" style="font-size:.82rem;color:#6366f1;">@pmt.ReceiptNo</td>
                                    <td style="font-size:.82rem;">@pmt.PaymentDate.ToString("dd MMM yyyy")</td>
                                    <td style="font-size:.8rem;color:#555;">@string.Join(", ", pmt.Lines.Select(l => l.PaymentModeName).Distinct())</td>
                                    <td class="text-end fw-semibold" style="font-size:.82rem;">₹@pmt.TotalAmountPaid.ToString("N2")</td>
                                    <td class="text-end pe-3">
                                        <a asp-controller="InvoicePayment" asp-action="Details" asp-route-id="@pmt.Id"
                                           class="btn btn-sm btn-outline-secondary py-0 px-1" title="View" style="font-size:.75rem;">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-controller="InvoicePayment" asp-action="Print" asp-route-id="@pmt.Id"
                                           class="btn btn-sm btn-outline-primary py-0 px-1 ms-1" title="Print" target="_blank" style="font-size:.75rem;">
                                            <i class="bi bi-printer"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr style="background:#f1f5f9;">
                                <td colspan="3" class="ps-3 fw-bold" style="font-size:.82rem;">Total Received</td>
                                <td class="text-end fw-bold" style="font-size:.85rem;">₹@pmtHistory.Sum(p => p.TotalAmountPaid).ToString("N2")</td>
                                <td class="pe-3"></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        }

    </div>

    <div class="col-lg-4">
        <!-- Financial summary -->
        <div class="card mb-3">
            <div class="card-header"><i class="bi bi-cash-stack me-2" style="color:#6366f1;"></i>Summary</div>
            <div class="card-body" style="font-size:.9rem;">
                <div class="d-flex justify-content-between mb-1">
                    <span class="text-muted">Sub Total</span>
                    <span>₹@Model.SubTotal.ToString("0.00")</span>
                </div>
                @if (Model.TotalCgst > 0)
                {
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted">CGST</span>
                        <span>₹@Model.TotalCgst.ToString("0.00")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted">SGST</span>
                        <span>₹@Model.TotalSgst.ToString("0.00")</span>
                    </div>
                }
                @if (Model.TotalIgst > 0)
                {
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted">IGST</span>
                        <span>₹@Model.TotalIgst.ToString("0.00")</span>
                    </div>
                }
                @if (Model.EnableRoundOff && Model.RoundOff != 0)
                {
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted">Round Off</span>
                        <span>₹@Model.RoundOff.ToString("0.##")</span>
                    </div>
                }
                <div class="d-flex justify-content-between mb-1 fw-bold border-top pt-2">
                    <span>Total Amount</span>
                    <span>₹@Model.TotalAmount.ToString("0.00")</span>
                </div>
                <div class="d-flex justify-content-between mb-1">
                    <span class="text-muted">Received Amount</span>
                    <span>₹@Model.ReceivedAmount.ToString("0.00")</span>
                </div>
                <div class="d-flex justify-content-between fw-bold border-top pt-2 @(Model.CurrentBalance > 0 ? "text-danger" : "text-success")">
                    <span>Invoice Balance Due</span>
                    <span>₹@Model.CurrentBalance.ToString("0.00")</span>
                </div>
                @if (Model.PreviousBalance > 0)
                {
                    <div class="d-flex justify-content-between mt-2 pt-2" style="border-top:1px dashed #e2e8f0;">
                        <span class="text-muted" style="font-size:.82rem;">Party's Other Open Dues</span>
                        <span class="fw-semibold" style="color:#b45309;font-size:.82rem;">₹@Model.PreviousBalance.ToString("0.00")</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="fw-semibold" style="font-size:.82rem;">Total Party Outstanding</span>
                        <span class="fw-bold" style="color:#b91c1c;font-size:.85rem;">₹@((Model.CurrentBalance + Model.PreviousBalance).ToString("0.00"))</span>
                    </div>
                }
            </div>
        </div>

        <!-- Actions -->
        <div class="card">
            <div class="card-header"><i class="bi bi-lightning me-2" style="color:#6366f1;"></i>Actions</div>
            <div class="card-body d-flex flex-column gap-2">
                <a asp-action="Print" asp-route-id="@Model.Id"
                   class="btn btn-outline-secondary w-100" style="border-radius:10px;" target="_blank">
                    <i class="bi bi-printer me-1"></i> Print / Download
                </a>
                @if (!Model.IsCancelled && Model.Status != "Paid" && Model.CurrentBalance > 0)
                {
                    <a asp-controller="InvoicePayment" asp-action="Create" asp-route-invoiceId="@Model.Id"
                       class="btn w-100 text-white" style="background:#10b981;border:none;border-radius:10px;">
                        <i class="bi bi-cash-coin me-1"></i> Record Payment
                    </a>
                }
                @if (User.IsInRole("Administrator"))
                {
                    @if (Model.IsCancelled)
                    {
                        <div class="alert alert-danger py-2 px-3 rounded-3 mb-0" style="font-size:.82rem;">
                            <i class="bi bi-x-circle me-1"></i> This invoice has been cancelled.
                        </div>
                        @if (!string.IsNullOrWhiteSpace(Model.CancelRemarks))
                        {
                            <div class="alert alert-secondary py-2 px-3 rounded-3 mb-0" style="font-size:.82rem;">
                                <strong>Remarks:</strong> @Model.CancelRemarks
                            </div>
                        }
                    }
                    else
                    {
                        @if (Model.ReceivedAmount == 0)
                        {
                            <a asp-action="Edit" asp-route-id="@Model.Id"
                               class="btn btn-outline-primary w-100" style="border-radius:10px;">
                                <i class="bi bi-pencil me-1"></i> Edit Invoice
                            </a>
                        }
                        @if (Model.Status != "Draft")
                        {
                            <form asp-action="ResendMail" asp-route-id="@Model.Id" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn w-100 text-white" style="background:#6366f1;border:none;border-radius:10px;">
                                    <i class="bi bi-envelope-arrow-up me-1"></i> Resend Mail
                                </button>
                            </form>
                        }
                        @foreach (var s in new[] { "Draft", "Sent" }
                            .Where(x => x != Model.Status && !(x == "Draft" && Model.ReceivedAmount > 0)))
                        {
                            <form asp-action="UpdateStatus" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.Id" />
                                <input type="hidden" name="status" value="@s" />
                                <button type="submit" class="btn btn-outline-secondary w-100" style="border-radius:10px;">
                                    <i class="bi bi-arrow-repeat me-1"></i> Mark as @s
                                </button>
                            </form>
                        }
                        <button type="button" class="btn btn-outline-danger w-100" style="border-radius:10px;"
                                data-bs-toggle="modal" data-bs-target="#cancelModal">
                            <i class="bi bi-x-circle me-1"></i> Cancel Invoice
                        </button>
                    }
                }
            </div>
        </div>
    </div>
</div>

<!-- Cancel Modal -->
<div class="modal fade" id="cancelModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:16px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-danger">Cancel Invoice</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" id="cancelForm">
                @Html.AntiForgeryToken()
                <div class="modal-body pt-2">
                    <p class="text-muted" style="font-size:.88rem;">
                        You are about to cancel <strong>@Model.InvoiceNo</strong>. This action cannot be undone.
                    </p>
                    <label class="form-label fw-semibold" style="font-size:.85rem;">
                        Cancellation Remarks <span class="text-danger">*</span>
                    </label>
                    <textarea name="remarks" id="cancelRemarks" class="form-control" rows="3"
                              placeholder="Enter reason for cancellation…" style="border-radius:10px;"></textarea>
                    <div id="cancelRemarksError" class="text-danger mt-1" style="font-size:.82rem;display:none;">
                        Remarks are required.
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" style="border-radius:8px;">Close</button>
                    <button type="submit" class="btn btn-danger" style="border-radius:8px;">
                        <i class="bi bi-x-circle me-1"></i> Confirm Cancel
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
<script>
    document.getElementById('cancelForm')?.addEventListener('submit', function (e) {
        var remarks = document.getElementById('cancelRemarks').value.trim();
        if (!remarks) {
            e.preventDefault();
            document.getElementById('cancelRemarksError').style.display = 'block';
            document.getElementById('cancelRemarks').focus();
        }
    });
    document.getElementById('cancelRemarks')?.addEventListener('input', function () {
        if (this.value.trim())
            document.getElementById('cancelRemarksError').style.display = 'none';
    });
</script>
