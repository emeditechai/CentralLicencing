</div>

@section Scripts {
<script>
    // ── Search / Filter ────────────────────────────────
    (function () {
        var searchInput = document.getElementById('helpSearchInput');
        var modules = document.querySelectorAll('.help-module');
        var quickLinks = document.querySelectorAll('.quick-link-card');
        var tocLinks = document.querySelectorAll('#helpToc a');

        searchInput.addEventListener('input', function () {
            var q = this.value.trim().toLowerCase();
            modules.forEach(function (m) {
                var text = (m.textContent + ' ' + (m.dataset.keywords || '')).toLowerCase();
                m.style.display = !q || text.includes(q) ? '' : 'none';
            });
            quickLinks.forEach(function (card) {
                var href = card.getAttribute('href');
                if (!href) return;
                var target = document.querySelector(href);
                if (target) card.style.display = target.style.display;
            });
        });
    })();

    // ── Smooth scroll ──────────────────────────────────
    document.querySelectorAll('a[href^="#module-"]').forEach(function (a) {
        a.addEventListener('click', function (e) {
            e.preventDefault();
            var target = document.querySelector(this.getAttribute('href'));
            if (target) {
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                // Flash highlight
                target.style.borderColor = '#c7d2fe';
                target.style.boxShadow = '0 0 0 3px rgba(99,102,241,.12)';
                setTimeout(function () {
                    target.style.borderColor = '';
                    target.style.boxShadow = '';
                }, 1500);
            }
        });
    });

    // ── Active TOC tracking ────────────────────────────
    (function () {
        var tocLinks = document.querySelectorAll('#helpToc a');
        var modules = document.querySelectorAll('.help-module[id]');
        if (!tocLinks.length || !modules.length) return;

        function updateActive() {
            var scrollY = window.scrollY + 120;
            var current = '';
            modules.forEach(function (m) {
                if (m.offsetTop <= scrollY) current = '#' + m.id;
            });
            tocLinks.forEach(function (a) {
                a.classList.toggle('active', a.getAttribute('href') === current);
            });
        }
        window.addEventListener('scroll', updateActive, { passive: true });
        updateActive();
    })();
</script>
}
