@model List<CentralLicenceApp.Models.LicenseValidationHistory>
@{
    ViewData["Title"] = "Validation History" + (ViewBag.ProductType != null ? " – " + ViewBag.ProductType : "");
    int page       = ViewBag.Page;
    int pageSize   = ViewBag.PageSize;
    int total      = ViewBag.Total;
    int totalPages = ViewBag.TotalPages;
    string? productType = ViewBag.ProductType;
    var selectedPT = productType ?? "";
    var availableProductTypes = ViewBag.AvailableProductTypes as List<string> ?? new List<string>();
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;">Validation History</h4>
        @if (!string.IsNullOrEmpty(selectedPT))
        {
            <p class="text-muted mb-0" style="font-size:.82rem;">Showing data for <strong style="color:#6366f1;">@selectedPT</strong> &mdash; @total event(s)</p>
        }
        else
        {
            <p class="text-muted mb-0" style="font-size:.85rem;">@total validation event(s)</p>
        }
    </div>
    <div class="d-flex align-items-center gap-2 flex-wrap">
        @if (TempData["PurgeSuccess"] != null)
        {
            <span class="badge bg-success px-3 py-2" style="border-radius:8px;font-size:.8rem;">
                <i class="bi bi-check-circle me-1"></i>@TempData["PurgeSuccess"]
            </span>
        }
        <button type="button" class="btn btn-sm btn-outline-danger" style="border-radius:10px;"
                data-bs-toggle="modal" data-bs-target="#purgeLogs7DaysModal">
            <i class="bi bi-trash3 me-1"></i> Keep Last 7 Days
        </button>
        <form method="get" class="d-flex align-items-center gap-2">
            <label class="fw-semibold mb-0" style="font-size:.82rem;color:#64748b;white-space:nowrap;">Product Type</label>
            <select name="productType" class="form-select form-select-sm" style="min-width:160px;border-radius:10px;"
                    onchange="this.form.submit()">
                <option value="">All Products</option>
                @foreach (var pt in availableProductTypes)
                {
                    <option value="@pt" selected="@(selectedPT == pt)">@pt</option>
                }
            </select>
            @if (!string.IsNullOrEmpty(selectedPT))
            {
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary" style="border-radius:8px;white-space:nowrap;">Clear</a>
            }
        </form>
    </div>
</div>

<!-- Purge Confirmation Modal -->
<div class="modal fade" id="purgeLogs7DaysModal" tabindex="-1" aria-labelledby="purgeLogs7DaysModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:14px;overflow:hidden;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="purgeLogs7DaysModalLabel" style="color:#1e293b;">
                    <i class="bi bi-trash3 me-2 text-danger"></i>Remove Old Validation Logs
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-2">
                <p class="mb-1" style="color:#334155;">This will permanently delete all validation history records older than <strong>7 days</strong>.</p>
                <p class="text-muted mb-0" style="font-size:.83rem;">Only the <code>LicenseValidationHistory</code> log table is affected. All licence, client, and configuration data remains untouched.</p>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-outline-secondary" style="border-radius:10px;" data-bs-dismiss="modal">Cancel</button>
                <form asp-action="PurgeOldLogs" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger" style="border-radius:10px;">
                        <i class="bi bi-trash3 me-1"></i> Yes, Delete Old Records
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="card mb-4">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <input type="hidden" name="productType" value="@selectedPT" />
            <div class="col-sm-5">
                <label class="form-label mb-1" style="font-size:.78rem;font-weight:600;color:#64748b;">Client Code / AppUrl</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control border-start-0" placeholder="Search…" style="border-radius:0 10px 10px 0;" />
                </div>
            </div>
            <div class="col-sm-3">
                <label class="form-label mb-1" style="font-size:.78rem;font-weight:600;color:#64748b;">Result</label>
                <select name="valid" class="form-select" style="border-radius:10px;">
                    <option value="">All Results</option>
                    <option value="valid"   selected="@(ViewBag.Valid=="valid")">Valid Only</option>
                    <option value="invalid" selected="@(ViewBag.Valid=="invalid")">Invalid Only</option>
                </select>
            </div>
            <div class="col-sm-auto">
                <button type="submit" class="btn btn-primary" style="background:#6366f1;border:none;border-radius:10px;"><i class="bi bi-funnel me-1"></i> Filter</button>
                <a asp-action="Index" asp-route-productType="@selectedPT" class="btn btn-outline-secondary ms-1" style="border-radius:10px;">Clear</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table tbl-clean mb-0">
                <thead>
                    <tr>
                        <th class="ps-3">#</th>
                        <th>Client Code</th>
                        <th>AppUrl</th>
                        <th>Result</th>
                        <th>Failure Reason</th>
                        <th>IP Address</th>
                        <th>Device Info</th>
                        <th class="pe-3">Date</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="8" class="text-center py-5 text-muted"><i class="bi bi-inbox fs-1 d-block mb-2"></i>No records found</td></tr>
                    }
                    @foreach (var v in Model)
                    {
                        <tr>
                            <td class="ps-3" style="color:#94a3b8;font-size:.8rem;">@v.Id</td>
                            <td class="fw-semibold" style="color:#6366f1;font-size:.86rem;">@v.ClientCode</td>
                            <td style="font-size:.78rem;max-width:220px;white-space:normal;word-break:break-word;">
                                @if (string.IsNullOrWhiteSpace(v.AppUrl))
                                {
                                    <span>—</span>
                                }
                                else
                                {
                                    <span>@v.AppUrl</span>
                                }
                            </td>
                            <td>
                                @if (v.IsValid)
                                {
                                    <span class="badge badge-ok rounded-pill px-2 py-1" style="font-size:.73rem;"><i class="bi bi-check-circle me-1"></i>Valid</span>
                                }
                                else
                                {
                                    <span class="badge badge-err rounded-pill px-2 py-1" style="font-size:.73rem;"><i class="bi bi-x-circle me-1"></i>Invalid</span>
                                }
                            </td>
                                    <td style="font-size:.8rem;max-width:180px;white-space:normal;">@(v.FailureReason ?? "—")</td>
                            <td style="font-size:.78rem;font-family:monospace;">@(v.PublicIPAddress ?? "—")</td>
                            <td style="font-size:.75rem;max-width:200px;white-space:normal;word-break:break-word;">
                                @(string.IsNullOrEmpty(v.DeviceInfo) ? "—" : v.DeviceInfo)
                            </td>
                            <td class="pe-3" style="font-size:.8rem;white-space:nowrap;">@v.CreatedAt.ToString("dd MMM yyyy HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (totalPages > 1)
        {
            <div class="d-flex align-items-center justify-content-between px-3 py-3 border-top" style="font-size:.82rem;">
                <span class="text-muted">Showing @((page-1)*pageSize+1)–@(Math.Min(page*pageSize,total)) of @total</span>
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        @for (int p = 1; p <= totalPages; p++)
                        {
                            <li class="page-item @(p == page ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@p" asp-route-search="@ViewBag.Search" asp-route-valid="@ViewBag.Valid" asp-route-productType="@selectedPT">@p</a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>
