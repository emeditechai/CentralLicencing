@model CentralLicenceApp.Models.EmailTemplate
@{
    ViewData["Title"] = "Edit Template";
    var keyLabel = Model.TemplateKey switch
    {
        "LICENSE_ACTIVATED"       => ("License Activation — Welcome Again", "bi-check-circle-fill", "#16a34a", "#dcfce7"),
        "LICENSE_EXPIRY_EXTENDED" => ("License Expiry Extended",             "bi-arrow-clockwise",   "#2563eb", "#dbeafe"),
        "LICENSE_EXPIRY_REMINDER" => ("License Expiry Reminder",             "bi-clock-fill",        "#d97706", "#fef3c7"),
        "AMC_EXPIRY_REMINDER"     => ("AMC Expiry Reminder",                 "bi-exclamation-triangle-fill", "#dc2626", "#fee2e2"),
        "EXPENSE_REQUEST_SUBMITTED" => ("Expense Request Submitted",          "bi-receipt-cutoff",   "#1d4ed8", "#dbeafe"),
        "EXPENSE_SETTLEMENT_COMPLETED" => ("Expense Settlement Completed",    "bi-cash-coin",        "#166534", "#dcfce7"),
        _                         => (Model.TemplateName,                    "bi-envelope",          "#64748b", "#f1f5f9")
    };
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-light" style="border-radius:8px;border:1px solid #e2e8f0;">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div class="d-flex align-items-center gap-3">
        <div style="width:44px;height:44px;border-radius:11px;background:@keyLabel.Item4;display:flex;align-items:center;justify-content:center;color:@keyLabel.Item3;font-size:1.2rem;flex-shrink:0;">
            <i class="bi @keyLabel.Item2"></i>
        </div>
        <div>
            <h4 class="fw-bold mb-0" style="color:#1e293b;">@keyLabel.Item1</h4>
            <code style="font-size:.75rem;color:#94a3b8;">@Model.TemplateKey</code>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- ── Left: Edit Form ───────────────────────────────────────── -->
    <div class="col-12 col-xl-7">
        <div class="card" style="border:1px solid #e2e8f0;border-radius:14px;overflow:hidden;">
            <div class="card-header px-4 py-3" style="background:#f8fafc;border-bottom:1px solid #e2e8f0;">
                <div class="fw-semibold" style="color:#1e293b;font-size:.9rem;"><i class="bi bi-pencil me-2" style="color:#8b5cf6;"></i>Edit Template</div>
            </div>
            <div class="card-body px-4 py-4">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="TemplateKey" />
                    <input type="hidden" asp-for="CreatedAt" />

                    <div class="mb-3">
                        <label asp-for="TemplateName" class="form-label fw-semibold" style="font-size:.83rem;color:#374151;">Template Name</label>
                        <input asp-for="TemplateName" class="form-control" style="border-radius:8px;" />
                        <span asp-validation-for="TemplateName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Subject" class="form-label fw-semibold" style="font-size:.83rem;color:#374151;">Email Subject</label>
                        <input asp-for="Subject" class="form-control" style="border-radius:8px;" />
                        <span asp-validation-for="Subject" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex align-items-center justify-content-between mb-1">
                            <label asp-for="Body" class="form-label fw-semibold mb-0" style="font-size:.83rem;color:#374151;">Email Body (HTML)</label>
                            <button type="button" class="btn btn-sm btn-outline-secondary" style="font-size:.75rem;border-radius:8px;" onclick="livePreview()">
                                <i class="bi bi-eye me-1"></i>Preview
                            </button>
                        </div>
                        <textarea asp-for="Body" class="form-control font-monospace" rows="18"
                                  style="border-radius:8px;font-size:.78rem;line-height:1.5;"
                                  id="bodyEditor"></textarea>
                        <span asp-validation-for="Body" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
                            <label asp-for="IsActive" class="form-check-label fw-semibold" style="font-size:.83rem;color:#374151;">Template Active</label>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary" style="background:#8b5cf6;border:none;border-radius:10px;padding:.5rem 1.5rem;">
                            <i class="bi bi-check-lg me-1"></i> Save Template
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius:10px;">Cancel</a>
                    </div>
                </form>
            </div>
        </div>

        <!-- ── Send Test Email ────────────────────────────────────── -->
        <div class="card mt-3" style="border:1px solid #e2e8f0;border-radius:14px;overflow:hidden;">
            <div class="card-header px-4 py-3" style="background:#f8fafc;border-bottom:1px solid #e2e8f0;">
                <div class="fw-semibold" style="color:#1e293b;font-size:.9rem;"><i class="bi bi-send me-2" style="color:#6366f1;"></i>Send Test Email</div>
            </div>
            <div class="card-body px-4 py-3">
                <form asp-action="SendTest" method="post" class="d-flex gap-2 align-items-end">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="flex-grow-1">
                        <label class="form-label fw-semibold" style="font-size:.83rem;color:#374151;">Test Recipient Email</label>
                        <input type="email" name="testEmail" class="form-control" placeholder="you@example.com"
                               style="border-radius:8px;" required />
                    </div>
                    <button type="submit" class="btn btn-outline-primary" style="border-radius:10px;white-space:nowrap;">
                        <i class="bi bi-send me-1"></i> Send Test
                    </button>
                </form>
                <p class="text-muted mt-2 mb-0" style="font-size:.77rem;">Uses sample placeholder values to send a preview.</p>
            </div>
        </div>
    </div>

    <!-- ── Right: Placeholder Reference + Preview ───────────────── -->
    <div class="col-12 col-xl-5">
        <div class="card mb-3" style="border:1px solid #e9d5ff;border-radius:14px;background:#faf5ff;">
            <div class="card-header px-4 py-3" style="background:#f5f0ff;border-bottom:1px solid #e9d5ff;">
                <div class="fw-semibold" style="color:#7c3aed;font-size:.9rem;"><i class="bi bi-braces me-2"></i>Placeholder Reference</div>
            </div>
            <div class="card-body px-4 py-3">
                <table class="table table-sm mb-0" style="font-size:.8rem;">
                    <thead>
                        <tr style="color:#6b7280;">
                            <th>Placeholder</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody style="color:#374151;">
                        <tr><td><code>{{ClientName}}</code></td><td>Client full name</td></tr>
                        <tr><td><code>{{ClientCode}}</code></td><td>Unique client code</td></tr>
                        <tr><td><code>{{ExpiryDate}}</code></td><td>License expiry date</td></tr>
                        <tr><td><code>{{AmcExpiryDate}}</code></td><td>AMC expiry date</td></tr>
                        <tr><td><code>{{DaysRemaining}}</code></td><td>Days until expiry</td></tr>
                        <tr><td><code>{{AppName}}</code></td><td>Application name (eRestoPOS)</td></tr>
                        <tr><td><code>{{AppUrl}}</code></td><td>Application URL</td></tr>
                        <tr><td><code>{{RequestNumber}}</code></td><td>Expense request number</td></tr>
                        <tr><td><code>{{EmployeeName}}</code></td><td>Employee full name</td></tr>
                        <tr><td><code>{{EmployeeCode}}</code></td><td>Employee code</td></tr>
                        <tr><td><code>{{PurposeOfTravel}}</code></td><td>Travel or advance purpose</td></tr>
                        <tr><td><code>{{TotalAmount}}</code></td><td>Total request amount</td></tr>
                        <tr><td><code>{{ItemCount}}</code></td><td>Number of request lines</td></tr>
                        <tr><td><code>{{SubmittedAt}}</code></td><td>Submission timestamp</td></tr>
                        <tr><td><code>{{CurrentStatus}}</code></td><td>Current workflow status</td></tr>
                        <tr><td><code>{{ApproverName}}</code></td><td>Assigned approver name</td></tr>
                        <tr><td><code>{{DetailsUrl}}</code></td><td>Absolute request details link</td></tr>
                        <tr><td><code>{{SettlementReceiptNumber}}</code></td><td>Settlement receipt number</td></tr>
                        <tr><td><code>{{SettlementDate}}</code></td><td>Settlement completion date</td></tr>
                        <tr><td><code>{{SettlementAmount}}</code></td><td>Final settled amount</td></tr>
                        <tr><td><code>{{SettlementMode}}</code></td><td>Mode of reimbursement payment</td></tr>
                        <tr><td><code>{{SettlementReferenceNo}}</code></td><td>Settlement payment reference</td></tr>
                        <tr><td><code>{{SettlementReceiptUrl}}</code></td><td>Absolute settlement receipt link</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Live Preview Frame -->
        <div class="card" style="border:1px solid #e2e8f0;border-radius:14px;overflow:hidden;">
            <div class="card-header px-4 py-3" style="background:#f8fafc;border-bottom:1px solid #e2e8f0;">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="fw-semibold" style="color:#1e293b;font-size:.9rem;"><i class="bi bi-window me-2" style="color:#6366f1;"></i>HTML Preview</div>
                    <button type="button" class="btn btn-sm btn-outline-secondary" style="font-size:.75rem;border-radius:8px;" onclick="livePreview()">
                        <i class="bi bi-arrow-clockwise me-1"></i>Refresh
                    </button>
                </div>
            </div>
            <div class="card-body p-0">
                <iframe id="previewFrame" style="width:100%;height:420px;border:none;"
                        srcdoc="<p style='padding:2rem;color:#94a3b8;font-family:sans-serif;'>Click &lt;Preview&gt; or &lt;Refresh&gt; to render.</p>">
                </iframe>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function livePreview() {
        var html = document.getElementById('bodyEditor').value;
        // Replace placeholders with sample values for preview
        var samples = {
            '{{ClientName}}': 'RAJ Traders',
            '{{ClientCode}}': 'CI-250001',
            '{{ExpiryDate}}': '01 Apr 2026',
            '{{AmcExpiryDate}}': '31 Mar 2026',
            '{{DaysRemaining}}': '7',
            '{{AppName}}': 'eRestoPOS',
            '{{AppUrl}}': 'http://198.38.81.123:2001',
            '{{RequestNumber}}': 'EXP-20260326-0007',
            '{{EmployeeName}}': 'Abhik Porel',
            '{{EmployeeCode}}': 'EMP-104',
            '{{PurposeOfTravel}}': 'Client implementation visit and advance booking for travel and accommodation.',
            '{{TotalAmount}}': '18,750.00',
            '{{ItemCount}}': '4',
            '{{SubmittedAt}}': '26 Mar 2026 10:30 AM',
            '{{CurrentStatus}}': 'Pending Approval',
            '{{ApproverName}}': 'Operations Manager',
            '{{DetailsUrl}}': 'http://your-app-url/ExpenseRequest/Details/7',
            '{{SettlementReceiptNumber}}': 'SET-20260326-0007',
            '{{SettlementDate}}': '26 Mar 2026',
            '{{SettlementAmount}}': '18,750.00',
            '{{SettlementMode}}': 'Bank Transfer',
            '{{SettlementReferenceNo}}': 'UTR0045892361',
            '{{SettlementReceiptUrl}}': 'http://your-app-url/ExpenseRequest/SettlementReceipt/7'
        };
        for (var key in samples) {
            html = html.split(key).join(samples[key]);
        }
        document.getElementById('previewFrame').srcdoc = html;
    }
</script>
}
