@model CentralLicenceApp.Models.ViewModels.ClientDueReportViewModel
@{
    ViewData["Title"] = "Client-wise Due Report";
}

<div class="d-flex align-items-center justify-content-between mb-4 gap-3 flex-wrap">
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;">Client-wise Due Report</h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">
            <span><i class="bi bi-exclamation-triangle me-1 text-warning"></i>Outstanding invoice balances by party</span>
        </p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="ExportClientDueExcel"
           asp-route-fromDate="@(Model.FromDate?.ToString("yyyy-MM-dd"))"
           asp-route-toDate="@(Model.ToDate?.ToString("yyyy-MM-dd"))"
           class="btn btn-success"
           style="border-radius:10px;background:#15803d;border:none;">
            <i class="bi bi-file-earmark-excel me-1"></i>Excel
        </a>
        <a asp-action="ExportClientDuePdf"
           asp-route-fromDate="@(Model.FromDate?.ToString("yyyy-MM-dd"))"
           asp-route-toDate="@(Model.ToDate?.ToString("yyyy-MM-dd"))"
           class="btn btn-danger"
           style="border-radius:10px;background:#b91c1c;border:none;">
            <i class="bi bi-file-earmark-pdf me-1"></i>PDF
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card h-100" style="border:1px solid #e2e8f0;box-shadow:0 10px 24px rgba(15,23,42,.05);">
            <div class="card-body">
                <div class="text-muted" style="font-size:.74rem;font-weight:800;letter-spacing:.05em;">OUTSTANDING INVOICES</div>
                <div class="mt-2" style="font-size:1.7rem;font-weight:800;color:#1e293b;">@Model.TotalOutstandingInvoices</div>
                <div class="text-muted" style="font-size:.78rem;">Invoices with pending balance</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100" style="border:1px solid #e2e8f0;box-shadow:0 10px 24px rgba(15,23,42,.05);">
            <div class="card-body">
                <div class="text-muted" style="font-size:.74rem;font-weight:800;letter-spacing:.05em;">TOTAL BALANCE DUE</div>
                <div class="mt-2" style="font-size:1.7rem;font-weight:800;color:#b91c1c;">₹@Model.TotalBalanceDue.ToString("N2")</div>
                <div class="text-muted" style="font-size:.78rem;">Sum of balance due on current page</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100" style="border:1px solid #e2e8f0;box-shadow:0 10px 24px rgba(15,23,42,.05);">
            <div class="card-body">
                <div class="text-muted" style="font-size:.74rem;font-weight:800;letter-spacing:.05em;">OVERDUE INVOICES</div>
                <div class="mt-2" style="font-size:1.7rem;font-weight:800;color:#dc2626;">@Model.OverdueCount</div>
                <div class="text-muted" style="font-size:.78rem;">Past due date on current page</div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4" style="border:1px solid #e2e8f0;">
    <div class="card-body py-3">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label mb-1" style="font-size:.78rem;font-weight:600;color:#64748b;">Invoice Date From</label>
                <input type="date" name="fromDate" value="@(Model.FromDate?.ToString("yyyy-MM-dd"))" class="form-control" style="border-radius:10px;" />
            </div>
            <div class="col-md-3">
                <label class="form-label mb-1" style="font-size:.78rem;font-weight:600;color:#64748b;">Invoice Date To</label>
                <input type="date" name="toDate" value="@(Model.ToDate?.ToString("yyyy-MM-dd"))" class="form-control" style="border-radius:10px;" />
            </div>
            <div class="col-md-auto">
                <button type="submit" class="btn btn-primary" style="background:#1d4ed8;border:none;border-radius:10px;"><i class="bi bi-funnel me-1"></i>Filter</button>
                <a asp-action="ClientDueReport" class="btn btn-outline-secondary ms-1" style="border-radius:10px;">Clear</a>
            </div>
        </form>
        @if (!ViewContext.ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger mt-3 mb-0 py-2 px-3 rounded-3" style="font-size:.83rem;"></div>
        }
    </div>
</div>

<div class="card" style="border:1px solid #e2e8f0;box-shadow:0 12px 28px rgba(15,23,42,.05);">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table tbl-clean mb-0">
                <thead>
                    <tr>
                        <th class="ps-3">#</th>
                        <th>Party Name</th>
                        <th>GSTIN</th>
                        <th>Invoice No.</th>
                        <th>Invoice Date</th>
                        <th>Due Date</th>
                        <th class="text-end">Total (₹)</th>
                        <th class="text-end">Received (₹)</th>
                        <th class="text-end">Balance Due (₹)</th>
                        <th class="text-center">Overdue</th>
                        <th class="pe-3">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="11" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-1 d-block mb-2"></i>No outstanding invoices found for the selected date range
                            </td>
                        </tr>
                    }
                    @{int sr = 0;}
                    @foreach (var row in Model.Items)
                    {
                        sr++;
                        <tr>
                            <td class="ps-3 text-muted" style="font-size:.8rem;">@sr</td>
                            <td style="font-size:.83rem;max-width:200px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="@row.PartyName">
                                <span class="fw-semibold">@row.PartyName</span>
                            </td>
                            <td style="font-size:.82rem;color:#64748b;">@(string.IsNullOrWhiteSpace(row.PartyGSTINNo) ? "—" : row.PartyGSTINNo)</td>
                            <td>
                                <a asp-controller="Invoice" asp-action="Details" asp-route-id="@row.Id"
                                   class="fw-semibold" style="color:#1d4ed8;font-size:.85rem;">@row.InvoiceNo</a>
                            </td>
                            <td style="font-size:.82rem;white-space:nowrap;">@row.InvoiceDate.ToString("dd MMM yyyy")</td>
                            <td style="font-size:.82rem;white-space:nowrap;">
                                @if (row.DueDate.HasValue)
                                {
                                    if (row.OverdueDays > 0)
                                    {
                                        <span class="text-danger fw-semibold">@row.DueDate.Value.ToString("dd MMM yyyy")</span>
                                    }
                                    else
                                    {
                                        @row.DueDate.Value.ToString("dd MMM yyyy")
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-end" style="font-size:.85rem;">@row.TotalAmount.ToString("N2")</td>
                            <td class="text-end" style="font-size:.85rem;">@row.ReceivedAmount.ToString("N2")</td>
                            <td class="text-end fw-semibold" style="font-size:.85rem;color:@(row.OverdueDays > 0 ? "#dc2626" : "#b91c1c");">@row.BalanceDue.ToString("N2")</td>
                            <td class="text-center" style="font-size:.82rem;">
                                @if (row.OverdueDays > 0)
                                {
                                    <span class="badge" style="background:#fef2f2;color:#dc2626;font-weight:700;">@row.OverdueDays days</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="pe-3" style="font-size:.82rem;">
                                @{
                                    var statusColor = row.Status switch
                                    {
                                        "Overdue" => "#dc2626",
                                        "Partially Paid" => "#d97706",
                                        "Sent" => "#2563eb",
                                        _ => "#64748b"
                                    };
                                    var statusBg = row.Status switch
                                    {
                                        "Overdue" => "#fef2f2",
                                        "Partially Paid" => "#fffbeb",
                                        "Sent" => "#eff6ff",
                                        _ => "#f1f5f9"
                                    };
                                }
                                <span class="badge" style="background:@statusBg;color:@statusColor;font-weight:600;">@row.Status</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="d-flex align-items-center justify-content-between px-3 py-3 border-top" style="font-size:.82rem;">
            <span class="text-muted">
                Showing @((Model.PageNumber - 1) * Model.PageSize + 1)&ndash;@(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount)) of @Model.TotalCount records
            </span>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    @if (Model.PageNumber > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="ClientDueReport"
                               asp-route-page="@(Model.PageNumber - 1)"
                               asp-route-fromDate="@(Model.FromDate?.ToString("yyyy-MM-dd"))"
                               asp-route-toDate="@(Model.ToDate?.ToString("yyyy-MM-dd"))">&laquo;</a>
                        </li>
                    }
                    @{
                        int startPg = Math.Max(1, Model.PageNumber - 2);
                        int endPg   = Math.Min(Model.TotalPages, startPg + 4);
                        if (endPg - startPg < 4) startPg = Math.Max(1, endPg - 4);
                    }
                    @for (int pg = startPg; pg <= endPg; pg++)
                    {
                        <li class="page-item @(pg == Model.PageNumber ? "active" : "")">
                            <a class="page-link" asp-action="ClientDueReport"
                               asp-route-page="@pg"
                               asp-route-fromDate="@(Model.FromDate?.ToString("yyyy-MM-dd"))"
                               asp-route-toDate="@(Model.ToDate?.ToString("yyyy-MM-dd"))">@pg</a>
                        </li>
                    }
                    @if (Model.PageNumber < Model.TotalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="ClientDueReport"
                               asp-route-page="@(Model.PageNumber + 1)"
                               asp-route-fromDate="@(Model.FromDate?.ToString("yyyy-MM-dd"))"
                               asp-route-toDate="@(Model.ToDate?.ToString("yyyy-MM-dd"))">&raquo;</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>
