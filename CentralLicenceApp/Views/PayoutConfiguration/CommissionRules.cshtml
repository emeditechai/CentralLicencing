@model CentralLicenceApp.Models.ViewModels.PayoutCommissionRulesViewModel
@{
    ViewData["Title"] = "Commission Rules — " + Model.UserName;
}

<style>
    .cr-hero { background:linear-gradient(135deg,#667eea 0%,#764ba2 100%); border-radius:20px; padding:2rem 2.25rem; margin-bottom:1.75rem; position:relative; overflow:hidden; }
    .cr-hero::before { content:''; position:absolute; top:-50%; right:-8%; width:320px; height:320px; background:rgba(255,255,255,.06); border-radius:50%; pointer-events:none; }
    .cr-hero h4 { color:#fff; font-weight:800; font-size:1.4rem; margin-bottom:.15rem; }
    .cr-hero .cr-sub { color:rgba(255,255,255,.75); font-size:.85rem; }

    .cr-stat { background:rgba(255,255,255,.15); backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,.18); border-radius:14px; padding:.7rem 1.1rem; min-width:110px; text-align:center; }
    .cr-stat-num { font-size:1.5rem; font-weight:800; color:#fff; line-height:1.2; }
    .cr-stat-lbl { font-size:.68rem; text-transform:uppercase; letter-spacing:.06em; font-weight:600; color:rgba(255,255,255,.7); }

    .cr-card { background:#fff; border-radius:14px; box-shadow:0 2px 12px rgba(0,0,0,.05); border:1px solid #f1f5f9; overflow:hidden; }
    .cr-table { margin-bottom:0; }
    .cr-table thead { background:linear-gradient(180deg,#f8fafc,#f1f5f9); }
    .cr-table thead th { font-size:.7rem; font-weight:700; color:#475569; text-transform:uppercase; letter-spacing:.08em; padding:.75rem .85rem; border-bottom:2px solid #e2e8f0; white-space:nowrap; }
    .cr-table tbody tr { transition:all .15s ease; border-bottom:1px solid #f8fafc; }
    .cr-table tbody tr:hover { background:linear-gradient(90deg,#f5f3ff,#eff6ff); }
    .cr-table td { vertical-align:middle; padding:.65rem .85rem; font-size:.84rem; color:#334155; }

    .cr-priority { font-size:.7rem; font-weight:700; padding:4px 10px; border-radius:20px; letter-spacing:.03em; }
    .cr-priority-30 { background:linear-gradient(135deg,#dbeafe,#bfdbfe); color:#1e40af; }
    .cr-priority-20 { background:linear-gradient(135deg,#e0f2fe,#bae6fd); color:#0369a1; }
    .cr-priority-10 { background:linear-gradient(135deg,#fef3c7,#fde68a); color:#92400e; }
    .cr-priority-0 { background:#f1f5f9; color:#64748b; }

    .cr-btn { border-radius:10px; font-weight:600; font-size:.8rem; padding:.35rem .9rem; border:none; transition:all .15s; }
    .cr-btn-add { background:linear-gradient(135deg,#6366f1,#4f46e5); color:#fff; }
    .cr-btn-add:hover { background:linear-gradient(135deg,#4f46e5,#4338ca); color:#fff; transform:translateY(-1px); }

    .cr-info-bar { background:#f5f3ff; border:1px solid #e9e4f5; border-radius:12px; padding:.75rem 1.25rem; margin-bottom:1.25rem; font-size:.82rem; color:#5b21b6; }
    .cr-hierarchy { display:flex; align-items:center; gap:.5rem; flex-wrap:wrap; font-size:.76rem; color:#64748b; margin-bottom:1rem; }
    .cr-hierarchy .cr-h-item { background:#f8fafc; padding:3px 10px; border-radius:8px; font-weight:600; border:1px solid #e2e8f0; }
    .cr-hierarchy .cr-h-arrow { color:#94a3b8; }
</style>

<!-- Hero -->
<div class="cr-hero">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
            <h4><i class="bi bi-list-check me-2"></i>Commission Rules</h4>
            <div class="cr-sub">@Model.UserName @(!string.IsNullOrEmpty(Model.EmployeeCode) ? $"({Model.EmployeeCode})" : "")</div>
        </div>
        <div class="d-flex gap-3 flex-wrap">
            <div class="cr-stat">
                <div class="cr-stat-num">@Model.Rules.Count</div>
                <div class="cr-stat-lbl">Rules</div>
            </div>
            <div class="cr-stat">
                <div class="cr-stat-num">₹@(Model.DefaultCommissionAmount?.ToString("N0") ?? "0")</div>
                <div class="cr-stat-lbl">Default Rate</div>
            </div>
        </div>
    </div>
</div>

<!-- Priority Hierarchy Info -->
<div class="cr-hierarchy">
    <span class="fw-bold text-dark">Resolution Order:</span>
    <span class="cr-h-item" style="background:#dbeafe;color:#1e40af;">Project (P=30)</span>
    <i class="bi bi-chevron-right cr-h-arrow"></i>
    <span class="cr-h-item" style="background:#e0f2fe;color:#0369a1;">Category (P=20)</span>
    <i class="bi bi-chevron-right cr-h-arrow"></i>
    <span class="cr-h-item" style="background:#fef3c7;color:#92400e;">Task Type (P=10)</span>
    <i class="bi bi-chevron-right cr-h-arrow"></i>
    <span class="cr-h-item">Default (P=0)</span>
</div>

<div class="cr-info-bar">
    <i class="bi bi-info-circle me-1"></i>
    When a task is processed, the system picks the <strong>highest priority rule</strong> that matches.
    If no rule matches, the default commission of <strong>₹@(Model.DefaultCommissionAmount?.ToString("N2") ?? "0.00")</strong> per task applies.
</div>

<!-- Actions Bar -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius:10px;font-size:.82rem;">
        <i class="bi bi-arrow-left me-1"></i> Back to Configuration
    </a>
    <button type="button" class="btn cr-btn cr-btn-add" data-bs-toggle="modal" data-bs-target="#ruleModal" onclick="openRuleModal(0)">
        <i class="bi bi-plus-lg me-1"></i> Add Rule
    </button>
</div>

<!-- Table -->
<div class="cr-card">
    <div class="table-responsive">
        <table class="table cr-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Rule Scope</th>
                    <th>Project / Module</th>
                    <th>Task Category</th>
                    <th>Task Type</th>
                    <th>Amount (₹)</th>
                    <th>Priority</th>
                    <th>Effective From</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody id="rulesTableBody">
                @if (!Model.Rules.Any())
                {
                    <tr id="emptyRow"><td colspan="9" class="text-center text-muted py-4"><i class="bi bi-inbox me-1"></i> No commission rules defined. The default rate will apply to all tasks.</td></tr>
                }
                @{ var idx = 0; }
                @foreach (var r in Model.Rules)
                {
                    idx++;
                    <tr id="rule-row-@r.Id">
                        <td class="text-muted" style="font-size:.78rem;">@idx</td>
                        <td class="fw-semibold" style="font-size:.82rem;">@r.RateSourceDisplay</td>
                        <td style="font-size:.82rem;">@(r.ProjectModuleName ?? "—")</td>
                        <td style="font-size:.82rem;">@(r.TaskCategoryName ?? "—")</td>
                        <td style="font-size:.82rem;">@(r.TaskTypeName ?? "—")</td>
                        <td class="fw-bold" style="font-size:.88rem;">₹@r.Amount.ToString("N2")</td>
                        <td>
                            <span class="cr-priority cr-priority-@r.Priority">P@r.Priority</span>
                        </td>
                        <td style="font-size:.82rem;">@r.EffectiveFrom.ToString("dd MMM yyyy")</td>
                        <td class="text-center">
                            <button type="button" class="btn btn-sm btn-outline-primary" style="border-radius:8px;font-size:.75rem;"
                                    onclick="openEditModal(@r.Id, @(r.TaskTypeId?.ToString() ?? "null"), @(r.TaskCategoryId?.ToString() ?? "null"), @(r.ProjectModuleId?.ToString() ?? "null"), @r.Amount, '@r.EffectiveFrom.ToString("yyyy-MM-dd")')">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-danger" style="border-radius:8px;font-size:.75rem;" onclick="deleteRule(@r.Id)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Rule Modal -->
<div class="modal fade" id="ruleModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:16px;border:none;">
            <div class="modal-header" style="background:linear-gradient(135deg,#7c3aed,#6d28d9);border-radius:16px 16px 0 0;padding:1rem 1.5rem;">
                <h6 class="modal-title text-white fw-bold" id="ruleModalTitle"><i class="bi bi-plus-lg me-1"></i> Add Commission Rule</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="ruleId" value="0" />
                <input type="hidden" id="ruleUserId" value="@Model.UserId" />

                <div class="mb-3">
                    <label class="form-label fw-semibold" style="font-size:.82rem;">Project / Module <small class="text-muted">(Priority 30 — highest)</small></label>
                    <select id="ruleProject" class="form-select" style="border-radius:10px;">
                        <option value="">— None —</option>
                        @foreach (var p in Model.Projects)
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold" style="font-size:.82rem;">Task Category <small class="text-muted">(Priority 20)</small></label>
                    <select id="ruleCategory" class="form-select" style="border-radius:10px;">
                        <option value="">— None —</option>
                        @foreach (var c in Model.TaskCategories)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold" style="font-size:.82rem;">Task Type <small class="text-muted">(Priority 10)</small></label>
                    <select id="ruleType" class="form-select" style="border-radius:10px;">
                        <option value="">— None —</option>
                        @foreach (var t in Model.TaskTypes)
                        {
                            <option value="@t.Id">@t.Name</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold" style="font-size:.82rem;">Amount (₹) <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <span class="input-group-text" style="border-radius:10px 0 0 10px;">₹</span>
                        <input type="number" step="0.01" min="0.01" max="999999.99" id="ruleAmount" class="form-control" style="border-radius:0 10px 10px 0;" placeholder="e.g. 300.00" required />
                    </div>
                    <div id="ruleAmountError" class="text-danger d-none" style="font-size:.78rem;">Amount is required and must be greater than zero.</div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold" style="font-size:.82rem;">Effective From <span class="text-danger">*</span></label>
                    <input type="date" id="ruleEffective" class="form-control" style="border-radius:10px;" value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                </div>
                <div class="text-muted" style="font-size:.74rem;">
                    <i class="bi bi-info-circle me-1"></i> Leave Project/Category/Type blank for the default rule. Select <strong>one</strong> dimension for the best results.
                </div>
            </div>
            <div class="modal-footer" style="border-top:1px solid #f1f5f9;padding:1rem 1.5rem;">
                <button type="button" class="btn btn-outline-secondary" style="border-radius:10px;" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn cr-btn cr-btn-add" id="saveRuleBtn" onclick="saveRule()">
                    <i class="bi bi-check-lg me-1"></i> <span id="saveRuleBtnText">Add Rule</span>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
var antiForgeryToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value
    || '@Html.AntiForgeryToken()'.match(/value="([^"]+)"/)?.[1] || '';

// If no form exists on page for token, create hidden one
(function() {
    if (!antiForgeryToken) {
        var tmp = document.createElement('div');
        tmp.innerHTML = '@Html.AntiForgeryToken()';
        antiForgeryToken = tmp.querySelector('input')?.value || '';
    }
})();

function openRuleModal(id) {
    document.getElementById('ruleId').value = 0;
    document.getElementById('ruleProject').value = '';
    document.getElementById('ruleCategory').value = '';
    document.getElementById('ruleType').value = '';
    document.getElementById('ruleAmount').value = '';
    document.getElementById('ruleEffective').value = '@DateTime.Today.ToString("yyyy-MM-dd")';
    document.getElementById('ruleAmountError').classList.add('d-none');
    document.getElementById('ruleAmount').classList.remove('is-invalid');
    document.getElementById('ruleModalTitle').innerHTML = '<i class="bi bi-plus-lg me-1"></i> Add Commission Rule';
    document.getElementById('saveRuleBtnText').textContent = 'Add Rule';
}

function openEditModal(id, typeId, catId, projId, amount, effective) {
    document.getElementById('ruleId').value = id;
    document.getElementById('ruleProject').value = projId || '';
    document.getElementById('ruleCategory').value = catId || '';
    document.getElementById('ruleType').value = typeId || '';
    document.getElementById('ruleAmount').value = amount;
    document.getElementById('ruleEffective').value = effective;
    document.getElementById('ruleAmountError').classList.add('d-none');
    document.getElementById('ruleAmount').classList.remove('is-invalid');
    document.getElementById('ruleModalTitle').innerHTML = '<i class="bi bi-pencil me-1"></i> Edit Commission Rule';
    document.getElementById('saveRuleBtnText').textContent = 'Update Rule';
    var modal = new bootstrap.Modal(document.getElementById('ruleModal'));
    modal.show();
}

function saveRule() {
    var amount = parseFloat(document.getElementById('ruleAmount').value);
    if (!amount || amount <= 0) {
        document.getElementById('ruleAmountError').classList.remove('d-none');
        document.getElementById('ruleAmount').classList.add('is-invalid');
        document.getElementById('ruleAmount').focus();
        return;
    }

    var id = parseInt(document.getElementById('ruleId').value);
    var url = id > 0
        ? '@Url.Action("EditRule")'
        : '@Url.Action("AddRule")';

    var fd = new FormData();
    fd.append('__RequestVerificationToken', antiForgeryToken);
    fd.append('UserId', '@Model.UserId');
    fd.append('Amount', amount);
    fd.append('EffectiveFrom', document.getElementById('ruleEffective').value);
    if (id > 0) fd.append('Id', id);

    var proj = document.getElementById('ruleProject').value;
    var cat = document.getElementById('ruleCategory').value;
    var typ = document.getElementById('ruleType').value;
    if (proj) fd.append('ProjectModuleId', proj);
    if (cat) fd.append('TaskCategoryId', cat);
    if (typ) fd.append('TaskTypeId', typ);

    document.getElementById('saveRuleBtn').disabled = true;

    fetch(url, { method: 'POST', body: fd })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) {
                bootstrap.Modal.getInstance(document.getElementById('ruleModal'))?.hide();
                location.reload();
            } else {
                Swal.fire('Error', data.message || 'Operation failed.', 'error');
            }
        })
        .catch(function() { Swal.fire('Error', 'Network error. Please try again.', 'error'); })
        .finally(function() { document.getElementById('saveRuleBtn').disabled = false; });
}

function deleteRule(id) {
    Swal.fire({
        title: 'Delete Rule?',
        text: 'This will remove the commission rule. The default rate will apply instead.',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#dc2626',
        confirmButtonText: 'Yes, delete'
    }).then(function(res) {
        if (!res.isConfirmed) return;

        var fd = new FormData();
        fd.append('__RequestVerificationToken', antiForgeryToken);
        fd.append('id', id);

        fetch('@Url.Action("DeleteRule")', { method: 'POST', body: fd })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.success) {
                    location.reload();
                } else {
                    Swal.fire('Error', data.message || 'Failed to delete.', 'error');
                }
            })
            .catch(function() { Swal.fire('Error', 'Network error.', 'error'); });
    });
}

document.getElementById('ruleAmount').addEventListener('input', function() {
    this.classList.remove('is-invalid');
    document.getElementById('ruleAmountError').classList.add('d-none');
});
</script>
}
