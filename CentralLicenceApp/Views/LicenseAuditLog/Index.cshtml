@model IEnumerable<CentralLicenceApp.Models.ClientLicenseAuditLog>
@{
    ViewData["Title"] = "Licence Audit Log";
    int    page       = ViewBag.Page;
    int    pageSize   = ViewBag.PageSize;
    int    total      = ViewBag.Total;
    int    totalPages = ViewBag.TotalPages;
    string search     = ViewBag.Search ?? "";
    string field      = ViewBag.Field  ?? "";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;"><i class="bi bi-clipboard2-pulse me-2" style="color:#6366f1;"></i>Licence Audit Log</h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">
            Tracks changes to <strong>Expiry Date</strong> and <strong>AMC Expiry Date</strong> &mdash; @total record(s)
        </p>
    </div>
</div>

<!-- Filters -->
<div class="card mb-4">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-sm-5">
                <label class="form-label mb-1" style="font-size:.78rem;font-weight:600;color:#64748b;">Client Code / Name / Changed By</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="search" value="@search" class="form-control border-start-0"
                           placeholder="Search…" style="border-radius:0 10px 10px 0;" />
                </div>
            </div>
            <div class="col-sm-3">
                <label class="form-label mb-1" style="font-size:.78rem;font-weight:600;color:#64748b;">Field Changed</label>
                <select name="field" class="form-select" style="border-radius:10px;">
                    <option value="">All Fields</option>
                    <option value="ExpiryDate"    selected="@(field == "ExpiryDate"    ? "selected" : null)">Expiry Date</option>
                    <option value="AMCExpiryDate" selected="@(field == "AMCExpiryDate" ? "selected" : null)">AMC Expiry Date</option>
                </select>
            </div>
            <div class="col-sm-auto">
                <button type="submit" class="btn btn-primary"
                        style="background:#6366f1;border:none;border-radius:10px;">
                    <i class="bi bi-funnel me-1"></i> Filter
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-1" style="border-radius:10px;">Clear</a>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table tbl-clean mb-0">
                <thead>
                    <tr>
                        <th class="ps-3">#</th>
                        <th>Client Code</th>
                        <th>Client Name</th>
                        <th>Product</th>
                        <th>Field Changed</th>
                        <th>Old Value</th>
                        <th>New Value</th>
                        <th>Changed By</th>
                        <th>Changed At</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4" style="font-size:.88rem;">
                                <i class="bi bi-inbox me-1"></i> No audit records found.
                            </td>
                        </tr>
                    }
                    @{ int serial = (page - 1) * pageSize; }
                    @foreach (var log in Model)
                    {
                        serial++;
                        var isExpiry = log.FieldChanged == "ExpiryDate";
                        <tr>
                            <td class="ps-3 text-muted" style="font-size:.82rem;">@serial</td>
                            <td>
                                <a asp-controller="ClientLicense" asp-action="Details"
                                   asp-route-id="@log.ClientLicenseId"
                                   class="fw-semibold text-decoration-none" style="color:#6366f1;">
                                    @log.ClientCode
                                </a>
                            </td>
                            <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"
                                title="@log.ClientName">@log.ClientName</td>
                            <td>
                                <span class="badge" style="background:#e0e7ff;color:#4338ca;font-size:.72rem;">
                                    @log.ProductType
                                </span>
                            </td>
                            <td>
                                @if (isExpiry)
                                {
                                    <span class="badge" style="background:#fef9c3;color:#92400e;font-size:.72rem;">
                                        <i class="bi bi-calendar-event me-1"></i>Expiry Date
                                    </span>
                                }
                                else
                                {
                                    <span class="badge" style="background:#dcfce7;color:#166534;font-size:.72rem;">
                                        <i class="bi bi-shield-check me-1"></i>AMC Expiry Date
                                    </span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(log.OldValue))
                                {
                                    <span class="badge bg-danger bg-opacity-10 text-danger" style="font-size:.76rem;">
                                        @log.OldValue
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted" style="font-size:.8rem;">—</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(log.NewValue))
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success" style="font-size:.76rem;">
                                        @log.NewValue
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted" style="font-size:.8rem;">—</span>
                                }
                            </td>
                            <td style="font-size:.83rem;">@log.ChangedBy</td>
                            <td style="font-size:.82rem;white-space:nowrap;">
                                @log.ChangedAt.ToString("dd MMM yyyy, hh:mm tt")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Pagination -->
@if (totalPages > 1)
{
    <nav class="mt-3 d-flex justify-content-between align-items-center">
        <small class="text-muted" style="font-size:.8rem;">
            Showing @((page - 1) * pageSize + 1)–@(Math.Min(page * pageSize, total)) of @total
        </small>
        <ul class="pagination pagination-sm mb-0">
            <li class="page-item @(page <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-page="@(page - 1)"
                   asp-route-search="@search"
                   asp-route-field="@field">&laquo;</a>
            </li>
            @for (int p = Math.Max(1, page - 2); p <= Math.Min(totalPages, page + 2); p++)
            {
                <li class="page-item @(p == page ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@p"
                       asp-route-search="@search"
                       asp-route-field="@field">@p</a>
                </li>
            }
            <li class="page-item @(page >= totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-page="@(page + 1)"
                   asp-route-search="@search"
                   asp-route-field="@field">&raquo;</a>
            </li>
        </ul>
    </nav>
}
