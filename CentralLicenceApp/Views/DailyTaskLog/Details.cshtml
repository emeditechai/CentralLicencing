@model CentralLicenceApp.Models.DailyTaskLog
@{
    ViewData["Title"] = "Task Details";
    var timeLogs = (List<CentralLicenceApp.Models.TaskTimeLog>)ViewBag.TimeLogs;
    bool canEditDelete = ViewBag.CanEditDelete;
    var statusCls = Model.Status == "Completed" ? "td-status-completed" : Model.Status == "In Progress" ? "td-status-inprogress" : Model.Status == "Started" ? "td-status-started" : Model.Status == "On Hold" ? "td-status-onhold" : "td-status-pending";
    var typeCls = Model.TaskTypeName == "Development" ? "td-type-dev" : "td-type-sup";
}

<style>
    .td-hero { background:linear-gradient(135deg,#667eea 0%,#764ba2 100%); border-radius:20px; padding:1.75rem 2rem; margin-bottom:1.75rem; position:relative; overflow:hidden; }
    .td-hero::before { content:''; position:absolute; top:-50%; right:-8%; width:280px; height:280px; background:rgba(255,255,255,.06); border-radius:50%; pointer-events:none; }
    .td-hero::after { content:''; position:absolute; bottom:-35%; left:15%; width:220px; height:220px; background:rgba(255,255,255,.04); border-radius:50%; pointer-events:none; }
    .td-hero h4 { color:#fff; font-weight:800; font-size:1.35rem; margin-bottom:.2rem; }
    .td-hero .td-sub { color:rgba(255,255,255,.7); font-size:.83rem; }

    .td-card { background:#fff; border-radius:16px; box-shadow:0 2px 16px rgba(0,0,0,.05); border:1px solid #f1f5f9; margin-bottom:1.5rem; }
    .td-card .card-body { padding:1.75rem 2rem; }
    .td-section-lbl { font-size:.72rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:#6366f1; margin-bottom:.75rem; padding-bottom:.35rem; border-bottom:2px solid #ede9fe; }

    .td-field-label { font-size:.72rem; font-weight:700; text-transform:uppercase; letter-spacing:.05em; color:#94a3b8; margin-bottom:.2rem; }
    .td-field-value { font-size:.88rem; font-weight:600; color:#1e293b; margin-bottom:1rem; }
    .td-field-value.td-muted { color:#94a3b8; font-weight:500; }

    .td-type-badge { font-size:.72rem; font-weight:700; padding:4px 12px; border-radius:20px; letter-spacing:.03em; }
    .td-type-dev { background:linear-gradient(135deg,#ede9fe,#ddd6fe); color:#5b21b6; }
    .td-type-sup { background:linear-gradient(135deg,#dbeafe,#bfdbfe); color:#1e40af; }
    .td-cat-badge { font-size:.72rem; font-weight:600; padding:4px 10px; border-radius:8px; background:#f1f5f9; color:#475569; }

    .td-status { font-size:.75rem; font-weight:700; padding:5px 14px; border-radius:20px; letter-spacing:.03em; }
    .td-status-pending { background:linear-gradient(135deg,#fef9c3,#fde68a); color:#92400e; }
    .td-status-started { background:linear-gradient(135deg,#e0e7ff,#c7d2fe); color:#3730a3; }
    .td-status-inprogress { background:linear-gradient(135deg,#dbeafe,#93c5fd); color:#1e40af; }
    .td-status-onhold { background:linear-gradient(135deg,#fee2e2,#fecaca); color:#991b1b; }
    .td-status-completed { background:linear-gradient(135deg,#dcfce7,#bbf7d0); color:#166534; }

    .td-time-card { background:linear-gradient(135deg,#f5f3ff,#ede9fe); border:1.5px solid #ddd6fe; border-radius:14px; padding:1rem 1.25rem; text-align:center; }
    .td-time-card .td-time-num { font-size:1.5rem; font-weight:800; color:#5b21b6; line-height:1.2; }
    .td-time-card .td-time-lbl { font-size:.68rem; text-transform:uppercase; letter-spacing:.06em; font-weight:600; color:#7c3aed; }

    .td-log-row { background:#f8fafc; border-radius:10px; padding:.65rem .85rem; margin-bottom:.4rem; display:flex; align-items:center; justify-content:space-between; border:1px solid #f1f5f9; transition:background .15s; }
    .td-log-row:hover { background:#f5f3ff; border-color:#e8e4f8; }
    .td-log-date { font-weight:700; font-size:.82rem; color:#1e293b; min-width:100px; }
    .td-log-time-pill { background:linear-gradient(135deg,#ede9fe,#ddd6fe); color:#5b21b6; font-weight:700; font-size:.75rem; padding:3px 10px; border-radius:20px; white-space:nowrap; }
    .td-log-remark { font-size:.8rem; color:#64748b; flex:1; margin:0 .75rem; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .td-log-user { font-size:.72rem; color:#94a3b8; font-weight:600; min-width:80px; text-align:right; }

    .td-btn-edit { background:linear-gradient(135deg,#6366f1,#4f46e5); border:none; border-radius:10px; font-weight:700; padding:.45rem 1.1rem; font-size:.82rem; color:#fff; box-shadow:0 3px 10px rgba(99,102,241,.3); transition:all .2s; text-decoration:none; }
    .td-btn-edit:hover { transform:translateY(-1px); box-shadow:0 5px 16px rgba(99,102,241,.4); color:#fff; }
    .td-btn-back { border-radius:10px; font-weight:600; font-size:.82rem; border:1.5px solid #e2e8f0; color:#64748b; padding:.45rem 1.1rem; text-decoration:none; }
    .td-btn-back:hover { border-color:#94a3b8; color:#1e293b; }

    .td-desc-box { background:#f8fafc; border:1px solid #f1f5f9; border-radius:10px; padding:.85rem 1rem; font-size:.85rem; color:#475569; line-height:1.6; white-space:pre-wrap; }
</style>

<!-- ─── Hero ─── -->
<div class="td-hero">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3" style="position:relative;z-index:1;">
        <div class="d-flex align-items-center gap-3">
            <a asp-action="Index" class="btn btn-sm" style="background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.2);color:#fff;border-radius:10px;">
                <i class="bi bi-arrow-left"></i>
            </a>
            <div>
                <h4><i class="bi bi-journal-text me-2" style="opacity:.85;"></i>Task Details</h4>
                <div class="td-sub">View task information, reference, and time log history</div>
            </div>
        </div>
        <div class="d-flex gap-2">
            @if (canEditDelete)
            {
                <a asp-action="Edit" asp-permission="DailyTaskLog:Edit" asp-route-id="@Model.Id" class="td-btn-edit"><i class="bi bi-pencil-square me-1"></i> Edit Task</a>
            }
        </div>
    </div>
</div>

<!-- ─── Task Info Card ─── -->
<div class="td-card">
    <div class="card-body">
        <div class="td-section-lbl"><i class="bi bi-info-circle me-1"></i> Basic Information</div>
        <div class="row">
            <div class="col-md-8">
                <div class="td-field-label">Task Title</div>
                <div class="td-field-value" style="font-size:1rem;">@Model.TaskTitle</div>
            </div>
            <div class="col-md-4 text-md-end">
                <span class="td-status @statusCls">@Model.Status</span>
            </div>
        </div>
        <div class="row">
            <div class="col-md-3">
                <div class="td-field-label">Task Date</div>
                <div class="td-field-value"><i class="bi bi-calendar3 me-1 text-muted"></i>@Model.TaskDate.ToString("dd MMM yyyy")</div>
            </div>
            <div class="col-md-3">
                <div class="td-field-label">Task Type</div>
                <div class="td-field-value"><span class="td-type-badge @typeCls">@Model.TaskTypeName</span></div>
            </div>
            <div class="col-md-3">
                <div class="td-field-label">Category</div>
                <div class="td-field-value"><span class="td-cat-badge">@Model.TaskCategoryName</span></div>
            </div>
            <div class="col-md-3">
                <div class="td-field-label">Created By</div>
                <div class="td-field-value"><i class="bi bi-person me-1 text-muted"></i>@Model.UserName</div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-3">
                <div class="td-field-label">Assigned To</div>
                <div class="td-field-value @(string.IsNullOrWhiteSpace(Model.AssignedToUserName) ? "td-muted" : "")">
                    @if (!string.IsNullOrWhiteSpace(Model.AssignedToUserName))
                    {
                        <i class="bi bi-person-check me-1" style="color:#6366f1;"></i>@Model.AssignedToUserName
                    }
                    else
                    {
                        <text>— Unassigned —</text>
                    }
                </div>
            </div>
            <div class="col-md-3">
                <div class="td-field-label">Created At</div>
                <div class="td-field-value" style="font-size:.82rem;">@Model.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")</div>
            </div>
            <div class="col-md-3">
                <div class="td-field-label">Last Updated</div>
                <div class="td-field-value @(Model.UpdatedAt == null ? "td-muted" : "")" style="font-size:.82rem;">
                    @(Model.UpdatedAt?.ToString("dd MMM yyyy, hh:mm tt") ?? "—")
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <div class="td-field-label">Description</div>
            <div class="td-desc-box">@Model.Description</div>
        }
    </div>
</div>

<!-- ─── Reference Card ─── -->
@if (Model.TicketId.HasValue || Model.ProjectModuleId.HasValue)
{
    <div class="td-card">
        <div class="card-body">
            <div class="td-section-lbl"><i class="bi bi-link-45deg me-1"></i> Reference</div>
            <div class="row">
                @if (Model.TicketId.HasValue)
                {
                    <div class="col-md-6">
                        <div class="td-field-label">Linked Ticket</div>
                        <div class="td-field-value">
                            <span style="background:#ede9fe;color:#6366f1;font-size:.78rem;font-weight:700;padding:4px 10px;border-radius:8px;">
                                <i class="bi bi-ticket-perforated me-1"></i>@Model.TicketNumber
                            </span>
                            @if (!string.IsNullOrWhiteSpace(Model.TicketSubject))
                            {
                                <span class="ms-2" style="font-size:.82rem;color:#475569;">@Model.TicketSubject</span>
                            }
                        </div>
                    </div>
                }
                @if (Model.ProjectModuleId.HasValue)
                {
                    <div class="col-md-6">
                        <div class="td-field-label">Project / Module</div>
                        <div class="td-field-value">
                            <span style="background:#ecfdf5;color:#059669;font-size:.78rem;font-weight:700;padding:4px 10px;border-radius:8px;">
                                <i class="bi bi-folder me-1"></i>@Model.ProjectModuleName
                            </span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

<!-- ─── Time Effort Card ─── -->
<div class="td-card">
    <div class="card-body">
        <div class="td-section-lbl"><i class="bi bi-clock-history me-1"></i> Time Effort</div>

        <!-- Summary Stats -->
        <div class="d-flex gap-3 flex-wrap mb-4">
            <div class="td-time-card" style="min-width:120px;">
                <div class="td-time-num">@FormatTime(Model.TotalTimeSpentMinutes)</div>
                <div class="td-time-lbl">Total Effort</div>
            </div>
            <div class="td-time-card" style="min-width:120px;">
                <div class="td-time-num">@Model.TimeLogCount</div>
                <div class="td-time-lbl">Time Entries</div>
            </div>
            @if (Model.LastLogDate.HasValue)
            {
                <div class="td-time-card" style="min-width:120px;">
                    <div class="td-time-num" style="font-size:1rem;">@Model.LastLogDate.Value.ToString("dd MMM")</div>
                    <div class="td-time-lbl">Last Logged</div>
                </div>
            }
        </div>

        <!-- Time Log Entries -->
        @if (timeLogs.Any())
        {
            <div class="td-field-label mb-2">Time Log History</div>
            @foreach (var log in timeLogs)
            {
                <div class="td-log-row">
                    <span class="td-log-date">@log.LogDate.ToString("dd MMM yyyy")</span>
                    <span class="td-log-time-pill">@FormatTime(log.TimeSpentMinutes)</span>
                    <span class="td-log-remark">@(string.IsNullOrWhiteSpace(log.Remarks) ? "—" : log.Remarks)</span>
                    <span class="td-log-user">@log.UserName</span>
                </div>
            }
        }
        else
        {
            <div class="text-center py-3" style="color:#94a3b8;font-size:.85rem;">
                <i class="bi bi-clock" style="font-size:1.5rem;display:block;margin-bottom:.5rem;color:#cbd5e1;"></i>
                No time logged yet.
            </div>
        }
    </div>
</div>

<!-- ─── Bottom Actions ─── -->
<div class="d-flex gap-2 mb-4">
    <a asp-action="Index" class="td-btn-back"><i class="bi bi-arrow-left me-1"></i> Back to Tasks</a>
    @if (canEditDelete)
    {
        <a asp-action="Edit" asp-permission="DailyTaskLog:Edit" asp-route-id="@Model.Id" class="td-btn-edit"><i class="bi bi-pencil-square me-1"></i> Edit Task</a>
    }
</div>

@functions {
    string FormatTime(int minutes)
    {
        if (minutes == 0) return "0m";
        var h = minutes / 60;
        var m = minutes % 60;
        if (h == 0) return $"{m}m";
        if (m == 0) return $"{h}h";
        return $"{h}h {m}m";
    }
}
