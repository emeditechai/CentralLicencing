@model CentralLicenceApp.Models.ViewModels.DailyTaskLogIndexViewModel
@{
    ViewData["Title"] = Model.IsManagerView ? "Team Tasks" : "My Tasks";
    var fromStr = Model.FromDate?.ToString("yyyy-MM-dd") ?? "";
    var toStr   = Model.ToDate?.ToString("yyyy-MM-dd") ?? "";
}

<style>
    .tl-hero { background:linear-gradient(135deg,#667eea 0%,#764ba2 100%); border-radius:20px; padding:2rem 2.25rem; margin-bottom:1.75rem; position:relative; overflow:hidden; }
    .tl-hero::before { content:''; position:absolute; top:-50%; right:-8%; width:320px; height:320px; background:rgba(255,255,255,.06); border-radius:50%; pointer-events:none; }
    .tl-hero::after { content:''; position:absolute; bottom:-35%; left:15%; width:220px; height:220px; background:rgba(255,255,255,.04); border-radius:50%; pointer-events:none; }
    .tl-hero h4 { color:#fff; font-weight:800; font-size:1.5rem; letter-spacing:-.02em; margin-bottom:.25rem; }
    .tl-hero .tl-sub { color:rgba(255,255,255,.75); font-size:.85rem; }

    .tl-stat { background:rgba(255,255,255,.15); backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,.18); border-radius:14px; padding:.7rem 1.1rem; min-width:105px; text-align:center; transition:transform .18s ease; }
    .tl-stat:hover { transform:translateY(-2px); background:rgba(255,255,255,.22); }
    .tl-stat-num { font-size:1.5rem; font-weight:800; color:#fff; line-height:1.2; }
    .tl-stat-lbl { font-size:.68rem; text-transform:uppercase; letter-spacing:.06em; font-weight:600; color:rgba(255,255,255,.7); }

    .tl-filter { background:#fff; border-radius:16px; box-shadow:0 2px 16px rgba(0,0,0,.05); border:1px solid #f1f5f9; padding:1rem 1.5rem; margin-bottom:1.5rem; }
    .tl-filter .form-control, .tl-filter .form-select { border-radius:10px; border:1.5px solid #e2e8f0; font-size:.85rem; }
    .tl-filter .form-control:focus, .tl-filter .form-select:focus { border-color:#818cf8; box-shadow:0 0 0 3px rgba(129,140,248,.15); }
    .tl-filter-btn { background:linear-gradient(135deg,#6366f1,#4f46e5); border:none; border-radius:10px; font-weight:600; font-size:.82rem; padding:.45rem 1.1rem; }

    .tl-card { background:#fff; border-radius:14px; box-shadow:0 2px 12px rgba(0,0,0,.05); border:1px solid #f1f5f9; overflow:hidden; }
    .tl-table { margin-bottom:0; }
    .tl-table thead { background:linear-gradient(180deg,#f8fafc,#f1f5f9); }
    .tl-table thead th { font-size:.7rem; font-weight:700; color:#475569; text-transform:uppercase; letter-spacing:.08em; padding:.75rem .85rem; border-bottom:2px solid #e2e8f0; white-space:nowrap; }
    .tl-table tbody tr { transition:all .15s ease; border-bottom:1px solid #f8fafc; }
    .tl-table tbody tr:hover { background:linear-gradient(90deg,#f5f3ff,#eff6ff); }
    .tl-table td { vertical-align:middle; padding:.7rem .85rem; font-size:.85rem; color:#334155; }

    .tl-type-badge { font-size:.7rem; font-weight:700; padding:4px 10px; border-radius:20px; letter-spacing:.03em; }
    .tl-type-dev { background:linear-gradient(135deg,#ede9fe,#ddd6fe); color:#5b21b6; }
    .tl-type-sup { background:linear-gradient(135deg,#dbeafe,#bfdbfe); color:#1e40af; }
    .tl-cat-badge { font-size:.7rem; font-weight:600; padding:3px 8px; border-radius:8px; background:#f1f5f9; color:#475569; }

    .tl-status { font-size:.7rem; font-weight:700; padding:4px 10px; border-radius:20px; letter-spacing:.03em; }
    .tl-status-pending { background:linear-gradient(135deg,#fef9c3,#fde68a); color:#92400e; }
    .tl-status-started { background:linear-gradient(135deg,#e0e7ff,#c7d2fe); color:#3730a3; }
    .tl-status-inprogress { background:linear-gradient(135deg,#dbeafe,#93c5fd); color:#1e40af; }
    .tl-status-onhold { background:linear-gradient(135deg,#fee2e2,#fecaca); color:#991b1b; }
    .tl-status-completed { background:linear-gradient(135deg,#dcfce7,#bbf7d0); color:#166534; }
    .tl-status-cancelled { background:linear-gradient(135deg,#f1f5f9,#e2e8f0); color:#64748b; }

    .tl-time { font-weight:700; font-size:.85rem; color:#1e293b; }
    .tl-time small { font-weight:500; color:#94a3b8; font-size:.72rem; }
    .tl-time-zero { color:#cbd5e1; font-weight:500; }
    .tl-log-count { font-size:.7rem; color:#6366f1; font-weight:600; cursor:pointer; }
    .tl-log-count:hover { text-decoration:underline; }

    .tl-action-btn { width:30px; height:30px; border-radius:8px; border:1.5px solid #e2e8f0; background:#fff; display:inline-flex; align-items:center; justify-content:center; transition:all .18s; font-size:.8rem; color:#64748b; text-decoration:none; }
    .tl-action-btn:hover { border-color:#818cf8; background:#f5f3ff; color:#6366f1; transform:translateY(-1px); }
    .tl-action-btn-danger:hover { border-color:#f87171; background:#fef2f2; color:#ef4444; }
    .tl-action-btn-time { border-color:#10b981; color:#059669; }
    .tl-action-btn-time:hover { background:#ecfdf5; border-color:#059669; color:#047857; transform:translateY(-1px); }

    .tl-add-btn { background:linear-gradient(135deg,#6366f1,#4f46e5); border:none; border-radius:12px; font-weight:700; padding:.55rem 1.25rem; font-size:.85rem; box-shadow:0 4px 14px rgba(99,102,241,.35); color:#fff; text-decoration:none; transition:all .2s; }
    .tl-add-btn:hover { transform:translateY(-1px); box-shadow:0 6px 20px rgba(99,102,241,.45); color:#fff; }

    .tl-empty { padding:3rem 1rem; text-align:center; }
    .tl-empty i { font-size:3rem; color:#cbd5e1; display:block; margin-bottom:.75rem; }
    .tl-empty span { color:#94a3b8; font-size:.9rem; }

    .tl-ticket-ref { font-size:.72rem; color:#6366f1; font-weight:600; }
    .tl-project-ref { font-size:.72rem; color:#059669; font-weight:600; }

    .tl-tab-toggle { display:inline-flex; background:#f1f5f9; border-radius:10px; padding:3px; gap:3px; }
    .tl-tab-toggle a { padding:.4rem 1rem; border-radius:8px; font-size:.82rem; font-weight:600; color:#64748b; text-decoration:none; transition:all .15s; }
    .tl-tab-toggle a.active { background:#fff; color:#6366f1; box-shadow:0 1px 4px rgba(0,0,0,.08); }
    .tl-tab-toggle a:hover:not(.active) { color:#1e293b; }

    .tl-modal .modal-content { border-radius:16px; border:none; box-shadow:0 20px 60px rgba(0,0,0,.15); }
    .tl-modal .modal-header { background:linear-gradient(135deg,#667eea,#764ba2); border-radius:16px 16px 0 0; padding:1.1rem 1.5rem; }
    .tl-modal .modal-header .modal-title { color:#fff; font-weight:700; font-size:1rem; }
    .tl-modal .modal-header .btn-close { filter:brightness(0) invert(1); opacity:.8; }
    .tl-modal .modal-body { padding:1.5rem; }
    .tl-modal .form-label { font-size:.82rem; font-weight:700; color:#1e293b; }
    .tl-modal .form-control, .tl-modal .form-select { border-radius:10px; border:1.5px solid #e2e8f0; font-size:.85rem; }
    .tl-modal .form-control:focus { border-color:#818cf8; box-shadow:0 0 0 3px rgba(129,140,248,.15); }

    .tl-log-row { background:#f8fafc; border-radius:10px; padding:.6rem .85rem; margin-bottom:.4rem; display:flex; align-items:center; justify-content:space-between; border:1px solid #f1f5f9; transition:background .15s; }
    .tl-log-row:hover { background:#f5f3ff; border-color:#e8e4f8; }
    .tl-log-date { font-weight:700; font-size:.82rem; color:#1e293b; min-width:90px; }
    .tl-log-time-pill { background:linear-gradient(135deg,#ede9fe,#ddd6fe); color:#5b21b6; font-weight:700; font-size:.75rem; padding:3px 10px; border-radius:20px; white-space:nowrap; }
    .tl-log-remark { font-size:.8rem; color:#64748b; flex:1; margin:0 .75rem; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .tl-log-user { font-size:.72rem; color:#94a3b8; font-weight:600; min-width:70px; text-align:right; }
    .tl-log-del { width:24px; height:24px; border-radius:6px; border:1px solid #fecaca; background:#fff; color:#ef4444; display:inline-flex; align-items:center; justify-content:center; font-size:.7rem; cursor:pointer; margin-left:.5rem; transition:all .15s; }
    .tl-log-del:hover { background:#fef2f2; border-color:#f87171; }
</style>

<!-- ── Hero Header ── -->
<div class="tl-hero">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3" style="position:relative;z-index:1;">
        <div>
            <h4>
                <i class="bi bi-journal-check me-2" style="opacity:.85;"></i>
                @(Model.IsManagerView ? "Team Tasks" : "My Tasks")
            </h4>
            <div class="tl-sub">Create tasks and log time against them to track effort</div>
        </div>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <div class="tl-stat"><div class="tl-stat-num">@Model.TotalTasks</div><div class="tl-stat-lbl">Tasks</div></div>
            <div class="tl-stat"><div class="tl-stat-num">@FormatTime(Model.TotalMinutes)</div><div class="tl-stat-lbl">Total Effort</div></div>
            <div class="tl-stat"><div class="tl-stat-num">@FormatTime(Model.DevMinutes)</div><div class="tl-stat-lbl"><i class="bi bi-code-slash" style="font-size:.6rem;"></i> Dev</div></div>
            <div class="tl-stat"><div class="tl-stat-num">@FormatTime(Model.SupportMinutes)</div><div class="tl-stat-lbl"><i class="bi bi-headset" style="font-size:.6rem;"></i> Support</div></div>
            @if (Model.CanCreateTask)
            {
                <a asp-action="Create" class="tl-add-btn ms-1"><i class="bi bi-plus-lg me-1"></i> New Task</a>
            }
        </div>
    </div>
</div>

<!-- ── Filters ── -->
<div class="tl-filter">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div class="tl-tab-toggle">
            <a asp-action="Index" class="@(!Model.IsManagerView ? "active" : "")"><i class="bi bi-person me-1"></i> My Tasks</a>
            @if (User.IsInRole("Administrator") || User.IsInRole("Ticket Admin") || User.IsInRole("Ticket Agent"))
            {
                <a asp-action="TeamView" class="@(Model.IsManagerView ? "active" : "")"><i class="bi bi-people me-1"></i> Team View</a>
            }
        </div>
        <div class="d-flex gap-1">
            <span class="badge tl-status-pending" style="font-size:.72rem;">@Model.PendingCount Pending</span>
            <span class="badge tl-status-inprogress" style="font-size:.72rem;">@Model.InProgressCount In Progress</span>
            <span class="badge tl-status-completed" style="font-size:.72rem;">@Model.CompletedCount Completed</span>
            <span class="badge tl-status-cancelled" style="font-size:.72rem;">@Model.CancelledCount Cancelled</span>
        </div>
    </div>
    <form method="get" asp-action="@(Model.IsManagerView ? "TeamView" : "Index")" class="row g-2 align-items-end">
        <div class="col-md-2 col-sm-4">
            <label class="form-label mb-1" style="font-size:.72rem;font-weight:700;color:#64748b;text-transform:uppercase;">Task Type</label>
            <select name="taskType" class="form-select form-select-sm">
                <option value="">All Types</option>
                @foreach (var tt in Model.TaskTypes) { <option value="@tt.Id" selected="@(Model.TaskTypeFilter == tt.Id)">@tt.Name</option> }
            </select>
        </div>
        <div class="col-md-2 col-sm-4">
            <label class="form-label mb-1" style="font-size:.72rem;font-weight:700;color:#64748b;text-transform:uppercase;">Category</label>
            <select name="category" class="form-select form-select-sm">
                <option value="">All Categories</option>
                @foreach (var c in Model.TaskCategories) { <option value="@c.Id" selected="@(Model.CategoryFilter == c.Id)">@c.Name</option> }
            </select>
        </div>
        <div class="col-md-2 col-sm-4">
            <label class="form-label mb-1" style="font-size:.72rem;font-weight:700;color:#64748b;text-transform:uppercase;">Status</label>
            <select name="status" class="form-select form-select-sm">
                <option value="">All Statuses</option>
                @foreach (var s in new[] { "Pending", "Started", "In Progress", "On Hold", "Completed", "Cancelled" }) { <option value="@s" selected="@(Model.StatusFilter == s)">@s</option> }
            </select>
        </div>
        @if (Model.IsManagerView && Model.TeamMembers.Any())
        {
            <div class="col-md-2 col-sm-4">
                <label class="form-label mb-1" style="font-size:.72rem;font-weight:700;color:#64748b;text-transform:uppercase;">User</label>
                <select name="user" class="form-select form-select-sm">
                    <option value="">All Members</option>
                    @foreach (var u in Model.TeamMembers) { <option value="@u.Id" selected="@(Model.UserFilter == u.Id)">@u.FullName</option> }
                </select>
            </div>
        }
        <div class="col-md-2 col-sm-4">
            <label class="form-label mb-1" style="font-size:.72rem;font-weight:700;color:#64748b;text-transform:uppercase;">Search</label>
            <input type="text" name="search" value="@Model.SearchTerm" class="form-control form-control-sm" placeholder="Search title…" />
        </div>
        <div class="col-md-auto col-sm-4">
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm tl-filter-btn"><i class="bi bi-funnel-fill me-1"></i> Filter</button>
                <a asp-action="@(Model.IsManagerView ? "TeamView" : "Index")" class="btn btn-outline-secondary btn-sm" style="border-radius:10px;font-size:.82rem;font-weight:600;"><i class="bi bi-x-lg me-1"></i> Clear</a>
            </div>
        </div>
    </form>
</div>

@Html.AntiForgeryToken()

<!-- ── Task Table ── -->
@if (!Model.Tasks.Any())
{
    <div class="tl-card">
        <div class="tl-empty">
            <i class="bi bi-journal-x"></i>
            <span>No tasks found.</span>
            @if (Model.CanCreateTask)
            {
                <div class="mt-3"><a asp-action="Create" class="tl-add-btn" style="font-size:.82rem;padding:.45rem 1.1rem;"><i class="bi bi-plus-lg me-1"></i> Create Your First Task</a></div>
            }
        </div>
    </div>
}
else
{
    <div class="tl-card">
        <div class="table-responsive">
            <table class="table tl-table">
                <thead>
                    <tr>
                        @if (Model.IsManagerView) { <th>Created By</th> }
                        <th>Task</th>
                        <th>Type</th>
                        <th>Category</th>
                        <th>Assigned To</th>
                        <th>Reference</th>
                        <th>Total Effort</th>
                        <th>Status</th>
                        <th class="text-center" style="min-width:130px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.Tasks)
                    {
                        var statusCls = t.Status == "Completed" ? "tl-status-completed" : t.Status == "Cancelled" ? "tl-status-cancelled" : t.Status == "In Progress" ? "tl-status-inprogress" : t.Status == "Started" ? "tl-status-started" : t.Status == "On Hold" ? "tl-status-onhold" : "tl-status-pending";
                        var typeCls = t.TaskTypeName == "Development" ? "tl-type-dev" : "tl-type-sup";
                        <tr>
                            @if (Model.IsManagerView) { <td style="font-size:.82rem;font-weight:600;color:#1e293b;">@t.UserName</td> }
                            <td>
                                <div style="font-weight:700;font-size:.85rem;color:#1e293b;">@t.TaskTitle</div>
                                @if (!string.IsNullOrWhiteSpace(t.Description))
                                {
                                    <div style="font-size:.73rem;color:#94a3b8;max-width:280px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@t.Description</div>
                                }
                                <div style="font-size:.68rem;color:#94a3b8;margin-top:2px;"><i class="bi bi-calendar3 me-1"></i>@t.TaskDate.ToString("dd MMM yyyy")</div>
                            </td>
                            <td><span class="tl-type-badge @typeCls">@t.TaskTypeName</span></td>
                            <td><span class="tl-cat-badge">@t.TaskCategoryName</span></td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(t.AssignedToUserName))
                                {
                                    <span style="font-size:.82rem;font-weight:600;color:#6366f1;"><i class="bi bi-person-check me-1"></i>@t.AssignedToUserName</span>
                                }
                                else
                                {
                                    <span class="text-muted" style="font-size:.78rem;">—</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(t.TicketNumber))
                                {
                                    <div class="tl-ticket-ref"><i class="bi bi-ticket-perforated me-1"></i>@t.TicketNumber</div>
                                }
                                else if (!string.IsNullOrWhiteSpace(t.ProjectModuleName))
                                {
                                    <div class="tl-project-ref"><i class="bi bi-folder me-1"></i>@t.ProjectModuleName</div>
                                }
                                else
                                {
                                    <span class="text-muted" style="font-size:.78rem;">—</span>
                                }
                            </td>
                            <td>
                                @if (t.TotalTimeSpentMinutes > 0)
                                {
                                    <div class="tl-time">@FormatTime(t.TotalTimeSpentMinutes)</div>
                                    <span class="tl-log-count" onclick="viewTimeLogs(@t.Id, '@t.TaskTitle.Replace("'", "\\'")')">@t.TimeLogCount log@(t.TimeLogCount != 1 ? "s" : "")</span>
                                }
                                else
                                {
                                    <span class="tl-time-zero">No time logged</span>
                                }
                            </td>
                            <td><span class="tl-status @statusCls">@t.Status</span></td>
                            <td class="text-center">
                                <div class="d-flex gap-1 justify-content-center">
                                    <a asp-action="Details" asp-route-id="@t.Id" class="tl-action-btn" title="View Task"><i class="bi bi-eye"></i></a>
                                    @if (t.Status != "Completed" && t.Status != "Cancelled")
                                    {
                                        <button type="button" class="tl-action-btn tl-action-btn-time" title="Log Time" onclick="openLogTime(@t.Id, '@t.TaskTitle.Replace("'", "\\'")')"><i class="bi bi-clock-history"></i></button>
                                    }
                                    else
                                    {
                                        <button type="button" class="tl-action-btn" title="@(t.Status == "Cancelled" ? "Task Cancelled" : "Task Completed") – Time logging disabled" disabled style="opacity:.4;cursor:not-allowed;"><i class="bi bi-clock-history"></i></button>
                                    }
                                    @if (t.Status != "Cancelled")
                                    {
                                        <button type="button" class="tl-action-btn" title="Change Status" style="border-color:#f59e0b;color:#d97706;" onclick="openChangeStatus(@t.Id, '@t.TaskTitle.Replace("'", "\\'")', '@t.Status')"><i class="bi bi-arrow-repeat"></i></button>
                                    }
                                    @if (Model.CanEditDelete && t.Status != "Cancelled")
                                    {
                                        <button type="button" class="tl-action-btn" title="Cancel Task" style="border-color:#64748b;color:#64748b;" onclick="cancelTask(@t.Id, '@t.TaskTitle.Replace("'", "\\'")')"><i class="bi bi-x-circle"></i></button>
                                    }
                                    @if (Model.CanEditDelete)
                                    {
                                        @if (t.Status == "Cancelled")
                                        {
                                            <span class="tl-action-btn" title="Task Cancelled – Edit disabled" style="opacity:.4;cursor:not-allowed;"><i class="bi bi-pencil-square"></i></span>
                                            <span class="tl-action-btn" title="Task Cancelled – Delete disabled" style="opacity:.4;cursor:not-allowed;"><i class="bi bi-trash3"></i></span>
                                        }
                                        else
                                        {
                                            <a asp-action="Edit" asp-route-id="@t.Id" class="tl-action-btn" title="Edit Task"><i class="bi bi-pencil-square"></i></a>
                                            <button type="button" class="tl-action-btn tl-action-btn-danger" title="Delete" onclick="deleteTask(@t.Id)"><i class="bi bi-trash3"></i></button>
                                        }
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- ── Log Time Modal ── -->
<div class="modal fade tl-modal" id="logTimeModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-clock-history me-2"></i>Log Time</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-2" style="font-size:.82rem;font-weight:600;color:#6366f1;" id="logTimeTaskTitle"></div>
                <input type="hidden" id="logTimeTaskId" />
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label">Date <span class="text-danger">*</span></label>
                        <input type="date" id="logTimeDate" class="form-control" required />
                    </div>
                    <div class="col-6">
                        <label class="form-label">Hours</label>
                        <input type="number" id="logTimeHours" class="form-control" min="0" max="23" value="0" />
                    </div>
                    <div class="col-6">
                        <label class="form-label">Minutes</label>
                        <input type="number" id="logTimeMinutes" class="form-control" min="0" max="59" step="5" value="0" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Remarks</label>
                        <textarea id="logTimeRemarks" class="form-control" rows="2" placeholder="What did you work on?"></textarea>
                    </div>
                </div>
                <div class="d-flex justify-content-end gap-2 mt-3">
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal" style="border-radius:10px;font-weight:600;">Cancel</button>
                    <button type="button" class="btn btn-primary btn-sm" onclick="submitLogTime()" style="background:linear-gradient(135deg,#6366f1,#4f46e5);border:none;border-radius:10px;font-weight:700;padding:.4rem 1.2rem;">
                        <i class="bi bi-check-lg me-1"></i> Save
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── Change Status Modal ── -->
<div class="modal fade tl-modal" id="changeStatusModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header" style="background:linear-gradient(135deg,#f59e0b,#d97706);">
                <h5 class="modal-title"><i class="bi bi-arrow-repeat me-2"></i>Change Status</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3" style="font-size:.82rem;font-weight:600;color:#6366f1;" id="changeStatusTaskTitle"></div>
                <input type="hidden" id="changeStatusTaskId" />
                <div class="mb-3">
                    <label class="form-label">New Status <span class="text-danger">*</span></label>
                    <select id="changeStatusSelect" class="form-select">
                        <option value="">-- Select Status --</option>
                        <option value="Pending">Pending</option>
                        <option value="Started">Started</option>
                        <option value="In Progress">In Progress</option>
                        <option value="On Hold">On Hold</option>
                        <option value="Completed">Completed</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Note / Reason <span class="text-danger">*</span></label>
                    <textarea id="changeStatusNote" class="form-control" rows="2" placeholder="Why are you changing the status?" required></textarea>
                </div>
                <div class="d-flex justify-content-end gap-2">
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal" style="border-radius:10px;font-weight:600;">Cancel</button>
                    <button type="button" class="btn btn-warning btn-sm" onclick="submitChangeStatus()" style="border:none;border-radius:10px;font-weight:700;padding:.4rem 1.2rem;color:#fff;background:linear-gradient(135deg,#f59e0b,#d97706);">
                        <i class="bi bi-check-lg me-1"></i> Update
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── View Time Logs Modal ── -->
<div class="modal fade tl-modal" id="viewLogsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-list-check me-2"></i>Time Log History</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3" style="font-size:.85rem;font-weight:700;color:#1e293b;" id="viewLogsTaskTitle"></div>
                <div id="viewLogsContent">
                    <div class="text-center py-3"><div class="spinner-border spinner-border-sm text-primary"></div></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

    // ── Change Status ──
    function openChangeStatus(taskId, title, currentStatus) {
        document.getElementById('changeStatusTaskId').value = taskId;
        document.getElementById('changeStatusTaskTitle').textContent = title;
        document.getElementById('changeStatusNote').value = '';
        var sel = document.getElementById('changeStatusSelect');
        sel.value = '';
        // Disable current status option
        for (var i = 0; i < sel.options.length; i++) {
            sel.options[i].disabled = sel.options[i].value === currentStatus;
        }
        new bootstrap.Modal(document.getElementById('changeStatusModal')).show();
    }

    function submitChangeStatus() {
        var taskId = document.getElementById('changeStatusTaskId').value;
        var status = document.getElementById('changeStatusSelect').value;
        var note = document.getElementById('changeStatusNote').value.trim();
        if (!status) {
            showAppAlert('warning', 'Required', 'Please select a status.');
            return;
        }
        if (!note) {
            showAppAlert('warning', 'Required', 'Please enter a note / reason for the status change.');
            document.getElementById('changeStatusNote').focus();
            return;
        }
        var fd = new FormData();
        fd.append('taskId', taskId);
        fd.append('status', status);
        fd.append('note', note);
        fd.append('__RequestVerificationToken', token);

        fetch('@Url.Action("ChangeStatus", "DailyTaskLog")', { method: 'POST', body: fd })
            .then(r => r.json())
            .then(function (data) {
                if (data.success) {
                    bootstrap.Modal.getInstance(document.getElementById('changeStatusModal')).hide();
                    showAppAlert('success', 'Updated', data.message);
                    setTimeout(function () { location.reload(); }, 600);
                } else {
                    showAppAlert('error', 'Error', data.message);
                }
            });
    }

    // ── Log Time ──
    function openLogTime(taskId, title) {
        document.getElementById('logTimeTaskId').value = taskId;
        document.getElementById('logTimeTaskTitle').textContent = title;
        document.getElementById('logTimeDate').value = new Date().toISOString().split('T')[0];
        document.getElementById('logTimeHours').value = 0;
        document.getElementById('logTimeMinutes').value = 0;
        document.getElementById('logTimeRemarks').value = '';
        new bootstrap.Modal(document.getElementById('logTimeModal')).show();
    }

    function submitLogTime() {
        var taskId = document.getElementById('logTimeTaskId').value;
        var fd = new FormData();
        fd.append('taskId', taskId);
        fd.append('logDate', document.getElementById('logTimeDate').value);
        fd.append('hours', document.getElementById('logTimeHours').value);
        fd.append('minutes', document.getElementById('logTimeMinutes').value);
        fd.append('remarks', document.getElementById('logTimeRemarks').value);
        fd.append('__RequestVerificationToken', token);

        fetch('@Url.Action("LogTime", "DailyTaskLog")', { method: 'POST', body: fd })
            .then(r => r.json())
            .then(function (data) {
                if (data.success) {
                    bootstrap.Modal.getInstance(document.getElementById('logTimeModal')).hide();
                    showAppAlert('success', 'Time Logged', data.message);
                    setTimeout(function () { location.reload(); }, 600);
                } else {
                    showAppAlert('error', 'Error', data.message);
                }
            });
    }

    // ── View Time Logs ──
    function viewTimeLogs(taskId, title) {
        document.getElementById('viewLogsTaskTitle').textContent = title;
        document.getElementById('viewLogsContent').innerHTML = '<div class="text-center py-3"><div class="spinner-border spinner-border-sm text-primary"></div></div>';
        new bootstrap.Modal(document.getElementById('viewLogsModal')).show();

        fetch('@Url.Action("GetTimeLogs", "DailyTaskLog")?taskId=' + taskId)
            .then(r => r.json())
            .then(function (logs) {
                if (!logs.length) {
                    document.getElementById('viewLogsContent').innerHTML = '<div class="text-center py-3 text-muted" style="font-size:.85rem;">No time entries yet.</div>';
                    return;
                }
                var total = logs.reduce(function (s, l) { return s + l.timeSpentMinutes; }, 0);
                var html = '<div class="mb-2" style="font-size:.78rem;font-weight:700;color:#6366f1;">Total: ' + fmtTime(total) + '</div>';
                logs.forEach(function (l) {
                    html += '<div class="tl-log-row">'
                        + '<span class="tl-log-date">' + escapeHtml(l.logDate) + '</span>'
                        + '<span class="tl-log-time-pill">' + fmtTime(l.timeSpentMinutes) + '</span>'
                        + '<span class="tl-log-remark">' + escapeHtml(l.remarks || '—') + '</span>'
                        + '<span class="tl-log-user">' + escapeHtml(l.userName) + '</span>'
                        + '<span class="tl-log-del" title="Delete" onclick="deleteTimeLog(' + l.id + ',' + l.taskId + ',\'' + escapeHtml(l.logDate) + '\')"><i class="bi bi-x-lg"></i></span>'
                        + '</div>';
                });
                document.getElementById('viewLogsContent').innerHTML = html;
            });
    }

    // ── Delete Time Log ──
    function deleteTimeLog(id, taskId, dateLabel) {
        Swal.fire({
            ...swalTheme, icon: 'warning', title: 'Delete Time Entry?',
            text: 'Remove ' + dateLabel + ' entry?', showCancelButton: true,
            confirmButtonText: 'Delete', confirmButtonColor: '#ef4444'
        }).then(function (r) {
            if (!r.isConfirmed) return;
            var fd = new FormData();
            fd.append('id', id);
            fd.append('__RequestVerificationToken', token);
            fetch('@Url.Action("DeleteTimeLog", "DailyTaskLog")', { method: 'POST', body: fd })
                .then(r => r.json())
                .then(function (data) {
                    if (data.success) { location.reload(); }
                    else { showAppAlert('error', 'Error', data.message); }
                });
        });
    }

    // ── Cancel Task ──
    function cancelTask(id, title) {
        Swal.fire({
            ...swalTheme, icon: 'warning', title: 'Cancel Task?',
            html: '<div style="font-size:.85rem;">Cancelling <strong>' + escapeHtml(title) + '</strong> will exclude its logged time from totals.</div>',
            input: 'textarea', inputPlaceholder: 'Reason for cancellation (required)…',
            inputAttributes: { required: true },
            showCancelButton: true, confirmButtonText: 'Cancel Task', confirmButtonColor: '#64748b',
            preConfirm: function(note) {
                if (!note || !note.trim()) { Swal.showValidationMessage('Please enter a reason.'); return false; }
                return note.trim();
            }
        }).then(function (r) {
            if (!r.isConfirmed) return;
            var fd = new FormData();
            fd.append('taskId', id);
            fd.append('note', r.value);
            fd.append('__RequestVerificationToken', token);
            fetch('@Url.Action("CancelTask", "DailyTaskLog")', { method: 'POST', body: fd })
                .then(r => r.json())
                .then(function (data) {
                    if (data.success) { showAppAlert('success', 'Cancelled', data.message); setTimeout(function () { location.reload(); }, 600); }
                    else { showAppAlert('error', 'Error', data.message); }
                });
        });
    }

    // ── Delete Task ──
    function deleteTask(id) {
        Swal.fire({
            ...swalTheme, icon: 'warning', title: 'Delete Task?',
            text: 'This will also remove all time entries.', showCancelButton: true,
            confirmButtonText: 'Delete', confirmButtonColor: '#ef4444'
        }).then(function (r) {
            if (!r.isConfirmed) return;
            var fd = new FormData();
            fd.append('__RequestVerificationToken', token);
            fetch('@Url.Action("Delete", "DailyTaskLog")' + '?id=' + id, { method: 'POST', body: fd })
                .then(r => r.json())
                .then(function (data) {
                    if (data.success) { showAppAlert('success', 'Deleted', data.message); setTimeout(function () { location.reload(); }, 600); }
                    else { showAppAlert('error', 'Error', data.message); }
                });
        });
    }

    function fmtTime(mins) {
        if (!mins) return '0m';
        var h = Math.floor(mins / 60), m = mins % 60;
        if (!h) return m + 'm';
        if (!m) return h + 'h';
        return h + 'h ' + m + 'm';
    }

    function escapeHtml(str) {
        var d = document.createElement('div');
        d.appendChild(document.createTextNode(str || ''));
        return d.innerHTML;
    }
</script>
}

@functions {
    string FormatTime(int minutes)
    {
        if (minutes == 0) return "0m";
        var h = minutes / 60;
        var m = minutes % 60;
        if (h == 0) return $"{m}m";
        if (m == 0) return $"{h}h";
        return $"{h}h {m}m";
    }
}

