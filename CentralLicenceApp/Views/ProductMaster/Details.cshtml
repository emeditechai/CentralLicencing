@using CentralLicenceApp.Helpers
@model CentralLicenceApp.Models.ViewModels.ProductMasterDetailsViewModel
@{
    ViewData["Title"] = "Product Details";
    var product = Model.Product;
    var pricingModelOptions = Model.ProductRates
        .Select(rate => rate.PricingModel)
        .Where(value => !string.IsNullOrWhiteSpace(value))
        .Distinct()
        .OrderBy(value => value)
        .ToList();
    var billingOptions = Model.ProductRates
        .Select(rate => string.IsNullOrWhiteSpace(rate.BillingFrequency)
            ? rate.BillingModel
            : $"{rate.BillingModel} / {rate.BillingFrequency}")
        .Where(value => !string.IsNullOrWhiteSpace(value))
        .Distinct()
        .OrderBy(value => value)
        .ToList();
}

<style>
    .product-details-page {
        --pd-ink: #1f2a44;
        --pd-muted: #667085;
        --pd-border: #dbe4f0;
        --pd-panel: #ffffff;
        --pd-surface: linear-gradient(180deg, #f4f7fb 0%, #eef4fb 100%);
        --pd-shadow: 0 18px 36px rgba(31, 42, 68, 0.08);
        --pd-shadow-soft: 0 10px 24px rgba(31, 42, 68, 0.06);
        --pd-indigo: #3147a8;
        --pd-cyan: #0f7ea8;
        --pd-green: #1f8f5f;
        --pd-amber: #c47b18;
        --pd-plum: #7047d1;
    }

    .product-details-page .pd-hero {
        max-width: 1080px;
        border: 1px solid rgba(219, 228, 240, 0.8);
        border-radius: 20px;
        overflow: hidden;
        box-shadow: var(--pd-shadow);
        background:
            radial-gradient(circle at top right, rgba(112, 71, 209, 0.12), transparent 28%),
            radial-gradient(circle at bottom left, rgba(15, 126, 168, 0.12), transparent 30%),
            linear-gradient(135deg, #ffffff 0%, #f6f9ff 44%, #eef4ff 100%);
    }

    .product-details-page .pd-hero-badge {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        padding: .5rem .9rem;
        border-radius: 999px;
        font-size: .76rem;
        font-weight: 700;
        letter-spacing: .02em;
    }

    .product-details-page .pd-chip-ok {
        background: #dcfce7;
        color: #166534;
    }

    .product-details-page .pd-chip-info {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .product-details-page .pd-card {
        position: relative;
        height: 100%;
        border: 1px solid rgba(219, 228, 240, 0.9);
        border-radius: 22px;
        background: var(--pd-panel);
        box-shadow: var(--pd-shadow-soft);
        overflow: hidden;
    }

    .product-details-page .pd-card::before {
        content: "";
        position: absolute;
        inset: 0 0 auto 0;
        height: 4px;
        background: var(--pd-accent, #3147a8);
    }

    .product-details-page .pd-card-body {
        padding: 1.2rem 1.2rem 1.1rem;
    }

    .product-details-page .pd-card-label {
        display: flex;
        align-items: center;
        gap: .55rem;
        color: var(--pd-muted);
        font-size: .75rem;
        font-weight: 800;
        letter-spacing: .08em;
    }

    .product-details-page .pd-card-icon {
        width: 34px;
        height: 34px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: color-mix(in srgb, var(--pd-accent, #3147a8) 12%, white);
        color: var(--pd-accent, #3147a8);
        font-size: 1rem;
    }

    .product-details-page .pd-card-value {
        margin-top: .95rem;
        color: var(--pd-ink);
        font-size: 1.7rem;
        font-weight: 800;
        line-height: 1.1;
    }

    .product-details-page .pd-card-value.smaller {
        font-size: 1.25rem;
    }

    .product-details-page .pd-card-note {
        margin-top: .45rem;
        color: var(--pd-muted);
        font-size: .8rem;
    }

    .product-details-page .pd-table-shell {
        border: 1px solid rgba(219, 228, 240, 0.9);
        border-radius: 24px;
        overflow: hidden;
        background: #fff;
        box-shadow: var(--pd-shadow);
    }

    .product-details-page .pd-toolbar {
        display: grid;
        grid-template-columns: minmax(0, 1.25fr) minmax(0, .9fr) minmax(0, .9fr) auto;
        gap: .9rem;
        padding: 1rem 1.25rem 1.15rem;
        background: linear-gradient(180deg, rgba(247, 250, 255, 0.96) 0%, rgba(240, 246, 255, 0.92) 100%);
        border-bottom: 1px solid #e5edf7;
    }

    .product-details-page .pd-toolbar-stat {
        display: flex;
        align-items: center;
        gap: .9rem;
        min-width: 0;
        padding: .95rem 1rem;
        border: 1px solid rgba(191, 209, 255, 0.9);
        border-radius: 18px;
        background: linear-gradient(135deg, rgba(255,255,255,.98) 0%, rgba(236,243,255,.96) 100%);
        box-shadow: 0 12px 24px rgba(49, 71, 168, 0.08);
    }

    .product-details-page .pd-toolbar-stat-icon {
        width: 44px;
        height: 44px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #2746b3;
        background: linear-gradient(135deg, #e4edff 0%, #d9f1ff 100%);
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .product-details-page .pd-toolbar-stat-title {
        color: var(--pd-muted);
        font-size: .72rem;
        font-weight: 800;
        letter-spacing: .08em;
    }

    .product-details-page .pd-toolbar-stat-value {
        color: var(--pd-ink);
        font-size: 1.25rem;
        font-weight: 800;
        line-height: 1.1;
    }

    .product-details-page .pd-toolbar-stat-note {
        color: var(--pd-muted);
        font-size: .78rem;
        margin-top: .1rem;
    }

    .product-details-page .pd-filter-group {
        display: flex;
        flex-direction: column;
        gap: .32rem;
        min-width: 0;
    }

    .product-details-page .pd-filter-label {
        font-size: .72rem;
        font-weight: 800;
        letter-spacing: .08em;
        color: var(--pd-muted);
        text-transform: uppercase;
    }

    .product-details-page .pd-filter-control {
        height: 46px;
        border-radius: 14px;
        border: 1px solid #cfdbeb;
        background: rgba(255,255,255,.96);
        color: #1e293b;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.7);
    }

    .product-details-page .pd-filter-control:focus {
        border-color: #8fb0ff;
        box-shadow: 0 0 0 .2rem rgba(49, 71, 168, .12);
    }

    .product-details-page .pd-toolbar-actions {
        display: flex;
        align-items: end;
        justify-content: flex-end;
    }

    .product-details-page .pd-reset-btn {
        min-width: 128px;
        height: 46px;
        border-radius: 14px;
        border: 1px solid #d8e1ee;
        background: #fff;
        color: #334155;
        font-weight: 700;
    }

    .product-details-page .pd-table-header {
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        border-bottom: 1px solid #e5edf7;
    }

    .product-details-page .pd-table-shell table thead th {
        color: #6b7280;
        font-size: .74rem;
        font-weight: 800;
        letter-spacing: .05em;
        background: #fbfdff;
    }

    .product-details-page .pd-table-shell table tbody tr {
        transition: background-color .18s ease;
    }

    .product-details-page .pd-table-shell table tbody tr:hover {
        background: #f8fbff;
    }

    .product-details-page .pd-table-shell table tbody td {
        padding-top: 1rem;
        padding-bottom: 1rem;
        vertical-align: middle;
        border-color: #edf2f8;
    }

    .product-details-page .pd-rate-cell {
        display: flex;
        flex-direction: column;
        gap: .18rem;
        white-space: nowrap;
    }

    .product-details-page .pd-rate-main {
        font-size: .98rem;
        font-weight: 800;
        color: #172554;
    }

    .product-details-page .pd-rate-note {
        color: var(--pd-muted);
        font-size: .74rem;
    }

    .product-details-page .pd-amc-card,
    .product-details-page .pd-detail-card,
    .product-details-page .pd-offer-card {
        border: 1px solid #ebf0f6;
        border-radius: 16px;
        padding: .72rem .85rem;
        background: linear-gradient(180deg, #ffffff 0%, #f9fbff 100%);
    }

    .product-details-page .pd-amc-card {
        min-width: 150px;
    }

    .product-details-page .pd-amc-main,
    .product-details-page .pd-offer-main,
    .product-details-page .pd-detail-main {
        font-size: .82rem;
        font-weight: 700;
        color: #1e293b;
        line-height: 1.4;
    }

    .product-details-page .pd-amc-note,
    .product-details-page .pd-offer-note,
    .product-details-page .pd-detail-note {
        font-size: .74rem;
        color: var(--pd-muted);
        margin-top: .22rem;
        line-height: 1.4;
    }

    .product-details-page .pd-detail-text {
        display: -webkit-box;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 1;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: normal;
    }

    .product-details-page .pd-detail-text.is-expanded {
        display: block;
        -webkit-line-clamp: unset;
        overflow: visible;
    }

    .product-details-page .pd-expand-btn {
        margin-top: .35rem;
        padding: 0;
        border: 0;
        background: transparent;
        color: #3156c9;
        font-size: .73rem;
        font-weight: 700;
        text-decoration: none;
    }

    .product-details-page .pd-expand-btn:hover {
        color: #223f96;
    }

    .product-details-page .pd-billing-stack {
        display: flex;
        flex-direction: column;
        gap: .22rem;
        min-width: 160px;
    }

    .product-details-page .pd-billing-main {
        color: #0f172a;
        font-size: .84rem;
        font-weight: 700;
    }

    .product-details-page .pd-billing-sub {
        color: var(--pd-muted);
        font-size: .74rem;
    }

    .product-details-page .pd-status-pill {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        padding: .44rem .72rem;
        border-radius: 999px;
        font-size: .74rem;
        font-weight: 800;
        letter-spacing: .01em;
        border: 1px solid transparent;
    }

    .product-details-page .pd-status-pill.is-active {
        color: #166534;
        background: #eafbf0;
        border-color: #cdeed8;
    }

    .product-details-page .pd-status-pill.is-inactive {
        color: #475569;
        background: #f1f5f9;
        border-color: #dbe3ec;
    }

    .product-details-page .pd-table-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1rem 1.25rem 1.15rem;
        border-top: 1px solid #e5edf7;
        background: linear-gradient(180deg, #fcfdff 0%, #f6f9ff 100%);
    }

    .product-details-page .pd-pagination-meta {
        color: var(--pd-muted);
        font-size: .82rem;
    }

    .product-details-page .pd-pagination-controls {
        display: flex;
        align-items: center;
        gap: .55rem;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .product-details-page .pd-page-btn {
        min-width: 40px;
        height: 40px;
        border-radius: 12px;
        border: 1px solid #d7e1ef;
        background: #fff;
        color: #334155;
        font-weight: 700;
        transition: all .18s ease;
    }

    .product-details-page .pd-page-btn:hover:not(:disabled) {
        border-color: #9fb9ff;
        color: #2746b3;
        background: #f8fbff;
    }

    .product-details-page .pd-page-btn.active {
        border-color: #3147a8;
        background: linear-gradient(135deg, #3147a8 0%, #22357f 100%);
        color: #fff;
        box-shadow: 0 10px 18px rgba(49, 71, 168, 0.18);
    }

    .product-details-page .pd-page-btn:disabled {
        opacity: .55;
        cursor: not-allowed;
        box-shadow: none;
    }

    .product-details-page .pd-action-btn {
        height: 38px;
        min-width: 38px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 .8rem;
        border-radius: 10px;
        font-size: .82rem;
        line-height: 1;
    }

    .product-details-page .pd-action-btn.icon-only {
        padding: 0;
        width: 38px;
    }

    .product-details-page .pd-action-btn i {
        font-size: .9rem;
        line-height: 1;
    }

    .product-details-page .pd-action-bar {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: .4rem;
        min-width: 156px;
        margin-left: auto;
    }

    .product-details-page .pd-empty-filter {
        display: none;
    }

    .product-details-page .pd-empty-state {
        padding: 2.4rem 1rem;
        text-align: center;
        color: var(--pd-muted);
    }

    .product-details-page .pd-empty-state i {
        font-size: 2rem;
        color: #9db0c7;
    }

    .product-details-page .pd-pricing-pill {
        display: inline-flex;
        align-items: center;
        padding: .38rem .7rem;
        border-radius: 999px;
        background: #f3e8ff;
        color: #7c3aed;
        font-size: .76rem;
        font-weight: 700;
    }

    .product-details-page .pd-secondary-block {
        color: var(--pd-muted);
        font-size: .77rem;
    }

    .product-details-page .pd-hero-icon {
        width: 56px;
        height: 56px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #6d28d9;
        font-size: 1.3rem;
        background: linear-gradient(135deg, #efe7ff 0%, #e0ecff 100%);
        box-shadow: inset 0 1px 0 rgba(255,255,255,.8);
    }

    @@media (max-width: 768px) {
        .product-details-page .pd-hero {
            max-width: 100%;
        }

        .product-details-page .pd-toolbar {
            grid-template-columns: 1fr;
        }

        .product-details-page .pd-toolbar-actions {
            justify-content: stretch;
        }

        .product-details-page .pd-reset-btn {
            width: 100%;
        }

        .product-details-page .pd-table-footer {
            flex-direction: column;
            align-items: stretch;
        }

        .product-details-page .pd-pagination-controls {
            justify-content: center;
        }

        .product-details-page .pd-card-value {
            font-size: 1.45rem;
        }

        .product-details-page .pd-card-value.smaller {
            font-size: 1.12rem;
        }
    }
</style>

<div class="product-details-page">
<div class="d-flex align-items-center justify-content-between mb-4 gap-3 flex-wrap">
    <div class="d-flex align-items-center gap-3">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary" style="border-radius:10px;border-color:#cfd8e3;color:#334155;"><i class="bi bi-arrow-left"></i></a>
        <div>
            <h4 class="fw-bold mb-0" style="color:#1e293b;">Product Details</h4>
            <p class="mb-0" style="font-size:.88rem;color:#667085;">Complete view of product profile, pricing models, AMC, and promotions</p>
        </div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Edit" asp-route-id="@product.Id" class="btn btn-outline-secondary" style="border-radius:12px;border-color:#cfd8e3;color:#475569;"><i class="bi bi-pencil me-1"></i>Edit Product</a>
        <a asp-controller="ProductRate" asp-action="Create" asp-route-productId="@product.Id" class="btn btn-primary" style="background:linear-gradient(135deg,#1d1b4b 0%,#3147a8 100%);border:none;border-radius:12px;box-shadow:0 10px 22px rgba(49,71,168,.22);"><i class="bi bi-plus-lg me-1"></i>Add Pricing Model</a>
    </div>
</div>

<div class="pd-hero mb-4">
    <div class="card-body p-3 p-lg-4">
        <div class="row g-3 align-items-center">
            <div class="col-lg-7">
                <div class="d-flex align-items-center gap-3">
                    <div class="pd-hero-icon">
                        <i class="bi bi-box-seam"></i>
                    </div>
                    <div>
                        <div class="fw-bold" style="font-size:1.2rem;color:#1e293b;line-height:1.1;">@product.ProductName</div>
                        <div style="font-size:.82rem;color:#5b6bff;font-weight:600;">@product.ProductCode • @product.ProductType</div>
                        <div style="font-size:.75rem;color:#667085;margin-top:.25rem;max-width:560px;">Central overview of pricing, annual maintenance, and promotional availability.</div>
                    </div>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="d-flex flex-wrap gap-2 justify-content-lg-end align-items-center">
                    @if (product.IsActive)
                    {
                        <span class="pd-hero-badge pd-chip-ok"><i class="bi bi-check-circle-fill"></i>Active Product</span>
                    }
                    else
                    {
                        <span class="pd-hero-badge" style="background:#e2e8f0;color:#475569;"><i class="bi bi-pause-circle-fill"></i>Inactive Product</span>
                    }
                    <span class="pd-hero-badge pd-chip-info"><i class="bi bi-calendar3"></i>Created @product.CreatedAt.ToString("dd MMM yyyy")</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="pd-card" style="--pd-accent:#3147a8;">
            <div class="pd-card-body">
                <div class="pd-card-label"><span class="pd-card-icon"><i class="bi bi-grid-1x2"></i></span>PRICING MODELS</div>
                <div class="pd-card-value">@product.PricingModelCount</div>
                <div class="pd-card-note">@product.ActivePricingModelCount active models</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="pd-card" style="--pd-accent:#0f7ea8;">
            <div class="pd-card-body">
                <div class="pd-card-label"><span class="pd-card-icon"><i class="bi bi-cash-stack"></i></span>RATE BAND</div>
                <div class="pd-card-value smaller">
                    @if (product.MinRate.HasValue && product.MaxRate.HasValue)
                    {
                        <span>₹@product.MinRate.Value.ToString("0.##") - ₹@product.MaxRate.Value.ToString("0.##")</span>
                    }
                    else
                    {
                        <span>-</span>
                    }
                </div>
                <div class="pd-card-note">Across all mapped pricing models</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="pd-card" style="--pd-accent:#1f8f5f;">
            <div class="pd-card-body">
                <div class="pd-card-label"><span class="pd-card-icon"><i class="bi bi-percent"></i></span>LIVE OFFERS</div>
                <div class="pd-card-value" style="color:#1f8f5f;">@product.ActiveDiscountOfferCount</div>
                <div class="pd-card-note">@product.ActivePromoCodeCount with promo code</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="pd-card" style="--pd-accent:#c47b18;">
            <div class="pd-card-body">
                <div class="pd-card-label"><span class="pd-card-icon"><i class="bi bi-alarm"></i></span>NEXT EXPIRY</div>
                <div class="pd-card-value smaller">
                    @(product.NextDiscountExpiryDate.HasValue ? product.NextDiscountExpiryDate.Value.ToString("dd MMM yyyy") : "-")
                </div>
                <div class="pd-card-note">@product.ExpiringSoonDiscountOfferCount expiring soon</div>
            </div>
        </div>
    </div>
</div>

<div class="pd-table-shell">
    <div class="pd-table-header d-flex align-items-center justify-content-between py-3 px-4 flex-wrap gap-2">
        <div>
            <h5 class="mb-0 fw-bold" style="color:#1e293b;">Mapped Pricing Models</h5>
            <div style="font-size:.82rem;color:#667085;">Detailed pricing, AMC, and discount visibility for this product</div>
        </div>
        <a asp-controller="ProductRate" asp-action="Index" asp-route-productId="@product.Id" class="btn btn-sm btn-outline-primary" style="border-radius:10px;border-color:#bfd1ff;color:#2f5bea;"><i class="bi bi-tags me-1"></i>Open Rate List</a>
    </div>
    @if (Model.ProductRates.Any())
    {
        <div class="pd-toolbar">
            <div class="pd-toolbar-stat">
                <div class="pd-toolbar-stat-icon">
                    <i class="bi bi-sliders2"></i>
                </div>
                <div>
                    <div class="pd-toolbar-stat-title">Visible Records</div>
                    <div class="pd-toolbar-stat-value"><span id="pdVisibleCount">@Model.ProductRates.Count</span> / @Model.ProductRates.Count</div>
                    <div class="pd-toolbar-stat-note">Client-side filter and pagination for mapped rates</div>
                </div>
            </div>
            <div class="pd-filter-group">
                <label class="pd-filter-label" for="pdPricingModelFilter">Pricing Model</label>
                <select id="pdPricingModelFilter" class="form-select pd-filter-control">
                    <option value="">All pricing models</option>
                    @foreach (var option in pricingModelOptions)
                    {
                        <option value="@option">@option</option>
                    }
                </select>
            </div>
            <div class="pd-filter-group">
                <label class="pd-filter-label" for="pdBillingFilter">Model / Frequency</label>
                <select id="pdBillingFilter" class="form-select pd-filter-control">
                    <option value="">All models / frequency</option>
                    @foreach (var option in billingOptions)
                    {
                        <option value="@option">@option</option>
                    }
                </select>
            </div>
            <div class="pd-toolbar-actions">
                <button type="button" class="btn pd-reset-btn" id="pdResetFilters">
                    <i class="bi bi-arrow-counterclockwise me-1"></i>Reset Filters
                </button>
            </div>
        </div>
    }
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table tbl-clean mb-0">
                <thead>
                    <tr>
                        <th class="ps-3">Pricing Model</th>
                        <th>Model / Frequency</th>
                        <th>Rate</th>
                        <th>AMC</th>
                        <th>Specification</th>
                        <th>Features</th>
                        <th>Discounts</th>
                        <th>Status</th>
                        <th class="pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.ProductRates.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center py-5 text-muted"><i class="bi bi-inbox fs-1 d-block mb-2"></i>No pricing models mapped for this product</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model.ProductRates)
                        {
                            var pricingModelTheme = PricingModelBadgeThemeHelper.Resolve(item.PricingModel);
                            var billingSummary = string.IsNullOrWhiteSpace(item.BillingFrequency)
                                ? item.BillingModel
                                : $"{item.BillingModel} / {item.BillingFrequency}";
                            <tr class="pd-rate-row"
                                data-pricing-model="@item.PricingModel"
                                data-billing-summary="@billingSummary">
                                <td class="ps-3" style="min-width:150px;">
                                    <span class="pd-pricing-pill"
                                          style="background:@pricingModelTheme.BackgroundColor;color:@pricingModelTheme.TextColor;border:1px solid @pricingModelTheme.BorderColor;">
                                        @item.PricingModel
                                    </span>
                                </td>
                                <td style="min-width:170px;">
                                    <div class="pd-billing-stack">
                                        <div class="pd-billing-main">@item.BillingModel</div>
                                        <div class="pd-billing-sub">@(string.IsNullOrWhiteSpace(item.BillingFrequency) ? "-" : item.BillingFrequency)</div>
                                    </div>
                                </td>
                                <td>
                                    <div class="pd-rate-cell">
                                        <div class="pd-rate-main">₹@item.Rate.ToString("0.00")</div>
                                        <div class="pd-rate-note">Base price for this mapped plan</div>
                                    </div>
                                </td>
                                <td>
                                    @if (string.IsNullOrWhiteSpace(item.AmcCalculationType))
                                    {
                                        <div class="pd-amc-card">
                                            <div class="pd-amc-main">-</div>
                                            <div class="pd-amc-note">No AMC configured</div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="pd-amc-card">
                                            <div class="pd-amc-main">₹@item.AmcAmount.ToString("0.00")</div>
                                            <div class="pd-amc-note">@item.AmcPercentage.ToString("0.####")% • @item.AmcCalculationType</div>
                                        </div>
                                    }
                                </td>
                                <td style="max-width:220px;">
                                    <div class="pd-detail-card">
                                        <div class="pd-detail-main pd-detail-text" data-expanded="false">@(string.IsNullOrWhiteSpace(item.ProductSpecification) ? "Not provided" : item.ProductSpecification)</div>
                                        @if (!string.IsNullOrWhiteSpace(item.ProductSpecification))
                                        {
                                            <button type="button" class="pd-expand-btn" data-expand-text="true">See more</button>
                                        }
                                        <div class="pd-detail-note">Specification</div>
                                    </div>
                                </td>
                                <td style="max-width:260px;">
                                    <div class="pd-detail-card">
                                        <div class="pd-detail-main pd-detail-text" data-expanded="false">@(string.IsNullOrWhiteSpace(item.Features) ? "Not provided" : item.Features)</div>
                                        @if (!string.IsNullOrWhiteSpace(item.Features))
                                        {
                                            <button type="button" class="pd-expand-btn" data-expand-text="true">See more</button>
                                        }
                                        <div class="pd-detail-note">Feature summary</div>
                                    </div>
                                </td>
                                <td style="white-space:nowrap;">
                                    <div class="pd-offer-card">
                                        <div class="pd-offer-main">@item.DiscountOfferCount offer@(item.DiscountOfferCount == 1 ? string.Empty : "s")</div>
                                        <div class="pd-offer-note">@item.ActiveDiscountOfferCount active right now</div>
                                    </div>
                                </td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="pd-status-pill is-active"><i class="bi bi-check-circle-fill"></i>Active</span>
                                    }
                                    else
                                    {
                                        <span class="pd-status-pill is-inactive"><i class="bi bi-pause-circle-fill"></i>Inactive</span>
                                    }
                                </td>
                                <td class="pe-3">
                                    <div class="pd-action-bar">
                                        <a asp-controller="ProductRateDiscount" asp-action="Index" asp-route-productRateId="@item.Id" class="btn btn-sm btn-outline-primary pd-action-btn" style="border-radius:10px;"><i class="bi bi-percent me-1"></i>Discounts</a>
                                        <a asp-controller="ProductRate" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary pd-action-btn icon-only" style="border-radius:10px;border-color:#e2e8f0;"><i class="bi bi-pencil"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                        <tr id="pdNoFilterResultsRow" class="pd-empty-filter">
                            <td colspan="9">
                                <div class="pd-empty-state">
                                    <i class="bi bi-funnel"></i>
                                    <div class="fw-bold mt-2" style="color:#1e293b;">No matching pricing models</div>
                                    <div class="mt-1">Try a different Pricing Model or Model / Frequency filter.</div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @if (Model.ProductRates.Any())
    {
        <div class="pd-table-footer">
            <div class="pd-pagination-meta" id="pdPaginationMeta">Showing 1 to @Math.Min(Model.ProductRates.Count, 5) of @Model.ProductRates.Count records</div>
            <div class="pd-pagination-controls">
                <button type="button" class="pd-page-btn" id="pdPrevPage" aria-label="Previous page">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <div id="pdPageNumbers" class="d-flex gap-2 flex-wrap"></div>
                <button type="button" class="pd-page-btn" id="pdNextPage" aria-label="Next page">
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        </div>
    }
</div>
</div>

@if (Model.ProductRates.Any())
{
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const pricingFilter = document.getElementById('pdPricingModelFilter');
            const billingFilter = document.getElementById('pdBillingFilter');
            const resetButton = document.getElementById('pdResetFilters');
            const rows = Array.from(document.querySelectorAll('.pd-rate-row'));
            const visibleCount = document.getElementById('pdVisibleCount');
            const emptyRow = document.getElementById('pdNoFilterResultsRow');
            const pageNumbers = document.getElementById('pdPageNumbers');
            const prevButton = document.getElementById('pdPrevPage');
            const nextButton = document.getElementById('pdNextPage');
            const paginationMeta = document.getElementById('pdPaginationMeta');

            if (!rows.length) {
                return;
            }

            const pageSize = 5;
            let currentPage = 1;

            function getFilteredRows() {
                const pricingValue = (pricingFilter.value || '').trim().toLowerCase();
                const billingValue = (billingFilter.value || '').trim().toLowerCase();

                return rows.filter(function (row) {
                    const rowPricing = (row.dataset.pricingModel || '').trim().toLowerCase();
                    const rowBilling = (row.dataset.billingSummary || '').trim().toLowerCase();
                    const matchesPricing = !pricingValue || rowPricing === pricingValue;
                    const matchesBilling = !billingValue || rowBilling === billingValue;
                    return matchesPricing && matchesBilling;
                });
            }

            function renderPagination(filteredRows) {
                const totalPages = Math.max(1, Math.ceil(filteredRows.length / pageSize));
                currentPage = Math.min(currentPage, totalPages);
                pageNumbers.innerHTML = '';

                for (let page = 1; page <= totalPages; page++) {
                    const button = document.createElement('button');
                    button.type = 'button';
                    button.className = 'pd-page-btn' + (page === currentPage ? ' active' : '');
                    button.textContent = page;
                    button.addEventListener('click', function () {
                        currentPage = page;
                        updateTable();
                    });
                    pageNumbers.appendChild(button);
                }

                prevButton.disabled = currentPage <= 1 || !filteredRows.length;
                nextButton.disabled = currentPage >= totalPages || !filteredRows.length;
            }

            function updateTable() {
                const filteredRows = getFilteredRows();
                const totalPages = Math.max(1, Math.ceil(filteredRows.length / pageSize));
                const startIndex = (currentPage - 1) * pageSize;
                const endIndex = startIndex + pageSize;
                const pagedRows = filteredRows.slice(startIndex, endIndex);

                rows.forEach(function (row) {
                    row.style.display = pagedRows.includes(row) ? '' : 'none';
                });

                visibleCount.textContent = filteredRows.length.toString();
                emptyRow.style.display = filteredRows.length ? 'none' : '';

                if (!filteredRows.length) {
                    paginationMeta.textContent = 'Showing 0 of 0 records';
                } else {
                    paginationMeta.textContent = 'Showing ' + (startIndex + 1) + ' to ' + Math.min(endIndex, filteredRows.length) + ' of ' + filteredRows.length + ' records';
                }

                renderPagination(filteredRows);
            }

            pricingFilter.addEventListener('change', function () {
                currentPage = 1;
                updateTable();
            });

            billingFilter.addEventListener('change', function () {
                currentPage = 1;
                updateTable();
            });

            resetButton.addEventListener('click', function () {
                pricingFilter.value = '';
                billingFilter.value = '';
                currentPage = 1;
                updateTable();
            });

            prevButton.addEventListener('click', function () {
                if (currentPage > 1) {
                    currentPage -= 1;
                    updateTable();
                }
            });

            nextButton.addEventListener('click', function () {
                const filteredRows = getFilteredRows();
                const totalPages = Math.max(1, Math.ceil(filteredRows.length / pageSize));
                if (currentPage < totalPages) {
                    currentPage += 1;
                    updateTable();
                }
            });

            document.querySelectorAll('[data-expand-text="true"]').forEach(function (button) {
                button.addEventListener('click', function () {
                    const textBlock = button.parentElement.querySelector('.pd-detail-text');
                    const isExpanded = textBlock.classList.toggle('is-expanded');
                    textBlock.dataset.expanded = isExpanded ? 'true' : 'false';
                    button.textContent = isExpanded ? 'See less' : 'See more';
                });
            });

            updateTable();
        });
    </script>
}