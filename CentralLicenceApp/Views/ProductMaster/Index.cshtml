@model List<CentralLicenceApp.Models.ProductMaster>
@{
    ViewData["Title"] = "eProduct Master";
    var activeProducts = Model.Count(x => x.IsActive);
    var configuredModels = Model.Sum(x => x.PricingModelCount);
    var liveOffers = Model.Sum(x => x.ActiveDiscountOfferCount);
}

<div class="product-shell">
    <div class="hero-panel mb-4">
        <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap position-relative" style="z-index:1;">
            <div>
                <div class="section-label mb-2">Business Unit Master</div>
                <h3 class="fw-bold mb-1" style="color:#1e293b;">eProduct Master</h3>
                <p class="mb-0" style="font-size:.9rem;color:#54657e;max-width:620px;">Manage your product catalog, pricing visibility, and promotional readiness from one place with a cleaner commercial overview.</p>
            </div>
            <a asp-action="Create" class="btn btn-primary align-self-start" style="background:#180a3c;border:none;border-radius:14px;padding:.8rem 1.1rem;box-shadow:0 10px 24px rgba(24,10,60,.18);">
                <i class="bi bi-plus-lg me-1"></i> New Product
            </a>
        </div>
        <div class="d-flex gap-3 flex-wrap mt-4 position-relative" style="z-index:1;">
            <div class="hero-kpi">
                <div class="hero-kpi-label">Products</div>
                <div class="hero-kpi-value">@Model.Count</div>
            </div>
            <div class="hero-kpi">
                <div class="hero-kpi-label">Active Products</div>
                <div class="hero-kpi-value" style="color:#059669;">@activeProducts</div>
            </div>
            <div class="hero-kpi">
                <div class="hero-kpi-label">Rate Models</div>
                <div class="hero-kpi-value" style="color:#2563eb;">@configuredModels</div>
            </div>
            <div class="hero-kpi">
                <div class="hero-kpi-label">Live Offers</div>
                <div class="hero-kpi-value" style="color:#c2410c;">@liveOffers</div>
            </div>
        </div>
    </div>

    <div class="glass-card">
        <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table tbl-clean mb-0">
                <thead>
                    <tr>
                        <th class="ps-3">#</th>
                        <th>Product</th>
                        <th>Type</th>
                        <th>Rate Models</th>
                        <th>Discount Summary</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th class="pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted"><i class="bi bi-inbox fs-1 d-block mb-2"></i>No products found</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            var hasLiveOffers = item.ActiveDiscountOfferCount > 0;
                            var expiryTone = item.ExpiringSoonDiscountOfferCount > 0 ? "#b45309" : "#64748b";
                            var productTone = item.IsActive ? "#059669" : "#64748b";
                            <tr>
                                <td class="ps-3" style="color:#94a3b8;font-size:.8rem;">@item.Id</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="product-avatar">
                                            <i class="bi bi-box-seam"></i>
                                        </div>
                                        <div>
                                            <div class="fw-semibold" style="font-size:.88rem;">@item.ProductName</div>
                                            <div style="font-size:.76rem;color:#6366f1;">@item.ProductCode</div>
                                        </div>
                                    </div>
                                </td>
                                <td style="font-size:.84rem;">
                                    <span class="badge rounded-pill px-2 py-1" style="background:#eff6ff;color:#1d4ed8;border:1px solid #bfdbfe;font-size:.73rem;">@item.ProductType</span>
                                </td>
                                <td style="font-size:.82rem;min-width:180px;">
                                    <div class="summary-box">
                                    <div class="fw-semibold">@item.PricingModelCount model@(item.PricingModelCount == 1 ? string.Empty : "s")</div>
                                    <div class="text-muted" style="font-size:.75rem;">
                                        @if (item.PricingModelCount == 0)
                                        {
                                            <span>No rates mapped</span>
                                        }
                                        else
                                        {
                                            <span>@item.ActivePricingModelCount active</span>
                                            @if (item.MinRate.HasValue && item.MaxRate.HasValue)
                                            {
                                                <span> • ₹@item.MinRate.Value.ToString("0.##") to ₹@item.MaxRate.Value.ToString("0.##")</span>
                                            }
                                        }
                                    </div>
                                    </div>
                                </td>
                                <td style="font-size:.81rem;min-width:220px;">
                                    @if (item.DiscountOfferCount == 0)
                                    {
                                        <div class="summary-box">
                                            <div class="fw-semibold" style="color:#94a3b8;">No offers mapped</div>
                                            <div class="text-muted" style="font-size:.75rem;">No promotion discount configured yet</div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="summary-box" style="background:@(hasLiveOffers ? "#f0fdf4" : "#f8fbff");border-color:@(hasLiveOffers ? "#bbf7d0" : "#e6eef8");">
                                            <div class="fw-semibold" style="color:@(hasLiveOffers ? "#166534" : "#1e293b");">
                                                @item.ActiveDiscountOfferCount live offer@(item.ActiveDiscountOfferCount == 1 ? string.Empty : "s")
                                            </div>
                                            <div class="text-muted" style="font-size:.75rem;">
                                                @item.DiscountOfferCount total
                                                @if (item.ActivePromoCodeCount > 0)
                                                {
                                                    <span> • @item.ActivePromoCodeCount promo code@(item.ActivePromoCodeCount == 1 ? string.Empty : "s")</span>
                                                }
                                            </div>
                                            @if (item.NextDiscountExpiryDate.HasValue)
                                            {
                                                <div style="font-size:.74rem;color:@expiryTone;">
                                                    Next expiry: @item.NextDiscountExpiryDate.Value.ToString("dd MMM yyyy")
                                                    @if (item.ExpiringSoonDiscountOfferCount > 0)
                                                    {
                                                        <span> • @item.ExpiringSoonDiscountOfferCount expiring soon</span>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge rounded-pill px-2 py-1" style="font-size:.73rem;background:#dcfce7;color:#166534;border:1px solid #bbf7d0;">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill px-2 py-1" style="font-size:.73rem;background:#e2e8f0;color:#475569;border:1px solid #cbd5e1;">Inactive</span>
                                    }
                                </td>
                                <td style="font-size:.82rem;color:@productTone;">@item.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td class="pe-3">
                                    <div class="d-flex gap-1 flex-wrap justify-content-end">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm" title="View Product" style="border-radius:9px;background:#ecfeff;color:#0f766e;border:1px solid #a5f3fc;"><i class="bi bi-eye"></i></a>
                                        <a asp-controller="ProductRate" asp-action="Index" asp-route-productId="@item.Id" class="btn btn-sm" title="Rate List" style="border-radius:9px;background:#eef2ff;color:#4338ca;border:1px solid #c7d2fe;"><i class="bi bi-tags me-1"></i>Rates</a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm" title="Edit" style="border-radius:9px;background:#f8fafc;color:#475569;border:1px solid #dbe4f0;"><i class="bi bi-pencil"></i></a>
                                        <form asp-action="Delete" method="post"
                                              data-swal-confirm="true"
                                              data-swal-title="Delete Product?"
                                              data-swal-text="Product <strong>@item.ProductName</strong> will be deleted permanently."
                                              data-swal-confirm-button="Yes, delete product">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm" title="Delete" style="border-radius:9px;background:#fff1f2;color:#dc2626;border:1px solid #fecdd3;"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
    </div>
</div>