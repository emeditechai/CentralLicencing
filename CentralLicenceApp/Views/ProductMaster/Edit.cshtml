@model CentralLicenceApp.Models.ViewModels.ProductMasterFormViewModel
@{
    ViewData["Title"] = "Edit eProduct";
    var productTypes = ViewBag.ProductTypes as string[] ?? System.Array.Empty<string>();
}

<div class="catalog-form-shell catalog-product">
    <div class="catalog-form-hero">
        <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap position-relative" style="z-index:1;">
            <div class="d-flex align-items-start gap-3">
                <a asp-action="Index" class="catalog-form-back"><i class="bi bi-arrow-left"></i></a>
                <div>
                    <div class="catalog-form-eyebrow mb-2">Product Setup</div>
                    <h3 class="fw-bold mb-1" style="color:#1e293b;">Edit eProduct</h3>
                    <p class="catalog-form-subtitle">Update product master information with the same visual language used across pricing and offer management.</p>
                </div>
            </div>
            <div class="catalog-form-mini-stat">
                <div class="catalog-form-mini-label">Record</div>
                <div class="catalog-form-mini-value" style="color:#7c3aed;">@Model.ProductCode</div>
            </div>
        </div>
    </div>

    <div class="catalog-form-card">
        <div class="catalog-form-surface">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 px-3 rounded-3 mb-3" style="font-size:.83rem;"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="ProductCode" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="ProductCode" class="form-control catalog-input" />
                    <span asp-validation-for="ProductCode" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ProductName" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="ProductName" class="form-control catalog-input" />
                    <span asp-validation-for="ProductName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ProductType" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <select asp-for="ProductType" class="form-select catalog-select">
                        <option value="">Select Product Type</option>
                        @foreach (var item in productTypes)
                        {
                            <option value="@item">@item</option>
                        }
                    </select>
                    <span asp-validation-for="ProductType" class="text-danger small"></span>
                </div>
                <div class="col-md-6 d-flex align-items-end">
                    <div class="catalog-toggle w-100">
                        <div class="form-check mb-0">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                            <label asp-for="IsActive" class="form-check-label fw-semibold" style="font-size:.85rem;"></label>
                            <div class="catalog-help">Disable the product if it should stop appearing in active commercial flows.</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn catalog-submit px-4">
                    <i class="bi bi-check-lg me-1"></i> Save Changes
                </button>
                <a asp-action="Index" class="btn catalog-cancel">Cancel</a>
            </div>
        </form>
    </div>
</div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}