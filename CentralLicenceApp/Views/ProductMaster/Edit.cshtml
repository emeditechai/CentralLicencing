@model CentralLicenceApp.Models.ViewModels.ProductMasterFormViewModel
@{
    ViewData["Title"] = "Edit eProduct";
    var productTypes = ViewBag.ProductTypes as string[] ?? System.Array.Empty<string>();
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary" style="border-radius:8px;"><i class="bi bi-arrow-left"></i></a>
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;">Edit eProduct</h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">Update product master information</p>
    </div>
</div>

<div class="card" style="max-width:620px;">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 px-3 rounded-3 mb-3" style="font-size:.83rem;"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="ProductCode" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="ProductCode" class="form-control" style="border-radius:10px;" />
                    <span asp-validation-for="ProductCode" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ProductName" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="ProductName" class="form-control" style="border-radius:10px;" />
                    <span asp-validation-for="ProductName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ProductType" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <select asp-for="ProductType" class="form-select" style="border-radius:10px;">
                        <option value="">Select Product Type</option>
                        @foreach (var item in productTypes)
                        {
                            <option value="@item">@item</option>
                        }
                    </select>
                    <span asp-validation-for="ProductType" class="text-danger small"></span>
                </div>
                <div class="col-md-6 d-flex align-items-end">
                    <div class="form-check mb-2">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label fw-semibold" style="font-size:.85rem;"></label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn text-white px-4" style="background:#180a3c;border:none;border-radius:10px;">
                    <i class="bi bi-check-lg me-1"></i> Save Changes
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius:10px;">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}