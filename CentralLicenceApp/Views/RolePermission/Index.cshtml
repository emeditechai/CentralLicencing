@model CentralLicenceApp.Models.ViewModels.RolePermissionGridViewModel
@{
    ViewData["Title"] = "Role Permissions";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;">Role Permissions</h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">Choose a role, then check the menu × permission combinations granted to it.</p>
    </div>
</div>

@if (TempData["SuccessMessage"] is string ok)
{
    <div class="alert alert-success py-2">@ok</div>
}

<form method="get" asp-action="Index" class="card mb-3">
    <div class="card-body d-flex align-items-end gap-3 flex-wrap">
        <div style="min-width:280px;">
            <label class="form-label">Role</label>
            <select name="roleId" class="form-select" onchange="this.form.submit()">
                @foreach (var r in Model.Roles)
                {
                    <option value="@r.Id" selected="@(r.Id == Model.RoleId)">@r.RoleName</option>
                }
            </select>
        </div>
    </div>
</form>

@if (Model.RoleId == 0)
{
    <div class="alert alert-info">Select a role to manage its permissions.</div>
}
else
{
    <form asp-action="Save" method="post" class="card">
        @Html.AntiForgeryToken()
        <input type="hidden" name="roleId" value="@Model.RoleId" />
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table tbl-clean mb-0 align-middle">
                    <thead style="background:#f8fafc;">
                        <tr>
                            <th class="ps-3" style="min-width:340px;">Menu</th>
                            @foreach (var p in Model.AllPermissions)
                            {
                                <th class="text-center" style="min-width:90px;">@p.DisplayName</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Rows)
                        {
                            <tr>
                                <td class="ps-3" style="padding-left:@(12 + row.Depth * 22)px;">
                                    <i class="@row.Menu.IconClass me-1 text-muted"></i>
                                    <span class="@(row.Menu.MenuType == "Link" ? "" : "fw-bold")">@row.Menu.MenuName</span>
                                </td>
                                @foreach (var p in Model.AllPermissions)
                                {
                                    var supported = row.Permissions.Any(rp => rp.Id == p.Id);
                                    var granted = row.Granted.Contains(p.Id);
                                    <td class="text-center">
                                        @if (supported)
                                        {
                                            <input type="checkbox" name="grants" value="@(row.Menu.Id):@(p.Id)"
                                                   @(granted ? "checked" : null)
                                                   class="form-check-input" />
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer text-end">
            <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-save me-1"></i> Save Permissions</button>
        </div>
    </form>
}
