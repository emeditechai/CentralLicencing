@model CentralLicenceApp.Models.ViewModels.CompanySettingsFormViewModel
@{
    ViewData["Title"] = "New Company";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary" style="border-radius:8px;"><i class="bi bi-arrow-left"></i></a>
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;">New Company</h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">Create company settings with master-based company type</p>
    </div>
</div>

<div class="card">
    <div class="card-body p-4">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 px-3 rounded-3 mb-3" style="font-size:.83rem;"></div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="CompanyCode" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="CompanyCode" class="form-control" style="border-radius:10px;" />
                    <span asp-validation-for="CompanyCode" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="CompanyTypeId" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <select asp-for="CompanyTypeId" class="form-select" style="border-radius:10px;">
                        <option value="">Select Company Type</option>
                        @foreach (var type in Model.CompanyTypes)
                        {
                            <option value="@type.Id">@type.TypeName</option>
                        }
                    </select>
                    <span asp-validation-for="CompanyTypeId" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="CompanyName" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="CompanyName" class="form-control" style="border-radius:10px;" />
                    <span asp-validation-for="CompanyName" class="text-danger small"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="Country" class="form-label fw-semibold" style="font-size:.82rem;">Country</label>
                    <input asp-for="Country" class="form-control" style="border-radius:10px;" />
                    <span asp-validation-for="Country" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="State" class="form-label fw-semibold" style="font-size:.82rem;">State</label>
                    <input asp-for="State" class="form-control" style="border-radius:10px;" />
                    <span asp-validation-for="State" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="District" class="form-label fw-semibold" style="font-size:.82rem;">District</label>
                    <input asp-for="District" class="form-control" style="border-radius:10px;" />
                    <span asp-validation-for="District" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="City" class="form-label fw-semibold" style="font-size:.82rem;">City</label>
                    <input asp-for="City" class="form-control" style="border-radius:10px;" />
                    <span asp-validation-for="City" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Address" class="form-label fw-semibold" style="font-size:.82rem;">Address</label>
                    <textarea asp-for="Address" class="form-control" rows="3" style="border-radius:10px;"></textarea>
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>
                <div class="col-md-2">
                    <label asp-for="Website" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="Website" class="form-control" style="border-radius:10px;" placeholder="https://example.com" />
                    <span asp-validation-for="Website" class="text-danger small"></span>
                </div>
                <div class="col-md-2">
                    <label asp-for="EmailId" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="EmailId" class="form-control" style="border-radius:10px;" />
                    <span asp-validation-for="EmailId" class="text-danger small"></span>
                </div>
                <div class="col-md-2">
                    <label asp-for="ContactNo" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="ContactNo" class="form-control" style="border-radius:10px;" />
                    <span asp-validation-for="ContactNo" class="text-danger small"></span>
                </div>
                <div class="col-md-2">
                    <label asp-for="Pincode" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="Pincode" class="form-control" style="border-radius:10px;" />
                    <span asp-validation-for="Pincode" class="text-danger small"></span>
                </div>
                <div class="col-md-2">
                    <label asp-for="GSTCode" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="GSTCode" class="form-control" style="border-radius:10px;" />
                    <span asp-validation-for="GSTCode" class="text-danger small"></span>
                </div>
                <div class="col-md-2">
                    <label asp-for="PANCard" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="PANCard" class="form-control" style="border-radius:10px;" />
                    <span asp-validation-for="PANCard" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="CompanyLogo" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="CompanyLogo" type="file" accept=".jpg,.jpeg,.png,.gif,.webp" class="form-control" style="border-radius:10px;" />
                    <span asp-validation-for="CompanyLogo" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <div class="p-3 p-md-4" style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:12px;">
                        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
                            <div>
                                <div class="fw-semibold" style="color:#1e293b;">Parameter Section</div>
                                <div class="text-muted" style="font-size:.82rem;">Configure whether expense request emails should be sent on submission and settlement.</div>
                            </div>
                            <div class="form-check form-switch mb-0">
                                <input asp-for="IsExpenseEmailNotificationRequired" class="form-check-input" type="checkbox" />
                                <label asp-for="IsExpenseEmailNotificationRequired" class="form-check-label fw-semibold" style="font-size:.85rem;"></label>
                            </div>
                        </div>
                        <div class="text-muted mt-2" style="font-size:.78rem;">Default is No. Turn this on only when expense request submission and settlement emails are required.</div>
                    </div>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <div class="form-check form-switch mb-2">
                        <input asp-for="IsParentCompany" class="form-check-input" type="checkbox" />
                        <label asp-for="IsParentCompany" class="form-check-label fw-semibold" style="font-size:.85rem;"></label>
                    </div>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <div class="form-check form-switch mb-2">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label fw-semibold" style="font-size:.85rem;"></label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn text-white px-4" style="background:#180a3c;border:none;border-radius:10px;">
                    <i class="bi bi-check2-circle me-1"></i> Save Company
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius:10px;">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}