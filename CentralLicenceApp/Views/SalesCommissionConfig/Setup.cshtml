@model CentralLicenceApp.Models.ViewModels.SalesCommConfigFormViewModel
@{
    ViewData["Title"] = Model.IsEdit ? "Edit Sales Commission" : "Setup Sales Commission";
}

<style>
    .ss-page { max-width:680px; margin:0 auto; }
    .ss-header { background:linear-gradient(135deg,#667eea 0%,#764ba2 100%); border-radius:18px 18px 0 0; padding:1.5rem 2rem; color:#fff; }
    .ss-header h5 { font-weight:800; font-size:1.2rem; margin-bottom:.15rem; }
    .ss-header .ss-sub { font-size:.82rem; color:rgba(255,255,255,.7); }
    .ss-body { background:#fff; border-radius:0 0 18px 18px; box-shadow:0 4px 20px rgba(0,0,0,.06); padding:2rem; border:1px solid #f1f5f9; border-top:none; }
    .ss-user-info { background:#f8fafc; border-radius:12px; padding:1rem 1.25rem; margin-bottom:1.5rem; border:1px solid #e2e8f0; }

    .ss-type-toggle { display:flex; gap:.75rem; margin-bottom:1.5rem; }
    .ss-type-option { flex:1; cursor:pointer; border:2px solid #e2e8f0; border-radius:14px; padding:1.25rem; text-align:center; transition:all .2s ease; }
    .ss-type-option:hover { border-color:#6366f1; background:#f5f3ff; }
    .ss-type-option.active { border-color:#6366f1; background:#f5f3ff; box-shadow:0 0 0 3px rgba(99,102,241,.15); }
    .ss-type-option i { font-size:1.5rem; margin-bottom:.5rem; display:block; }
    .ss-type-option .ss-opt-title { font-weight:700; font-size:.88rem; color:#0f172a; }
    .ss-type-option .ss-opt-desc { font-size:.74rem; color:#64748b; margin-top:.25rem; }

    .ss-form .form-control { border-radius:10px; border:1.5px solid #e2e8f0; font-size:.88rem; }
    .ss-form .form-control:focus { border-color:#6366f1; box-shadow:0 0 0 3px rgba(99,102,241,.15); }
    .ss-form .form-label { font-weight:600; font-size:.82rem; color:#334155; }

    .ss-btn-save { background:linear-gradient(135deg,#6366f1,#4f46e5); border:none; border-radius:12px; font-weight:700; font-size:.88rem; padding:.55rem 1.8rem; color:#fff; transition:all .15s; }
    .ss-btn-save:hover { background:linear-gradient(135deg,#4f46e5,#4338ca); color:#fff; transform:translateY(-1px); }
    .ss-required::after { content:' *'; color:#ef4444; font-weight:700; }
</style>

<div class="ss-page">
    <div class="ss-header">
        <h5><i class="bi bi-cash-coin me-2"></i>@(Model.IsEdit ? "Edit Sales Commission" : "Setup Sales Commission")</h5>
        <div class="ss-sub">Configure commission type and default rate for this user</div>
    </div>
    <div class="ss-body">
        <!-- User Info -->
        <div class="ss-user-info d-flex align-items-center gap-3">
            <div class="d-flex align-items-center justify-content-center rounded-circle text-white fw-bold" style="width:42px;height:42px;min-width:42px;background:#6366f1;font-size:.95rem;">
                @(Model.UserName?.Length > 0 ? Model.UserName[0].ToString().ToUpper() : "U")
            </div>
            <div>
                <div class="fw-bold" style="font-size:.95rem;">@Model.UserName</div>
                <small style="font-size:.78rem;color:#64748b;">
                    @if (!string.IsNullOrEmpty(Model.EmployeeCode)) { <span>@Model.EmployeeCode</span> }
                    @if (!string.IsNullOrEmpty(Model.DepartmentName)) { <span class="ms-2">@Model.DepartmentName</span> }
                </small>
            </div>
        </div>

        <form asp-action="Setup" method="post" class="ss-form" id="setupForm">
            <input type="hidden" name="UserId" value="@Model.UserId" />
            <input type="hidden" name="IsEdit" value="@Model.IsEdit" />

            <!-- Commission Type Toggle -->
            <label class="form-label ss-required">Commission Type</label>
            <div class="ss-type-toggle">
                <div class="ss-type-option @(Model.CommissionType == "Percentage" ? "active" : "")" data-type="Percentage" onclick="selectType('Percentage')">
                    <i class="bi bi-percent text-purple"></i>
                    <div class="ss-opt-title">Percentage</div>
                    <div class="ss-opt-desc">% of payment received</div>
                </div>
                <div class="ss-type-option @(Model.CommissionType == "FixedAmount" ? "active" : "")" data-type="FixedAmount" onclick="selectType('FixedAmount')">
                    <i class="bi bi-currency-rupee text-success"></i>
                    <div class="ss-opt-title">Fixed Amount</div>
                    <div class="ss-opt-desc">Flat amount per payment</div>
                </div>
            </div>
            <input type="hidden" name="CommissionType" id="commissionType" value="@Model.CommissionType" />

            <!-- Default Rate -->
            <div class="mb-3">
                <label class="form-label ss-required" id="rateLabel">Default Rate</label>
                <div class="input-group">
                    <span class="input-group-text" id="ratePrefix" style="border-radius:10px 0 0 10px;">@(Model.CommissionType == "Percentage" ? "%" : "₹")</span>
                    <input type="number" step="0.01" min="0.01" max="999999.99" name="DefaultRate" id="defaultRate"
                           class="form-control" value="@(Model.DefaultRate > 0 ? Model.DefaultRate.ToString("F2") : "")" placeholder="e.g. 10.00" />
                </div>
                <span asp-validation-for="DefaultRate" class="text-danger" style="font-size:.78rem;"></span>
                <div class="form-text" style="font-size:.74rem;" id="rateHint">This is the fallback rate when no product-specific rule matches.</div>
            </div>

            <!-- Effective From -->
            <div class="mb-4">
                <label class="form-label ss-required">Effective From</label>
                <input type="date" name="EffectiveFrom" class="form-control" value="@Model.EffectiveFrom.ToString("yyyy-MM-dd")" required />
                <span asp-validation-for="EffectiveFrom" class="text-danger" style="font-size:.78rem;"></span>
            </div>

            <!-- Actions -->
            <div class="d-flex gap-3">
                <button type="submit" class="ss-btn-save" id="saveBtn">
                    <i class="bi bi-check-lg me-1"></i> @(Model.IsEdit ? "Update Configuration" : "Save Configuration")
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius:12px;font-weight:600;font-size:.85rem;">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function selectType(type) {
    document.getElementById('commissionType').value = type;
    document.querySelectorAll('.ss-type-option').forEach(function(el) {
        el.classList.toggle('active', el.dataset.type === type);
    });
    var prefix = document.getElementById('ratePrefix');
    var hint = document.getElementById('rateHint');
    if (type === 'Percentage') {
        prefix.textContent = '%';
        hint.textContent = 'Percentage of each payment received. e.g. 10 = 10%';
    } else {
        prefix.textContent = '₹';
        hint.textContent = 'Flat amount per payment received.';
    }
}

document.getElementById('setupForm').addEventListener('submit', function(e) {
    var rate = parseFloat(document.getElementById('defaultRate').value);
    if (!rate || rate <= 0) {
        e.preventDefault();
        document.getElementById('defaultRate').classList.add('is-invalid');
        document.getElementById('defaultRate').focus();
        return;
    }
});

document.getElementById('defaultRate')?.addEventListener('input', function() { this.classList.remove('is-invalid'); });
</script>
}
