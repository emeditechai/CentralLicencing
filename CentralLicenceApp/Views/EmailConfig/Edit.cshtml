@model CentralLicenceApp.Models.MailConfiguration
@{
    ViewData["Title"] = "Edit Email Configuration";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary" style="border-radius:8px;"><i class="bi bi-arrow-left"></i></a>
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;">Edit Email Configuration</h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">ID: @Model.Id &nbsp;|&nbsp; @Model.SmtpServer</p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <form asp-action="Edit" asp-permission="EmailConfig:Edit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedAt" />
            <input type="hidden" asp-for="CreatedBy" />

            <div class="card mb-3">
                <div class="card-header"><i class="bi bi-server me-2" style="color:#6366f1;"></i>SMTP Server Settings</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label">SMTP Server <span class="text-danger">*</span></label>
                            <input asp-for="SmtpServer" class="form-control" placeholder="e.g. smtp.gmail.com" />
                            <span asp-validation-for="SmtpServer" class="text-danger" style="font-size:.78rem;"></span>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Port <span class="text-danger">*</span></label>
                            <input asp-for="SmtpPort" class="form-control" type="number" />
                            <span asp-validation-for="SmtpPort" class="text-danger" style="font-size:.78rem;"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Username <span class="text-danger">*</span></label>
                            <input asp-for="SmtpUsername" class="form-control" autocomplete="off" />
                            <span asp-validation-for="SmtpUsername" class="text-danger" style="font-size:.78rem;"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">App Password <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input asp-for="SmtpPassword" class="form-control" type="password" id="smtpPwd" autocomplete="new-password" />
                                <button class="btn btn-outline-secondary" type="button" onclick="togglePwd()" style="border-radius:0 8px 8px 0;"><i class="bi bi-eye" id="eyeIcon"></i></button>
                            </div>
                            <span asp-validation-for="SmtpPassword" class="text-danger" style="font-size:.78rem;"></span>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input asp-for="EnableSSL" class="form-check-input" type="checkbox" role="switch" id="enableSSL" />
                                <label class="form-check-label" for="enableSSL">Enable SSL / TLS</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header"><i class="bi bi-envelope me-2" style="color:#6366f1;"></i>Sender & Notification</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">From Email <span class="text-danger">*</span></label>
                            <input asp-for="FromEmail" class="form-control" />
                            <span asp-validation-for="FromEmail" class="text-danger" style="font-size:.78rem;"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">From Name <span class="text-danger">*</span></label>
                            <input asp-for="FromName" class="form-control" />
                            <span asp-validation-for="FromName" class="text-danger" style="font-size:.78rem;"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Admin Notification Email</label>
                            <input asp-for="AdminNotificationEmail" class="form-control" />
                            <span asp-validation-for="AdminNotificationEmail" class="text-danger" style="font-size:.78rem;"></span>
                            <div class="form-text">Receives system alerts and notifications.</div>
                        </div>
                        <div class="col-md-6 d-flex align-items-center">
                            <div class="form-check form-switch mt-4">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" id="isActive" />
                                <label class="form-check-label" for="isActive">Active</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @if (Model.UpdatedAt.HasValue || Model.CreatedAt != default)
            {
                <div class="card mb-3" style="background:#f8fafc;">
                    <div class="card-body py-2 px-3" style="font-size:.78rem;color:#64748b;">
                        <span><i class="bi bi-calendar3 me-1"></i>Created: @Model.CreatedAt.ToString("dd MMM yyyy HH:mm")</span>
                        @if (Model.UpdatedAt.HasValue)
                        {
                            <span class="ms-3"><i class="bi bi-pencil-square me-1"></i>Updated: @Model.UpdatedAt.Value.ToString("dd MMM yyyy HH:mm") @(Model.UpdatedBy != null ? "by " + Model.UpdatedBy : "")</span>
                        }
                    </div>
                </div>
            }

            <div class="d-flex gap-2">
                <button type="submit" class="btn text-white px-4" style="background:#6366f1;border:none;border-radius:10px;">
                    <i class="bi bi-check-lg me-1"></i> Update Configuration
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius:10px;">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePwd() {
            var f = document.getElementById('smtpPwd');
            var i = document.getElementById('eyeIcon');
            if (f.type === 'password') { f.type = 'text'; i.className = 'bi bi-eye-slash'; }
            else { f.type = 'password'; i.className = 'bi bi-eye'; }
        }
    </script>
}
