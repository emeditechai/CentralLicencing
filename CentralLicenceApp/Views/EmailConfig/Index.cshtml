@model IEnumerable<CentralLicenceApp.Models.MailConfiguration>
@{
    ViewData["Title"] = "Email Engine";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div class="d-flex align-items-center gap-3">
        <div style="width:46px;height:46px;border-radius:12px;background:linear-gradient(135deg,#6366f1,#4f46e5);display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.25rem;flex-shrink:0;">
            <i class="bi bi-send-check"></i>
        </div>
        <div>
            <h4 class="fw-bold mb-0" style="color:#1e293b;">Email Engine</h4>
            <p class="text-muted mb-0" style="font-size:.83rem;">SMTP mail server configurations</p>
        </div>
    </div>
    <a asp-action="Create" class="btn btn-primary" style="background:#6366f1;border:none;border-radius:10px;">
        <i class="bi bi-plus-lg me-1"></i> New Configuration
    </a>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-envelope-x" style="font-size:3rem;color:#cbd5e1;"></i>
            <div class="mt-3 fw-semibold" style="color:#64748b;">No configurations yet</div>
            <div style="font-size:.83rem;color:#94a3b8;">Click <strong>New Configuration</strong> to add an SMTP server.</div>
        </div>
    </div>
}
else
{
    @foreach (var cfg in Model)
    {
        var badgeCls = cfg.IsActive ? "badge-ok" : "badge-neu";
        var badgeTxt = cfg.IsActive ? "Active" : "Inactive";
        <div class="card mb-4" style="border:1px solid #e2e8f0;border-radius:14px;overflow:hidden;">

            <!-- Header -->
            <div class="card-header d-flex align-items-center justify-content-between py-3 px-4" style="background:#f8fafc;border-bottom:1px solid #e2e8f0;">
                <div class="d-flex align-items-center gap-3">
                    <div style="width:42px;height:42px;border-radius:10px;background:linear-gradient(135deg,#6366f1,#4f46e5);display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.15rem;flex-shrink:0;">
                        <i class="bi bi-envelope-at"></i>
                    </div>
                    <div>
                        <div class="fw-bold" style="font-size:1rem;color:#0f172a;">@cfg.FromName</div>
                        <div style="font-size:.8rem;color:#6366f1;">@cfg.FromEmail</div>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span class="badge @badgeCls rounded-pill px-3 py-2" style="font-size:.75rem;">@badgeTxt</span>
                    <a asp-action="Edit" asp-route-id="@cfg.Id" class="btn btn-sm btn-outline-secondary" style="border-radius:8px;">
                        <i class="bi bi-pencil me-1"></i> Edit
                    </a>
                    <form asp-action="ToggleActive" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@cfg.Id" />
                        <input type="hidden" name="isActive" value="@(!cfg.IsActive ? "true" : "false")" />
                        <button type="submit" class="btn btn-sm @(cfg.IsActive ? "btn-outline-warning" : "btn-outline-success")" style="border-radius:8px;">
                            <i class="bi @(cfg.IsActive ? "bi-pause-circle" : "bi-play-circle") me-1"></i>
                            @(cfg.IsActive ? "Deactivate" : "Activate")
                        </button>
                    </form>
                </div>
            </div>

            <!-- Body -->
            <div class="card-body px-4 py-3">
                <div class="row g-0">

                    <!-- Section: SMTP -->
                    <div class="col-12 col-lg-6 pe-lg-4">
                        <div class="d-flex align-items-center gap-2 mb-3" style="color:#6366f1;">
                            <i class="bi bi-server"></i>
                            <span class="fw-semibold" style="font-size:.82rem;letter-spacing:.04em;text-transform:uppercase;">SMTP Server</span>
                        </div>
                        <div class="row g-2" style="font-size:.845rem;">
                            <div class="col-6">
                                <div class="text-muted mb-1" style="font-size:.73rem;">Host</div>
                                <div class="fw-semibold">@cfg.SmtpServer</div>
                            </div>
                            <div class="col-6">
                                <div class="text-muted mb-1" style="font-size:.73rem;">Port</div>
                                <div class="fw-semibold">
                                    @cfg.SmtpPort
                                    <span class="badge rounded-pill ms-1" style="background:#ede9fe;color:#6366f1;font-size:.68rem;">@(cfg.SmtpPort == 465 ? "SMTPS" : cfg.SmtpPort == 587 ? "STARTTLS" : "Custom")</span>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="text-muted mb-1" style="font-size:.73rem;">Username</div>
                                <div class="fw-semibold text-truncate">@cfg.SmtpUsername</div>
                            </div>
                            <div class="col-6">
                                <div class="text-muted mb-1" style="font-size:.73rem;">Encryption</div>
                                <div class="fw-semibold">
                                    @if (cfg.EnableSSL)
                                    {
                                        <span style="color:#22c55e;"><i class="bi bi-shield-check me-1"></i>SSL / TLS Enabled</span>
                                    }
                                    else
                                    {
                                        <span style="color:#f59e0b;"><i class="bi bi-shield-exclamation me-1"></i>No Encryption</span>
                                    }
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="text-muted mb-1" style="font-size:.73rem;">Password</div>
                                <div class="d-flex align-items-center gap-2">
                                    <code id="pwd-@cfg.Id" style="font-size:.78rem;letter-spacing:.12em;">••••••••••••</code>
                                    <button class="btn btn-sm" style="padding:.1rem .4rem;font-size:.72rem;border:1px solid #e2e8f0;border-radius:6px;color:#94a3b8;" onclick="togglePwd(@cfg.Id,'@cfg.SmtpPassword')">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Divider -->
                    <div class="col-12 d-lg-none"><hr class="my-3" style="border-color:#f1f5f9;"/></div>
                    <div class="col-auto d-none d-lg-block"><div style="width:1px;background:#e2e8f0;height:100%;margin:0 1.5rem;"></div></div>

                    <!-- Section: Sender & Notifications -->
                    <div class="col-12 col-lg">
                        <div class="d-flex align-items-center gap-2 mb-3" style="color:#6366f1;">
                            <i class="bi bi-envelope-paper"></i>
                            <span class="fw-semibold" style="font-size:.82rem;letter-spacing:.04em;text-transform:uppercase;">Sender &amp; Notifications</span>
                        </div>
                        <div class="row g-2" style="font-size:.845rem;">
                            <div class="col-12">
                                <div class="text-muted mb-1" style="font-size:.73rem;">From Name</div>
                                <div class="fw-semibold">@cfg.FromName</div>
                            </div>
                            <div class="col-12">
                                <div class="text-muted mb-1" style="font-size:.73rem;">From Email</div>
                                <div class="fw-semibold">@cfg.FromEmail</div>
                            </div>
                            <div class="col-12">
                                <div class="text-muted mb-1" style="font-size:.73rem;">Admin Notification Email</div>
                                <div class="fw-semibold">@(cfg.AdminNotificationEmail ?? "—")</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <div class="card-footer px-4 py-2 d-flex align-items-center gap-4 flex-wrap" style="background:#f8fafc;border-top:1px solid #f1f5f9;font-size:.77rem;color:#94a3b8;">
                <span><i class="bi bi-calendar3 me-1"></i>Created: <strong style="color:#64748b;">@cfg.CreatedAt.ToString("dd MMM yyyy  HH:mm")</strong>@(cfg.CreatedBy != null ? " by " + cfg.CreatedBy : "")</span>
                @if (cfg.UpdatedAt.HasValue)
                {
                    <span><i class="bi bi-pencil-square me-1"></i>Updated: <strong style="color:#64748b;">@cfg.UpdatedAt.Value.ToString("dd MMM yyyy  HH:mm")</strong>@(cfg.UpdatedBy != null ? " by " + cfg.UpdatedBy : "")</span>
                }
                <span class="ms-auto">ID: @cfg.Id</span>
            </div>
        </div>
    }
}

@section Scripts {
    <script>
        function togglePwd(id, pwd) {
            var el = document.getElementById('pwd-' + id);
            if (el.textContent.includes('•')) { el.textContent = pwd; }
            else { el.textContent = '••••••••••••'; }
        }
    </script>
}
