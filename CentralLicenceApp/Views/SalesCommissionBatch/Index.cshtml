@model CentralLicenceApp.Models.ViewModels.SalesCommBatchIndexViewModel
@{
    ViewData["Title"] = "Sales Commission Batches";
    var totalGross = Model.Batches.Sum(b => b.GrossCommission);
    var totalNet = Model.Batches.Sum(b => b.NetCommission);
}

<style>
    .sb-hero { background:linear-gradient(135deg,#667eea 0%,#764ba2 100%); border-radius:20px; padding:2rem 2.25rem; margin-bottom:1.75rem; position:relative; overflow:hidden; }
    .sb-hero::before { content:''; position:absolute; top:-50%; right:-8%; width:320px; height:320px; background:rgba(255,255,255,.06); border-radius:50%; pointer-events:none; }
    .sb-hero h4 { color:#fff; font-weight:800; font-size:1.4rem; margin-bottom:.15rem; }
    .sb-hero .sb-sub { color:rgba(255,255,255,.75); font-size:.85rem; }

    .sb-stat { background:rgba(255,255,255,.15); backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,.18); border-radius:14px; padding:.7rem 1.1rem; min-width:110px; text-align:center; }
    .sb-stat-num { font-size:1.5rem; font-weight:800; color:#fff; line-height:1.2; }
    .sb-stat-lbl { font-size:.68rem; text-transform:uppercase; letter-spacing:.06em; font-weight:600; color:rgba(255,255,255,.7); }

    .sb-card { background:#fff; border-radius:14px; box-shadow:0 2px 12px rgba(0,0,0,.05); border:1px solid #f1f5f9; overflow:hidden; }
    .sb-table { margin-bottom:0; }
    .sb-table thead { background:linear-gradient(180deg,#f8fafc,#f1f5f9); }
    .sb-table thead th { font-size:.7rem; font-weight:700; color:#475569; text-transform:uppercase; letter-spacing:.08em; padding:.75rem .85rem; border-bottom:2px solid #e2e8f0; white-space:nowrap; }
    .sb-table tbody tr { transition:all .15s ease; border-bottom:1px solid #f8fafc; }
    .sb-table tbody tr:hover { background:linear-gradient(90deg,#f5f3ff,#eff6ff); }
    .sb-table td { vertical-align:middle; padding:.65rem .85rem; font-size:.84rem; color:#334155; }

    .sb-filter { background:linear-gradient(145deg,#faf8ff,#f3f0ff); border:1px solid #e9e4f5; border-radius:14px; padding:1.1rem 1.5rem; margin-bottom:1.25rem; }
    .sb-btn-gen { background:linear-gradient(135deg,#6366f1,#4f46e5); color:#fff; border-radius:10px; font-weight:600; font-size:.82rem; border:none; }
    .sb-btn-gen:hover { background:linear-gradient(135deg,#4f46e5,#4338ca); color:#fff; transform:translateY(-1px); }
</style>

<!-- Hero -->
<div class="sb-hero">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
            <h4><i class="bi bi-collection me-2"></i>Sales Commission Batches</h4>
            <div class="sb-sub">Generate, review and manage sales commission batches</div>
        </div>
        <div class="d-flex gap-3 flex-wrap">
            <div class="sb-stat">
                <div class="sb-stat-num">@Model.Batches.Count</div>
                <div class="sb-stat-lbl">Batches</div>
            </div>
            <div class="sb-stat">
                <div class="sb-stat-num">₹@totalGross.ToString("N0")</div>
                <div class="sb-stat-lbl">Gross</div>
            </div>
            <div class="sb-stat">
                <div class="sb-stat-num">₹@totalNet.ToString("N0")</div>
                <div class="sb-stat-lbl">Net</div>
            </div>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="sb-filter">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-3">
            <label class="form-label fw-semibold" style="font-size:.78rem;">Employee</label>
            <select name="userId" class="form-select form-select-sm" style="border-radius:10px;">
                <option value="">All</option>
                @foreach (var u in Model.Users)
                {
                    <option value="@u.Id" selected="@(Model.UserFilter == u.Id)">@u.FullName @(!string.IsNullOrEmpty(u.EmployeeCode) ? $"({u.EmployeeCode})" : "")</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label fw-semibold" style="font-size:.78rem;">Status</label>
            <select name="status" class="form-select form-select-sm" style="border-radius:10px;">
                <option value="">All</option>
                <option value="Draft" selected="@(Model.StatusFilter == "Draft")">Draft</option>
                <option value="PendingApproval" selected="@(Model.StatusFilter == "PendingApproval")">Pending</option>
                <option value="L1Approved" selected="@(Model.StatusFilter == "L1Approved")">L1 Approved</option>
                <option value="Approved" selected="@(Model.StatusFilter == "Approved")">Approved</option>
                <option value="Paid" selected="@(Model.StatusFilter == "Paid")">Paid</option>
                <option value="Rejected" selected="@(Model.StatusFilter == "Rejected")">Rejected</option>
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label fw-semibold" style="font-size:.78rem;">From</label>
            <input type="date" name="from" class="form-control form-control-sm" style="border-radius:10px;" value="@Model.FromDate?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-md-2">
            <label class="form-label fw-semibold" style="font-size:.78rem;">To</label>
            <input type="date" name="to" class="form-control form-control-sm" style="border-radius:10px;" value="@Model.ToDate?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-sm btn-primary" style="border-radius:10px;"><i class="bi bi-funnel me-1"></i> Filter</button>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary" style="border-radius:10px;"><i class="bi bi-x-lg"></i></a>
            <a asp-action="Generate" class="btn btn-sm sb-btn-gen ms-auto"><i class="bi bi-plus-lg me-1"></i> Generate</a>
            <button type="button" class="btn btn-sm" style="background:linear-gradient(135deg,#059669,#047857);color:#fff;border-radius:10px;font-weight:600;font-size:.82rem;" onclick="openBulkModal()">
                <i class="bi bi-lightning-charge me-1"></i> Bulk Generate
            </button>
        </div>
    </form>
</div>

<!-- Table -->
<div class="sb-card">
    <div class="table-responsive">
        <table class="table sb-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Employee</th>
                    <th>Period</th>
                    <th>Type</th>
                    <th>Invoices</th>
                    <th>Payments</th>
                    <th>Sales (₹)</th>
                    <th>Commission (₹)</th>
                    <th>Status</th>
                    <th>Generated</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Batches.Any())
                {
                    <tr><td colspan="11" class="text-center text-muted py-4"><i class="bi bi-inbox me-1"></i> No batches found.</td></tr>
                }
                @foreach (var b in Model.Batches)
                {
                    <tr>
                        <td class="text-muted" style="font-size:.78rem;">@b.Id</td>
                        <td>
                            <div class="fw-semibold" style="font-size:.82rem;">@b.UserName</div>
                            @if (!string.IsNullOrEmpty(b.EmployeeCode))
                            {
                                <small class="text-muted">@b.EmployeeCode</small>
                            }
                        </td>
                        <td style="font-size:.82rem;">@b.FromDate.ToString("dd MMM") – @b.ToDate.ToString("dd MMM yyyy")</td>
                        <td>
                            <span class="badge @(b.CommissionTypeSnapshot == "Percentage" ? "" : "bg-success")" style="font-size:.7rem;@(b.CommissionTypeSnapshot == "Percentage" ? "background:#7c3aed !important;" : "")">@b.CommissionTypeDisplay</span>
                        </td>
                        <td class="fw-semibold">@b.TotalInvoices</td>
                        <td class="fw-semibold">@b.TotalPayments</td>
                        <td class="fw-bold">₹@b.TotalSalesAmount.ToString("N2")</td>
                        <td class="fw-bold text-primary">₹@b.NetCommission.ToString("N2")</td>
                        <td><span class="badge @b.StatusBadgeClass" style="font-size:.7rem;">@b.StatusDisplay</span></td>
                        <td style="font-size:.78rem;">@b.GeneratedAt.ToString("dd MMM yyyy")</td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@b.Id" class="btn btn-sm btn-outline-primary" style="border-radius:8px;font-size:.75rem;">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Bulk Generate Modal -->
<div class="modal fade" id="bulkModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius:16px;border:none;">
            <div class="modal-header" style="background:linear-gradient(135deg,#059669,#047857);border-radius:16px 16px 0 0;">
                <h5 class="modal-title text-white fw-bold"><i class="bi bi-lightning-charge me-2"></i>Bulk Generate</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="GenerateBulk" method="post" id="bulkForm">
                <div class="modal-body">
                    <p class="text-muted" style="font-size:.84rem;">
                        Generate commission batches for <strong>all configured sales persons</strong> at once.
                        Users with no eligible payments in the selected period will be skipped.
                    </p>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold" style="font-size:.82rem;">From Date <span class="text-danger">*</span></label>
                            <input type="date" name="fromDate" id="bulkFromDate" class="form-control" style="border-radius:10px;" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold" style="font-size:.82rem;">To Date <span class="text-danger">*</span></label>
                            <input type="date" name="toDate" id="bulkToDate" class="form-control" style="border-radius:10px;" required />
                        </div>
                    </div>
                </div>
                <div class="modal-footer" style="border-top:1px solid #f1f5f9;">
                    <button type="button" class="btn btn-outline-secondary" style="border-radius:10px;" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn" style="background:linear-gradient(135deg,#059669,#047857);color:#fff;border-radius:10px;font-weight:600;">
                        <i class="bi bi-lightning-charge me-1"></i> Generate All
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
var bulkModal;
document.addEventListener('DOMContentLoaded', function() {
    bulkModal = new bootstrap.Modal(document.getElementById('bulkModal'));

    // SweetAlert confirmation on bulk form submit
    document.getElementById('bulkForm').addEventListener('submit', function(e) {
        e.preventDefault();
        var form = this;
        var from = document.getElementById('bulkFromDate').value;
        var to = document.getElementById('bulkToDate').value;
        if (!from || !to) return;

        Swal.fire({
            title: 'Bulk Generate Batches?',
            html: 'This will generate commission batches for <strong>all configured sales persons</strong> for the period <strong>' + from + '</strong> to <strong>' + to + '</strong>.',
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: 'Yes, Generate All',
            cancelButtonText: 'Cancel',
            confirmButtonColor: '#059669',
            cancelButtonColor: '#6c757d',
            reverseButtons: true
        }).then(function(result) {
            if (result.isConfirmed) form.submit();
        });
    });
});

function openBulkModal() {
    // Default: 1st of current month → today
    var today = new Date();
    var firstDay = new Date(today.getFullYear(), today.getMonth(), 1);
    document.getElementById('bulkFromDate').value = firstDay.toISOString().split('T')[0];
    document.getElementById('bulkToDate').value = today.toISOString().split('T')[0];
    bulkModal.show();
}
</script>
}
