@model CentralLicenceApp.Models.Quotation
@{
    ViewData["Title"] = "Quotation – " + Model.QuotationNo;
    var statusStyle = Model.Status switch
    {
        "Accepted"   => "background:#dcfce7;color:#166534;",
        "Converted"  => "background:#dbeafe;color:#1d4ed8;",
        "Rejected"   => "background:#fee2e2;color:#b91c1c;",
        "Cancelled"  => "background:#fee2e2;color:#b91c1c;",
        "Sent"       => "background:#fef9c3;color:#854d0e;",
        _            => "background:#f1f5f9;color:#475569;"
    };
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary" style="border-radius:8px;"><i class="bi bi-arrow-left"></i></a>
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;">Quotation Details</h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">@Model.QuotationNo</p>
    </div>
    <span class="badge rounded-pill px-3 py-2 ms-auto" style="font-size:.8rem;@statusStyle">@Model.Status</span>
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <!-- Party & Dates -->
        <div class="card mb-3">
            <div class="card-header"><i class="bi bi-building me-2" style="color:#6366f1;"></i>Party Information</div>
            <div class="card-body">
                <dl class="row mb-0" style="font-size:.875rem;">
                    <dt class="col-sm-4 text-muted fw-normal">Party Name</dt>
                    <dd class="col-sm-8 fw-semibold">@Model.PartyName</dd>
                    @if (!string.IsNullOrWhiteSpace(Model.PartyAddress))
                    {
                        <dt class="col-sm-4 text-muted fw-normal">Address</dt>
                        <dd class="col-sm-8">@Model.PartyAddress</dd>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.PartyGSTINNo))
                    {
                        <dt class="col-sm-4 text-muted fw-normal">GSTIN</dt>
                        <dd class="col-sm-8"><code>@Model.PartyGSTINNo</code></dd>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.PartyPANNo))
                    {
                        <dt class="col-sm-4 text-muted fw-normal">PAN</dt>
                        <dd class="col-sm-8"><code>@Model.PartyPANNo</code></dd>
                    }
                    <dt class="col-sm-4 text-muted fw-normal">Quotation Date</dt>
                    <dd class="col-sm-8">@Model.QuotationDate.ToString("dd MMM yyyy")</dd>
                    <dt class="col-sm-4 text-muted fw-normal">Valid Until</dt>
                    <dd class="col-sm-8">@(Model.ValidUntilDate.HasValue ? Model.ValidUntilDate.Value.ToString("dd MMM yyyy") : "—")</dd>
                </dl>
            </div>
        </div>

        <!-- Line Items -->
        <div class="card mb-3">
            <div class="card-header"><i class="bi bi-list-ul me-2" style="color:#6366f1;"></i>Line Items</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3" style="width:40px;">#</th>
                                <th>Item</th>
                                <th>Plan</th>
                                <th>Type</th>
                                <th class="text-end">Qty</th>
                                <th class="text-end">Rate</th>
                                <th class="text-end">Disc</th>
                                <th class="text-end">Taxable</th>
                                <th class="text-end">GST%</th>
                                <th class="text-end pe-3">GST Amt</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var line in Model.Lines)
                            {
                                <tr>
                                    <td class="ps-3 text-muted" style="font-size:.8rem;">@line.SNo</td>
                                    <td class="fw-semibold" style="font-size:.875rem;">@line.ItemDescription</td>
                                    <td style="font-size:.82rem;">@(line.PlanName ?? "—")</td>
                                    <td style="font-size:.82rem;">@(line.Type ?? "—")</td>
                                    <td class="text-end">@line.Qty</td>
                                    <td class="text-end">₹@line.Rate.ToString("0.00")</td>
                                    <td class="text-end" style="font-size:.8rem;">
                                        @if (line.DiscountPercent > 0)
                                        {
                                            <span>₹@line.DiscountAmount.ToString("0.00")<br /><span class="text-muted">(@line.DiscountPercent.ToString("0.##")%)</span></span>
                                        }
                                        else { <span>—</span> }
                                    </td>
                                    <td class="text-end">₹@line.Amount.ToString("0.00")</td>
                                    <td class="text-end" style="font-size:.82rem;">@(line.GstPercent > 0 ? line.GstPercent.ToString("0.##") + "%" : "—")</td>
                                    <td class="text-end pe-3 fw-semibold">
                                        @{
                                            var lineGst = line.CgstAmount + line.SgstAmount + line.IgstAmount;
                                        }
                                        @(lineGst > 0 ? "₹" + lineGst.ToString("0.00") : "—")
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="7" class="text-end fw-bold pe-2">SUBTOTAL</td>
                                <td class="text-end fw-bold">₹@Model.SubTotal.ToString("0.00")</td>
                                <td></td>
                                <td class="text-end pe-3 fw-bold">₹@Model.TotalGst.ToString("0.00")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Notes))
        {
            <div class="card mb-3">
                <div class="card-header"><i class="bi bi-chat-text me-2" style="color:#6366f1;"></i>Notes</div>
                <div class="card-body" style="font-size:.875rem;">@Model.Notes</div>
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.TermsAndConditions))
        {
            <div class="card mb-3">
                <div class="card-header"><i class="bi bi-file-text me-2" style="color:#6366f1;"></i>Terms &amp; Conditions</div>
                <div class="card-body terms-html" style="font-size:.875rem;">@Html.Raw(Model.TermsAndConditions)</div>
            </div>
        }
    </div>

    <div class="col-lg-4">
        <!-- Summary -->
        <div class="card mb-3">
            <div class="card-header"><i class="bi bi-receipt me-2" style="color:#6366f1;"></i>Summary</div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2" style="font-size:.875rem;">
                    <span class="text-muted">Sub Total</span>
                    <span>₹@Model.SubTotal.ToString("0.00")</span>
                </div>
                @if (Model.TotalCgst > 0)
                {
                    <div class="d-flex justify-content-between mb-2" style="font-size:.875rem;">
                        <span class="text-muted">CGST</span>
                        <span>₹@Model.TotalCgst.ToString("0.00")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2" style="font-size:.875rem;">
                        <span class="text-muted">SGST</span>
                        <span>₹@Model.TotalSgst.ToString("0.00")</span>
                    </div>
                }
                @if (Model.TotalIgst > 0)
                {
                    <div class="d-flex justify-content-between mb-2" style="font-size:.875rem;">
                        <span class="text-muted">IGST</span>
                        <span>₹@Model.TotalIgst.ToString("0.00")</span>
                    </div>
                }
                @if (Model.EnableRoundOff && Model.RoundOff != 0)
                {
                    <div class="d-flex justify-content-between mb-2" style="font-size:.875rem;">
                        <span class="text-muted">Round Off</span>
                        <span>₹@Model.RoundOff.ToString("0.##")</span>
                    </div>
                }
                <hr class="my-2" />
                <div class="d-flex justify-content-between mb-0" style="font-size:.9rem;">
                    <span class="fw-bold">Total Amount</span>
                    <span class="fw-bold" style="color:#6366f1;">₹@Model.TotalAmount.ToString("0.00")</span>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="card">
            <div class="card-header"><i class="bi bi-lightning me-2" style="color:#6366f1;"></i>Actions</div>
            <div class="card-body d-flex flex-column gap-2">
                <a asp-action="Print" asp-permission="Quotation:Print" asp-route-id="@Model.Id"
                   class="btn btn-outline-secondary w-100" style="border-radius:10px;" target="_blank">
                    <i class="bi bi-printer me-1"></i> Print / Download
                </a>

                @if (User.IsInRole("Administrator"))
                {
                    @if (Model.IsCancelled)
                    {
                        <div class="alert alert-danger py-2 px-3 rounded-3 mb-0" style="font-size:.82rem;">
                            <i class="bi bi-x-circle me-1"></i> This quotation has been cancelled.
                        </div>
                        @if (!string.IsNullOrWhiteSpace(Model.CancelRemarks))
                        {
                            <div class="alert alert-secondary py-2 px-3 rounded-3 mb-0" style="font-size:.82rem;">
                                <strong>Remarks:</strong> @Model.CancelRemarks
                            </div>
                        }
                    }
                    else if (Model.IsConverted)
                    {
                        <div class="alert alert-info py-2 px-3 rounded-3 mb-0" style="font-size:.82rem;">
                            <i class="bi bi-check-circle me-1"></i> Converted to Invoice
                        </div>
                    }
                    else
                    {
                        <a asp-action="Edit" asp-permission="Quotation:Edit" asp-route-id="@Model.Id"
                           class="btn btn-outline-primary w-100" style="border-radius:10px;">
                            <i class="bi bi-pencil me-1"></i> Edit Quotation
                        </a>

                        @if (Model.Status != "Draft")
                        {
                            <form asp-action="ResendMail" asp-route-id="@Model.Id" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn w-100 text-white" style="background:#6366f1;border:none;border-radius:10px;">
                                    <i class="bi bi-envelope-arrow-up me-1"></i> Resend Mail
                                </button>
                            </form>
                        }

                        <!-- Status change -->
                        @foreach (var s in new[] { "Draft", "Sent", "Accepted", "Rejected" }.Where(x => x != Model.Status))
                        {
                            <form asp-action="UpdateStatus" asp-permission="Quotation:Edit" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.Id" />
                                <input type="hidden" name="status" value="@s" />
                                <button type="submit" class="btn btn-outline-secondary w-100" style="border-radius:10px;">
                                    <i class="bi bi-arrow-repeat me-1"></i> Mark as @s
                                </button>
                            </form>
                        }

                        @if (Model.Status == "Accepted")
                        {
                            <a asp-controller="Invoice" asp-action="CreateFromQuotation" asp-permission="Invoice:Create" asp-route-id="@Model.Id"
                               class="btn w-100 text-white" style="background:#6366f1;border:none;border-radius:10px;">
                                <i class="bi bi-arrow-right-circle me-1"></i> Convert to Invoice
                            </a>
                        }
                        else if (!Model.IsConverted && !Model.IsCancelled)
                        {
                            <div class="alert alert-warning py-2 px-3 rounded-3 mb-0" style="font-size:.82rem;">
                                <i class="bi bi-info-circle me-1"></i>
                                Quotation must be <strong>Accepted</strong> before converting to Invoice.
                            </div>
                        }

                        <button type="button" class="btn btn-outline-danger w-100" style="border-radius:10px;"
                                data-bs-toggle="modal" data-bs-target="#cancelModal">
                            <i class="bi bi-x-circle me-1"></i> Cancel Quotation
                        </button>
                    }
                }
            </div>
        </div>
    </div>
</div>

<!-- Cancel Modal -->
<div class="modal fade" id="cancelModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:16px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-danger">Cancel Quotation</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Cancel" asp-permission="Quotation:Cancel" asp-route-id="@Model.Id" method="post" id="cancelForm">
                @Html.AntiForgeryToken()
                <div class="modal-body pt-2">
                    <p class="text-muted" style="font-size:.88rem;">
                        You are about to cancel <strong>@Model.QuotationNo</strong>. This action cannot be undone.
                    </p>
                    <label class="form-label fw-semibold" style="font-size:.85rem;">
                        Cancellation Remarks <span class="text-danger">*</span>
                    </label>
                    <textarea name="remarks" id="cancelRemarks" class="form-control" rows="3"
                              placeholder="Enter reason for cancellation…" style="border-radius:10px;"></textarea>
                    <div id="cancelRemarksError" class="text-danger mt-1" style="font-size:.82rem;display:none;">
                        Remarks are required.
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" style="border-radius:8px;">Close</button>
                    <button type="submit" class="btn btn-danger" style="border-radius:8px;">
                        <i class="bi bi-x-circle me-1"></i> Confirm Cancel
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
<script>
    document.getElementById('cancelForm')?.addEventListener('submit', function (e) {
        var remarks = document.getElementById('cancelRemarks').value.trim();
        if (!remarks) {
            e.preventDefault();
            document.getElementById('cancelRemarksError').style.display = 'block';
            document.getElementById('cancelRemarks').focus();
        }
    });
    document.getElementById('cancelRemarks')?.addEventListener('input', function () {
        if (this.value.trim())
            document.getElementById('cancelRemarksError').style.display = 'none';
    });
</script>
