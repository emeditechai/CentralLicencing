@model List<CentralLicenceApp.Models.Quotation>
@using System.Linq
@{
    ViewData["Title"] = "Quotations";
    var totalValue     = Model.Sum(q => q.TotalAmount);
    var draftCount     = Model.Count(q => q.Status == "Draft");
    var sentCount      = Model.Count(q => q.Status == "Sent");
    var acceptedCount  = Model.Count(q => q.Status == "Accepted");
    var convertedCount = Model.Count(q => q.Status == "Converted");
    var rejectedCount  = Model.Count(q => q.Status == "Rejected" || q.Status == "Cancelled");
    var acceptedValue  = Model.Where(q => q.Status == "Accepted").Sum(q => q.TotalAmount);
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;">Quotations</h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">@Model.Count quotation@(Model.Count == 1 ? "" : "s")</p>
    </div>
    <a asp-action="Create" class="btn btn-primary" style="background:#180a3c;border:none;border-radius:10px;">
        <i class="bi bi-plus-lg me-1"></i> New Quotation
    </a>
</div>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card h-100 border-0 shadow-sm" style="border-radius:14px;">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="rounded-3 d-flex align-items-center justify-content-center" style="width:36px;height:36px;background:#ede9fe;">
                        <i class="bi bi-file-earmark-text" style="color:#7c3aed;font-size:1.05rem;"></i>
                    </div>
                    <span class="text-muted" style="font-size:.74rem;font-weight:600;letter-spacing:.03em;">TOTAL</span>
                </div>
                <div class="fw-bold" style="font-size:1.6rem;color:#1e293b;line-height:1.1;">@Model.Count</div>
                <div class="text-muted mt-1" style="font-size:.73rem;">₹@totalValue.ToString("N2")</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card h-100 border-0 shadow-sm" style="border-radius:14px;">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="rounded-3 d-flex align-items-center justify-content-center" style="width:36px;height:36px;background:#f1f5f9;">
                        <i class="bi bi-pencil-square" style="color:#64748b;font-size:1.05rem;"></i>
                    </div>
                    <span class="text-muted" style="font-size:.74rem;font-weight:600;letter-spacing:.03em;">DRAFT</span>
                </div>
                <div class="fw-bold" style="font-size:1.6rem;color:#1e293b;line-height:1.1;">@draftCount</div>
                <div class="text-muted mt-1" style="font-size:.73rem;">Pending send</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card h-100 border-0 shadow-sm" style="border-radius:14px;">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="rounded-3 d-flex align-items-center justify-content-center" style="width:36px;height:36px;background:#e0f2fe;">
                        <i class="bi bi-send" style="color:#0284c7;font-size:1.05rem;"></i>
                    </div>
                    <span class="text-muted" style="font-size:.74rem;font-weight:600;letter-spacing:.03em;">SENT</span>
                </div>
                <div class="fw-bold" style="font-size:1.6rem;color:#1e293b;line-height:1.1;">@sentCount</div>
                <div class="text-muted mt-1" style="font-size:.73rem;">Awaiting reply</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card h-100 border-0 shadow-sm" style="border-radius:14px;">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="rounded-3 d-flex align-items-center justify-content-center" style="width:36px;height:36px;background:#dcfce7;">
                        <i class="bi bi-check-circle" style="color:#16a34a;font-size:1.05rem;"></i>
                    </div>
                    <span class="text-muted" style="font-size:.74rem;font-weight:600;letter-spacing:.03em;">ACCEPTED</span>
                </div>
                <div class="fw-bold" style="font-size:1.6rem;color:#1e293b;line-height:1.1;">@acceptedCount</div>
                <div class="text-muted mt-1" style="font-size:.73rem;">₹@acceptedValue.ToString("N2")</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card h-100 border-0 shadow-sm" style="border-radius:14px;">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="rounded-3 d-flex align-items-center justify-content-center" style="width:36px;height:36px;background:#fef3c7;">
                        <i class="bi bi-arrow-repeat" style="color:#d97706;font-size:1.05rem;"></i>
                    </div>
                    <span class="text-muted" style="font-size:.74rem;font-weight:600;letter-spacing:.03em;">CONVERTED</span>
                </div>
                <div class="fw-bold" style="font-size:1.6rem;color:#1e293b;line-height:1.1;">@convertedCount</div>
                <div class="text-muted mt-1" style="font-size:.73rem;">To invoice</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card h-100 border-0 shadow-sm" style="border-radius:14px;">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="rounded-3 d-flex align-items-center justify-content-center" style="width:36px;height:36px;background:#fee2e2;">
                        <i class="bi bi-x-circle" style="color:#dc2626;font-size:1.05rem;"></i>
                    </div>
                    <span class="text-muted" style="font-size:.74rem;font-weight:600;letter-spacing:.03em;">REJECTED / CANCELLED</span>
                </div>
                <div class="fw-bold" style="font-size:1.6rem;color:#1e293b;line-height:1.1;">@rejectedCount</div>
                <div class="text-muted mt-1" style="font-size:.73rem;">Closed</div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table tbl-clean mb-0">
                <thead>
                    <tr>
                        <th class="ps-3">Quotation No</th>
                        <th>Party</th>
                        <th>Date</th>
                        <th>Valid Until</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th class="pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="bi bi-file-earmark-text fs-1 d-block mb-2"></i>No quotations yet
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            var statusStyle = item.Status switch
                            {
                                "Accepted"  => "background:#dcfce7;color:#166534;",
                                "Converted" => "background:#dbeafe;color:#1d4ed8;",
                                "Rejected"  => "background:#fee2e2;color:#b91c1c;",
                                "Sent"      => "background:#fef9c3;color:#854d0e;",
                                _           => "background:#f1f5f9;color:#475569;"
                            };
                            <tr>
                                <td class="ps-3">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="fw-semibold" style="color:#6366f1;text-decoration:none;">@item.QuotationNo</a>
                                </td>
                                <td>
                                    <div class="fw-semibold" style="font-size:.875rem;">@item.PartyName</div>
                                </td>
                                <td style="font-size:.85rem;">@item.QuotationDate.ToString("dd MMM yyyy")</td>
                                <td style="font-size:.85rem;">@(item.ValidUntilDate.HasValue ? item.ValidUntilDate.Value.ToString("dd MMM yyyy") : "—")</td>
                                <td class="fw-semibold" style="font-size:.875rem;">₹@item.TotalAmount.ToString("0.00")</td>
                                <td><span class="badge rounded-pill px-2 py-1" style="font-size:.72rem;@statusStyle">@item.Status</span></td>
                                <td class="pe-3">
                                    <div class="d-flex gap-2">
                                        <a asp-action="Details" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-primary" style="border-radius:8px;font-size:.78rem;" title="View">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (User.IsInRole("Administrator") && item.Status != "Converted")
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id"
                                               class="btn btn-sm btn-outline-secondary" style="border-radius:8px;font-size:.78rem;" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                                                  data-swal-confirm="true"
                                                  data-swal-title="Delete Quotation?"
                                                  data-swal-text="Delete @item.QuotationNo?"
                                                  data-swal-confirm-button="Yes, delete">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger" style="border-radius:8px;font-size:.78rem;" title="Delete">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
