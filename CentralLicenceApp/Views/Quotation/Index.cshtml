@model List<CentralLicenceApp.Models.Quotation>
@{
    ViewData["Title"] = "Quotations";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;">Quotations</h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">@Model.Count quotation@(Model.Count == 1 ? "" : "s")</p>
    </div>
    <a asp-action="Create" class="btn btn-primary" style="background:#180a3c;border:none;border-radius:10px;">
        <i class="bi bi-plus-lg me-1"></i> New Quotation
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show py-2 px-3 rounded-3" style="font-size:.85rem;">
        @Html.Raw(TempData["Success"])
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show py-2 px-3 rounded-3" style="font-size:.85rem;">
        @Html.Raw(TempData["Error"])
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table tbl-clean mb-0">
                <thead>
                    <tr>
                        <th class="ps-3">Quotation No</th>
                        <th>Party</th>
                        <th>Date</th>
                        <th>Valid Until</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th class="pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="bi bi-file-earmark-text fs-1 d-block mb-2"></i>No quotations yet
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            var statusStyle = item.Status switch
                            {
                                "Accepted"  => "background:#dcfce7;color:#166534;",
                                "Converted" => "background:#dbeafe;color:#1d4ed8;",
                                "Rejected"  => "background:#fee2e2;color:#b91c1c;",
                                "Sent"      => "background:#fef9c3;color:#854d0e;",
                                _           => "background:#f1f5f9;color:#475569;"
                            };
                            <tr>
                                <td class="ps-3">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="fw-semibold" style="color:#6366f1;text-decoration:none;">@item.QuotationNo</a>
                                </td>
                                <td>
                                    <div class="fw-semibold" style="font-size:.875rem;">@item.PartyName</div>
                                </td>
                                <td style="font-size:.85rem;">@item.QuotationDate.ToString("dd MMM yyyy")</td>
                                <td style="font-size:.85rem;">@(item.ValidUntilDate.HasValue ? item.ValidUntilDate.Value.ToString("dd MMM yyyy") : "—")</td>
                                <td class="fw-semibold" style="font-size:.875rem;">₹@item.TotalAmount.ToString("0.00")</td>
                                <td><span class="badge rounded-pill px-2 py-1" style="font-size:.72rem;@statusStyle">@item.Status</span></td>
                                <td class="pe-3">
                                    <div class="d-flex gap-2">
                                        <a asp-action="Details" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-primary" style="border-radius:8px;font-size:.78rem;" title="View">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (User.IsInRole("Administrator") && item.Status != "Converted")
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id"
                                               class="btn btn-sm btn-outline-secondary" style="border-radius:8px;font-size:.78rem;" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                                                  data-swal-confirm="true"
                                                  data-swal-title="Delete Quotation?"
                                                  data-swal-text="Delete @item.QuotationNo?"
                                                  data-swal-confirm-button="Yes, delete">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger" style="border-radius:8px;font-size:.78rem;" title="Delete">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
