@using CentralLicenceApp.Helpers
@model CentralLicenceApp.Models.ViewModels.ProductRateIndexViewModel
@{
    ViewData["Title"] = "Product Rate List";
}

<div class="d-flex align-items-center justify-content-between mb-4 gap-3 flex-wrap">
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;">Product Rate List</h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">
            @if (Model.SelectedProduct != null)
            {
                <span>Showing pricing models for <strong style="color:#6366f1;">@Model.SelectedProduct.ProductName</strong></span>
            }
            else
            {
                <span>@Model.Items.Count pricing model record(s) across all products</span>
            }
        </p>
    </div>
    <a asp-action="Create" asp-route-productId="@Model.SelectedProductId" class="btn btn-primary" style="background:#180a3c;border:none;border-radius:10px;">
        <i class="bi bi-plus-lg me-1"></i> New Product Rate
    </a>
</div>

<div class="card mb-4">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label mb-1" style="font-size:.78rem;font-weight:600;color:#64748b;">Product</label>
                <select name="productId" class="form-select" style="border-radius:10px;" onchange="this.form.submit()">
                    <option value="">All Products</option>
                    @foreach (var item in Model.Products)
                    {
                        <option value="@item.Id" selected="@(Model.SelectedProductId == item.Id)">@item.ProductName (@item.ProductCode)</option>
                    }
                </select>
            </div>
            <div class="col-md-auto">
                <button type="submit" class="btn btn-primary" style="background:#6366f1;border:none;border-radius:10px;"><i class="bi bi-funnel me-1"></i> Filter</button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-1" style="border-radius:10px;">Clear</a>
            </div>
        </form>
    </div>
</div>

@if (Model.SelectedProduct != null)
{
    <div class="card mb-4" style="border:1px solid #e2e8f0;">
        <div class="card-body d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div>
                <div class="fw-semibold" style="font-size:1rem;color:#1e293b;">@Model.SelectedProduct.ProductName</div>
                <div style="font-size:.82rem;color:#6366f1;">@Model.SelectedProduct.ProductCode • @Model.SelectedProduct.ProductType</div>
            </div>
            <a asp-controller="ProductMaster" asp-action="Edit" asp-route-id="@Model.SelectedProduct.Id" class="btn btn-sm btn-outline-secondary" style="border-radius:8px;">
                <i class="bi bi-pencil me-1"></i> Edit Product
            </a>
        </div>
    </div>
}

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table tbl-clean mb-0">
                <thead>
                    <tr>
                        <th class="ps-3">#</th>
                        <th>Product</th>
                        <th>Pricing Model</th>
                        <th>Specification</th>
                        <th>Features</th>
                        <th>Rate</th>
                        <th>AMC</th>
                        <th>Status</th>
                        <th class="pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center py-5 text-muted"><i class="bi bi-inbox fs-1 d-block mb-2"></i>No product rates found</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model.Items)
                        {
                            var pricingModelTheme = PricingModelBadgeThemeHelper.Resolve(item.PricingModel);
                            <tr>
                                <td class="ps-3" style="color:#94a3b8;font-size:.8rem;">@item.Id</td>
                                <td style="min-width:180px;">
                                    <div class="fw-semibold" style="font-size:.86rem;">@item.ProductName</div>
                                    <div style="font-size:.75rem;color:#6366f1;">@item.ProductCode • @item.ProductType</div>
                                </td>
                                <td style="font-size:.82rem;min-width:150px;">
                                    <span class="badge rounded-pill px-2 py-1"
                                          style="background:@pricingModelTheme.BackgroundColor;color:@pricingModelTheme.TextColor;border:1px solid @pricingModelTheme.BorderColor;">
                                        @item.PricingModel
                                    </span>
                                    <div class="text-muted mt-1" style="font-size:.74rem;">@item.DiscountOfferCount discount offer(s)</div>
                                </td>
                                <td style="font-size:.8rem;max-width:220px;white-space:normal;word-break:break-word;">@(string.IsNullOrWhiteSpace(item.ProductSpecification) ? "-" : item.ProductSpecification)</td>
                                <td style="font-size:.8rem;max-width:260px;white-space:normal;word-break:break-word;">@(string.IsNullOrWhiteSpace(item.Features) ? "-" : item.Features)</td>
                                <td style="font-size:.82rem;font-weight:700;white-space:nowrap;">₹@item.Rate.ToString("0.00")</td>
                                <td style="font-size:.8rem;white-space:nowrap;min-width:140px;">
                                    <div class="fw-semibold">₹@item.AmcAmount.ToString("0.00")</div>
                                    <div class="text-muted">@item.AmcPercentage.ToString("0.####")% • @item.AmcCalculationType</div>
                                </td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge badge-ok rounded-pill px-2 py-1" style="font-size:.73rem;">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-neu rounded-pill px-2 py-1" style="font-size:.73rem;">Inactive</span>
                                    }
                                </td>
                                <td class="pe-3">
                                    <div class="d-flex gap-1 flex-wrap justify-content-end">
                                        <a asp-controller="ProductRateDiscount" asp-action="Index" asp-route-productRateId="@item.Id" class="btn btn-sm btn-outline-primary" style="border-radius:7px;"><i class="bi bi-percent me-1"></i>Discounts</a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" style="border-radius:7px;border-color:#e2e8f0;"><i class="bi bi-pencil"></i></a>
                                        <form asp-action="Delete" method="post"
                                              data-swal-confirm="true"
                                              data-swal-title="Delete Product Rate?"
                                              data-swal-text="Pricing model <strong>@item.PricingModel</strong> for <strong>@item.ProductName</strong> will be deleted permanently."
                                              data-swal-confirm-button="Yes, delete rate">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" style="border-radius:7px;"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>