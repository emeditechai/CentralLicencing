@using CentralLicenceApp.Helpers
@model CentralLicenceApp.Models.ViewModels.ProductRateIndexViewModel
@{
    ViewData["Title"] = "Product Rate List";
    var activeRates = Model.Items.Count(x => x.IsActive);
    var discountMappedRates = Model.Items.Count(x => x.DiscountOfferCount > 0);
    var averageRate = Model.Items.Any() ? Model.Items.Average(x => x.Rate) : 0;
}

<div class="rate-shell">
    <div class="hero-panel mb-4">
        <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap position-relative" style="z-index:1;">
            <div>
                <div class="section-label mb-2">Pricing Control</div>
                <h3 class="fw-bold mb-1" style="color:#1e293b;">Product Rate List</h3>
                <p class="mb-0" style="font-size:.9rem;color:#54657e;max-width:620px;">
                    @if (Model.SelectedProduct != null)
                    {
                        <span>Showing pricing models for <strong style="color:#4338ca;">@Model.SelectedProduct.ProductName</strong> with rate, AMC, and offer visibility.</span>
                    }
                    else
                    {
                        <span>@Model.Items.Count pricing model record(s) across all products with commercial comparison at a glance.</span>
                    }
                </p>
            </div>
            <a asp-action="Create" asp-route-productId="@Model.SelectedProductId" class="btn btn-primary align-self-start" style="background:#180a3c;border:none;border-radius:14px;padding:.8rem 1.1rem;box-shadow:0 10px 24px rgba(24,10,60,.18);">
                <i class="bi bi-plus-lg me-1"></i> New Product Rate
            </a>
        </div>
        <div class="d-flex gap-3 flex-wrap mt-4 position-relative" style="z-index:1;">
            <div class="hero-stat">
                <div class="section-label">Rate Models</div>
                <div class="hero-stat-value">@Model.Items.Count</div>
            </div>
            <div class="hero-stat">
                <div class="section-label">Active</div>
                <div class="hero-stat-value" style="color:#059669;">@activeRates</div>
            </div>
            <div class="hero-stat">
                <div class="section-label">Offer Mapped</div>
                <div class="hero-stat-value" style="color:#c2410c;">@discountMappedRates</div>
            </div>
            <div class="hero-stat">
                <div class="section-label">Average Rate</div>
                <div class="hero-stat-value" style="color:#2563eb;">₹@averageRate.ToString("0.##")</div>
            </div>
        </div>
    </div>

<div class="soft-card mb-4">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label mb-1" style="font-size:.78rem;font-weight:600;color:#64748b;">Product</label>
                <select name="productId" class="form-select" style="border-radius:10px;" onchange="this.form.submit()">
                    <option value="">All Products</option>
                    @foreach (var item in Model.Products)
                    {
                        <option value="@item.Id" selected="@(Model.SelectedProductId == item.Id)">@item.ProductName (@item.ProductCode)</option>
                    }
                </select>
            </div>
            <div class="col-md-auto">
                <button type="submit" class="btn btn-primary" style="background:#6366f1;border:none;border-radius:10px;"><i class="bi bi-funnel me-1"></i> Filter</button>
                <a asp-action="Index" class="btn ms-1" style="border-radius:10px;border:1px solid #cfd9e6;color:#475569;background:#fff;">Clear</a>
            </div>
        </form>
    </div>
</div>

@if (Model.SelectedProduct != null)
{
    <div class="soft-card mb-4" style="background:linear-gradient(135deg,#ffffff 0%,#f8fbff 100%);">
        <div class="card-body d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div>
                <div class="fw-semibold" style="font-size:1rem;color:#1e293b;">@Model.SelectedProduct.ProductName</div>
                <div style="font-size:.82rem;color:#6366f1;">@Model.SelectedProduct.ProductCode • @Model.SelectedProduct.ProductType</div>
            </div>
            <a asp-controller="ProductMaster" asp-action="Edit" asp-route-id="@Model.SelectedProduct.Id" class="btn btn-sm" style="border-radius:10px;background:#fff;color:#475569;border:1px solid #dbe4f0;">
                <i class="bi bi-pencil me-1"></i> Edit Product
            </a>
        </div>
    </div>
}

<div class="soft-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table tbl-clean mb-0">
                <thead>
                    <tr>
                        <th class="ps-3">#</th>
                        <th>Product</th>
                        <th>Pricing Model</th>
                        <th>Model / Frequency</th>
                        <th>Specification</th>
                        <th>Features</th>
                        <th>Rate</th>
                        <th>AMC</th>
                        <th>Status</th>
                        <th class="pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="10" class="text-center py-5 text-muted"><i class="bi bi-inbox fs-1 d-block mb-2"></i>No product rates found</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model.Items)
                        {
                            var pricingModelTheme = PricingModelBadgeThemeHelper.Resolve(item.PricingModel);
                            <tr>
                                <td class="ps-3" style="color:#94a3b8;font-size:.8rem;">@item.Id</td>
                                <td style="min-width:180px;">
                                    <div class="fw-semibold" style="font-size:.86rem;">@item.ProductName</div>
                                    <div style="font-size:.75rem;color:#6366f1;">@item.ProductCode • @item.ProductType</div>
                                </td>
                                <td style="font-size:.82rem;min-width:150px;">
                                    <span class="badge rounded-pill px-2 py-1"
                                          style="background:@pricingModelTheme.BackgroundColor;color:@pricingModelTheme.TextColor;border:1px solid @pricingModelTheme.BorderColor;">
                                        @item.PricingModel
                                    </span>
                                    <div class="mt-2">
                                        <span class="info-chip" style="background:#f8fafc;color:#475569;border:1px solid #e2e8f0;">@item.DiscountOfferCount offer(s)</span>
                                    </div>
                                </td>
                                <td style="font-size:.8rem;white-space:nowrap;min-width:150px;">
                                    <div class="fw-semibold" style="color:#1e293b;">@item.BillingModel</div>
                                    <div class="text-muted">@(string.IsNullOrWhiteSpace(item.BillingFrequency) ? "-" : item.BillingFrequency)</div>
                                </td>
                                <td style="font-size:.8rem;max-width:220px;white-space:normal;word-break:break-word;">@(string.IsNullOrWhiteSpace(item.ProductSpecification) ? "-" : item.ProductSpecification)</td>
                                <td style="font-size:.8rem;max-width:260px;white-space:normal;word-break:break-word;">@(string.IsNullOrWhiteSpace(item.Features) ? "-" : item.Features)</td>
                                <td style="font-size:.82rem;font-weight:700;white-space:nowrap;color:#1d4ed8;">₹@item.Rate.ToString("0.00")</td>
                                <td style="font-size:.8rem;white-space:nowrap;min-width:140px;">
                                    @if (string.IsNullOrWhiteSpace(item.AmcCalculationType))
                                    {
                                        <div class="fw-semibold" style="color:#64748b;">-</div>
                                        <div class="text-muted">No AMC</div>
                                    }
                                    else
                                    {
                                        <div class="fw-semibold" style="color:#0f766e;">₹@item.AmcAmount.ToString("0.00")</div>
                                        <div class="text-muted">@item.AmcPercentage.ToString("0.####")% • @item.AmcCalculationType</div>
                                    }
                                </td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge rounded-pill px-2 py-1" style="font-size:.73rem;background:#dcfce7;color:#166534;border:1px solid #bbf7d0;">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill px-2 py-1" style="font-size:.73rem;background:#e2e8f0;color:#475569;border:1px solid #cbd5e1;">Inactive</span>
                                    }
                                </td>
                                <td class="pe-3">
                                    <div class="d-flex gap-1 flex-wrap justify-content-end">
                                        <a asp-controller="ProductRateDiscount" asp-action="Index" asp-route-productRateId="@item.Id" class="btn btn-sm" style="border-radius:9px;background:#eef2ff;color:#4338ca;border:1px solid #c7d2fe;"><i class="bi bi-percent me-1"></i>Discounts</a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm" style="border-radius:9px;background:#f8fafc;color:#475569;border:1px solid #dbe4f0;"><i class="bi bi-pencil"></i></a>
                                        <form asp-action="Delete" method="post"
                                              data-swal-confirm="true"
                                              data-swal-title="Delete Product Rate?"
                                                data-swal-text="Pricing model <strong>@item.PricingModel</strong> with <strong>@item.BillingSummary</strong> for <strong>@item.ProductName</strong> will be deleted permanently."
                                              data-swal-confirm-button="Yes, delete rate">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <button type="submit" class="btn btn-sm" style="border-radius:9px;background:#fff1f2;color:#dc2626;border:1px solid #fecdd3;"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
</div>