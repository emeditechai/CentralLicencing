@model CentralLicenceApp.Models.ViewModels.ExpenseRequestManageViewModel
@using CentralLicenceApp.Models
@using CentralLicenceApp.Repositories
@inject ICompanySettingsRepository CompanySettingsRepo
@{
    Layout = null;
    var company = ViewBag.ParentCompany as CompanySetting ?? await CompanySettingsRepo.GetParentCompanyAsync();
    var brandName = string.IsNullOrWhiteSpace(company?.CompanyName) ? "Emeditech Plus LLP" : company.CompanyName.Trim();
    var brandLogoPath = string.IsNullOrWhiteSpace(company?.CompanyLogoPath) ? null : Url.Content(company.CompanyLogoPath);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Request.SettlementReceiptNumber - Settlement Receipt</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <style>
        @@page {
            size: A4 portrait;
            margin: 10mm;
        }
        body {
            margin: 0;
            background: #edf2f7;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            color: #0f172a;
        }
        .receipt-shell {
            width: 210mm;
            min-height: 297mm;
            margin: 1rem auto;
            background: #fff;
            border: 1px solid #dbe3ef;
            box-shadow: 0 12px 30px rgba(15, 23, 42, .08);
        }
        .receipt-toolbar {
            display: flex;
            justify-content: flex-end;
            padding: .75rem 1rem;
            background: #f8fafc;
            border-bottom: 1px solid #dbe3ef;
        }
        .receipt-doc {
            padding: 1.1rem 1.25rem 1rem;
        }
        .receipt-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 1rem;
            border-bottom: 2px solid #14532d;
            padding-bottom: 1rem;
        }
        .receipt-brand {
            display: flex;
            gap: .85rem;
            align-items: center;
        }
        .receipt-brand img {
            max-width: 120px;
            max-height: 52px;
            object-fit: contain;
        }
        .receipt-kicker {
            text-transform: uppercase;
            letter-spacing: .14em;
            font-size: .6rem;
            color: #64748b;
            font-weight: 700;
        }
        .receipt-title {
            font-size: 1.3rem;
            font-weight: 800;
            margin: .18rem 0;
            color: #14532d;
        }
        .receipt-subtitle {
            color: #64748b;
            font-size: .76rem;
            margin: 0;
        }
        .pill {
            display: inline-block;
            border-radius: 999px;
            background: #dcfce7;
            color: #166534;
            padding: .35rem .75rem;
            font-size: .72rem;
            font-weight: 700;
        }
        .meta-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: .65rem;
            margin: .95rem 0;
        }
        .meta-card, .section-card {
            border: 1px solid #dbe3ef;
            border-radius: 12px;
            background: #f8fafc;
            padding: .75rem .85rem;
            break-inside: avoid;
            page-break-inside: avoid;
        }
        .meta-label, .section-label {
            font-size: .6rem;
            text-transform: uppercase;
            letter-spacing: .08em;
            color: #64748b;
            font-weight: 700;
            margin-bottom: .3rem;
        }
        .meta-value {
            font-size: .88rem;
            font-weight: 700;
        }
        .section-grid {
            display: grid;
            grid-template-columns: 1.3fr .9fr;
            gap: .7rem;
        }
        .detail-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: .55rem;
        }
        .detail-table th,
        .detail-table td {
            padding: .48rem .42rem;
            border-bottom: 1px solid #dbe3ef;
            font-size: .74rem;
            vertical-align: top;
        }
        .detail-table th {
            text-transform: uppercase;
            letter-spacing: .06em;
            color: #64748b;
            font-size: .58rem;
        }
        .history-list {
            display: flex;
            flex-direction: column;
            gap: .5rem;
            margin-top: .55rem;
        }
        .history-item {
            border-left: 3px solid #14532d;
            padding-left: .6rem;
        }
        .history-title {
            font-size: .76rem;
            font-weight: 700;
        }
        .history-meta, .fine-note {
            color: #64748b;
            font-size: .68rem;
        }
        .footer-note {
            margin-top: 1rem;
            border-top: 1px dashed #dbe3ef;
            padding-top: .7rem;
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            color: #64748b;
            font-size: .66rem;
        }
        @@media print {
            body {
                background: #fff;
            }
            .receipt-shell {
                margin: 0;
                border: none;
                box-shadow: none;
                width: auto;
                min-height: auto;
            }
            .receipt-toolbar {
                display: none;
            }
        }
    </style>
</head>
<body>
    <div class="receipt-shell">
        <div class="receipt-toolbar">
            <button type="button" class="btn btn-sm btn-dark" onclick="window.print()">Print Receipt</button>
        </div>
        <div class="receipt-doc">
            <div class="receipt-header">
                <div class="receipt-brand">
                    @if (!string.IsNullOrWhiteSpace(brandLogoPath))
                    {
                        <img src="@brandLogoPath" alt="@brandName" />
                    }
                    <div>
                        <div class="receipt-kicker">Settlement Receipt</div>
                        <div class="receipt-title">@brandName</div>
                        <p class="receipt-subtitle">Official reimbursement settlement acknowledgement.</p>
                    </div>
                </div>
                <div class="text-end">
                    <span class="pill">@Model.Request.Status</span>
                    <div class="mt-2 fw-bold">@Model.Request.SettlementReceiptNumber</div>
                    <div class="receipt-subtitle">Generated @DateTime.Now.ToString("dd MMM yyyy hh:mm tt")</div>
                </div>
            </div>

            <div class="meta-grid">
                <div class="meta-card">
                    <div class="meta-label">Request No.</div>
                    <div class="meta-value">@Model.Request.RequestNumber</div>
                </div>
                <div class="meta-card">
                    <div class="meta-label">Employee</div>
                    <div class="meta-value">@Model.Request.EmployeeName</div>
                </div>
                <div class="meta-card">
                    <div class="meta-label">Settlement Date</div>
                    <div class="meta-value">@((Model.Request.SettlementDate ?? Model.Request.SettledAt)?.ToString("dd MMM yyyy"))</div>
                </div>
                <div class="meta-card">
                    <div class="meta-label">Settled Amount</div>
                    <div class="meta-value">INR @((Model.Request.SettlementAmount ?? 0).ToString("N2"))</div>
                </div>
            </div>

            <div class="section-grid">
                <div class="section-card">
                    <div class="section-label">Settlement Details</div>
                    <table class="detail-table">
                        <tbody>
                            <tr><th>Purpose</th><td>@Model.Request.PurposeOfTravel</td></tr>
                            <tr><th>Payment Mode</th><td>@(string.IsNullOrWhiteSpace(Model.Request.SettlementMode) ? "-" : Model.Request.SettlementMode)</td></tr>
                            <tr><th>Reference No.</th><td>@(string.IsNullOrWhiteSpace(Model.Request.SettlementReferenceNo) ? "-" : Model.Request.SettlementReferenceNo)</td></tr>
                            <tr><th>Processed By</th><td>@(string.IsNullOrWhiteSpace(Model.Request.SettledByName) ? "Administrator" : Model.Request.SettledByName)</td></tr>
                            <tr><th>Remarks</th><td>@(string.IsNullOrWhiteSpace(Model.Request.SettlementRemarks) ? "-" : Model.Request.SettlementRemarks)</td></tr>
                        </tbody>
                    </table>
                </div>
                <div class="section-card">
                    <div class="section-label">Financial Snapshot</div>
                    <table class="detail-table">
                        <tbody>
                            <tr><th>Approved Total</th><td>INR @Model.Request.TotalAmount.ToString("N2")</td></tr>
                            <tr><th>Settled Total</th><td>INR @((Model.Request.SettlementAmount ?? 0).ToString("N2"))</td></tr>
                            <tr><th>Item Count</th><td>@Model.Request.ItemCount</td></tr>
                            <tr><th>Approved On</th><td>@(Model.Request.ApprovedAt?.ToString("dd MMM yyyy") ?? "-")</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="section-card mt-3">
                <div class="section-label">Settled Transaction Lines</div>
                <table class="detail-table">
                    <thead>
                        <tr>
                            <th>Type</th>
                            <th>Title</th>
                            <th>Date</th>
                            <th>Category</th>
                            <th>Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in Model.Lines)
                        {
                            <tr>
                                <td>@line.ItemType</td>
                                <td>@line.Title</td>
                                <td>@line.ExpenseDate.ToString("dd MMM yyyy")</td>
                                <td>@(line.ExpenseCategoryName ?? "-")</td>
                                <td>@line.CurrencyCode @line.Amount.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="section-card mt-3">
                <div class="section-label">Workflow Trail</div>
                <div class="history-list">
                    @foreach (var entry in Model.History)
                    {
                        <div class="history-item">
                            <div class="history-title">@entry.ActionTaken</div>
                            <div class="history-meta">@(string.IsNullOrWhiteSpace(entry.ActionByName) ? "System" : entry.ActionByName) · @entry.ActionAt.ToString("dd MMM yyyy hh:mm tt")</div>
                            @if (!string.IsNullOrWhiteSpace(entry.Remarks))
                            {
                                <div class="fine-note mt-1">@entry.Remarks</div>
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="footer-note">
                <span>This document is system-generated and serves as settlement acknowledgement for the employee request.</span>
                <span>@brandName</span>
            </div>
        </div>
    </div>
</body>
</html>