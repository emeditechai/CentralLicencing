@model CentralLicenceApp.Models.ViewModels.ExpenseRequestLineFormViewModel
@{
    ViewData["Title"] = "Add Expense / Booking";
    var existingReceipts = Model.ExistingAttachments
        .Select(attachment => new
        {
            url = Url.Content(attachment.FilePath),
            fileName = string.IsNullOrWhiteSpace(attachment.OriginalFileName) ? System.IO.Path.GetFileName(attachment.FilePath) : attachment.OriginalFileName
        })
        .ToList();
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Manage" asp-route-id="@Model.RequestId" class="btn btn-sm btn-outline-secondary" style="border-radius:8px;"><i class="bi bi-arrow-left"></i></a>
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e293b;">Add / Update Expenses</h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">Add an expense or advance booking line to the request.</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card h-100" style="background:#4b5563;color:#fff;min-height:420px;">
            <div class="card-body d-flex flex-column align-items-center justify-content-center text-center p-4">
                @if (Model.ExistingAttachments.Any())
                {
                    <div class="mb-3 d-flex flex-wrap justify-content-center" style="gap:.5rem;">
                        @foreach (var attachment in Model.ExistingAttachments)
                        {
                            <a href="@Url.Content(attachment.FilePath)" target="_blank" class="btn btn-light btn-sm" style="border-radius:10px;">@((string.IsNullOrWhiteSpace(attachment.OriginalFileName) ? System.IO.Path.GetFileName(attachment.FilePath) : attachment.OriginalFileName))</a>
                        }
                    </div>
                }
                <label for="ReceiptFile" class="btn btn-sm text-white px-3 py-2" style="background:#6366f1;border-radius:8px;cursor:pointer;">Upload Receipts</label>
                <div class="mt-3" style="font-size:.85rem;">You can preview uploaded receipts</div>
                <div id="receiptPreviewState" class="w-100 mt-4 d-flex flex-column align-items-center justify-content-center" style="gap:.75rem;min-height:280px;border:1px dashed rgba(255,255,255,.18);border-radius:18px;background:rgba(15,23,42,.12);padding:1rem;">
                    <div id="receiptPreviewPlaceholder" class="d-flex flex-column align-items-center justify-content-center text-center" style="gap:.7rem;">
                        <i class="bi bi-file-earmark-image" style="font-size:2rem;color:#cbd5e1;"></i>
                        <div style="font-size:.88rem;font-weight:600;">Receipt preview will appear here</div>
                        <div data-preview-empty-message style="font-size:.78rem;color:#dbe4f0;max-width:240px;">Supports image and PDF files before you save the expense line.</div>
                    </div>
                    <div id="receiptPreviewContent" class="w-100 d-none"></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="card">
            <div class="card-body p-4">
                <form asp-action="AddLine" asp-permission="ExpenseRequest:Create" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="RequestId" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 px-3 rounded-3 mb-3" style="font-size:.83rem;"></div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="ItemType" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                            <select asp-for="ItemType" class="form-select" style="border-radius:10px;">
                                @foreach (var type in Model.AvailableItemTypes)
                                {
                                    <option value="@type">@type</option>
                                }
                            </select>
                            <span asp-validation-for="ItemType" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ExpenseCategoryId" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                            <select asp-for="ExpenseCategoryId" class="form-select" style="border-radius:10px;">
                                <option value="">Select category</option>
                                @foreach (var category in Model.ExpenseCategories)
                                {
                                    <option value="@category.Id">@category.CategoryName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ProjectOrCostCenter" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                            <input asp-for="ProjectOrCostCenter" class="form-control" style="border-radius:10px;" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Title" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                            <input asp-for="Title" class="form-control" style="border-radius:10px;" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ExpenseDate" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                            <input asp-for="ExpenseDate" type="date" class="form-control" style="border-radius:10px;" />
                            <span asp-validation-for="ExpenseDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CurrencyCode" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                            <select asp-for="CurrencyCode" class="form-select" style="border-radius:10px;">
                                @foreach (var currency in Model.AvailableCurrencies)
                                {
                                    <option value="@currency">@currency</option>
                                }
                            </select>
                            <span asp-validation-for="CurrencyCode" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Amount" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                            <input asp-for="Amount" class="form-control" style="border-radius:10px;" />
                            <span asp-validation-for="Amount" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PayableAmountInr" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                            <input asp-for="PayableAmountInr" class="form-control" style="border-radius:10px;" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="AccommodationCountry" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                            <select asp-for="AccommodationCountry" class="form-select" style="border-radius:10px;">
                                <option value="">Select a country</option>
                                @foreach (var country in Model.AvailableCountries)
                                {
                                    <option value="@country">@country</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="AccommodationCity" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                            <input asp-for="AccommodationCity" class="form-control" style="border-radius:10px;" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CheckInDate" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                            <input asp-for="CheckInDate" type="date" class="form-control" style="border-radius:10px;" />
                            <span asp-validation-for="CheckInDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CheckOutDate" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                            <input asp-for="CheckOutDate" type="date" class="form-control" style="border-radius:10px;" />
                            <span asp-validation-for="CheckOutDate" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="ReceiptFiles" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                            <input asp-for="ReceiptFiles" id="ReceiptFile" class="form-control" style="border-radius:10px;" multiple />
                        </div>
                        <div class="col-12">
                            <label asp-for="Notes" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                            <textarea asp-for="Notes" rows="3" class="form-control" style="border-radius:10px;"></textarea>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-4 flex-wrap">
                        <button type="submit" class="btn text-white" style="background:#180a3c;border:none;border-radius:10px;">Save Expense</button>
                        <a asp-action="Manage" asp-route-id="@Model.RequestId" class="btn btn-outline-secondary" style="border-radius:10px;">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/receipt-preview.js" asp-append-version="true"></script>
    <script>
        initializeReceiptPreview({
            inputId: 'ReceiptFile',
            placeholderId: 'receiptPreviewPlaceholder',
            contentId: 'receiptPreviewContent',
            existingReceipts: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(existingReceipts)),
            emptyMessage: 'Supports multiple image and PDF files before you save the expense line.'
        });
    </script>
}