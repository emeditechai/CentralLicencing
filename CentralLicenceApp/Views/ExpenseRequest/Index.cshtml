        }

        .finance-compact-table .btn-sm {
            padding: .2rem .5rem;
            font-size: .74rem;
        }

        @@media (max-width: 1200px) {
            .finance-card-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        }

        @@media (max-width: 900px) {
            .finance-insights-row {
                grid-template-columns: 1fr;
            }

            .finance-insight-card {
                grid-template-columns: 1fr;
                row-gap: .35rem;
            }

            .finance-insight-head {
                min-width: 0;
            }
        }

        @@media (max-width: 640px) {
            .finance-title {
                font-size: 1.35rem;
            }

            .finance-card-grid {
                grid-template-columns: 1fr;
            }

            .finance-hero-inline-metrics { flex-direction: column; }
            .finance-overdue-strip {
                align-items: flex-start;
            }
        }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var filterButtons = Array.from(document.querySelectorAll('.finance-filter-chip'));
            var tableRows = Array.from(document.querySelectorAll('.finance-compact-table tbody tr[data-status]'));

            if (!filterButtons.length || !tableRows.length) {
                return;
            }

            function applyFinanceFilter(filter) {
                tableRows.forEach(function (row) {
                    var rowStatus = row.dataset.status || '';
                    var isOverdue = row.dataset.overdue === 'true';
                    var isVisible = filter === 'all'
                        || (filter === 'overdue' && isOverdue)
                        || rowStatus === filter;
                    row.classList.toggle('d-none', !isVisible);
                });

                filterButtons.forEach(function (button) {
                    button.classList.toggle('active', button.dataset.filter === filter);
                });
            }

            filterButtons.forEach(function (button) {
                button.addEventListener('click', function () {
                    applyFinanceFilter(button.dataset.filter || 'all');
                });
            });

            applyFinanceFilter('all');
        });
    </script>
}