@model CentralLicenceApp.Models.ViewModels.ExpenseRequestListPageViewModel
@{
    ViewData["Title"] = Model.PageTitle;
    var subtitle = Model.ShowFinanceActions
        ? "Process approved requests through reimbursement and final settlement."
        : "Track your draft, submitted, approved, reimbursed, and settled expense requests.";
    var totalRequests = Model.Requests.Count;
    var approvedCount = Model.Requests.Count(r => r.Status == CentralLicenceApp.Models.ExpenseRequestStatus.Approved);
    var reimbursementCount = Model.Requests.Count(r => r.Status == CentralLicenceApp.Models.ExpenseRequestStatus.ReimbursementInProcess);
    var settledCount = Model.Requests.Count(r => r.Status == CentralLicenceApp.Models.ExpenseRequestStatus.Settled);
    var queueAmount = Model.Requests.Sum(r => r.TotalAmount);
    var approvedAmount = Model.Requests
        .Where(r => r.Status == CentralLicenceApp.Models.ExpenseRequestStatus.Approved)
        .Sum(r => r.TotalAmount);
    var reimbursementAmount = Model.Requests
        .Where(r => r.Status == CentralLicenceApp.Models.ExpenseRequestStatus.ReimbursementInProcess)
        .Sum(r => r.TotalAmount);
    var settledAmount = Model.Requests
        .Where(r => r.Status == CentralLicenceApp.Models.ExpenseRequestStatus.Settled)
        .Sum(r => r.TotalAmount);
    var oldestPending = Model.Requests
        .Where(r => r.Status == CentralLicenceApp.Models.ExpenseRequestStatus.Approved)
        .OrderBy(r => r.SubmittedAt ?? r.CreatedAt)
        .FirstOrDefault();
    var biggestOpenRequest = Model.Requests
        .Where(r => r.Status == CentralLicenceApp.Models.ExpenseRequestStatus.Approved || r.Status == CentralLicenceApp.Models.ExpenseRequestStatus.ReimbursementInProcess)
        .OrderByDescending(r => r.TotalAmount)
        .FirstOrDefault();
    var today = DateTime.Today;
    var overdueApprovedRequests = Model.Requests
        .Where(r => r.Status == CentralLicenceApp.Models.ExpenseRequestStatus.Approved)
        .Select(r => new
        {
            Request = r,
            AgeDays = Math.Max(0, (today - (r.ApprovedAt ?? r.SubmittedAt ?? r.CreatedAt).Date).Days)
        })
        .Where(x => x.AgeDays >= 3)
        .OrderByDescending(x => x.AgeDays)
        .ToList();
    var overdueReimbursementRequests = Model.Requests
        .Where(r => r.Status == CentralLicenceApp.Models.ExpenseRequestStatus.ReimbursementInProcess)
        .Select(r => new
        {
            Request = r,
            AgeDays = Math.Max(0, (today - (r.ReimbursementStartedAt ?? r.ApprovedAt ?? r.SubmittedAt ?? r.CreatedAt).Date).Days)
        })
        .Where(x => x.AgeDays >= 5)
        .OrderByDescending(x => x.AgeDays)
        .ToList();
    var overdueApprovedCount = overdueApprovedRequests.Count;
    var overdueApprovedAmount = overdueApprovedRequests.Sum(x => x.Request.TotalAmount);
    var overdueReimbursementCount = overdueReimbursementRequests.Count;
    var overdueReimbursementAmount = overdueReimbursementRequests.Sum(x => x.Request.TotalAmount);
    var oldestApprovedOverdue = overdueApprovedRequests.FirstOrDefault();
    var oldestReimbursementOverdue = overdueReimbursementRequests.FirstOrDefault();
    var overdueTotalCount = overdueApprovedCount + overdueReimbursementCount;
}

@if (Model.ShowFinanceActions)
{
    <section class="finance-hero mb-4">
        <div class="finance-hero-copy">
            <span class="finance-kicker">Finance Control Center</span>
            <h2 class="finance-title mb-2">@Model.PageTitle</h2>
            <p class="finance-subtitle mb-0">@subtitle</p>
            <div class="finance-hero-inline-metrics mt-3">
                <div class="finance-hero-pill">
                    <span class="finance-hero-pill-label">Live Queue</span>
                    <strong>@totalRequests</strong>
                </div>
                <div class="finance-hero-pill">
                    <span class="finance-hero-pill-label">Pipeline Value</span>
                    <strong>INR @queueAmount.ToString("N2")</strong>
                </div>
            </div>
        </div>
    </section>

    <section class="finance-card-grid mb-4">
        <article class="finance-stat-card finance-stat-card-approved">
            <div class="finance-stat-icon"><i class="bi bi-check2-circle"></i></div>
            <div class="finance-stat-label">Ready For Reimbursement</div>
            <div class="finance-stat-value">@approvedCount</div>
            <div class="finance-stat-meta">INR @approvedAmount.ToString("N2") waiting to be picked up</div>
        </article>
        <article class="finance-stat-card finance-stat-card-process">
            <div class="finance-stat-icon"><i class="bi bi-arrow-repeat"></i></div>
            <div class="finance-stat-label">In Reimbursement</div>
            <div class="finance-stat-value">@reimbursementCount</div>
            <div class="finance-stat-meta">INR @reimbursementAmount.ToString("N2") currently under processing</div>
        </article>
        <article class="finance-stat-card finance-stat-card-settled">
            <div class="finance-stat-icon"><i class="bi bi-bank2"></i></div>
            <div class="finance-stat-label">Settled Requests</div>
            <div class="finance-stat-value">@settledCount</div>
            <div class="finance-stat-meta">INR @settledAmount.ToString("N2") completed in this desk view</div>
        </article>
        <article class="finance-stat-card finance-stat-card-total">
            <div class="finance-stat-icon"><i class="bi bi-cash-stack"></i></div>
            <div class="finance-stat-label">Total Queue Value</div>
            <div class="finance-stat-value finance-stat-value-money">INR @queueAmount.ToString("N2")</div>
            <div class="finance-stat-meta">Across @totalRequests request@(totalRequests == 1 ? string.Empty : "s") visible to finance</div>
        </article>
    </section>

    <section class="finance-insights-row mb-4">
        <article class="finance-insight-card">
            <div class="finance-insight-head">
                <span class="finance-insight-kicker">Oldest Approved Request</span>
                <i class="bi bi-hourglass-split"></i>
            </div>
            @if (oldestPending != null)
            {
                <div class="finance-insight-title">@oldestPending.RequestNumber</div>
                <div class="finance-insight-copy">@oldestPending.EmployeeName · @oldestPending.PurposeOfTravel</div>
                <div class="finance-insight-foot">Submitted @((oldestPending.SubmittedAt ?? oldestPending.CreatedAt).ToString("dd MMM yyyy"))</div>
            }
            else
            {
                <div class="finance-insight-empty">No approved requests are waiting right now.</div>
            }
        </article>
        <article class="finance-insight-card">
            <div class="finance-insight-head">
                <span class="finance-insight-kicker">Largest Open Value</span>
                <i class="bi bi-graph-up-arrow"></i>
            </div>
            @if (biggestOpenRequest != null)
            {
                <div class="finance-insight-title">INR @biggestOpenRequest.TotalAmount.ToString("N2")</div>
                <div class="finance-insight-copy">@biggestOpenRequest.RequestNumber · @biggestOpenRequest.EmployeeName</div>
                <div class="finance-insight-foot">Current stage: @biggestOpenRequest.Status</div>
            }
            else
            {
                <div class="finance-insight-empty">No open reimbursement items are currently pending.</div>
            }
        </article>
    </section>

    <section class="finance-overdue-strip mb-3">
        <div class="finance-overdue-strip-lead">
            <i class="bi bi-exclamation-triangle"></i>
            <span>Overdue finance watch</span>
        </div>
        <div class="finance-overdue-pill finance-overdue-pill-alert">
            <span class="finance-overdue-pill-title">Reimbursement start</span>
            <strong>@overdueApprovedCount</strong>
            <span class="finance-overdue-pill-copy">INR @overdueApprovedAmount.ToString("N2") over 3+ days</span>
            @if (oldestApprovedOverdue != null)
            {
                <span class="finance-overdue-pill-note">Oldest: @oldestApprovedOverdue.Request.RequestNumber · @oldestApprovedOverdue.AgeDays days</span>
            }
        </div>
        <div class="finance-overdue-pill finance-overdue-pill-warning">
            <span class="finance-overdue-pill-title">Settlement pending</span>
            <strong>@overdueReimbursementCount</strong>
            <span class="finance-overdue-pill-copy">INR @overdueReimbursementAmount.ToString("N2") over 5+ days</span>
            @if (oldestReimbursementOverdue != null)
            {
                <span class="finance-overdue-pill-note">Oldest: @oldestReimbursementOverdue.Request.RequestNumber · @oldestReimbursementOverdue.AgeDays days</span>
            }
        </div>
    </section>
}
else
{
    <div class="d-flex align-items-center justify-content-between mb-4 expense-list-header">
        <div>
            <h4 class="fw-bold mb-0" style="color:#1e293b;">@Model.PageTitle</h4>
            <p class="text-muted mb-0" style="font-size:.85rem;">@subtitle</p>
        </div>
        @if (Model.ShowCreateButton)
        {
            <a asp-action="Create" class="btn btn-primary expense-list-create-btn" style="background:#180a3c;border:none;border-radius:10px;">
                <i class="bi bi-plus-lg me-1"></i> New Request
            </a>
        }
    </div>
}

@if (Model.ShowFinanceActions)
{
    <section class="finance-table-toolbar mb-2">
        <button type="button" class="finance-filter-chip active" data-filter="all">All <span>@totalRequests</span></button>
        <button type="button" class="finance-filter-chip" data-filter="Approved">Approved <span>@approvedCount</span></button>
        <button type="button" class="finance-filter-chip" data-filter="Reimbursement In Process">In Reimbursement <span>@reimbursementCount</span></button>
        <button type="button" class="finance-filter-chip" data-filter="Settled">Settled <span>@settledCount</span></button>
        <button type="button" class="finance-filter-chip finance-filter-chip-overdue" data-filter="overdue">Overdue <span>@overdueTotalCount</span></button>
    </section>
}

<div class="card @(Model.ShowFinanceActions ? "finance-table-card" : string.Empty)">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table tbl-clean mb-0 responsive-expense-table @(Model.ShowFinanceActions ? "finance-compact-table" : string.Empty)">
                <thead>
                    <tr>
                        <th class="ps-3">Request No.</th>
                        <th>Purpose</th>
                        <th>Approver</th>
                        <th>Items</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th class="pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Requests.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">
                                <i class="bi bi-wallet2 fs-1 d-block mb-2"></i>
                                <div class="fw-semibold mb-1">@Model.EmptyStateTitle</div>
                                <div style="font-size:.85rem;">@Model.EmptyStateDescription</div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model.Requests)
                        {
                            var itemAgeAnchor = item.Status == CentralLicenceApp.Models.ExpenseRequestStatus.ReimbursementInProcess
                                ? (item.ReimbursementStartedAt ?? item.ApprovedAt ?? item.SubmittedAt ?? item.CreatedAt)
                                : (item.ApprovedAt ?? item.SubmittedAt ?? item.CreatedAt);
                            var itemAgeDays = Math.Max(0, (today - itemAgeAnchor.Date).Days);
                            var isApprovedOverdue = Model.ShowFinanceActions
                                && item.Status == CentralLicenceApp.Models.ExpenseRequestStatus.Approved
                                && itemAgeDays >= 3;
                            var isReimbursementOverdue = Model.ShowFinanceActions
                                && item.Status == CentralLicenceApp.Models.ExpenseRequestStatus.ReimbursementInProcess
                                && itemAgeDays >= 5;
                            var isOverdueRow = isApprovedOverdue || isReimbursementOverdue;
                            var badgeClass = item.Status switch
                            {
                                "Settled" => "badge-ok",
                                "Reimbursement In Process" => "badge-warn",
                                "Approved" => "badge-ok",
                                "Rejected" => "badge-err",
                                "Pending Approval" => "badge-warn",
                                _ => "badge-neu"
                            };

                            <tr class="@(isOverdueRow ? (isReimbursementOverdue ? "finance-row-overdue-strong" : "finance-row-overdue") : string.Empty)"
                                data-status="@item.Status"
                                data-overdue="@(isOverdueRow ? "true" : "false")">
                                <td class="ps-3" data-label="Request No.">
                                    <div class="fw-semibold" style="font-size:.86rem;">@item.RequestNumber</div>
                                    <div class="text-muted" style="font-size:.73rem;">@item.EmployeeName</div>
                                </td>
                                <td data-label="Purpose">
                                    <div class="fw-semibold" style="font-size:.85rem;">@item.PurposeOfTravel</div>
                                    @if (!string.IsNullOrWhiteSpace(item.EmployeeRemarks))
                                    {
                                        <div class="text-muted" style="font-size:.74rem;">@item.EmployeeRemarks</div>
                                    }
                                </td>
                                <td data-label="Approver" style="font-size:.82rem;">@(string.IsNullOrWhiteSpace(item.ApproverName) ? "Auto / Not Assigned" : item.ApproverName)</td>
                                <td data-label="Items" style="font-size:.82rem;">@item.ItemCount</td>
                                <td data-label="Total" style="font-size:.82rem;font-weight:600;">INR @item.TotalAmount.ToString("N2")</td>
                                <td data-label="Status">
                                    <div class="d-flex align-items-center gap-1 flex-wrap">
                                        <span class="badge @badgeClass rounded-pill px-2 py-1" style="font-size:.73rem;">@item.Status</span>
                                        @if (isOverdueRow)
                                        {
                                            <span class="badge finance-overdue-badge rounded-pill px-2 py-1">@itemAgeDays d overdue</span>
                                        }
                                    </div>
                                </td>
                                <td data-label="Created" style="font-size:.82rem;">@((item.SettlementDate ?? item.SubmittedAt ?? item.CreatedAt).ToString("dd MMM yyyy"))</td>
                                <td class="pe-3" data-label="Actions">
                                    <div class="d-flex gap-1 expense-row-actions">
                                        @if (item.Status == CentralLicenceApp.Models.ExpenseRequestStatus.Draft)
                                        {
                                            <a asp-action="Manage" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" style="border-radius:7px;">Open</a>
                                        }
                                        else
                                        {
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" style="border-radius:7px;">View</a>
                                        }
                                        @if (Model.ShowFinanceActions && item.Status == CentralLicenceApp.Models.ExpenseRequestStatus.ReimbursementInProcess)
                                        {
                                            <a asp-action="Settle" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success" style="border-radius:7px;">Settle</a>
                                        }
                                        @if (item.Status == CentralLicenceApp.Models.ExpenseRequestStatus.Settled)
                                        {
                                            <a asp-action="SettlementReceipt" asp-route-id="@item.Id" target="_blank" class="btn btn-sm btn-outline-success" style="border-radius:7px;" title="Settlement Receipt">
                                                <i class="bi bi-receipt"></i>
                                            </a>
                                        }
                                        <a asp-action="Print" asp-route-id="@item.Id" target="_blank" class="btn btn-sm btn-outline-secondary" style="border-radius:7px;" title="Print Request">
                                            <i class="bi bi-printer"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

