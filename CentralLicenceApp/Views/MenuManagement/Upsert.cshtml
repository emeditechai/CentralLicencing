@model CentralLicenceApp.Models.ViewModels.MenuUpsertViewModel
@{
    ViewData["Title"] = Model.Id == 0 ? "New Menu" : "Edit Menu";
    var perms = ViewBag.Permissions as List<CentralLicenceApp.Models.PermissionMaster> ?? new();
    var parents = ViewBag.ParentOptions as List<CentralLicenceApp.Models.MenuMaster> ?? new();
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0">@ViewData["Title"]</h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">Define a navigation node and the permissions it supports.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i> Back</a>
</div>

<form asp-action="Upsert" method="post" class="card">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Menu Name <span class="text-danger">*</span></label>
                <input asp-for="MenuName" class="form-control" required />
                <span asp-validation-for="MenuName" class="text-danger small"></span>
            </div>
            <div class="col-md-3">
                <label class="form-label">Type</label>
                <select asp-for="MenuType" class="form-select">
                    <option value="Section">Section (header label)</option>
                    <option value="Collapsible">Collapsible (group)</option>
                    <option value="Link">Link (page)</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Sort Order</label>
                <input asp-for="SortOrder" type="number" class="form-control" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Parent</label>
                <select asp-for="ParentId" class="form-select">
                    <option value="">— Top level —</option>
                    @foreach (var p in parents.OrderBy(x => x.MenuName))
                    {
                        <option value="@p.Id">@p.MenuName</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Controller</label>
                <input asp-for="ControllerName" class="form-control" placeholder="e.g. Invoice" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Action</label>
                <input asp-for="ActionName" class="form-control" placeholder="Index" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Icon (Bootstrap icon class)</label>
                <input asp-for="IconClass" class="form-control" placeholder="bi bi-list" />
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <div class="form-check">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                    <label asp-for="IsActive" class="form-check-label">Active</label>
                </div>
            </div>
            <div class="col-12">
                <label class="form-label d-block">Applicable Permissions</label>
                <div class="d-flex flex-wrap gap-3">
                    @foreach (var p in perms)
                    {
                        var checkedAttr = (Model.PermissionIds ?? new()).Contains(p.Id) ? "checked" : null;
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="checkbox" name="PermissionIds" value="@p.Id" id="perm-@p.Id" @checkedAttr />
                            <label class="form-check-label" for="perm-@p.Id">@p.DisplayName</label>
                        </div>
                    }
                </div>
                <div class="form-text">"View" is implied; mutating permissions like Create/Edit/Delete should be checked when relevant.</div>
            </div>
        </div>
    </div>
    <div class="card-footer text-end">
        <a asp-action="Index" class="btn btn-light btn-sm">Cancel</a>
        <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-save me-1"></i> Save</button>
    </div>
</form>
